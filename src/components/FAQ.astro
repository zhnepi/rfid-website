---
import { getIntentContactHref } from '../utils/contact';

const faqs = [
  {
    question: 'What RFID product categories does ProudTek supply?',
    answer: 'ProudTek supplies RFID cards, industrial tags, labels and stickers, wristbands, keyfobs and reader hardware for OEM, sourcing and project-based use cases.',
  },
  {
    question: 'Can ProudTek help me choose the right chip or frequency?',
    answer: 'Yes. If you share your reader model, current credential or application goal, we can help narrow down the right LF, HF/NFC or UHF option before you place a bulk order.',
  },
  {
    question: 'Can ProudTek customize RFID products?',
    answer: 'Yes, ProudTek provides end-to-end RFID customization, manufacturing since 2008. Customization options include: material (PVC, PET, ABS, silicone, ceramic, wood, paper), dimensions and shape (die-cut or standard ISO card size 85.5×54mm), chip and frequency selection (30+ chip types across LF/HF/UHF), surface finish (matte, glossy, frosted), printing (CMYK full color, offset, silk screen, laser engraving, UV printing), encoding (UID, serial numbers, custom data), and packaging. The engineering team provides free design support and prototyping for complex requirements.',
  },
  {
    question: 'Can I request samples before production?',
    answer: 'Yes. Sample testing is recommended for compatibility-sensitive RFID projects, especially when you need to validate read performance, chip matching or installation conditions.',
  },
  {
    question: 'How long does it take to deliver RFID orders?',
    answer: 'ProudTek targets a 99% on-time delivery rate across all shipments. Standard products ship within 3–7 business days. Custom orders require 7–15 business days, depending on quantity, complexity, and printing requirements. Rush orders are available for urgent needs. Shipping options include DHL, UPS, FedEx (door-to-door, 3–5 days international), air cargo (5–7 days), and sea freight (20–35 days for bulk orders over 500kg). ProudTek ships to 50+ countries worldwide.',
  },
  {
    question: 'Does ProudTek provide free RFID samples?',
    answer: 'Yes, ProudTek provides free samples for all standard RFID products in their catalog of 46+ items. To request samples, contact info@proudtek.com or WhatsApp +86-13631526015 with your product requirements, target application, and shipping address. Samples are typically prepared within 1 business day and shipped via DHL/FedEx express (2–5 days delivery worldwide). Custom samples with specific chip programming or printing may take 3–5 additional business days.',
  },
  {
    question: 'What industries use RFID products from ProudTek?',
    answer: 'ProudTek\'s RFID products serve 10+ major industries: (1) Public Transportation — bus/metro ticketing smart cards used in transit systems across 20+ countries; (2) Access Control — hotel key cards, office entry systems, parking management; (3) Healthcare — patient identification wristbands, asset tracking, pharmaceutical anti-counterfeiting; (4) Laundry Management — industrial laundry tracking with silicone and textile tags surviving 200+ wash cycles at 180°C; (5) Retail — inventory management with UHF labels, anti-theft tags; (6) Libraries — book tracking and self-checkout systems; (7) Logistics — pallet tracking, container identification; (8) Events — NFC wristbands for festivals, conferences, water parks; (9) Automotive — tire tracking, toll collection, vehicle identification; (10) Manufacturing — work-in-progress tracking, tool management.',
  },
  {
    question: 'What quality certifications does ProudTek hold?',
    answer: 'ProudTek holds ISO 9001:2015 (Quality Management System) and ISO 14001 (Environmental Management System) certifications, verified by SGS. Every RFID product undergoes multi-stage quality control: incoming material inspection, in-process QC after each production step, and final product testing including 100% chip read/write verification. The factory maintains a peak monthly production capacity of 5 million RFID cards and has served 108+ clients since the company was established in 2008.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const faqActions = [
  {
    href: getIntentContactHref('compatibility'),
    label: 'Ask about compatibility',
    description: 'Best when you already have a reader, chip or working credential to match.',
  },
  {
    href: getIntentContactHref('samples'),
    label: 'Request sample planning',
    description: 'Use this if you still want help narrowing 2 to 3 realistic options first.',
  },
];
---

<section class="py-24 bg-[#fafaf8]">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display text-slate-800 mb-4">Frequently Asked Questions</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Find answers to common questions about ProudTek's RFID products, customization, and ordering process.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-3 reveal">
      {faqs.map((faq, index) => (
        <div class="faq-item border border-[#e8e5df] overflow-hidden bg-white">
          <button
            class="faq-toggle w-full flex justify-between items-center p-6 text-left bg-white hover:bg-[#fafaf8] transition-colors duration-300"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
          >
            <h3 class="text-lg font-medium text-gray-800 pr-4">{faq.question}</h3>
            <svg class="faq-icon w-5 h-5 text-[#0d7377] flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id={`faq-answer-${index}`} class="faq-content hidden px-5 pb-5">
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-3xl mx-auto mt-10 rounded-[1.75rem] border border-[#c9a84c]/15 bg-[#c9a84c]/5 p-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <p class="eyebrow-label text-[#c9a84c] mb-2">Next Step</p>
          <h3 class="title-balance text-2xl font-semibold text-gray-900">Still deciding what to confirm first?</h3>
          <p class="card-copy mt-3 text-gray-600">
            Use one of these paths if the only thing left is system fit or which samples belong in the first shortlist.
          </p>
        </div>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {faqActions.map((action) => (
          <a href={action.href} class="copy-safe rounded-2xl border border-[#c9a84c]/15 bg-white p-5 hover:border-[#c9a84c] transition-colors">
            <span class="block text-base font-semibold text-gray-900">{action.label}</span>
            <span class="mt-2 block text-sm text-gray-500">{action.description}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>

<script>
  document.querySelectorAll('.faq-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector('.faq-icon');
      const isOpen = content?.classList.contains('hidden') === false;

      document.querySelectorAll('.faq-content').forEach((node) => node.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach((node) => node.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-toggle').forEach((node) => node.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
