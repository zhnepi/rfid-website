---
// GEO-optimized FAQs: direct answers, specific data, citation-friendly format
const faqs = [
  {
    question: 'What types of RFID products does RFIDAK manufacture?',
    answer: 'RFIDAK manufactures 6 main categories of RFID products across 46+ SKUs: (1) RFID Cards — PVC, ABS, wood, paper, and clamshell cards; (2) RFID Tags — laundry tags, library tags, nail tags, ceramic tags, PCB tags, tire tags, and pallet tags; (3) RFID Labels & Stickers — UHF stickers, NFC stickers, tamper-proof labels, and jewellery tags; (4) RFID Wristbands — silicone, fabric, and disposable wristbands; (5) RFID Keyfobs — ABS, leather, and epoxy keyfobs; (6) RFID Readers/Writers — desktop and handheld models. All products are available in three frequency bands: LF (125kHz), HF (13.56MHz), and UHF (860–960MHz).',
  },
  {
    question: 'What is the minimum order quantity (MOQ) for RFID products?',
    answer: 'RFIDAK\'s MOQ varies by product type: RFID cards start at 500 pieces, RFID tags and labels start at 1,000 pieces, and RFID wristbands start at 500 pieces. For custom-shaped or specialty products, the MOQ may be 2,000–5,000 pieces depending on tooling requirements. RFIDAK also provides free samples of standard products before bulk orders, shipped within 1–3 business days via DHL or FedEx.',
  },
  {
    question: 'Can RFIDAK customize RFID products?',
    answer: 'Yes, RFIDAK provides end-to-end RFID customization since 2008. Customization options include: material (PVC, PET, ABS, silicone, ceramic, wood, paper), dimensions and shape (die-cut or standard ISO card size 85.5×54mm), chip and frequency selection (30+ chip types across LF/HF/UHF), surface finish (matte, glossy, frosted), printing (CMYK full color, offset, silk screen, laser engraving, UV printing), encoding (UID, serial numbers, custom data), and packaging. The engineering team provides free design support and prototyping for complex requirements.',
  },
  {
    question: 'What RFID chip types does RFIDAK support?',
    answer: 'RFIDAK supports 30+ RFID chip types across all major manufacturers. LF chips: EM4100, EM4200, T5577, HID Prox, Hitag1/2/S. HF chips (13.56MHz): NXP Mifare Classic 1K (S50) and 4K (S70), Mifare Plus S/X 2K/4K, Mifare DESFire EV2 2K/4K/8K and EV3, NTAG213 (144 bytes), NTAG215 (504 bytes), NTAG216 (888 bytes), ICODE SLIX/SLIX2. UHF chips (860–960MHz): Impinj Monza R6, Monza 4/5, NXP UCODE 7/8, Alien Higgs-3/4. RFIDAK maintains a stable chip supply chain, including for chips that are scarce in the global market such as DESFire EV2/EV3.',
  },
  {
    question: 'How long does it take to deliver RFID orders?',
    answer: 'RFIDAK maintains a 99% on-time delivery rate measured across 2,000+ shipments in 2023–2025. Standard products ship within 3–7 business days. Custom orders require 7–15 business days, depending on quantity, complexity, and printing requirements. Rush orders are available for urgent needs. Shipping options include DHL, UPS, FedEx (door-to-door, 3–5 days international), air cargo (5–7 days), and sea freight (20–35 days for bulk orders over 500kg). RFIDAK ships to 50+ countries worldwide.',
  },
  {
    question: 'Does RFIDAK provide free RFID samples?',
    answer: 'Yes, RFIDAK provides free samples for all standard RFID products in their catalog of 46+ items. To request samples, contact info@rfidak.com or WhatsApp +86-18665820632 with your product requirements, target application, and shipping address. Samples are typically prepared within 1 business day and shipped via DHL/FedEx express (2–5 days delivery worldwide). Custom samples with specific chip programming or printing may take 3–5 additional business days.',
  },
  {
    question: 'What industries use RFID products from RFIDAK?',
    answer: 'RFIDAK\'s RFID products serve 10+ major industries: (1) Public Transportation — bus/metro ticketing smart cards used in transit systems across 20+ countries; (2) Access Control — hotel key cards, office entry systems, parking management; (3) Healthcare — patient identification wristbands, asset tracking, pharmaceutical anti-counterfeiting; (4) Laundry Management — industrial laundry tracking with silicone and textile tags surviving 200+ wash cycles at 180°C; (5) Retail — inventory management with UHF labels, anti-theft tags; (6) Libraries — book tracking and self-checkout systems; (7) Logistics — pallet tracking, container identification; (8) Events — NFC wristbands for festivals, conferences, water parks; (9) Automotive — tire tracking, toll collection, vehicle identification; (10) Manufacturing — work-in-progress tracking, tool management.',
  },
  {
    question: 'What quality certifications does RFIDAK hold?',
    answer: 'RFIDAK holds ISO 9001:2015 (Quality Management System) and ISO 14001 (Environmental Management System) certifications, verified by SGS. Every RFID product undergoes multi-stage quality control: incoming material inspection, in-process QC after each production step, and final product testing including 100% chip read/write verification. The factory maintains a monthly production capacity of 5 million RFID cards and has served 108+ clients with a 99% positive feedback rate since 2008.',
  },
];

// FAQ JSON-LD
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display text-slate-800 mb-4">Frequently Asked Questions</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Find answers to common questions about RFIDAK's RFID products, customization, and ordering process.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <div class="faq-item border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-toggle w-full flex justify-between items-center p-5 text-left bg-white hover:bg-gray-50 transition-colors"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
          >
            <h3 class="text-lg font-medium text-gray-800 pr-4">{faq.question}</h3>
            <svg class="faq-icon w-5 h-5 text-[#0d7377] flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id={`faq-answer-${index}`} class="faq-content hidden px-5 pb-5">
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- W8 QW#9: FAQ triple-CTA — catches users who still have questions after reading -->
    <div class="max-w-3xl mx-auto mt-10 rounded-2xl border border-gray-200 bg-gray-50 p-6 text-center">
      <p class="eyebrow-label text-[#0d7377] mb-2">Still have questions?</p>
      <h3 class="title-balance text-xl font-semibold text-gray-900 mb-4">Pick the fastest path and we reply in 2&ndash;4 hours</h3>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://wa.me/8618665820632?text=Hi%20RFIDAK%2C%20I%20still%20have%20questions%20after%20reading%20your%20FAQ%20%E2%80%94%20can%20you%20help%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-whatsapp"
          data-analytics="faq_cta_whatsapp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp a question
        </a>
        <a
          href="/contact?intent=general&source=faq-cta#contactForm"
          class="cta-primary"
          data-analytics="faq_cta_quote"
        >
          Get a Quote
        </a>
        <a
          href="/contact?intent=samples&express=1&source=faq-cta#contactForm"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border-2 border-[#0d7377] text-[#0d7377] font-semibold hover:bg-[#0d7377]/5 transition-colors"
          data-analytics="faq_cta_sample"
        >
          Request Free Sample
        </a>
      </div>
    </div>
  </div>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>

<script>
  document.querySelectorAll('.faq-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector('.faq-icon');
      const isOpen = content?.classList.contains('hidden') === false;

      // Close all
      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-toggle').forEach(b => b.setAttribute('aria-expanded', 'false'));

      // Open clicked if was closed
      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
