---
import { getIntentContactHref } from '../utils/contact';

const faqs = [
  {
    question: 'What RFID product categories does ProudTek supply?',
    answer: 'ProudTek supplies RFID cards, industrial tags, labels and stickers, wristbands, keyfobs and reader hardware for OEM, sourcing and project-based use cases.',
  },
  {
    question: 'Can ProudTek help me choose the right chip or frequency?',
    answer: 'Yes. If you share your reader model, current credential or application goal, we can help narrow down the right LF, HF/NFC or UHF option before you place a bulk order.',
  },
  {
    question: 'Do you support custom printing and encoding?',
    answer: 'Yes. Many RFID products can be customized with artwork, UID or serial numbering, encoding, packaging and other project-specific finishing requirements.',
  },
  {
    question: 'Can I request samples before production?',
    answer: 'Yes. Sample testing is recommended for compatibility-sensitive RFID projects, especially when you need to validate read performance, chip matching or installation conditions.',
  },
  {
    question: 'What industries commonly use ProudTek RFID products?',
    answer: 'Typical applications include access control, hospitality, events, healthcare, laundry management, logistics, library systems, inventory tracking and product authentication.',
  },
  {
    question: 'What should I include in an RFID inquiry?',
    answer: 'The most useful information is product type, chip or protocol requirement, quantity, customization details, target application and delivery timing. If you have artwork or a sample photo, include that as well.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const faqActions = [
  {
    href: getIntentContactHref('compatibility'),
    label: 'Ask about compatibility',
    description: 'Best when you already have a reader, chip or working credential to match.',
  },
  {
    href: getIntentContactHref('samples'),
    label: 'Request sample planning',
    description: 'Use this if you still want help narrowing 2 to 3 realistic options first.',
  },
];
---

<section class="py-24 bg-[#fafaf8]">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 reveal">
      <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-3">FAQ</p>
      <h2 class="font-serif text-4xl font-normal text-[#0d0d0d] mb-4">Frequently Asked Questions</h2>
      <div class="w-12 h-[1px] bg-[#c9a84c] mx-auto my-4"></div>
      <p class="text-[#666] max-w-2xl mx-auto">
        Quick answers about product selection, customization, samples and how to start an RFID project with ProudTek.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-3 reveal">
      {faqs.map((faq, index) => (
        <div class="faq-item border border-[#e8e5df] overflow-hidden bg-white">
          <button
            class="faq-toggle w-full flex justify-between items-center p-6 text-left bg-white hover:bg-[#fafaf8] transition-colors duration-300"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
          >
            <h3 class="text-base font-medium text-[#2a2a2a] pr-4">{faq.question}</h3>
            <svg class="faq-icon w-5 h-5 text-[#c9a84c] flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id={`faq-answer-${index}`} class="faq-content hidden px-5 pb-5">
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-3xl mx-auto mt-10 rounded-[1.75rem] border border-[#c9a84c]/15 bg-[#c9a84c]/5 p-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <p class="eyebrow-label text-[#c9a84c] mb-2">Next Step</p>
          <h3 class="title-balance text-2xl font-semibold text-gray-900">Still deciding what to confirm first?</h3>
          <p class="card-copy mt-3 text-gray-600">
            Use one of these paths if the only thing left is system fit or which samples belong in the first shortlist.
          </p>
        </div>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {faqActions.map((action) => (
          <a href={action.href} class="copy-safe rounded-2xl border border-[#c9a84c]/15 bg-white p-5 hover:border-[#c9a84c] transition-colors">
            <span class="block text-base font-semibold text-gray-900">{action.label}</span>
            <span class="mt-2 block text-sm text-gray-500">{action.description}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>

<script>
  document.querySelectorAll('.faq-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector('.faq-icon');
      const isOpen = content?.classList.contains('hidden') === false;

      document.querySelectorAll('.faq-content').forEach((node) => node.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach((node) => node.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-toggle').forEach((node) => node.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
