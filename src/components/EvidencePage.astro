---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Newsletter from './Newsletter.astro';
import { evidencePages } from '../data/evidencePages';
import { getContextualContactAction, getContextualInquiryLabel, getEvidenceContactHref, getEvidenceInquiryIntent } from '../utils/contact';

interface Props {
  pageKey: keyof typeof evidencePages;
}

const { pageKey } = Astro.props;
const config = evidencePages[pageKey];
const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/${config.slug}`;
const evidenceContactHref = getEvidenceContactHref(config.slug);
const evidenceInquiryLabel = getContextualInquiryLabel(getEvidenceInquiryIntent(config.slug), 'evidence');

function getResourceActionLabel(href: string) {
  const normalizedHref = href.split(/[?#]/)[0] || '';

  if (normalizedHref.startsWith('/contact')) return 'Open inquiry path';
  if (normalizedHref.startsWith('/blogs')) return 'Read guide';
  if (normalizedHref.startsWith('/compare')) return 'Review comparison';
  if (normalizedHref.startsWith('/solutions')) return 'Review workflow';
  if (normalizedHref.startsWith('/markets')) return 'Review market path';
  if (normalizedHref.startsWith('/products') || normalizedHref.startsWith('/rfid') || normalizedHref.startsWith('/product') || normalizedHref.startsWith('/category')) {
    return 'Browse product path';
  }
  if (
    normalizedHref.startsWith('/certifications')
    || normalizedHref.startsWith('/quality-control')
    || normalizedHref.startsWith('/sample-policy')
    || normalizedHref.startsWith('/shipping-and-incoterms')
  ) {
    return 'Review proof page';
  }

  return 'Open resource';
}

const resourceCards = config.resources.map((resource) =>
  resource.href.startsWith('/contact')
    ? {
        ...resource,
        href: evidenceContactHref,
        name: evidenceInquiryLabel,
        contactAction: null,
        openLabel: getResourceActionLabel(resource.href),
      }
    : {
        ...resource,
        contactAction: resource.href.startsWith('/') ? getContextualContactAction(resource.href) : null,
        openLabel: getResourceActionLabel(resource.href),
      }
);

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalURL}#page`,
  url: canonicalURL,
  name: config.title,
  description: config.description,
  isPartOf: { '@id': `${siteURL}/#website` },
  about: { '@id': `${siteURL}/#organization` },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: config.heroEyebrow, item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

// HowTo JSON-LD — generated only when the page has a step-by-step process.
// Currently used by /sample-policy and /quality-control. Google uses this for "How to" rich results
// in SERP, showing the step carousel directly in search results for "how to request RFID samples"
// or "how RFIDAK checks quality" queries.
const howToJsonLd = config.howTo
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      '@id': `${canonicalURL}#how-to`,
      name: config.howTo.title,
      description: config.howTo.intro,
      totalTime: config.howTo.totalTime,
      ...(config.howTo.supply && config.howTo.supply.length > 0 && {
        supply: config.howTo.supply.map((s) => ({ '@type': 'HowToSupply', name: s })),
      }),
      ...(config.howTo.tool && config.howTo.tool.length > 0 && {
        tool: config.howTo.tool.map((t) => ({ '@type': 'HowToTool', name: t })),
      }),
      step: config.howTo.steps.map((s, idx) => ({
        '@type': 'HowToStep',
        position: idx + 1,
        name: s.name,
        text: s.description,
        url: `${canonicalURL}#step-${idx + 1}`,
        ...(s.estimatedTime && { performTime: s.estimatedTime }),
      })),
    }
  : null;

// Only attach hasCredential schema when the page actually lists certificates (currently /certifications).
const credentialJsonLd = config.certificateRegistry
  ? {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      '@id': `${siteURL}/#organization`,
      name: 'Shenzhen RFIDAK Co., LTD',
      url: siteURL,
      hasCredential: config.certificateRegistry.records.map((cert) => ({
        '@type': 'EducationalOccupationalCredential',
        name: cert.name,
        credentialCategory: cert.category,
        recognizedBy: { '@type': 'Organization', name: cert.issuer },
        identifier: cert.certificateNumber,
        validFrom: cert.issueDate,
        validThrough: cert.expiryDate,
        about: cert.scope,
        url: `${siteURL}${cert.documentHref}`,
      })),
    }
  : null;

const jsonLdPayload = [pageJsonLd, breadcrumbJsonLd, faqJsonLd];
if (credentialJsonLd) jsonLdPayload.push(credentialJsonLd);
if (howToJsonLd) jsonLdPayload.push(howToJsonLd);

// Format ISO dates for display in the buyer's locale-independent way: "Jan 2024".
function formatMonthYear(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Layout
  title={config.title}
  description={config.description}
  keywords={config.keywords}
  canonicalURL={canonicalURL}
  jsonLd={jsonLdPayload}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>{config.heroEyebrow}</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label text-[#0d7377] mb-4">{config.heroEyebrow}</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">{config.heroTitle}</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">{config.heroDescription}</p>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid gap-5 md:grid-cols-3">
          {config.highlights.map((item) => (
            <div class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-7">
              <h2 class="title-balance text-xl font-semibold text-gray-900">{item.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
          <div>
            <p class="eyebrow-label text-[#0d7377] mb-2">{config.proofEyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-4">{config.proofTitle}</h2>
            <p class="card-copy text-gray-600 leading-relaxed">{config.proofDescription}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {config.proofCards.map((item) => {
              const anchorId = item.title
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
              return (
                <div id={anchorId} class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6 scroll-mt-24">
                  <h3 class="title-balance text-lg font-semibold text-gray-900">{item.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    {config.certificateRegistry && (
      <section class="bg-[#0b2a30] py-16 text-white border-y border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mb-10">
            <p class="eyebrow-label text-[#4fd1c5] mb-2">{config.certificateRegistry.eyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold">{config.certificateRegistry.title}</h2>
            <p class="card-copy mt-4 text-white/80 leading-relaxed">{config.certificateRegistry.description}</p>
          </div>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3" data-speakable="cert-registry">
            {config.certificateRegistry.records.map((cert) => (
              <article class="copy-safe rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
                <p class="eyebrow-label text-[#4fd1c5] mb-2">{cert.category}</p>
                <h3 class="text-xl font-semibold text-white mb-3">{cert.name}</h3>
                <dl class="space-y-2 text-sm text-white/80">
                  <div class="flex justify-between gap-4">
                    <dt class="text-white/60">Issuer</dt>
                    <dd class="text-right">{cert.issuer}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-white/60">Certificate No.</dt>
                    <dd class="text-right font-mono text-xs">{cert.certificateNumber}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-white/60">Issued</dt>
                    <dd class="text-right">{formatMonthYear(cert.issueDate)}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-white/60">Valid until</dt>
                    <dd class="text-right">{formatMonthYear(cert.expiryDate)}</dd>
                  </div>
                </dl>
                <p class="mt-4 text-xs text-white/70 leading-relaxed border-t border-white/10 pt-3">
                  <span class="block font-semibold text-white/90 mb-1">Scope</span>
                  {cert.scope}
                </p>
                <div class="mt-5 flex flex-wrap gap-3">
                  <a
                    href={cert.documentHref}
                    data-analytics={`cert_view_${cert.name.replace(/[^a-z0-9]+/gi, '-').toLowerCase()}`}
                    class="inline-flex items-center gap-1 rounded-lg bg-[#4fd1c5] px-3 py-1.5 text-xs font-semibold text-[#072a31] hover:bg-[#65dcd0] transition-colors"
                    target="_blank" rel="noopener noreferrer"
                  >
                    View certificate
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                  {cert.verifyUrl && (
                    <a
                      href={cert.verifyUrl}
                      data-analytics={`cert_verify_${cert.name.replace(/[^a-z0-9]+/gi, '-').toLowerCase()}`}
                      class="inline-flex items-center gap-1 rounded-lg border border-white/30 px-3 py-1.5 text-xs font-medium text-white hover:bg-white/10 transition-colors"
                      target="_blank" rel="noopener noreferrer"
                    >
                      Verify with issuer
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
          <p class="mt-10 max-w-3xl text-sm leading-relaxed text-white/70">
            <span class="font-semibold text-white">Note:</span> {config.certificateRegistry.verificationNote}
          </p>
        </div>
      </section>
    )}

    {config.howTo && (
      <section class="bg-white py-16 border-y border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mb-10">
            <p class="eyebrow-label text-[#0d7377] mb-2">{config.howTo.eyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">{config.howTo.title}</h2>
            <p class="card-copy mt-4 text-gray-600 leading-relaxed" data-speakable="howto-intro">
              {config.howTo.intro}
            </p>
            {config.howTo.totalTime && (
              <p class="mt-3 inline-flex items-center gap-2 rounded-full bg-[#0d7377]/5 px-3 py-1 text-xs font-semibold text-[#0d7377]">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Typical total time: {config.howTo.totalTime.replace('P', '').replace('T', '').replace('D', ' days').replace('H', ' hours')}</span>
              </p>
            )}
          </div>

          <ol class="grid gap-5 md:grid-cols-2 xl:grid-cols-3" data-speakable="howto-steps">
            {config.howTo.steps.map((step, idx) => (
              <li id={`step-${idx + 1}`} class="copy-safe rounded-lg border border-gray-200 bg-gray-50 p-6 scroll-mt-24">
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-10 h-10 rounded-full bg-[#0d7377] text-white font-bold flex items-center justify-center text-base">
                    {idx + 1}
                  </span>
                  <div class="min-w-0">
                    <h3 class="text-base font-semibold text-gray-900 leading-snug">{step.name}</h3>
                    <p class="mt-2 text-sm text-gray-600 leading-relaxed">{step.description}</p>
                    {step.estimatedTime && (
                      <p class="mt-3 text-xs text-gray-500">
                        <span class="font-semibold text-gray-700">Estimated:</span>{' '}
                        {step.estimatedTime.replace('P', '').replace('T', '').replace('D', ' days').replace('H', ' hours')}
                      </p>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ol>

          {(config.howTo.supply || config.howTo.tool) && (
            <div class="grid gap-5 md:grid-cols-2 mt-8">
              {config.howTo.supply && config.howTo.supply.length > 0 && (
                <div class="copy-safe rounded-lg border border-gray-200 bg-white p-6">
                  <p class="eyebrow-label text-[#0d7377] mb-2">What you provide</p>
                  <ul class="space-y-2 text-sm text-gray-700">
                    {config.howTo.supply.map((item) => (
                      <li class="flex gap-2">
                        <svg class="w-4 h-4 text-[#0d7377] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {config.howTo.tool && config.howTo.tool.length > 0 && (
                <div class="copy-safe rounded-lg border border-gray-200 bg-white p-6">
                  <p class="eyebrow-label text-[#0d7377] mb-2">What RFIDAK uses</p>
                  <ul class="space-y-2 text-sm text-gray-700">
                    {config.howTo.tool.map((item) => (
                      <li class="flex gap-2">
                        <svg class="w-4 h-4 text-[#0d7377] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    <section class="bg-gray-50 py-16 border-y border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label text-[#0d7377] mb-2">{config.checklistEyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-4">{config.checklistTitle}</h2>
            <p class="card-copy text-gray-600 mb-6">{config.checklistDescription}</p>
            <ul class="space-y-3">
              {config.checklist.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-gray-700">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0d7377]/15 bg-[#0d7377]/5 p-8">
            <h2 class="title-balance text-2xl font-semibold text-gray-900 mb-4">{config.resourcesTitle}</h2>
            <p class="card-copy text-gray-600 mb-6">{config.resourcesDescription}</p>
            <div class="space-y-3">
              {resourceCards.map((resource) => (
                <article class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-white p-4 transition-colors hover:border-[#0d7377]">
                  <a href={resource.href} class="block">
                    <span class="block text-sm font-semibold text-gray-800">{resource.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{resource.description}</span>
                  </a>
                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    <a href={resource.href} class="inline-flex items-center text-sm font-semibold text-[#0d7377]">
                      {resource.openLabel}
                      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                    {resource.contactAction && (
                      <a href={resource.contactAction.href} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                        {resource.contactAction.label}
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl">
          <div class="text-center mb-10">
            <p class="eyebrow-label text-[#0d7377] mb-2">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Questions buyers often ask on this topic</h2>
          </div>
          <div class="space-y-4">
            {config.faqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-gray-50 p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0d7377] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 leading-relaxed text-gray-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0d7377] py-14">
      <div class="container mx-auto px-4 text-center">
        <h2 class="title-balance text-3xl font-bold text-white mb-4">{config.ctaTitle}</h2>
        <p class="mx-auto mb-7 max-w-3xl text-white/90">{config.ctaDescription}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={evidenceContactHref} class="rounded-lg bg-white px-6 py-3 font-semibold text-[#0d7377] hover:bg-gray-100 transition-colors">
            {evidenceInquiryLabel}
          </a>
          <a href="/products" class="rounded-lg border border-white px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
            Browse product families
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
