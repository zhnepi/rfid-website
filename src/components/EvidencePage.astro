---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Newsletter from './Newsletter.astro';
import { evidencePages } from '../data/evidencePages';
import { getContextualContactAction, getContextualInquiryLabel, getEvidenceContactHref, getEvidenceInquiryIntent } from '../utils/contact';

interface Props {
  pageKey: keyof typeof evidencePages;
}

const { pageKey } = Astro.props;
const config = evidencePages[pageKey];
const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/${config.slug}`;
const evidenceContactHref = getEvidenceContactHref(config.slug);
const evidenceInquiryLabel = getContextualInquiryLabel(getEvidenceInquiryIntent(config.slug), 'evidence');

function getResourceActionLabel(href: string) {
  const normalizedHref = href.split(/[?#]/)[0] || '';

  if (normalizedHref.startsWith('/contact')) return 'Open inquiry path';
  if (normalizedHref.startsWith('/blogs')) return 'Read guide';
  if (normalizedHref.startsWith('/compare')) return 'Review comparison';
  if (normalizedHref.startsWith('/solutions')) return 'Review workflow';
  if (normalizedHref.startsWith('/markets')) return 'Review market path';
  if (normalizedHref.startsWith('/products') || normalizedHref.startsWith('/rfid') || normalizedHref.startsWith('/product') || normalizedHref.startsWith('/category')) {
    return 'Browse product path';
  }
  if (
    normalizedHref.startsWith('/certifications')
    || normalizedHref.startsWith('/quality-control')
    || normalizedHref.startsWith('/sample-policy')
    || normalizedHref.startsWith('/shipping-and-incoterms')
  ) {
    return 'Review proof page';
  }

  return 'Open resource';
}

const resourceCards = config.resources.map((resource) =>
  resource.href.startsWith('/contact')
    ? {
        ...resource,
        href: evidenceContactHref,
        name: evidenceInquiryLabel,
        contactAction: null,
        openLabel: getResourceActionLabel(resource.href),
      }
    : {
        ...resource,
        contactAction: resource.href.startsWith('/') ? getContextualContactAction(resource.href) : null,
        openLabel: getResourceActionLabel(resource.href),
      }
);

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalURL}#page`,
  url: canonicalURL,
  name: config.title,
  description: config.description,
  isPartOf: { '@id': `${siteURL}/#website` },
  about: { '@id': `${siteURL}/#organization` },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: config.heroEyebrow, item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout
  title={config.title}
  description={config.description}
  keywords={config.keywords}
  canonicalURL={canonicalURL}
  jsonLd={[pageJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>{config.heroEyebrow}</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label text-[#0d7377] mb-4">{config.heroEyebrow}</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">{config.heroTitle}</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">{config.heroDescription}</p>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid gap-5 md:grid-cols-3">
          {config.highlights.map((item) => (
            <div class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-7">
              <h2 class="title-balance text-xl font-semibold text-gray-900">{item.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
          <div>
            <p class="eyebrow-label text-[#0d7377] mb-2">{config.proofEyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-4">{config.proofTitle}</h2>
            <p class="card-copy text-gray-600 leading-relaxed">{config.proofDescription}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {config.proofCards.map((item) => {
              const anchorId = item.title
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
              return (
                <div id={anchorId} class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6 scroll-mt-24">
                  <h3 class="title-balance text-lg font-semibold text-gray-900">{item.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16 border-y border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label text-[#0d7377] mb-2">{config.checklistEyebrow}</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-4">{config.checklistTitle}</h2>
            <p class="card-copy text-gray-600 mb-6">{config.checklistDescription}</p>
            <ul class="space-y-3">
              {config.checklist.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-gray-700">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0d7377]/15 bg-[#0d7377]/5 p-8">
            <h2 class="title-balance text-2xl font-semibold text-gray-900 mb-4">{config.resourcesTitle}</h2>
            <p class="card-copy text-gray-600 mb-6">{config.resourcesDescription}</p>
            <div class="space-y-3">
              {resourceCards.map((resource) => (
                <article class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-white p-4 transition-colors hover:border-[#0d7377]">
                  <a href={resource.href} class="block">
                    <span class="block text-sm font-semibold text-gray-800">{resource.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{resource.description}</span>
                  </a>
                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    <a href={resource.href} class="inline-flex items-center text-sm font-semibold text-[#0d7377]">
                      {resource.openLabel}
                      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                    {resource.contactAction && (
                      <a href={resource.contactAction.href} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                        {resource.contactAction.label}
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl">
          <div class="text-center mb-10">
            <p class="eyebrow-label text-[#0d7377] mb-2">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Questions buyers often ask on this topic</h2>
          </div>
          <div class="space-y-4">
            {config.faqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-gray-50 p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0d7377] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 leading-relaxed text-gray-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0d7377] py-14">
      <div class="container mx-auto px-4 text-center">
        <h2 class="title-balance text-3xl font-bold text-white mb-4">{config.ctaTitle}</h2>
        <p class="mx-auto mb-7 max-w-3xl text-white/90">{config.ctaDescription}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={evidenceContactHref} class="rounded-lg bg-white px-6 py-3 font-semibold text-[#0d7377] hover:bg-gray-100 transition-colors">
            {evidenceInquiryLabel}
          </a>
          <a href="/products" class="rounded-lg border border-white px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
            Browse product families
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
