      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-[#0d7377] transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Product Categories -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Products</h3>
        <ul class="space-y-2">
          {productCategories.map(cat => (
            <li>
              <a href={cat.href} class="text-sm text-gray-400 hover:text-[#0d7377] transition-colors">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-[#0d7377] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
