---
const currentYear = new Date().getFullYear();

const productCategories = [
  { name: 'RFID Cards', href: '/category/rfid-cards' },
  { name: 'RFID Tags', href: '/category/rfid-tags' },
  { name: 'RFID Labels', href: '/category/rfid-labels' },
  { name: 'RFID Wristbands', href: '/category/rfid-wristbands' },
  { name: 'RFID Keyfobs', href: '/category/rfid-keyfob' },
  { name: 'RFID Readers', href: '/category/rfid-readers' },
];

const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'About Us', href: '/about' },
  { name: 'All Products', href: '/rfid' },
  { name: 'RFID Technology Guide', href: '/rfid-technology' },
  { name: 'Blog', href: '/blogs' },
  { name: 'Contact Us', href: '/contact' },
];
---

