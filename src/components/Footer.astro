---
import { evidenceLinks, footerQuickLinks, guideLinks, productCategoryLinks } from '../data/navigation';
import { getContextualContactAction, getContextualEmailAction, getContextualWhatsAppAction } from '../utils/contact';

const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const contextualContactAction = getContextualContactAction(currentPath);
const contextualEmailAction = getContextualEmailAction(currentPath);
const contextualWhatsAppAction = getContextualWhatsAppAction(currentPath);
const footerCtaLabel = currentPath === '/' ? 'Request samples or quote' : contextualContactAction.label;
---

<footer class="bg-[#0d0d0d] text-white/50 mt-auto border-t border-[#c9a84c]/10">
  <!-- Gold accent line at top -->
  <div class="h-[1px] bg-gradient-to-r from-transparent via-[#c9a84c]/40 to-transparent"></div>

  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-10">
      <!-- Brand Column -->
      <div>
        <a href="/" class="inline-block mb-5">
          <span class="text-2xl font-bold tracking-[0.18em]">
            <span class="text-[#c9a84c]">PR</span><span class="text-white/90">O</span><span class="text-[#c9a84c]">UDTEK</span>
          </span>
        </a>
        <p class="text-sm text-white/35 mb-5 leading-relaxed">
          Professional RFID cards, tags, labels, wristbands and readers from Shenzhen, China, with practical buying guides, supplier evidence and sample-planning support.
        </p>
        <div class="flex items-center gap-3">
          <a href="https://www.linkedin.com/company/proudtek" target="_blank" rel="noopener noreferrer" class="brand-icon-shell-dark" aria-label="LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@proudtek" target="_blank" rel="noopener noreferrer" class="brand-icon-shell-dark" aria-label="YouTube">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
          </a>
          <a href={contextualWhatsAppAction.href} target="_blank" rel="noopener noreferrer" class="brand-icon-shell-dark" aria-label={contextualWhatsAppAction.label}>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white/80 font-medium text-sm tracking-wider uppercase mb-5">Quick Links</h3>
        <ul class="space-y-2.5">
          {footerQuickLinks.map((link) => (
            <li>
              <a href={link.href.startsWith('/contact') ? contextualContactAction.href : link.href} class="text-sm text-white/35 hover:text-[#c9a84c] transition-colors duration-300">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Product Categories -->
      <div>
        <h3 class="text-white/80 font-medium text-sm tracking-wider uppercase mb-5">Product Categories</h3>
        <ul class="space-y-2.5">
          {productCategoryLinks.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-white/35 hover:text-[#c9a84c] transition-colors duration-300">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Guides -->
      <div>
        <h3 class="text-white/80 font-medium text-sm tracking-wider uppercase mb-5">Guides And Hubs</h3>
        <ul class="space-y-2.5">
          {guideLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/35 hover:text-[#c9a84c] transition-colors duration-300">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Proof -->
      <div>
        <h3 class="text-white/80 font-medium text-sm tracking-wider uppercase mb-5">Proof And Policies</h3>
        <ul class="space-y-2.5">
          {evidenceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/35 hover:text-[#c9a84c] transition-colors duration-300">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-white/80 font-medium text-sm tracking-wider uppercase mb-5">Contact Us</h3>
        <ul class="space-y-3.5 text-sm text-white/35">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 text-[#c9a84c]/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>Shenzhen, Guangdong, China</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-[#c9a84c]/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href={contextualEmailAction.href} aria-label={contextualEmailAction.label} class="hover:text-[#c9a84c] transition-colors duration-300">info@proudtek.com</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-[#c9a84c]/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span>+86-755-2376-5843</span>
          </li>
          <li class="pt-3">
            <a href={contextualContactAction.href} class="cta-primary">
              {footerCtaLabel}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="text-center mt-14 pt-8 border-t border-white/5">
      <p class="text-xs text-white/25 tracking-wide">&copy; {currentYear} Shenzhen Proud Tek Co., LTD. All Rights Reserved. | <a href="/rfid" class="hover:text-[#c9a84c] transition-colors duration-300">RFID Manufacturer</a></p>
    </div>
  </div>
</footer>

<!-- Scroll-to-top -->
<button
  id="scroll-top-btn"
  class="fixed bottom-8 right-8 bg-[#0d0d0d] text-[#c9a84c] border border-[#c9a84c]/20 p-3 shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-[#141414] hover:border-[#c9a84c]/40 hover:shadow-[0_4px_20px_rgba(13,13,13,0.24)] z-50"
  aria-label="Scroll to top"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</button>

<script>
  const scrollTopBtn = document.getElementById('scroll-top-btn');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      scrollTopBtn?.classList.remove('opacity-0', 'invisible');
      scrollTopBtn?.classList.add('opacity-100', 'visible');
    } else {
      scrollTopBtn?.classList.add('opacity-0', 'invisible');
      scrollTopBtn?.classList.remove('opacity-100', 'visible');
    }
  }, { passive: true });

  scrollTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
