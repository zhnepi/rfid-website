---
import { blogPosts } from '../data/blogs';
const blogs = blogPosts.slice(0, 3).map(post => ({
  title: post.title,
  category: post.category,
  date: post.date,
  image: post.image.replace('w=600', 'w=400'),
  href: `/blogs/${post.slug}`,
}));
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-semibold text-gray-800 mb-4">Latest News and Blogs</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Be the first to find out about our latest news, promotions and special offers by reading our news stories, and subscribing to our newsletter.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {blogs.map((blog) => (
        <article class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <a href={blog.href} class="block">
            <div class="relative aspect-[16/10] overflow-hidden">
              <img 
                src={blog.image} 
                alt={blog.title}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              />
            </div>
          </a>
          <div class="p-6">
            <span class="text-[#0d7377] text-xs uppercase tracking-wider font-medium">{blog.category}</span>
            <h3 class="text-xl font-semibold text-gray-800 mt-2 mb-4 hover:text-[#0d7377] transition-colors">
              <a href={blog.href}>{blog.title}</a>
            </h3>
            <div class="flex items-center justify-between">
              <a 
                href={blog.href}
                class="text-[#0d7377] font-medium hover:text-[#0a5c5f] transition-colors inline-flex items-center gap-1"
              >
                Read more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              <span class="text-gray-400 text-sm">{blog.date}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- View all blogs -->
    <div class="flex justify-center mt-10">
      <a href="/blogs" class="bg-[#0d7377] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#0a5c5f] transition-colors inline-flex items-center gap-2">
        View All Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
