---
import { blogPosts } from '../data/blogs';
import { getBlogComparisonLinks } from '../utils/comparisons';

const blogs = [...blogPosts]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3)
  .map(post => ({
    slug: post.slug,
    title: post.title,
    category: post.category,
    date: post.date,
    image: post.image,
    href: `/blogs/${post.slug}`,
    topComparison: getBlogComparisonLinks(post.slug, post.category, 1)[0],
  }));
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="title-balance text-4xl font-semibold text-gray-800 mb-4">RFID Guides and Insights</h2>
      <p class="card-copy text-gray-600 max-w-2xl mx-auto">
        Explore practical content around RFID frequencies, chip selection, product sourcing and industry applications, then move into the matching product categories when you are ready.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {blogs.map((blog) => (
        <article class="copy-safe bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <a href={blog.href} class="block">
            <div class="relative aspect-[16/10] overflow-hidden">
              <img 
                src={blog.image} 
                alt={blog.title}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                width="640"
                height="400"
              />
            </div>
          </a>
          <div class="p-6">
            <span class="text-[#0d7377] text-xs uppercase tracking-wider font-medium">{blog.category}</span>
            <h3 class="text-xl font-semibold text-gray-800 mt-2 mb-4 hover:text-[#0d7377] transition-colors">
              <a href={blog.href}>{blog.title}</a>
            </h3>
            {blog.topComparison && (
              <a
                href={`/compare/${blog.topComparison.slug}`}
                class="mb-4 inline-flex max-w-full rounded-full border border-[#c9a84c]/15 bg-[#c9a84c]/5 px-3 py-1.5 text-xs font-medium text-[#c9a84c] transition-colors hover:border-[#c9a84c] hover:bg-white"
              >
                <span class="truncate">Compare: {blog.topComparison.name}</span>
              </a>
            )}
            <div class="flex items-center justify-between">
              <a 
                href={blog.href}
                class="text-[#0d7377] font-medium hover:text-[#0a5c5f] transition-colors inline-flex items-center gap-1"
              >
                Read guide
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              <span class="text-gray-400 text-sm">{blog.date}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- View all blogs -->
    <div class="flex justify-center mt-10">
      <a href="/blogs" class="bg-[#0d7377] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#0a5c5f] transition-colors inline-flex items-center gap-2">
        View All Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
