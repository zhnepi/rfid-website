---
const stats = [
  { number: '108+', label: 'Global Clients' },
  { number: '50+', label: 'Countries Served' },
  { number: '15+', label: 'Years Experience' },
  { number: '46+', label: 'Product Models' },
];

const industries = [
  'Public Transit', 'Hotels & Resorts', 'Hospitals', 'Libraries',
  'Retail Chains', 'Industrial Laundry', 'Events & Festivals', 'Smart Buildings',
  'Logistics', 'Automotive', 'Education', 'Government',
];
---

<section class="py-16 bg-white border-y border-[#e8e5df]">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10 reveal">
      <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-3">Trusted Worldwide</p>
      <h2 class="font-serif text-2xl md:text-3xl font-normal text-[#0d0d0d]">Serving Clients in 50+ Countries</h2>
      <div class="w-12 h-[1px] bg-[#c9a84c] mx-auto mt-4"></div>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12 max-w-4xl mx-auto reveal">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-serif text-[#c9a84c]">{stat.number}</p>
          <p class="text-xs text-[#888] mt-1.5 tracking-wider uppercase">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Industries Served -->
    <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto reveal reveal-delay-1">
      {industries.map((industry) => (
        <span class="px-5 py-2.5 bg-[#fafaf8] border border-[#e8e5df] text-xs text-[#666] font-medium tracking-wider uppercase hover:border-[#c9a84c]/30 hover:text-[#c9a84c] transition-all duration-300 cursor-default">
          {industry}
        </span>
      ))}
    </div>
  </div>
</section>
