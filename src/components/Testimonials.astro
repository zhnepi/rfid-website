---
const testimonials = [
  {
    quote: "We would hate to go to another supplier, as we prefer doing business with Proud Tek! We are very satisfied with your company! It is always a pleasure to do business with you.",
    name: "Sladjan M.",
    title: "CEO",
    company: "Security Solutions",
    country: "Serbia",
    rating: 5,
  },
  {
    quote: "Your cards and keyfobs are selling very well here in Brazil. After this order is ready, I will probably place another order of 50k or 100k for each card type and keyfobs.",
    name: "Claudio R.",
    title: "Director",
    company: "RFID Distributor",
    country: "Brazil",
    rating: 5,
  },
  {
    quote: "I am very excited to say the cards worked perfectly with our system. The readers entered the required information into our software program and enrolment of users is very easy and quick. Thanks so much for all your help!",
    name: "James W.",
    title: "Project Engineer",
    company: "Access Systems Ltd",
    country: "Australia",
    rating: 5,
  },
  {
    quote: "ProudTek delivered 200,000 RFID laundry tags on time with zero defects. Their quality control is exceptional and pricing is very competitive. We have been working together for 5 years now.",
    name: "Ahmed K.",
    title: "Procurement Manager",
    company: "Industrial Laundry Group",
    country: "UAE",
    rating: 5,
  },
  {
    quote: "The NFC wristbands worked flawlessly at our music festival with 30,000 attendees. Custom printing quality was excellent. ProudTek is now our go-to supplier for all event RFID products.",
    name: "Maria L.",
    title: "Operations Director",
    company: "Event Tech Solutions",
    country: "Mexico",
    rating: 5,
  },
];
---

<section class="py-24 bg-[#0d0d0d] relative overflow-hidden">
  <!-- Subtle gold radial glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(201,168,76,0.04),transparent_70%)]"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-14 reveal">
      <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-3">Testimonials</p>
      <h2 class="font-serif text-3xl md:text-4xl font-normal text-white/90">What Our Clients Say</h2>
      <div class="w-12 h-[1px] bg-[#c9a84c] mx-auto mt-5"></div>
    </div>

    <div class="relative max-w-4xl mx-auto reveal">
      <!-- Testimonial Slider -->
      <div id="testimonial-slider" class="overflow-hidden">
        <div id="testimonial-track" class="flex transition-transform duration-700 ease-in-out">
          {testimonials.map((testimonial) => (
            <div class="testimonial-slide w-full flex-shrink-0 px-4">
              <div class="bg-[#141414] border border-white/5 p-10">
                <!-- Stars -->
                <div class="flex gap-1 mb-5">
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <svg class="w-4 h-4 text-[#c9a84c]" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                    </svg>
                  ))}
                </div>
                <div class="border-l border-[#c9a84c]/30 pl-7">
                  <p class="font-serif text-white/70 text-lg italic leading-relaxed mb-6">
                    "{testimonial.quote}"
                  </p>
                </div>
                <div class="mt-7 flex items-center gap-4">
                  <div class="w-11 h-11 bg-[#c9a84c]/10 border border-[#c9a84c]/20 flex items-center justify-center text-[#c9a84c] font-medium text-lg">
                    {testimonial.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-medium text-white/80 text-sm">{testimonial.name}</p>
                    <p class="text-xs text-white/40">{testimonial.title}, {testimonial.company}</p>
                    <p class="text-xs text-white/25 mt-0.5">{testimonial.country}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Buttons -->
      <button
        id="testimonial-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-[#141414] border border-white/10 p-3 hover:border-[#c9a84c]/30 hover:text-[#c9a84c] transition-all duration-300 z-10"
        aria-label="Previous testimonial"
      >
        <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        id="testimonial-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-[#141414] border border-white/10 p-3 hover:border-[#c9a84c]/30 hover:text-[#c9a84c] transition-all duration-300 z-10"
        aria-label="Next testimonial"
      >
        <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('testimonial-track');
  const slides = document.querySelectorAll('.testimonial-slide');
  const prevBtn = document.getElementById('testimonial-prev');
  const nextBtn = document.getElementById('testimonial-next');
  let currentIndex = 0;

  function updateSlider() {
    if (track) {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
    }
  }

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
    updateSlider();
  });

  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % slides.length;
    updateSlider();
  });

  // Auto-play
  setInterval(() => {
    currentIndex = (currentIndex + 1) % slides.length;
    updateSlider();
  }, 6000);
</script>
