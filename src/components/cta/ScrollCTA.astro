---
// W6 QW#13: Sticky bottom CTA bar that rises after 70% scroll depth.
// - Mobile: visible under 768px, positioned above Layout's fixed mobile bar
// - Desktop (≥ 768px): visible bottom-right as a compact pill
// - Dismissible (7-day localStorage key per-page)
// - Reads contextual CTA via passed props (caller decides intent/category)

interface Props {
  contactHref: string;
  contactLabel: string;
  whatsappHref: string;
  whatsappMessage?: string;
  source?: string; // used for analytics key e.g. "product", "category", "blog"
}

const {
  contactHref,
  contactLabel = 'Get a Quote',
  whatsappHref,
  source = 'page',
} = Astro.props;
---

<div
  id="scroll-cta"
  class="scroll-cta hidden fixed z-40 left-0 right-0 bottom-16 md:bottom-5 md:left-auto md:right-5 md:w-auto"
  data-source={source}
  aria-hidden="true"
>
  <div class="mx-3 md:mx-0 rounded-xl border border-gray-200 bg-white/98 backdrop-blur shadow-[0_12px_28px_-12px_rgba(15,23,42,0.28)] p-3 md:p-4 flex items-center gap-3 md:max-w-sm">
    <div class="w-9 h-9 rounded-lg bg-[#0d7377]/8 flex items-center justify-center flex-shrink-0" aria-hidden="true">
      <svg class="w-5 h-5 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs font-semibold text-gray-900 leading-tight">Still deciding?</p>
      <p class="text-[11px] text-gray-500 leading-snug">Free samples · Reply in 2–4h</p>
    </div>
    <div class="flex items-center gap-1.5 flex-shrink-0">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[#25D366] hover:bg-[#20ba5a] text-white transition-colors"
        data-analytics={`scroll_cta_whatsapp_${source}`}
        aria-label="Open WhatsApp"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <a
        href={contactHref}
        class="inline-flex items-center justify-center px-3 h-9 rounded-lg bg-[#0d7377] hover:bg-[#0a5c5f] text-white text-xs font-semibold transition-colors"
        data-analytics={`scroll_cta_quote_${source}`}
      >
        {contactLabel}
      </a>
    </div>
    <button
      type="button"
      id="scroll-cta-close"
      class="ml-1 text-gray-400 hover:text-gray-600 flex-shrink-0"
      aria-label="Dismiss"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var bar = document.getElementById('scroll-cta');
    if (!bar) return;

    var key = 'rfidak_scroll_cta_v1:' + location.pathname;
    var now = Date.now();
    var sevenDays = 7 * 24 * 3600 * 1000;

    try {
      var raw = localStorage.getItem(key);
      if (raw) {
        var until = parseInt(raw, 10);
        if (!Number.isNaN(until) && until > now) return;
      }
    } catch (_) {}

    var shown = false;
    var threshold = 0.7;

    function checkScroll() {
      if (shown) return;
      var doc = document.documentElement;
      var max = Math.max(doc.scrollHeight - doc.clientHeight, 1);
      var ratio = window.scrollY / max;
      if (ratio >= threshold) {
        bar.classList.remove('hidden');
        bar.setAttribute('aria-hidden', 'false');
        shown = true;
        window.removeEventListener('scroll', checkScroll);
        try { window.rfidakTrack && window.rfidakTrack('scroll_cta_shown', { page: location.pathname, source: bar.dataset.source || 'page' }); } catch (_) {}
      }
    }

    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();

    var close = document.getElementById('scroll-cta-close');
    close && close.addEventListener('click', function () {
      bar.classList.add('hidden');
      bar.setAttribute('aria-hidden', 'true');
      try { localStorage.setItem(key, String(now + sevenDays)); } catch (_) {}
      try { window.rfidakTrack && window.rfidakTrack('scroll_cta_dismissed', { page: location.pathname }); } catch (_) {}
    });
  })();
</script>
