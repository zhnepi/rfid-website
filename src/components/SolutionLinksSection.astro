---
import { solutionPagesList } from '../data/solutions';
import { getSolutionComparisonLinks } from '../utils/comparisons';
import { getContextualInquiryLabel, getSolutionContactHref, getSolutionInquiryIntent } from '../utils/contact';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
}

const {
  eyebrow = 'Solution Hubs',
  title = 'Go from application problem to the most relevant RFID product path',
  description = 'Use these workflow pages when the operational problem is clear but the right product family, proof page or sample path still is not.',
} = Astro.props;

const solutionCards = solutionPagesList.map((page) => ({
  ...page,
  topComparison: getSolutionComparisonLinks(page.slug, page.productSlugs, 1)[0],
  contactHref: getSolutionContactHref(page.slug),
  inquiryLabel: getContextualInquiryLabel(getSolutionInquiryIntent(page.slug), 'solution'),
}));
---

<section class="border-y border-gray-100 bg-white py-16">
  <div class="container mx-auto px-4">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow-label mb-2 text-[#0d7377]">{eyebrow}</p>
        <h2 class="title-balance text-3xl font-semibold text-gray-900">{title}</h2>
      </div>
      <p class="card-copy max-w-xl text-gray-600">{description}</p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {solutionCards.map((page) => (
        <article class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0d7377] hover:bg-white">
          <a href={`/solutions/${page.slug}`} class="block">
            <span class="eyebrow-label text-[#0d7377]">{page.heroEyebrow}</span>
            <h3 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{page.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{page.description}</p>
          </a>
          <div class="mt-5 flex items-end justify-between gap-4 border-t border-gray-200/80 pt-4">
            <div class="min-w-0">
              {page.topComparison ? (
                <a href={`/compare/${page.topComparison.slug}`} class="min-w-0 text-xs font-medium text-[#0d7377] transition-colors hover:text-[#0a5c5f]">
                  <span class="block truncate">Compare: {page.topComparison.name}</span>
                </a>
              ) : (
                <span class="block text-xs text-gray-400">Use-case buying path</span>
              )}
              <a href={page.contactHref} class="mt-2 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                {page.inquiryLabel}
              </a>
            </div>
            <a href={`/solutions/${page.slug}`} class="inline-flex shrink-0 items-center text-sm font-semibold text-[#0d7377]">
              Review workflow
              <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
