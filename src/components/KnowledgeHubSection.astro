---
import { getIntentContactHref } from '../utils/contact';

const clusters = [
  {
    eyebrow: 'Technology',
    title: 'RFID technology guide',
    description: 'Start with the core differences between LF, HF/NFC and UHF, then move into chip families, form factors and sample planning.',
    href: '/rfid-technology',
    cta: 'Read the guide',
  },
  {
    eyebrow: 'Buying Guide',
    title: 'How to order RFID cards from China',
    description: 'Helpful for sourcing teams comparing sample policy, lead times, customization and manufacturer communication.',
    href: '/blogs/how-to-order-rfid-cards-from-china',
    cta: 'See buyer checklist',
  },
  {
    eyebrow: 'Comparisons',
    title: 'RFID comparison pages',
    description: 'Move quickly through chip, frequency and product-format tradeoffs when visitors are choosing between two realistic directions.',
    href: '/compare',
    cta: 'Explore comparisons',
  },
  {
    eyebrow: 'Applications',
    title: 'RFID solution hubs by use case',
    description: 'Jump from hotel access, laundry, asset tracking or library workflows into the landing pages built around that buying conversation.',
    href: '/solutions',
    cta: 'Explore solutions',
  },
];

const quickLinks = [
  { href: '/blogs/rfid-frequency-guide', label: 'RFID frequency selection' },
  { href: '/blogs/nfc-technology', label: 'NFC basics and smartphone use' },
  { href: '/compare/hf-vs-uhf-rfid', label: 'HF vs UHF comparison' },
  { href: '/compare/mifare-classic-vs-desfire', label: 'Mifare Classic vs DESFire' },
  { href: '/solutions/hotel-access-rfid', label: 'Hotel access solution hub' },
  { href: '/solutions/laundry-linen-rfid', label: 'Laundry and linen hub' },
  { href: '/compare/rfid-labels-vs-hard-tags', label: 'Labels vs hard tags' },
  { href: '/solutions/industrial-asset-tracking-rfid', label: 'Asset tracking solution hub' },
  { href: getIntentContactHref('samples'), label: 'Request samples and advice' },
];
---

<section class="py-20 bg-gray-50 border-y border-gray-100">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mb-10">
      <p class="eyebrow-label eyebrow-label-wide text-[#0e7490] mb-2">Knowledge Hub</p>
      <h2 class="title-balance text-3xl md:text-4xl font-semibold text-gray-900">A stronger path from search intent to product shortlist</h2>
      <p class="card-copy text-gray-600 mt-4">
        Start here when the team has a broad RFID question but still needs to turn it into a product shortlist, a sample plan or a sourcing decision.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {clusters.map((cluster) => (
        <a
          href={cluster.href}
          class="copy-safe group rounded-[1.75rem] border border-gray-200 bg-white p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
        >
          <p class="eyebrow-label text-[#0e7490]">{cluster.eyebrow}</p>
          <h3 class="title-balance text-2xl font-semibold text-gray-900 mt-4">{cluster.title}</h3>
          <p class="card-copy text-gray-600 mt-3">{cluster.description}</p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-[#0e7490]">
            {cluster.cta}
            <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-10 rounded-[1.75rem] bg-slate-950 px-7 py-8 text-white">
      <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-8 items-start">
        <div>
          <p class="eyebrow-label text-[#0e7490] mb-2">Quick Links</p>
          <h3 class="title-balance text-2xl font-semibold">High-intent topics visitors often search first</h3>
        </div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
          {quickLinks.map((link) => (
            <a
              href={link.href}
              class="copy-safe rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-sm text-white/85 hover:bg-white/10 transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
