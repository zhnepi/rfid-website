---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { products } from '../data/products';
import { categoryPages } from '../data/categoryPages';
import { truncateText } from '../utils/content';
import { getCategoryComparisonLinks, getProductComparisonLinks } from '../utils/comparisons';
import { getCategoryContactHref, getCategoryInquiryIntent, getContextualInquiryLabel, getWhatsAppHref } from '../utils/contact';
import { getProductBuyerSummary } from '../utils/productCopy';

interface Props {
  categoryKey: string;
}

const { categoryKey } = Astro.props;
const config = categoryPages[categoryKey];
const categoryProducts = products.filter((product) => product.category === config.categoryName);
const categoryProductsWithCompare = categoryProducts.map((product) => ({
  product,
  topComparison: getProductComparisonLinks(product, 1)[0],
}));
const categoryHighlightQuestions: Record<string, string[]> = {
  'rfid-cards': [
    'Will these cards match our existing readers?',
    'What print and finishing options should we lock first?',
    'Can we approve samples before a repeat order program starts?',
  ],
  'rfid-tags': [
    'Will the tag survive the real environment and mounting surface?',
    'Which enclosure and chip fit this workflow best?',
    'Can we compare a sample set before rollout?',
  ],
  'rfid-labels': [
    'Do we need NFC tap or UHF inventory reading?',
    'Will the label stock work with our printer and surface?',
    'How should serialization or tamper needs be planned?',
  ],
  'rfid-readers': [
    'Which reader supports our chip, protocol, and interface?',
    'Do we need desktop hardware or an integration-ready module?',
    'Can readers, cards, and tags be tested together first?',
  ],
  'rfid-keyfob': [
    'Will the keyfob match the system already in the field?',
    'Which shell balances daily durability and brand look?',
    'Can repeat supply stay consistent for replacements?',
  ],
  'rfid-wristbands': [
    'Which wristband fits the venue and wear time?',
    'Do we need waterproof access, payment, or both?',
    'Can branding, size, and closure be confirmed before rollout?',
  ],
};
const categoryComparisonLinks = getCategoryComparisonLinks(config.key, categoryProducts, 4);
const categoryContactHref = getCategoryContactHref({
  key: config.key,
  slug: config.slug,
  categoryName: config.categoryName,
});
const categoryWhatsAppHref = getWhatsAppHref(config.whatsappMessage);
const heroPrimaryCtaLabel = config.heroPrimaryCtaLabel || getContextualInquiryLabel(
  getCategoryInquiryIntent({
    key: config.key,
    slug: config.slug,
    categoryName: config.categoryName,
  }),
  'category'
);
const heroGuideCta = config.heroGuideCta || (
  categoryComparisonLinks[0]
    ? {
        href: `/compare/${categoryComparisonLinks[0].slug}`,
        label: `Review ${categoryComparisonLinks[0].name}`,
      }
    : config.resources[0]
);
const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/category/${config.slug}`;

const itemListElements = categoryProducts.slice(0, 16).map((product, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  url: `${siteURL}/product/${product.slug}`,
  name: product.name,
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: config.title,
  description: config.description,
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: itemListElements,
  },
  about: {
    '@type': 'Thing',
    name: config.categoryName,
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'RFID Products', item: `${siteURL}/rfid` },
    { '@type': 'ListItem', position: 3, name: config.categoryName, item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout
  title={config.title}
  description={config.description}
  keywords={config.keywords}
  canonicalURL={canonicalURL}
  ogImage={categoryProducts[0]?.images?.[0] || '/images/hero/smart-card-banner.webp'}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-r from-[#0e7490] to-[#0097a7] text-white py-16">
      <div class="container mx-auto px-4">
        <nav class="text-sm mb-4" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <a href="/rfid" class="hover:underline">RFID Products</a>
          <span class="mx-2">/</span>
          <span>{config.categoryName}</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label text-[#0e7490]/70 mb-3">RFID Product Category</p>
          <h1 class="title-balance text-4xl md:text-5xl font-bold mb-4">{config.categoryName}</h1>
          <p class="card-copy text-lg md:text-xl text-white/90 max-w-3xl">{config.heroDescription}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={categoryContactHref} class="rounded-lg bg-white px-6 py-3 font-semibold text-[#0e7490] hover:bg-gray-100 transition-colors">
              {heroPrimaryCtaLabel}
            </a>
            {heroGuideCta && (
              <a href={heroGuideCta.href} class="rounded-lg border border-white/70 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                {heroGuideCta.label}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="py-8 bg-white border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-4">
          {config.highlights.map((item, index) => (
            <div class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6">
              <p class="eyebrow-label text-[#0e7490] mb-2">{item.title}</p>
              <h2 class="title-balance text-lg font-semibold text-gray-800 mb-2">
                {categoryHighlightQuestions[config.key]?.[index] || item.title}
              </h2>
              <p class="card-copy text-sm text-gray-600 leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-8">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Product Lineup</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800">Available {config.categoryName}</h2>
          </div>
          <p class="text-gray-600">{categoryProducts.length} product pages ready to compare</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {categoryProductsWithCompare.map(({ product, topComparison }) => (
            <article class="copy-safe group overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:shadow-xl">
              <a href={`/product/${product.slug}`} class="block">
                <div class="aspect-square overflow-hidden bg-gray-100">
                  <img
                    src={product.images[0]}
                    alt={`${product.name} - ${config.categoryName} from ProudTek RFID manufacturer in China`}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="500"
                    height="500"
                  />
                </div>
                <div class="p-5">
                  <h3 class="title-balance font-semibold text-gray-800 transition-colors group-hover:text-[#0e7490] line-clamp-2">
                    {product.name}
                  </h3>
                  <p class="card-copy mt-2 text-sm text-gray-500 line-clamp-3">
                    {getProductBuyerSummary(product, 118)}
                  </p>
                </div>
              </a>
              <div class="flex items-center justify-between gap-3 border-t border-gray-100 px-5 pb-5 pt-4">
                {topComparison ? (
                  <a href={`/compare/${topComparison.slug}`} class="min-w-0 text-xs font-medium text-[#0e7490] transition-colors hover:text-[#155e75]">
                    <span class="block truncate">Compare: {topComparison.name}</span>
                  </a>
                ) : (
                  <span class="text-xs text-gray-400">Browse product details</span>
                )}
                <a href={`/product/${product.slug}`} class="inline-flex shrink-0 items-center text-sm font-medium text-[#0e7490]">
                  View product
                  <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {categoryComparisonLinks.length > 0 && (
      <section class="py-16 bg-white border-t border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
              <div>
                <p class="eyebrow-label text-[#0e7490] mb-2">Comparison Pages</p>
                <h2 class="title-balance text-3xl font-bold text-gray-800">Useful head-to-head pages before you lock this category</h2>
              </div>
              <p class="card-copy max-w-2xl text-gray-600">
                Use these head-to-head pages when this category is close, but chip, frequency or format choice is still keeping the shortlist open.
              </p>
            </div>
            <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
              {categoryComparisonLinks.map((page) => (
                <a href={`/compare/${page.slug}`} class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6 transition-all hover:-translate-y-0.5 hover:border-[#0e7490]">
                  <span class="eyebrow-label text-[#0e7490]">{page.heroEyebrow}</span>
                  <span class="title-balance mt-3 block text-base font-semibold text-gray-800">{page.name}</span>
                  <span class="card-copy mt-2 block text-sm text-gray-500">{truncateText(page.description, 120)}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="max-w-3xl mb-10">
            <p class="eyebrow-label text-[#0e7490] mb-2">Buying Guide</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800 mb-4">{config.categoryName} buying guide</h2>
            <p class="card-copy text-lg text-gray-600">{config.guideIntro}</p>
          </div>

            <div class="copy-safe overflow-x-auto rounded-2xl border border-gray-200">
              <table class="w-full text-sm bg-white">
              <caption class="sr-only">{config.comparisonTable.caption}</caption>
              <thead class="bg-gray-100 text-gray-700">
                <tr>
                  {config.comparisonTable.headers.map((header) => (
                    <th class="px-5 py-4 text-left font-semibold border-b border-gray-200">{header}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {config.comparisonTable.rows.map((row, index) => (
                  <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    {row.map((cell) => (
                      <td class="px-5 py-4 border-b border-gray-100 text-gray-600 align-top">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mt-12 grid lg:grid-cols-[1.3fr_0.7fr] gap-8">
            <div class="copy-safe rounded-2xl bg-gray-50 border border-gray-100 p-8">
              <h3 class="text-2xl font-semibold text-gray-800 mb-5">How to choose the right {config.categoryName.toLowerCase()}</h3>
              <ol class="space-y-4">
                {config.selectionTips.map((tip, index) => (
                  <li class="flex gap-4">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0e7490] text-sm font-semibold text-white">{index + 1}</span>
                    <p class="text-gray-600 leading-relaxed">{tip}</p>
                  </li>
                ))}
              </ol>
            </div>

            <div class="copy-safe rounded-2xl border border-[#0e7490]/15 bg-[#0e7490]/5 p-8">
              <h3 class="text-2xl font-semibold text-gray-800 mb-4">Where buyers usually shortlist this category</h3>
              <p class="text-gray-600 leading-relaxed mb-6">{config.applicationsSummary}</p>
              <div class="space-y-3">
                {config.resources.map((resource) => (
                  <a href={resource.href} class="copy-safe block rounded-xl bg-white p-4 border border-[#0e7490]/15 hover:border-[#0e7490] transition-colors">
                    <span class="block text-sm font-semibold text-gray-800">{resource.label}</span>
                    <span class="block text-sm text-gray-500 mt-1">{resource.description}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50 border-y border-gray-100">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto grid lg:grid-cols-[1.02fr_0.98fr] gap-8 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Commercial Fit</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800 mb-4">Who usually buys {config.categoryName.toLowerCase()} and what they want to confirm first</h2>
            <p class="card-copy text-gray-600 mb-6">
              Use these buyer profiles when you still need to decide whether to start with samples, pricing, compatibility checks or repeat supply planning.
            </p>
            <div class="grid gap-4">
              {config.buyerProfiles.map((profile) => (
                <div class="copy-safe rounded-2xl border border-gray-200 bg-white p-6">
                  <h3 class="title-balance text-lg font-semibold text-gray-800">{profile.title}</h3>
                  <p class="card-copy text-sm text-gray-600 mt-2">{profile.description}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="space-y-6">
            <div class="copy-safe rounded-2xl border border-[#0e7490]/15 bg-[#0e7490]/5 p-8">
              <p class="eyebrow-label text-[#0e7490] mb-2">Market Focus</p>
              <h3 class="title-balance text-2xl font-semibold text-gray-800 mb-5">Regional buying conversations this category often supports</h3>
              <div class="grid gap-4">
                {config.marketFocus.map((market) => (
                  <div class="rounded-2xl border border-[#0e7490]/15 bg-white p-5">
                    <h4 class="title-balance text-base font-semibold text-gray-800">{market.title}</h4>
                    <p class="card-copy text-sm text-gray-600 mt-2">{market.description}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="copy-safe rounded-2xl border border-gray-200 bg-white p-8">
              <p class="eyebrow-label text-[#0e7490] mb-2">Inquiry Checklist</p>
              <h3 class="title-balance text-2xl font-semibold text-gray-800 mb-5">What to send for a faster sample or quote</h3>
              <ul class="space-y-3">
                {config.inquiryChecklist.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-gray-600">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-6 flex flex-wrap gap-3">
                <a href={categoryContactHref} class="rounded-lg bg-[#0e7490] px-5 py-3 text-sm font-semibold text-white hover:bg-[#155e75] transition-colors">
                  Send project details
                </a>
                <a
                  href={categoryWhatsAppHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-lg border border-gray-200 px-5 py-3 text-sm font-semibold text-gray-700 hover:border-[#0e7490] hover:text-[#0e7490] transition-colors"
                >
                  WhatsApp for a quick check
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <p class="eyebrow-label text-[#0e7490] mb-2">FAQ</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800">Questions buyers often ask</h2>
          </div>
          <div class="space-y-4">
            {config.faqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-white p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0e7490] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-gray-600 leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 bg-[#0e7490]">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">{config.ctaTitle}</h2>
        <p class="text-white/90 max-w-3xl mx-auto mb-7">{config.ctaDescription}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={categoryContactHref} class="bg-white text-[#0e7490] px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors">
            Request samples or quote
          </a>
          <a
            href={categoryWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            class="border-2 border-white text-white px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors"
          >
            WhatsApp us
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
