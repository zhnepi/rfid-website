---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Newsletter from './Newsletter.astro';
import { products } from '../data/products';
import { marketPages, marketPagesList } from '../data/markets';
import { truncateText } from '../utils/content';
import { getMarketComparisonLinks } from '../utils/comparisons';
import { getMarketContactHref, getWhatsAppHref } from '../utils/contact';

interface Props {
  marketKey: keyof typeof marketPages;
}

const { marketKey } = Astro.props;
const config = marketPages[marketKey];
const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/markets/${config.slug}`;
const featuredProducts = config.productSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);
const relatedMarkets = marketPagesList.filter((page) => page.slug !== config.slug);
const comparisonLinks = getMarketComparisonLinks(config.slug, config.productSlugs, 4);
const marketWhatsAppHref = getWhatsAppHref(config.whatsappMessage);

const itemListElements = featuredProducts.map((product, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  url: `${siteURL}/product/${product!.slug}`,
  name: product!.name,
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: config.title,
  description: config.description,
  isPartOf: { '@id': `${siteURL}/#website` },
  about: {
    '@type': 'Thing',
    name: `${config.regionName} ${config.productFocus}`,
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: itemListElements,
  },
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalURL}#service`,
  serviceType: `${config.productFocus} sourcing support`,
  name: `${config.regionName} ${config.productFocus}`,
  provider: { '@id': `${siteURL}/#organization` },
  areaServed: {
    '@type': 'Place',
    name: config.regionName,
  },
  audience: config.buyerProfiles.map((profile) => ({
    '@type': 'Audience',
    audienceType: profile.title,
  })),
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: `${siteURL}${getMarketContactHref(config.slug)}`,
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Markets', item: `${siteURL}/markets` },
    { '@type': 'ListItem', position: 3, name: config.regionName, item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout
  title={config.title}
  description={config.description}
  keywords={config.keywords}
  canonicalURL={canonicalURL}
  ogImage={featuredProducts[0]?.images?.[0] || '/images/hero/smart-card-banner.webp'}
  jsonLd={[collectionJsonLd, serviceJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <a href="/markets" class="hover:underline">Markets</a>
          <span class="mx-2">/</span>
          <span>{config.regionName}</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label mb-4 text-[#0e7490]">{config.heroEyebrow}</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">{config.heroTitle}</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">{config.heroDescription}</p>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow-label mb-2 text-[#0e7490]">Market Signals</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">Why buyers in {config.regionName} often land on this product focus first</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {config.signals.map((item) => (
            <div class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-7">
              <h3 class="title-balance text-xl font-semibold text-gray-900">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow-label mb-2 text-[#0e7490]">Recommended Products</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Product pages that usually move this conversation forward</h2>
          </div>
          <a href="/rfid" class="text-sm font-semibold text-[#0e7490] transition-colors hover:text-[#155e75]">Browse full catalog</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {featuredProducts.map((product) => (
            <a href={`/product/${product!.slug}`} class="copy-safe overflow-hidden rounded-[1.75rem] border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-lg">
              <div class="aspect-square overflow-hidden bg-gray-100">
                <img
                  src={product!.images[0]}
                  alt={product!.name}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  width="500"
                  height="500"
                />
              </div>
              <div class="p-5">
                <span class="eyebrow-label text-[#0e7490]">{product!.category}</span>
                <h3 class="title-balance mt-3 text-lg font-semibold text-gray-900">{product!.name}</h3>
                <p class="card-copy mt-2 text-sm text-gray-500">{truncateText(product!.description, 116)}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div>
            <p class="eyebrow-label mb-2 text-[#0e7490]">Buyer Profiles</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Who usually buys this mix of products in {config.regionName}</h2>
            <p class="card-copy mb-6 text-gray-600">
              Use the buyer profiles below to judge whether the shortlist should start with samples, compatibility work, price comparison or repeat-supply planning.
            </p>
            <div class="grid gap-4">
              {config.buyerProfiles.map((profile) => (
                <div class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6">
                  <h3 class="title-balance text-lg font-semibold text-gray-900">{profile.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{profile.description}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0e7490]/15 bg-[#0e7490]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0e7490]">Decision Drivers</p>
            <h2 class="title-balance mb-5 text-3xl font-semibold text-gray-900">What usually shapes the buying discussion next</h2>
            <div class="space-y-4">
              {config.marketDrivers.map((driver) => (
                <div class="rounded-2xl border border-[#0e7490]/15 bg-white p-5">
                  <h3 class="title-balance text-lg font-semibold text-gray-900">{driver.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{driver.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label mb-2 text-[#0e7490]">Inquiry Checklist</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">{config.checklistTitle}</h2>
            <p class="card-copy mb-6 text-gray-600">{config.checklistDescription}</p>
            <ul class="space-y-3">
              {config.checklist.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-gray-700">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0e7490]/15 bg-[#0e7490]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0e7490]">Useful Links</p>
            <h2 class="title-balance mb-4 text-2xl font-semibold text-gray-900">Pages that support the next buyer decision</h2>
            <div class="space-y-3">
              {config.resources.map((resource) => (
                <a href={resource.href} class="copy-safe block rounded-2xl border border-[#0e7490]/15 bg-white p-4 transition-colors hover:border-[#0e7490]">
                  <span class="block text-sm font-semibold text-gray-800">{resource.name}</span>
                  <span class="mt-1 block text-sm text-gray-500">{resource.description}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {comparisonLinks.length > 0 && (
      <section class="border-y border-gray-100 bg-white py-16">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="eyebrow-label mb-2 text-[#0e7490]">Comparison Pages</p>
                <h2 class="title-balance text-3xl font-semibold text-gray-900">Head-to-head pages that often help this regional buying path</h2>
              </div>
              <p class="card-copy max-w-2xl text-gray-600">
                Open these if buyers in {config.regionName} still need to settle format, frequency or product construction before sending the first RFQ.
              </p>
            </div>
            <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
              {comparisonLinks.map((page) => (
                <a href={`/compare/${page.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:-translate-y-0.5 hover:border-[#0e7490]">
                  <span class="eyebrow-label text-[#0e7490]">{page.heroEyebrow}</span>
                  <h3 class="title-balance mt-3 text-lg font-semibold text-gray-900">{page.name}</h3>
                  <p class="card-copy mt-2 text-sm text-gray-500">{truncateText(page.description, 118)}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="border-y border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow-label mb-2 text-[#0e7490]">Related Markets</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Compare nearby regional buying paths if the market route is still open</h2>
          </div>
          <a href="/markets" class="text-sm font-semibold text-[#0e7490] transition-colors hover:text-[#155e75]">Open markets hub</a>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {relatedMarkets.map((market) => (
            <a href={`/markets/${market.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0e7490] hover:bg-white">
              <span class="eyebrow-label text-[#0e7490]">{market.regionName}</span>
              <h3 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{market.productFocus}</h3>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{market.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl">
          <div class="mb-10 text-center">
            <p class="eyebrow-label mb-2 text-[#0e7490]">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Common questions from this market and product focus</h2>
          </div>
          <div class="space-y-4">
            {config.faqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-gray-50 p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0e7490] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 leading-relaxed text-gray-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0e7490] py-14">
      <div class="container mx-auto px-4 text-center">
        <h2 class="title-balance mb-4 text-3xl font-bold text-white">{config.ctaTitle}</h2>
        <p class="mx-auto mb-7 max-w-3xl text-white/90">{config.ctaDescription}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={getMarketContactHref(config.slug)} class="rounded-lg bg-white px-6 py-3 font-semibold text-[#0e7490] transition-colors hover:bg-gray-100">
            Request samples or quote
          </a>
          <a
            href={marketWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-white px-6 py-3 font-semibold text-white transition-colors hover:bg-white/10"
          >
            WhatsApp us
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
