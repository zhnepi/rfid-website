---

---

<section class="py-16 bg-[#0d7377]">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h2 class="text-3xl md:text-4xl font-display mb-4">Get Free RFID Samples</h2>
      <p class="text-white/90 mb-8 text-lg">
        Try before you buy. Request free samples of any RFID product from our 46+ SKU catalog.
        Samples shipped via DHL/FedEx within 1-3 business days worldwide.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact?intent=samples&express=1&source=newsletter#contactForm"
          data-analytics="newsletter_click_sample_express"
          class="px-8 py-3 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors inline-flex items-center justify-center gap-2 shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8 4-8-4m16 0v10a2 2 0 01-2 2H6a2 2 0 01-2-2V7m16 0l-8-4-8 4"></path>
          </svg>
          Request Free Samples
        </a>
        <a
          href="https://wa.me/8618665820632?text=Hi,%20I'd%20like%20to%20request%20free%20RFID%20samples"
          target="_blank"
          rel="noopener noreferrer"
          data-analytics="newsletter_click_whatsapp"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>

      <!-- W10: Email-only fallback — for visitors who want the catalog PDF but not a full inquiry -->
      <div class="mt-10 pt-8 border-t border-white/20">
        <p class="text-white/85 mb-4 text-sm">Not ready to chat? Just drop your email and we'll send the RFIDAK product catalog (PDF).</p>
        <form
          action="/api/inquiry"
          method="post"
          class="flex flex-col sm:flex-row gap-3 justify-center items-stretch max-w-xl mx-auto"
          id="newsletterCatalogForm"
        >
          <input type="hidden" name="inquiryType" value="compatibility" />
          <input type="hidden" name="subject" value="Catalog request from Newsletter" />
          <input type="hidden" name="message" value="Hi, please send me the RFIDAK product catalog PDF. Submitted via Newsletter footer." />
          <input type="hidden" name="preferredContact" value="email" />
          <input type="hidden" name="product" value="" />
          <input type="hidden" name="country" value="" />
          <input type="hidden" name="quantityRange" value="" />
          <input type="hidden" name="company" value="" />
          <input type="hidden" name="contextType" value="newsletter" />
          <input type="hidden" name="contextSlug" value="newsletter" />
          <input type="hidden" name="contextName" value="Newsletter Catalog Request" />
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" value="" />
          <input
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            autocomplete="email"
            class="flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-400 bg-white border border-transparent focus:outline-none focus:ring-2 focus:ring-amber-300"
          />
          <input type="hidden" name="name" value="Newsletter catalog subscriber" />
          <button
            type="submit"
            data-analytics="newsletter_email_catalog_submit"
            class="px-6 py-3 bg-white text-[#0d7377] font-semibold rounded-lg hover:bg-gray-100 transition-colors inline-flex items-center justify-center gap-2 shadow-sm"
          >
            Email me the catalog
          </button>
        </form>
        <p class="text-white/60 text-xs mt-3">We'll only use your email to send the catalog and reply to your inquiry.</p>
      </div>
    </div>
  </div>
</section>
