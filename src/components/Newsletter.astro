---
import {
  getContextualContactAction,
  getContextualWhatsAppAction,
  type ContextualContactAction,
} from '../utils/contact';

const pathname = Astro.url.pathname;
const contactAction = getContextualContactAction(pathname);
const whatsappAction = getContextualWhatsAppAction(pathname);

function normalizePathname(path: string) {
  const sanitizedPath = (path || '').split(/[?#]/)[0] || '/';

  if (!sanitizedPath || sanitizedPath === '/') {
    return '/';
  }

  return sanitizedPath.replace(/\/+$/, '') || '/';
}

function getNewsletterContent(path: string, action: ContextualContactAction) {
  const normalizedPath = normalizePathname(path);
  const [section] = normalizedPath.split('/').filter(Boolean);

  if (action.source === 'product') {
    if (action.intent === 'compatibility') {
      return {
        eyebrow: 'Product Next Step',
        title: 'Ready to confirm fit before you sample this product?',
        description: 'Share your reader, lock, chip, protocol, or installation constraint and we will point you to the closest matching product path.',
        whatsappLabel: 'WhatsApp this product',
      };
    }

    if (action.intent === 'oem') {
      return {
        eyebrow: 'Product Next Step',
        title: 'Ready to customize this product for your rollout?',
        description: 'Send branding, numbering, encoding, or packaging requirements and we will help translate this product into a workable OEM plan.',
        whatsappLabel: 'WhatsApp this product',
      };
    }

    return {
      eyebrow: 'Product Next Step',
      title: 'Ready to move this product into samples?',
      description: 'Tell us the target environment, mounting style, and quantity goal, and we will help narrow the right sample set before quoting.',
      whatsappLabel: 'WhatsApp this product',
    };
  }

  if (action.source === 'category') {
    if (action.intent === 'compatibility') {
      return {
        eyebrow: 'Category Next Step',
        title: 'Ready to narrow this category by system fit?',
        description: 'Share the installed reader, lock, or chip family and we will point you to the most compatible options inside this category.',
        whatsappLabel: 'WhatsApp this category',
      };
    }

    if (action.intent === 'oem') {
      return {
        eyebrow: 'Category Next Step',
        title: 'Ready to tailor this category to your event or brand?',
        description: 'Send the use case, artwork, numbering, and credential requirements and we will map the cleanest customization path.',
        whatsappLabel: 'WhatsApp this category',
      };
    }

    return {
      eyebrow: 'Category Next Step',
      title: 'Ready to sample the right options from this category?',
      description: 'Share the surface, wash cycle, operating environment, or deployment goal and we will help shortlist the best sample mix.',
      whatsappLabel: 'WhatsApp this category',
    };
  }

  if (action.source === 'solution') {
    return {
      eyebrow: 'Workflow Next Step',
      title: 'Ready to turn this workflow into a sample plan?',
      description: 'Tell us how the credential, tag, or reader will be used in the field and we will convert this solution path into a practical shortlist.',
      whatsappLabel: 'WhatsApp this workflow',
    };
  }

  if (action.source === 'market') {
    return {
      eyebrow: 'Regional Next Step',
      title: 'Ready to request samples that fit this market?',
      description: 'Share the region, compliance needs, and deployment style and we will help shape a sample or sourcing path that matches the target market.',
      whatsappLabel: 'WhatsApp this market',
    };
  }

  if (action.source === 'comparison') {
    return {
      eyebrow: 'Shortlist Next Step',
      title: 'Ready to turn this comparison into a clearer shortlist?',
      description: 'Send the tradeoffs you are weighing, plus the reader, environment, or credential constraints, and we will suggest the cleanest next step.',
      whatsappLabel: 'WhatsApp this comparison',
    };
  }

  if (action.source === 'blog') {
    return {
      eyebrow: 'Guide Next Step',
      title: 'Ready to turn this guide into a real project plan?',
      description: 'Share the article you are using, your application, and the sample or compatibility questions still open, and we will help turn the guide into action.',
      whatsappLabel: 'WhatsApp this guide',
    };
  }

  if (action.source === 'evidence') {
    return {
      eyebrow: 'Approval Next Step',
      title: 'Need proof and the next buying step in one conversation?',
      description: 'Tell us which certifications, QC checks, or shipping terms matter to your team and we will pair the proof page with the right commercial next step.',
      whatsappLabel: 'WhatsApp about proof',
    };
  }

  if (normalizedPath === '/compare') {
    return {
      eyebrow: 'Shortlist Next Step',
      title: 'Ready to talk through your shortlist?',
      description: 'Share the options you are comparing and we will help translate those tradeoffs into the right sample, compatibility, or quote path.',
      whatsappLabel: 'WhatsApp shortlist help',
    };
  }

  if (normalizedPath === '/markets') {
    return {
      eyebrow: 'Regional Next Step',
      title: 'Ready to request region-fit samples?',
      description: 'Tell us the target market, project scope, and supply expectation and we will point you to the best regional starting path.',
      whatsappLabel: 'WhatsApp this market',
    };
  }

  if (normalizedPath === '/solutions') {
    return {
      eyebrow: 'Workflow Next Step',
      title: 'Ready to plan solution samples?',
      description: 'Send the workflow you are building around and we will help convert it into a product shortlist, sample plan, and next discussion.',
      whatsappLabel: 'WhatsApp this workflow',
    };
  }

  if (normalizedPath === '/blogs' || normalizedPath === '/rfid-technology') {
    return {
      eyebrow: 'Guide Next Step',
      title: 'Ready to turn reading into a sample plan?',
      description: 'Share the guide, protocol, or buyer question you are starting from and we will help convert that research into a concrete next step.',
      whatsappLabel: 'WhatsApp this guide',
    };
  }

  if (normalizedPath === '/products' || normalizedPath === '/rfid') {
    return {
      eyebrow: 'Catalog Next Step',
      title: 'Ready to shortlist samples from the catalog?',
      description: 'Tell us which product families are still under review and we will help narrow the right mix for testing, approval, or quoting.',
      whatsappLabel: 'WhatsApp this catalog',
    };
  }

  if (normalizedPath === '/about') {
    return {
      eyebrow: 'Supplier Next Step',
      title: 'Ready to review factory fit and next samples?',
      description: 'Send the products, order stage, and proof points you still need and we will help connect supplier fit with the next practical buying step.',
      contactLabel: 'Discuss sample planning',
      whatsappLabel: 'WhatsApp about supplier fit',
    };
  }

  if (normalizedPath === '/authors' || section === 'authors') {
    return {
      eyebrow: 'Guide Next Step',
      title: 'Ready to turn these buyer notes into a project conversation?',
      description: 'Tell us what you are trying to confirm after reading the guides and we will help move the topic into samples, compatibility, or sourcing support.',
      contactLabel: 'Use this in a sample plan',
      whatsappLabel: 'WhatsApp this guide',
    };
  }

  return {
    eyebrow: 'Next Step',
    title: 'Ready to move your RFID shortlist forward?',
    description: 'Share your use case, chip or protocol, environment, and quantity target and we will help point you to the right sample or quote path.',
    whatsappLabel: 'WhatsApp for a quick check',
  };
}

const newsletterContent = getNewsletterContent(pathname, contactAction);
---

<section class="py-20 bg-[#0d0d0d] relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(201,168,76,0.06),transparent_60%)]"></div>
  <div class="container mx-auto px-4 relative z-10">
    <div class="copy-safe max-w-3xl mx-auto text-center text-white reveal">
      <p class="eyebrow-label mb-3 text-[#c9a84c]">{newsletterContent.eyebrow}</p>
      <h2 class="font-serif title-balance text-3xl md:text-4xl font-normal mb-4 text-white/90">{newsletterContent.title}</h2>
      <div class="w-12 h-[1px] bg-[#c9a84c] mx-auto my-5"></div>
      <p class="card-copy text-white/50 mb-10 text-lg font-light">
        {newsletterContent.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={contactAction.href}
          class="px-8 py-3.5 bg-[#c9a84c] text-[#0d0d0d] font-medium text-sm tracking-[0.12em] uppercase transition-all duration-300 hover:bg-[#d4b85e] hover:shadow-[0_8px_30px_rgba(201,168,76,0.25)] inline-flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8 4-8-4m16 0v10a2 2 0 01-2 2H6a2 2 0 01-2-2V7m16 0l-8-4-8 4"></path>
          </svg>
          {newsletterContent.contactLabel || contactAction.label}
        </a>
        <a
          href={whatsappAction.href}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3.5 border border-white/15 text-white/70 font-medium text-sm tracking-[0.12em] uppercase transition-all duration-300 hover:border-[#c9a84c]/40 hover:text-[#c9a84c] inline-flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {newsletterContent.whatsappLabel || whatsappAction.label}
        </a>
      </div>
    </div>
  </div>
</section>
