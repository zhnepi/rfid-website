---
const badges = [
  { icon: 'shield', label: 'ISO 9001 Certified' },
  { icon: 'leaf', label: 'ISO 14001' },
  { icon: 'check', label: 'SGS Verified' },
  { icon: 'clock', label: 'Since 2008' },
  { icon: 'globe', label: '50+ Countries' },
  { icon: 'factory', label: '5M Cards/Month' },
];
---

<section class="py-8 bg-[#0d0d0d] border-y border-[#c9a84c]/10">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      {badges.map((badge) => (
        <div class="flex items-center gap-2.5 text-white/50 hover:text-[#c9a84c] transition-colors duration-300">
          {badge.icon === 'shield' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          )}
          {badge.icon === 'leaf' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          )}
          {badge.icon === 'check' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
            </svg>
          )}
          {badge.icon === 'clock' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          )}
          {badge.icon === 'globe' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          )}
          {badge.icon === 'factory' && (
            <svg class="w-5 h-5 text-[#c9a84c]/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          )}
          <span class="text-xs font-medium tracking-wider uppercase whitespace-nowrap">{badge.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
