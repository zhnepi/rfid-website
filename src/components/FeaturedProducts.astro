---
import { products } from '../data/products';
import { getProductComparisonLinks } from '../utils/comparisons';
import { getContextualInquiryLabel, getProductContactHref, getProductInquiryIntent } from '../utils/contact';
import { getProductBuyerQuestion, getProductBuyerSummary } from '../utils/productCopy';

const featuredSlugs = [
  'rfid-cards',
  'rfid-keyfob',
  'textile-rfid-laundry-tag',
  'rfid-silicone-wristband',
  'rfid-metal-tag',
  'rfid-reader-writer',
];

const featuredProductMessaging: Record<string, { question: string; summary: string }> = {
  'rfid-cards': {
    question: 'Need cards that match an installed reader or hotel lock?',
    summary: 'Start here when protocol matching, print finish, and repeat supply matter most.',
  },
  'rfid-keyfob': {
    question: 'Want a smaller credential than a full-size access card?',
    summary: 'Useful for apartments, gyms, parking systems, and programs built around portable credentials.',
  },
  'textile-rfid-laundry-tag': {
    question: 'Will the tag survive wash, heat, pressure, and bulk reading?',
    summary: 'Built for linen, uniform, and garment workflows where wash-cycle durability comes first.',
  },
  'rfid-silicone-wristband': {
    question: 'Do guests need waterproof tap access and fast check-in?',
    summary: 'A strong fit for resorts, events, and leisure venues that need wearable credentials.',
  },
  'rfid-metal-tag': {
    question: 'Tagging metal tools or equipment without losing read range?',
    summary: 'Use anti-metal construction when assets, bins, or tools sit directly on metal surfaces.',
  },
  'rfid-reader-writer': {
    question: 'Need hardware that can read and encode your chosen chip?',
    summary: 'Good for issuance desks, test benches, and projects that need reader compatibility checks first.',
  },
};

const featuredProducts = featuredSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean)
  .map((product) => ({
    ...product,
    cardQuestion: featuredProductMessaging[product.slug]?.question || getProductBuyerQuestion(product),
    cardSummary: featuredProductMessaging[product.slug]?.summary || getProductBuyerSummary(product, 112),
    topComparison: getProductComparisonLinks(product, 1)[0],
    contactHref: getProductContactHref(product),
    inquiryLabel: getContextualInquiryLabel(getProductInquiryIntent(product), 'product'),
  }));
---

<section class="py-24 bg-[#fafaf8]">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 reveal">
      <div class="max-w-2xl">
        <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-3">Featured Product Lines</p>
        <h2 class="font-serif title-balance text-4xl md:text-5xl font-normal text-[#0d0d0d]">RFID products buyers ask for most often</h2>
        <div class="w-12 h-[1px] bg-[#c9a84c] mt-5"></div>
      </div>
      <a href="/rfid" class="text-[#c9a84c] font-medium hover:text-[#b8943f] transition-colors duration-300 text-sm tracking-wider uppercase">View full catalog</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {featuredProducts.map((product, idx) => (
        <article class={`copy-safe group bg-white border border-[#e8e5df] overflow-hidden shadow-sm hover:shadow-xl hover:border-[#c9a84c]/25 transition-all duration-500 hover:-translate-y-2 reveal reveal-delay-${(idx % 3) + 1}`}>
          <a href={`/product/${product.slug}`} class="block">
            <div class="aspect-[4/3] overflow-hidden bg-[#f0ede8]">
              <img
                src={product.images[0]}
                alt={`${product.name} - ${product.category} by ProudTek RFID manufacturer`}
                class="w-full h-full object-cover img-luxury-zoom"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                width="400"
                height="300"
              />
            </div>
          </a>
          <div class="p-7">
            <p class="eyebrow-label text-[#c9a84c] mb-2">{product.category}</p>
            <a href={`/product/${product.slug}`} class="block">
              <h3 class="font-serif title-balance text-xl font-normal text-[#0d0d0d] group-hover:text-[#c9a84c] transition-colors duration-300">{product.name}</h3>
            </a>
            <p class="mt-3 text-sm font-medium leading-relaxed text-[#2a2a2a]">{product.cardQuestion}</p>
            <p class="card-copy text-sm text-[#666] mt-2">{product.cardSummary}</p>
            <div class="mt-6 flex items-end justify-between gap-4 border-t border-[#e8e5df] pt-4">
              <div class="min-w-0">
                {product.topComparison ? (
                  <a href={`/compare/${product.topComparison.slug}`} class="min-w-0 text-xs font-medium text-[#c9a84c] transition-colors hover:text-[#b8943f]">
                    <span class="block truncate">Compare: {product.topComparison.name}</span>
                  </a>
                ) : (
                  <span class="block text-xs text-[#999]">Top product path</span>
                )}
                <a href={product.contactHref} class="mt-2 inline-flex text-xs font-medium text-[#888] transition-colors hover:text-[#c9a84c]">
                  {product.inquiryLabel}
                </a>
              </div>
              <a href={`/product/${product.slug}`} class="inline-flex shrink-0 items-center text-sm font-medium text-[#c9a84c] tracking-wide">
                Explore
                <svg class="w-4 h-4 ml-1 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
