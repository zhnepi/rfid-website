---
const products = [
  {
    name: 'RFID Keyfob',
    image: '/images/products/PROUDTEK-RFID-KEYFOB.webp',
    href: '/product/rfid-keyfob',
    category: 'Keyfob',
    specs: ['125KHz / 13.56MHz', 'ABS / Epoxy / Leather', 'Custom shape & color'],
  },
  {
    name: 'RFID Smart Card',
    image: '/images/products/ticket-smart-card.webp',
    href: '/product/rfid-cards',
    category: 'Cards',
    specs: ['MIFARE / DESFire / EM', 'PVC / PET / ABS', 'Full color printing'],
  },
  {
    name: 'RFID Silicone Wristband',
    image: '/images/products/RFID-SIlicone-wristbands-006.webp',
    href: '/product/rfid-silicone-wristband',
    category: 'Wristbands',
    specs: ['13.56MHz NFC', 'Medical-grade silicone', 'Waterproof IP68'],
  },
  {
    name: 'Textile RFID Laundry Tag',
    image: '/images/products/textile-RFID-laundry-tag-heat-seal.webp',
    href: '/product/textile-rfid-laundry-tag',
    category: 'Tags',
    specs: ['UHF 860-960MHz', '200+ wash cycles', 'Heat-seal attachment'],
  },
  {
    name: 'RFID Reader Writer',
    image: '/images/products/RFID_reader_writer.webp',
    href: '/product/rfid-reader-writer',
    category: 'Readers',
    specs: ['USB / RS232 / TCP', 'SDK included', 'Multi-protocol support'],
  },
  {
    name: 'RFID Metal Tag',
    image: '/images/products/Printable-RFID-metal-tag.webp',
    href: '/product/rfid-metal-tag',
    category: 'Tags',
    specs: ['On-metal optimized', 'FR4 / Ceramic substrate', 'Industrial grade'],
  },
];

const featuredProductMessaging: Record<string, { question: string; summary: string }> = {
  'rfid-cards': {
    question: 'Need cards that match an installed reader or hotel lock?',
    summary: 'Start here when protocol matching, print finish, and repeat supply matter most.',
  },
  'rfid-keyfob': {
    question: 'Want a smaller credential than a full-size access card?',
    summary: 'Useful for apartments, gyms, parking systems, and programs built around portable credentials.',
  },
  'textile-rfid-laundry-tag': {
    question: 'Will the tag survive wash, heat, pressure, and bulk reading?',
    summary: 'Built for linen, uniform, and garment workflows where wash-cycle durability comes first.',
  },
  'rfid-silicone-wristband': {
    question: 'Do guests need waterproof tap access and fast check-in?',
    summary: 'A strong fit for resorts, events, and leisure venues that need wearable credentials.',
  },
  'rfid-metal-tag': {
    question: 'Tagging metal tools or equipment without losing read range?',
    summary: 'Use anti-metal construction when assets, bins, or tools sit directly on metal surfaces.',
  },
  'rfid-reader-writer': {
    question: 'Need hardware that can read and encode your chosen chip?',
    summary: 'Good for issuance desks, test benches, and projects that need reader compatibility checks first.',
  },
};

const featuredProducts = featuredSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean)
  .map((product) => ({
    ...product,
    cardQuestion: featuredProductMessaging[product.slug]?.question || getProductBuyerQuestion(product),
    cardSummary: featuredProductMessaging[product.slug]?.summary || getProductBuyerSummary(product, 112),
    topComparison: getProductComparisonLinks(product, 1)[0],
    contactHref: getProductContactHref(product),
    inquiryLabel: getContextualInquiryLabel(getProductInquiryIntent(product), 'product'),
  }));
---

<section class="py-16 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <p class="text-[#0d7377] text-xs uppercase tracking-[3px] font-semibold mb-3">Our Products</p>
      <h2 class="text-3xl md:text-4xl font-display text-slate-800">Featured Products</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {products.map((product) => (
        <a
          href={product.href}
          class="group bg-white rounded-xl border border-slate-200 overflow-hidden hover:border-[#0d7377]/30 hover:shadow-lg transition-all duration-300"
        >
          <!-- Image -->
          <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
            <img
              src={product.image}
              alt={product.name}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-[#0d7377] text-xs font-semibold px-2.5 py-1 rounded-md">
              {product.category}
            </span>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="text-lg font-semibold text-slate-800 group-hover:text-[#0d7377] transition-colors mb-3">{product.name}</h3>

            <!-- Specs -->
            <ul class="space-y-1.5 mb-4">
              {product.specs.map((spec) => (
                <li class="flex items-center gap-2 text-sm text-slate-600">
                  <svg class="w-3.5 h-3.5 text-[#0d7377] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                  </svg>
                  {spec}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <div class="flex items-center justify-between pt-3 border-t border-slate-100">
              <span class="text-sm font-medium text-[#0d7377] group-hover:text-[#0a5c5f]">View Details</span>
              <svg class="w-4 h-4 text-[#0d7377] group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View All -->
    <div class="text-center mt-10">
      <a href="/rfid" class="inline-flex items-center gap-2 bg-[#0d7377] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#0a5c5f] transition-colors">
        Browse All Products
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
