---
const applications = [
  {
    name: 'Access Control',
    image: 'https://images.unsplash.com/photo-1558002038-1055907df827?w=400&q=80',
    href: '/category/rfid-cards',
  },
  {
    name: 'RFID Retails',
    image: 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=400&q=80',
    href: '/category/rfid-labels',
  },
  {
    name: 'RFID Hotel',
    image: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=80',
    href: '/category/rfid-cards',
  },
  {
    name: 'RFID Events',
    image: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=400&q=80',
    href: '/category/rfid-wristbands',
  },
  {
    name: 'RFID Laundry',
    image: 'https://images.unsplash.com/photo-1545173168-9f1947eebb7f?w=400&q=80',
    href: '/category/rfid-tags',
  },
  {
    name: 'RFID Industry',
    image: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=400&q=80',
    href: '/category/rfid-tags',
  },
];
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <p class="text-[#00bcd4] text-sm uppercase tracking-widest mb-2">RFID Applications...</p>
      <h2 class="text-3xl font-semibold text-gray-800">What RFID application are you looking for?</h2>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-0">
      {applications.map((app) => (
        <a 
          href={app.href}
          class="group relative overflow-hidden aspect-square"
        >
          <img 
            src={app.image} 
            alt={app.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/50 transition-colors"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <h3 class="text-white text-lg md:text-xl font-semibold text-center px-2">{app.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
