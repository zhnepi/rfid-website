---
import { solutionPages } from '../data/solutions';
import { getSolutionComparisonLinks } from '../utils/comparisons';

const applications = [
  {
    name: 'Access Control',
    description: 'RFID cards and keyfobs for offices, apartments, campuses, hospitals, and smart buildings.',
    image: '/images/products/ticket-smart-card.webp',
    href: '/solutions/access-control-rfid',
    solutionSlug: 'access-control-rfid',
  },
  {
    name: 'Hotels and Resorts',
    description: 'Hotel key cards, wristbands, and guest credentials for room access, lockers, and cashless spend.',
    image: '/images/products/RFID-SIlicone-wristbands-006.webp',
    href: '/solutions/hotel-access-rfid',
    solutionSlug: 'hotel-access-rfid',
  },
  {
    name: 'Laundry and Linen Tracking',
    description: 'Textile, silicone, and PPS laundry tags for uniforms, towels, sheets, and reusable garments.',
    image: '/images/products/textile-RFID-laundry-tag-heat-seal.webp',
    href: '/solutions/laundry-linen-rfid',
    solutionSlug: 'laundry-linen-rfid',
  },
  {
    name: 'Libraries and Media',
    description: 'Library labels and book tags that support circulation, shelving, and self-check workflows.',
    image: '/images/products/library-rfid-tags.webp',
    href: '/solutions/library-media-rfid',
    solutionSlug: 'library-media-rfid',
  },
  {
    name: 'Industrial Asset Tracking',
    description: 'On-metal tags, pallet tags, PCB tags, and rugged transponders for tools, machinery, and containers.',
    image: '/images/products/Printable-RFID-metal-tag.webp',
    href: '/solutions/industrial-asset-tracking-rfid',
    solutionSlug: 'industrial-asset-tracking-rfid',
  },
  {
    name: 'Retail, Events, and NFC',
    description: 'NFC stickers, labels, and wristbands for promotions, attendance, anti-counterfeit, and smart interactions.',
    image: '/images/products/nfc-sticker.webp',
    href: '/solutions/event-nfc-rfid',
    solutionSlug: 'event-nfc-rfid',
  },
].map((application) => {
  const solutionPage = solutionPages[application.solutionSlug];

  return {
    ...application,
    topComparison: solutionPage ? getSolutionComparisonLinks(application.solutionSlug, solutionPage.productSlugs, 1)[0] : undefined,
  };
});
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 max-w-3xl mx-auto">
      <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-2">Application Coverage</p>
      <h2 class="title-balance text-3xl md:text-4xl font-semibold text-gray-900">RFID solutions organized by real buying scenarios</h2>
      <p class="card-copy text-gray-600 mt-4">
        Start here when the workflow is clear but the right product family still is not. These solution hubs help narrow the shortlist before buyers jump into products, samples or compatibility checks.
      </p>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
      {applications.map((app) => (
        <article class="copy-safe group overflow-hidden rounded-[1.75rem] border border-gray-200 bg-white shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <a href={app.href} class="block">
            <div class="aspect-[5/4] overflow-hidden bg-slate-100">
              <img
                src={app.image}
                alt={app.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                width="560"
                height="448"
              />
            </div>
          </a>
          <div class="p-6">
            <a href={app.href} class="block">
              <h3 class="copy-safe title-balance text-xl font-semibold text-gray-900">{app.name}</h3>
            </a>
            <p class="copy-safe card-copy text-sm text-gray-600 mt-3">{app.description}</p>
            <div class="mt-5 flex items-center justify-between gap-3 border-t border-gray-100 pt-4">
              {app.topComparison ? (
                <a href={`/compare/${app.topComparison.slug}`} class="min-w-0 text-xs font-medium text-[#c9a84c] transition-colors hover:text-[#b8943f]">
                  <span class="block truncate">Compare: {app.topComparison.name}</span>
                </a>
              ) : (
                <span class="text-xs text-gray-400">Use-case buying path</span>
              )}
              <a href={app.href} class="inline-flex shrink-0 items-center text-sm font-medium text-[#c9a84c]">
                Explore solution
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
