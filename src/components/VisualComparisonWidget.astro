---
// VisualComparisonWidget — reusable side-by-side visual comparison for product-page
// decision help. Created 2026-04-23 after benchmarking against the original rfidak.com
// which had a visual closed-loop vs adjustable wristband comparison that the Astro
// rebuild had dropped. Reusable across any product where the buyer is choosing between
// two physical variants of the same family.
//
// Usage: drop into a product page template and pass a ProductVisualComparison object
// (populated from products.ts). Keep the props minimal so editors don't need to learn
// complex markup — just label, image path, 2-4 specs, and a "best for" list.

import type { ProductVisualComparison } from '../data/products';

interface Props {
  data: ProductVisualComparison;
}

const { data } = Astro.props;
---

<section class="visual-comparison py-16 bg-gradient-to-br from-gray-50 to-white border-y border-gray-100">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mb-10">
      <p class="eyebrow-label text-[#0d7377] mb-2">{data.eyebrow}</p>
      <h2 class="title-balance text-3xl font-semibold text-gray-900">{data.title}</h2>
      <p class="card-copy text-gray-600 mt-4 leading-relaxed" data-speakable="comparison-intro">
        {data.intro}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {data.options.map((option, idx) => (
        <article class="copy-safe rounded-lg border-2 border-gray-200 bg-white shadow-sm overflow-hidden flex flex-col">
          <div class="aspect-[4/3] bg-gray-100 relative overflow-hidden">
            <img
              src={option.image}
              alt={option.alt}
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <span class="absolute top-3 left-3 bg-[#0d7377] text-white px-3 py-1 rounded text-xs font-semibold uppercase tracking-wider">
              Option {String.fromCharCode(65 + idx)}
            </span>
          </div>
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="text-xl font-bold text-gray-900">{option.label}</h3>
            <p class="text-sm text-[#0d7377] font-medium mt-1">{option.tagline}</p>

            <dl class="mt-5 space-y-2 text-sm border-t border-gray-100 pt-4">
              {option.specs.map((spec) => (
                <div class="flex justify-between gap-4">
                  <dt class="text-gray-500">{spec.label}</dt>
                  <dd class="text-gray-900 font-medium text-right">{spec.value}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-5 border-t border-gray-100 pt-4 flex-1">
              <p class="eyebrow-label text-gray-500 mb-2 text-xs">Best for</p>
              <ul class="space-y-1.5 text-sm text-gray-700">
                {option.bestFor.map((scenario) => (
                  <li class="flex gap-2">
                    <svg class="w-4 h-4 text-[#0d7377] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span>{scenario}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 copy-safe rounded-lg border border-[#0d7377]/20 bg-[#0d7377]/5 p-6 max-w-4xl">
      <div class="flex gap-3">
        <svg class="w-6 h-6 text-[#0d7377] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-sm text-gray-700 leading-relaxed">
          <span class="font-semibold text-gray-900">Quick decision tip — </span>
          <span data-speakable="comparison-tip">{data.decisionTip}</span>
        </p>
      </div>
    </div>
  </div>
</section>
