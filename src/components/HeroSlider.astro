---
import { getCategoryContactHref, getSolutionContactHref } from '../utils/contact';

const slides = [
  {
    id: 'smart-cards',
    eyebrow: 'RFID Card Manufacturer Since 2008',
    title: 'RFID Cards for Transit, Hotels, Access Control, and Cashless Programs',
    description: 'Factory-direct RFID cards, inlays, and printed credentials with stable chip supply, OEM customization, and repeatable bulk production.',
    image: '/images/hero/smart-card-banner.webp',
    primaryCta: { href: '/category/rfid-cards', label: 'Explore Card Formats' },
    secondaryCta: {
      href: getCategoryContactHref({ key: 'rfid-cards', slug: 'rfid-cards', categoryName: 'RFID Cards' }),
      label: 'Request Card Matching',
    },
    highlights: ['PVC, PET, ABS, paper, and wood', 'LF, HF, and UHF chip options'],
    tabTitle: 'SMART CARDS',
    tabDescription: 'Transit cards, hotel cards, access badges, membership cards, and NFC credentials.',
  },
  {
    id: 'laundry-tag',
    eyebrow: 'Industrial Laundry RFID',
    title: 'RFID Laundry Tags for High Heat, Washing, and Bulk Reading',
    description: 'Textile, silicone, and PPS laundry tags for linens, uniforms, towels, and garments in industrial laundry workflows.',
    image: '/images/hero/laundry-banner.webp',
    primaryCta: { href: '/solutions/laundry-linen-rfid', label: 'Compare Laundry Formats' },
    secondaryCta: { href: getSolutionContactHref('laundry-linen-rfid'), label: 'Plan Laundry Samples' },
    highlights: ['200+ wash cycles', 'Heat-seal or sew-on installation'],
    tabTitle: 'RFID LAUNDRY TAGS',
    tabDescription: 'Reliable laundry tags for linen rental, hospitals, hospitality, and uniform tracking.',
  },
  {
    id: 'wristbands',
    eyebrow: 'RFID For Events and Resorts',
    title: 'RFID Wristbands and Keyfobs for Hotels, Events, and Resorts',
    description: 'Waterproof guest credentials for access control, lockers, e-ticketing, and cashless tap experiences.',
    image: '/images/hero/wristband-banner.webp',
    primaryCta: { href: '/solutions/event-nfc-rfid', label: 'Plan Guest Credentials' },
    secondaryCta: { href: '/category/rfid-keyfob', label: 'See Keyfob Formats' },
    highlights: ['Hotels, festivals, gyms, and waterparks', 'Custom logo, UID, QR, and print'],
    tabTitle: 'WRISTBANDS & KEYFOBS',
    tabDescription: 'Wearable and portable credentials for resorts, events, clubs, and visitor access.',
  },
];

const slideCount = slides.length;
---

<section
  class="relative"
  data-hero-slider
  aria-label="Featured RFID product families"
  aria-roledescription="carousel"
>
  <p id="hero-slider-status" class="sr-only" aria-live="polite">
    Showing slide 1 of {slideCount}: {slides[0].tabTitle}
  </p>
  <!-- Full-screen cinematic hero -->
  <div class="relative h-[560px] min-h-[560px] overflow-hidden md:h-[85vh] md:min-h-[600px] md:max-h-[900px]">
    <div id="slider" class="relative h-full">
      {slides.map((slide, index) => {
        const isActive = index === 0;

        return (
          <div
            id={`hero-slide-${index}`}
            class={`slide absolute inset-0 transition-opacity duration-700 ease-in-out ${isActive ? 'opacity-100' : 'opacity-0'}`}
            data-index={index}
            aria-hidden={isActive ? 'false' : 'true'}
            inert={!isActive}
          >
            <div class="absolute inset-0 bg-black/30"></div>
          </div>
          
          <!-- Content -->
          <div class="relative h-full flex items-center justify-center text-center text-white z-10">
            <div class="max-w-3xl px-4">
              <h2 class="text-4xl md:text-6xl font-display mb-4">{slide.title}</h2>
              <p class="text-lg md:text-xl">
                {slide.subtitle}<br />
                {slide.description}
              </p>
              <div class="flex gap-4 justify-center mt-8">
                <a href="/rfid" class="bg-white text-[#0d7377] px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors text-sm md:text-base">
                  Explore Products
                </a>
                <a href="/contact" class="bg-amber-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-amber-600 transition-colors text-sm md:text-base shadow-lg">
                  Get a Quote
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Elegant Navigation Arrows -->
    <button
      id="prev-btn"
      type="button"
      class="brand-icon-shell-dark absolute left-6 top-1/2 z-20 -translate-y-1/2"
      aria-label="Previous slide"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <button
      id="next-btn"
      type="button"
      class="brand-icon-shell-dark absolute right-6 top-1/2 z-20 -translate-y-1/2"
      aria-label="Next slide"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

    <!-- Luxury Dots -->
    <div class="absolute bottom-8 left-1/2 z-20 -translate-x-1/2">
      <div class="flex items-center gap-4 rounded-full border border-white/10 bg-[#0d0d0d]/55 px-4 py-2 backdrop-blur-sm">
        <div class="flex gap-3">
          {slides.map((slide, index) => (
            <button
              type="button"
              id={`dot-${index}`}
              class={`dot h-[2px] rounded-none transition-all duration-500 ${index === 0 ? 'w-10 bg-[#c9a84c]' : 'w-4 bg-white/30'}`}
              data-index={index}
              aria-controls={`hero-slide-${index}`}
              aria-label={`Show slide ${index + 1}: ${slide.tabTitle}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
        <button
          id="pause-btn"
          type="button"
          class="min-w-[4.5rem] text-xs font-medium uppercase tracking-[0.16em] text-white/70 transition-colors duration-300 hover:text-[#c9a84c]"
          aria-pressed="false"
          aria-label="Pause automatic slide rotation"
        >
          Pause
        </button>
      </div>
    </div>
  </div>
  
  <!-- Service Tabs - Connected to Slides -->
  <div class="bg-[#0d7377]">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3" aria-label="Featured product groups">
        {slides.map((slide, index) => (
          <button 
            class={`service-tab group p-8 text-center text-white transition-all duration-300 hover:bg-[#0a5c5f] ${index === 0 ? 'bg-[#0a5c5f]' : ''}`}
            data-tab-index={index}
            aria-controls={`hero-slide-${index}`}
            aria-label={`Show slide ${index + 1}: ${slide.tabTitle}`}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="eyebrow-label text-[#c9a84c]/70 mb-2">{slide.tabTitle}</p>
                <p class="card-copy text-sm text-white/45">{slide.tabDescription}</p>
              </div>
              <span class="text-[#c9a84c]/40 text-xl font-light font-serif">{String(index + 1).padStart(2, '0')}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const tabs = document.querySelectorAll('.service-tab');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  let currentSlide = 0;
  let autoPlayInterval: ReturnType<typeof setInterval>;
  
  function showSlide(index: number) {
    // Update slides
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === index);
      slide.classList.toggle('opacity-0', i !== index);
    });
    // Update dots
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === index);
      dot.classList.toggle('bg-white/50', i !== index);
    });
    // Update tabs
    tabs.forEach((tab, i) => {
      tab.classList.toggle('bg-[#0a5c5f]', i === index);
    });
    currentSlide = index;
  }
  
  function nextSlide() {
    showSlide((currentSlide + 1) % slides.length);
  }
  
  function prevSlide() {
    showSlide((currentSlide - 1 + slides.length) % slides.length);
  }
  
  function startAutoPlay() {
    autoPlayInterval = setInterval(nextSlide, 5000);
  }
  
  function stopAutoPlay() {
    clearInterval(autoPlayInterval);
  }
  
  prevBtn?.addEventListener('click', () => {
    stopAutoPlay();
    prevSlide();
    startAutoPlay();
  });
  
  nextBtn?.addEventListener('click', () => {
    stopAutoPlay();
    nextSlide();
    startAutoPlay();
  });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoPlay();

      if (!autoPlayEnabled || temporarilyPaused || slides.length < 2 || document.hidden) {
        return;
      }

      autoPlayInterval = setInterval(nextSlide, 6000);
    }

    function handleManualNavigation(callback: () => void) {
      temporarilyPaused = false;
      stopAutoPlay();
      callback();
      startAutoPlay();
    }

    prevBtn?.addEventListener('click', () => {
      handleManualNavigation(prevSlide);
    });

    nextBtn?.addEventListener('click', () => {
      handleManualNavigation(nextSlide);
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        handleManualNavigation(() => showSlide(index));
      });
    });

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        handleManualNavigation(() => showSlide(index));
      });
    });

    pauseBtn?.addEventListener('click', () => {
      autoPlayEnabled = !autoPlayEnabled;
      updatePauseButton();
      startAutoPlay();
    });

    sliderRoot.addEventListener('mouseenter', () => {
      temporarilyPaused = true;
      stopAutoPlay();
    });

    sliderRoot.addEventListener('mouseleave', () => {
      temporarilyPaused = false;
      startAutoPlay();
    });

    sliderRoot.addEventListener('focusin', () => {
      temporarilyPaused = true;
      stopAutoPlay();
    });

    sliderRoot.addEventListener('focusout', (event) => {
      if (!sliderRoot.contains(event.relatedTarget as Node)) {
        temporarilyPaused = false;
        startAutoPlay();
      }
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoPlay();
      } else {
        startAutoPlay();
      }
    });

    prefersReducedMotion.addEventListener('change', (event) => {
      autoPlayEnabled = !event.matches;
      updatePauseButton();
      startAutoPlay();
    });

    window.addEventListener('pagehide', stopAutoPlay, { once: true });

    showSlide(0);
    updatePauseButton();
    startAutoPlay();
  }
</script>
