---
import { getWhatsAppHref } from '../utils/contact';

// W3 QW#6: each slide owns its CTA copy, target category, intent and WhatsApp context
const slides = [
  {
    id: 'smart-cards',
    title: 'Smart Card Manufacturer',
    subtitle: 'We supply',
    description: 'smart cards and security.',
    image: '/images/hero/smart-card-banner.webp',
    tabTitle: 'SMART CARDS',
    tabDescription: 'We Produce and supply smart cards for public transportation, school, hospital, airport, and public buildings.',
    primaryCtaLabel: 'Request Smart Card Sample',
    primaryCtaHref: '/contact?intent=samples&category=rfid-cards&source=hero-smart-cards#contactForm',
    secondaryCtaLabel: 'Browse Smart Cards',
    secondaryCtaHref: '/category/rfid-cards',
    whatsappMessage: "Hi RFIDAK, I saw your smart card slide on the homepage and want to discuss a card sample for my access / transit / ID project.",
  },
  {
    id: 'laundry-tag',
    title: 'Laundry Management',
    subtitle: 'We supply',
    description: 'RFID laundry tag and efficiency.',
    image: '/images/hero/laundry-banner.webp',
    tabTitle: 'RFID LAUNDRY TAG',
    tabDescription: 'Managing and tracing towels, bedsheets, uniforms, and linens. Tag size: 36x11mm, 55x12mm, 58x15mm, 70x10mm, 70x15mm, 75x15mm, etc.',
    primaryCtaLabel: 'Request Laundry Tag Sample',
    primaryCtaHref: '/contact?intent=samples&category=rfid-tags&source=hero-laundry-tag#contactForm',
    secondaryCtaLabel: 'See Laundry Tags',
    secondaryCtaHref: '/category/rfid-tags',
    whatsappMessage: "Hi RFIDAK, I saw your laundry tag slide on the homepage and want to discuss tag sizes, wash cycles and sampling for a laundry management project.",
  },
  {
    id: 'wristbands',
    title: 'RFID Wristband for Events',
    subtitle: 'We supply',
    description: 'RFID wristband and happiness.',
    image: '/images/hero/wristband-banner.webp',
    tabTitle: 'RFID WRISTBANDS',
    tabDescription: 'RFID disposable wristbands: musical festivals, exhibitions. RFID silicone wristbands: hotels, waterparks, and fitness clubs.',
    primaryCtaLabel: 'Get Event Wristband Quote',
    primaryCtaHref: '/contact?intent=oem&category=rfid-wristbands&source=hero-wristbands#contactForm',
    secondaryCtaLabel: 'Browse Wristbands',
    secondaryCtaHref: '/category/rfid-wristbands',
    whatsappMessage: "Hi RFIDAK, I saw your wristband slide on the homepage and want to discuss branded event / festival / hotel wristbands with MOQ and lead time.",
  },
];
---

<section class="relative">
  <!-- Hero Slider -->
  <div class="relative h-[500px] md:h-[600px] overflow-hidden">
    <!-- Slides Container -->
    <div id="slider" class="relative h-full">
      {slides.map((slide, index) => (
        <div 
          class={`slide absolute inset-0 transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-index={index}
        >
          <!-- Background Image -->
          <div 
            class="absolute inset-0 bg-cover bg-center"
            style={`background-image: url('${slide.image}')`}
          >
            <div class="absolute inset-0 bg-black/30"></div>
          </div>
          
          <!-- Content -->
          <div class="relative h-full flex items-center justify-center text-center text-white z-10">
            <div class="max-w-3xl px-4">
              <h2 class="text-4xl md:text-6xl font-display mb-4">{slide.title}</h2>
              <p class="text-lg md:text-xl">
                {slide.subtitle}<br />
                {slide.description}
              </p>
              <div class="flex flex-wrap gap-4 justify-center mt-8">
                <a
                  href={slide.primaryCtaHref}
                  class="bg-amber-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-amber-600 transition-colors text-sm md:text-base shadow-lg"
                  data-analytics={`hero_primary_click_${slide.id}`}
                >
                  {slide.primaryCtaLabel}
                </a>
                <a
                  href={getWhatsAppHref(slide.whatsappMessage)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-[#25D366] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#20ba5a] transition-colors text-sm md:text-base shadow-lg inline-flex items-center gap-2"
                  data-analytics={`hero_whatsapp_click_${slide.id}`}
                  aria-label={`Open WhatsApp about ${slide.tabTitle}`}
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Navigation Arrows -->
    <button 
      id="prev-btn"
      class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white p-3 rounded-full transition-colors z-20"
      aria-label="Previous slide"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    
    <button 
      id="next-btn"
      class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white p-3 rounded-full transition-colors z-20"
      aria-label="Next slide"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
    
    <!-- Dots Indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-20">
      {slides.map((_, index) => (
        <button 
          class={`dot w-3 h-3 rounded-full transition-colors ${index === 0 ? 'bg-white' : 'bg-white/50'}`}
          data-index={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
  
  <!-- Service Tabs - Connected to Slides -->
  <div class="bg-[#0d7377]">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3">
        {slides.map((slide, index) => (
          <button 
            class={`service-tab group p-8 text-center text-white transition-all duration-300 hover:bg-[#0a5c5f] ${index === 0 ? 'bg-[#0a5c5f]' : ''}`}
            data-tab-index={index}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-full border-2 border-white/30 flex items-center justify-center group-hover:border-white/60 transition-colors">
              {index === 0 && (
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                </svg>
              )}
              {index === 1 && (
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
              )}
              {index === 2 && (
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              )}
            </div>
            <h3 class="text-lg font-semibold mb-3">{slide.tabTitle}</h3>
            <p class="text-sm text-white/80 leading-relaxed">{slide.tabDescription}</p>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const tabs = document.querySelectorAll('.service-tab');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  let currentSlide = 0;
  let autoPlayInterval: ReturnType<typeof setInterval>;
  
  function showSlide(index: number) {
    // Update slides
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === index);
      slide.classList.toggle('opacity-0', i !== index);
    });
    // Update dots
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === index);
      dot.classList.toggle('bg-white/50', i !== index);
    });
    // Update tabs
    tabs.forEach((tab, i) => {
      tab.classList.toggle('bg-[#0a5c5f]', i === index);
    });
    currentSlide = index;
  }
  
  function nextSlide() {
    showSlide((currentSlide + 1) % slides.length);
  }
  
  function prevSlide() {
    showSlide((currentSlide - 1 + slides.length) % slides.length);
  }
  
  function startAutoPlay() {
    autoPlayInterval = setInterval(nextSlide, 5000);
  }
  
  function stopAutoPlay() {
    clearInterval(autoPlayInterval);
  }
  
  prevBtn?.addEventListener('click', () => {
    stopAutoPlay();
    prevSlide();
    startAutoPlay();
  });
  
  nextBtn?.addEventListener('click', () => {
    stopAutoPlay();
    nextSlide();
    startAutoPlay();
  });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoPlay();
      showSlide(index);
      startAutoPlay();
    });
  });
  
  // Tab click handlers - clicking a tab switches to that slide
  tabs.forEach((tab, index) => {
    tab.addEventListener('click', () => {
      stopAutoPlay();
      showSlide(index);
      startAutoPlay();
    });
  });
  
  startAutoPlay();
</script>
