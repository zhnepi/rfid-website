---
const services = [
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
    </svg>`,
    title: 'SMART CARDS',
    description: 'We Produce and supply smart cards for public transportation, school, hospital, airport, and public buildings.',
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
    </svg>`,
    title: 'RFID LAUNDRY TAG',
    description: 'Managing and tracing towels, bedsheets, uniforms, and linens. Tag size: 36x11mm, 55x12mm, 58x15mm, 70x10mm, 70x15mm, 75x15mm, etc.',
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="3" stroke-width="1.5"></circle>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
    </svg>`,
    title: 'RFID WRISTBANDS',
    description: 'RFID disposable wristbands: musical festivals, exhibitions. RFID silicone wristbands: hotels, waterparks, and fitness clubs.',
  },
];
---

<section class="bg-[#0d7377] py-16">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-8 text-white text-center hover:bg-white/20 transition-colors">
          <div class="flex justify-center mb-4">
            <div class="p-4 bg-white/20 rounded-full" set:html={service.icon}></div>
          </div>
          <h3 class="text-xl font-semibold mb-4">{service.title}</h3>
          <p class="text-white/90 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
