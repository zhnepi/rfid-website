---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Newsletter from './Newsletter.astro';
import { products } from '../data/products';
import { marketPagesList } from '../data/markets';
import { solutionPages, solutionPagesList } from '../data/solutions';
import { truncateText } from '../utils/content';
import { getSolutionComparisonLinks } from '../utils/comparisons';
import { getSolutionContactHref, getWhatsAppHref } from '../utils/contact';

interface Props {
  solutionKey: keyof typeof solutionPages;
}

const { solutionKey } = Astro.props;
const config = solutionPages[solutionKey];
const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/solutions/${config.slug}`;
const featuredProducts = config.productSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);
const relatedSolutions = solutionPagesList.filter((page) => page.slug !== config.slug);
const relatedMarkets = marketPagesList.filter((page) => config.relatedMarketSlugs.includes(page.slug));
const comparisonLinks = getSolutionComparisonLinks(config.slug, config.productSlugs, 4);
const solutionWhatsAppHref = getWhatsAppHref(config.whatsappMessage);

const itemListElements = featuredProducts.map((product, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  url: `${siteURL}/product/${product!.slug}`,
  name: product!.name,
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: config.title,
  description: config.description,
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: itemListElements,
  },
  about: {
    '@type': 'Thing',
    name: config.name,
  },
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalURL}#service`,
  serviceType: `${config.name} RFID sourcing support`,
  name: config.name,
  provider: { '@id': `${siteURL}/#organization` },
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: `${siteURL}${getSolutionContactHref(config.slug)}`,
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: `${siteURL}/solutions` },
    { '@type': 'ListItem', position: 3, name: config.name, item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout
  title={config.title}
  description={config.description}
  keywords={config.keywords}
  canonicalURL={canonicalURL}
  ogImage={featuredProducts[0]?.images?.[0] || '/images/hero/smart-card-banner.webp'}
  jsonLd={[collectionJsonLd, serviceJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <a href="/solutions" class="hover:underline">Solutions</a>
          <span class="mx-2">/</span>
          <span>{config.name}</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label mb-4 text-[#0d7377]">{config.heroEyebrow}</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">{config.heroTitle}</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">{config.heroDescription}</p>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow-label mb-2 text-[#0d7377]">Decision Signals</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">What buyers usually need clarified first</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {config.signals.map((item) => (
            <div class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-7">
              <h2 class="title-balance text-xl font-semibold text-gray-900">{item.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow-label mb-2 text-[#0d7377]">Recommended Products</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Product pages that usually move the project forward</h2>
          </div>
          <a href="/products" class="text-sm font-semibold text-[#0d7377] transition-colors hover:text-[#0a5c5f]">View product families</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {featuredProducts.map((product) => (
            <a href={`/product/${product!.slug}`} class="copy-safe overflow-hidden rounded-[1.75rem] border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-lg">
              <div class="aspect-square overflow-hidden bg-gray-100">
                <img
                  src={product!.images[0]}
                  alt={product!.name}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  width="500"
                  height="500"
                />
              </div>
              <div class="p-5">
                <span class="eyebrow-label text-[#0d7377]">{product!.category}</span>
                <h3 class="title-balance mt-3 text-lg font-semibold text-gray-900">{product!.name}</h3>
                <p class="card-copy mt-2 text-sm text-gray-500">{truncateText(product!.description, 116)}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-gray-50 p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Buying Workflow</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">{config.workflowTitle}</h2>
            <p class="card-copy mb-6 text-gray-600">{config.workflowDescription}</p>
            <div class="space-y-4">
              {config.workflowSteps.map((step, index) => (
                <div class="flex gap-4 rounded-2xl border border-gray-200 bg-white px-5 py-5">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#0d7377] text-sm font-semibold text-white">{index + 1}</span>
                  <p class="text-sm leading-relaxed text-gray-700">{step}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0d7377]/15 bg-[#0d7377]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Useful Links</p>
            <h2 class="title-balance mb-4 text-2xl font-semibold text-gray-900">Pages that support the next buyer decision</h2>
            <div class="space-y-3">
              {config.resources.map((resource) => (
                <a href={resource.href} class="copy-safe block rounded-2xl border border-[#0d7377]/15 bg-white p-4 transition-colors hover:border-[#0d7377]">
                  <span class="block text-sm font-semibold text-gray-800">{resource.name}</span>
                  <span class="mt-1 block text-sm text-gray-500">{resource.description}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {comparisonLinks.length > 0 && (
      <section class="bg-white py-16 border-b border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="eyebrow-label mb-2 text-[#0d7377]">Comparison Pages</p>
                <h2 class="title-balance text-3xl font-semibold text-gray-900">Useful when the buyer still needs to compare two technical directions</h2>
              </div>
              <p class="card-copy max-w-2xl text-gray-600">
                Open the comparison pages below when the workflow is clear but chip family, credential format or tag construction still needs to be settled before samples.
              </p>
            </div>
            <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
              {comparisonLinks.map((page) => (
                <a href={`/compare/${page.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:-translate-y-0.5 hover:border-[#0d7377]">
                  <span class="eyebrow-label text-[#0d7377]">{page.heroEyebrow}</span>
                  <h3 class="title-balance mt-3 text-lg font-semibold text-gray-900">{page.name}</h3>
                  <p class="card-copy mt-2 text-sm text-gray-500">{truncateText(page.description, 118)}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {relatedMarkets.length > 0 && (
      <section class="bg-gray-50 py-16">
        <div class="container mx-auto px-4">
          <div class="mb-8 max-w-3xl">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Regional Buyer Hubs</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Open a regional path if approval style or sourcing habits vary by market</h2>
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            {relatedMarkets.map((market) => (
              <a href={`/markets/${market.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-white p-6 transition-all hover:border-[#0d7377] hover:shadow-lg">
                <span class="eyebrow-label text-[#0d7377]">{market.regionName}</span>
                <h3 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{market.productFocus}</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">{market.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="border-y border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow-label mb-2 text-[#0d7377]">Related Solutions</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Review nearby workflows if the shortlist is still split across use cases</h2>
          </div>
          <a href="/solutions" class="text-sm font-semibold text-[#0d7377] transition-colors hover:text-[#0a5c5f]">Open solutions hub</a>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {relatedSolutions.slice(0, 2).map((solution) => (
            <a href={`/solutions/${solution.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0d7377] hover:bg-white">
              <span class="eyebrow-label text-[#0d7377]">{solution.heroEyebrow}</span>
              <h3 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{solution.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{solution.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl">
          <div class="mb-10 text-center">
            <p class="eyebrow-label mb-2 text-[#0d7377]">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Common questions buyers ask on this solution path</h2>
          </div>
          <div class="space-y-4">
            {config.faqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-gray-50 p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0d7377] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 leading-relaxed text-gray-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0d7377] py-14">
      <div class="container mx-auto px-4 text-center">
        <h2 class="title-balance mb-4 text-3xl font-bold text-white">{config.ctaTitle}</h2>
        <p class="mx-auto mb-7 max-w-3xl text-white/90">{config.ctaDescription}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={getSolutionContactHref(config.slug)} class="rounded-lg bg-white px-6 py-3 font-semibold text-[#0d7377] transition-colors hover:bg-gray-100">
            Request samples or quote
          </a>
          <a
            href={solutionWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-white px-6 py-3 font-semibold text-white transition-colors hover:bg-white/10"
          >
            WhatsApp us
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
