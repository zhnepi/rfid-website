---
import '../styles/global.css';
import { getContextualContactAction, getContextualWhatsAppAction } from '../utils/contact';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  articleAuthor?: string;
}

const {
  title,
  description = 'ProudTek - Professional RFID cards, smart cards, RFID tags manufacturer since 2008. Custom RFID solutions for access control, asset tracking, and more.',
  keywords = 'RFID cards, RFID tags, smart cards, RFID manufacturer, RFID wristbands, RFID keyfob, NFC tags, RFID labels, RFID reader, China RFID factory',
  ogImage = '/images/hero/smart-card-banner.webp',
  ogType = 'website',
  canonicalURL,
  jsonLd,
  noindex = false,
  publishedTime,
  modifiedTime,
  articleAuthor,
} = Astro.props;

const siteURL = 'https://www.proudtek.com';
const canonical = canonicalURL || new URL(Astro.url.pathname, siteURL).href;
const ogImageURL = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteURL).href;
const contextualContactAction = getContextualContactAction(Astro.url.pathname);
const contextualWhatsAppAction = getContextualWhatsAppAction(Astro.url.pathname);
const mobileQuoteLabel = Astro.url.pathname === '/' ? 'Get a Quote' : contextualContactAction.label;
const preloadHeroImage = Astro.url.pathname === '/' ? '/images/hero/smart-card-banner.webp' : null;
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

// LocalBusiness + Organization JSON-LD (GEO: richer entity data for AI engines)
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness"],
  "@id": `${siteURL}/#organization`,
  "name": "ProudTek",
  "legalName": "Shenzhen Proud Tek Co., LTD",
  "url": siteURL,
  "logo": {
    "@type": "ImageObject",
    "url": new URL('/favicon.svg', siteURL).href,
    "width": 512,
    "height": 512
  },
  "description": "ProudTek is a professional RFID manufacturer established in 2008 in Shenzhen, China. We specialize in RFID cards, smart cards, RFID tags, wristbands, keyfobs, and readers, serving over 108 clients across 50+ countries.",
  "foundingDate": "2008",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "A2109, Zhantao Science & Tech Park, Minzhi Ave",
    "addressLocality": "Shenzhen",
    "addressRegion": "Guangdong",
    "postalCode": "518131",
    "addressCountry": "CN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "22.6543",
    "longitude": "114.0298"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+86-755-2376-5843",
      "contactType": "sales",
      "email": "info@proudtek.com",
      "availableLanguage": ["English", "Chinese"]
    },
    {
      "@type": "ContactPoint",
      "telephone": "+86-186-6582-0632",
      "contactType": "customer service",
      "contactOption": "TollFree",
      "availableLanguage": ["English", "Chinese"]
    }
  ],
  "sameAs": [
    "https://www.linkedin.com/company/proudtek",
    "https://www.youtube.com/@proudtek"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "RFID Products",
    "itemListElement": [
      { "@type": "OfferCatalog", "name": "RFID Cards", "url": `${siteURL}/category/rfid-cards` },
      { "@type": "OfferCatalog", "name": "RFID Tags", "url": `${siteURL}/category/rfid-tags` },
      { "@type": "OfferCatalog", "name": "RFID Labels", "url": `${siteURL}/category/rfid-labels` },
      { "@type": "OfferCatalog", "name": "RFID Wristbands", "url": `${siteURL}/category/rfid-wristbands` },
      { "@type": "OfferCatalog", "name": "RFID Keyfobs", "url": `${siteURL}/category/rfid-keyfob` },
      { "@type": "OfferCatalog", "name": "RFID Readers", "url": `${siteURL}/category/rfid-readers` }
    ]
  },
  "knowsAbout": [
    "RFID Technology",
    "NFC Technology",
    "Contactless Smart Cards",
    "Access Control Systems",
    "RFID Asset Tracking",
    "RFID Laundry Management",
    "Supply Chain RFID Solutions"
  ],
  "iso6523Code": "ISO9001:2015",
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "ISO 9001:2015" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "ISO 14001" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "verification", "name": "SGS Verified Supplier" }
  ]
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteURL}/#website`,
  "name": "ProudTek - RFID Manufacturer",
  "url": siteURL,
  "publisher": { "@id": `${siteURL}/#organization` },
  "inLanguage": "en-US"
};

const webpageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  "url": canonical,
  "name": title,
  "description": description,
  "isPartOf": { "@id": `${siteURL}/#website` },
  "about": { "@id": `${siteURL}/#organization` },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": ogImageURL
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".product-description", ".blog-excerpt", "article header", "[data-speakable]"]
  },
  "inLanguage": "en-US"
};

// Combine all JSON-LD
const allJsonLd = [organizationJsonLd, websiteJsonLd, webpageJsonLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robotsContent} />
    <meta name="format-detection" content="telephone=no" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="alternate" type="application/rss+xml" href="/feed.xml" title="ProudTek RFID Blog" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs Full Technical Specifications" />

    <!-- Font Preloads (LCP optimization) -->
    <link rel="preload" href="/fonts/playfair-display-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-600-latin.woff2" as="font" type="font/woff2" crossorigin />
    {preloadHeroImage && (
      <link rel="preload" href={preloadHeroImage} as="image" type="image/webp" fetchpriority="high" />
    )}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <script>
      import { inject } from '@vercel/analytics';

      inject();
    </script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.proudtekTrack = function(eventName, detail) {
        const payload = {
          event: eventName,
          page_path: window.location.pathname,
          event_time: new Date().toISOString(),
          ...(detail || {}),
        };

        window.dataLayer.push(payload);

        window.va = window.va || function() {
          (window.vaq = window.vaq || []).push(arguments);
        };
        window.va('event', {
          name: eventName,
          data: detail || {},
        });
      };
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="ProudTek" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@proudtek" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Additional SEO -->
    <meta name="author" content="ProudTek - Shenzhen Proud Tek Co., LTD" />
    <meta name="theme-color" content="#0d7377" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- JSON-LD Structured Data -->
    {allJsonLd.map(ld => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
</head>
  <body class="min-h-screen flex flex-col pb-16 md:pb-0 bg-[#fafaf8] antialiased">
    <a
      href="#site-main"
      class="sr-only fixed left-4 top-4 z-[60] rounded-lg bg-slate-950 px-4 py-3 text-sm font-semibold text-white focus:not-sr-only"
    >
      Skip to main content
    </a>
    <slot />

    <!-- Floating WhatsApp Button (Desktop: bottom-left, Mobile: hidden because of bottom bar) -->
    <a
      href={contextualWhatsAppAction.href}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:flex fixed bottom-6 left-6 z-50 bg-[#1b8f53] text-white p-4 rounded-full shadow-lg hover:bg-[#167445] transition-all duration-300 hover:scale-110 group items-center justify-center whatsapp-pulse"
      aria-label={contextualWhatsAppAction.label}
    >
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-gray-800 text-white text-xs px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
        Chat with us on WhatsApp
      </span>
    </a>

    <!-- Mobile Bottom Inquiry Bar -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-[#0d0d0d] border-t border-[#c9a84c]/20 shadow-[0_-4px_20px_rgba(0,0,0,0.4)]">
      <div class="flex">
        <a
          href={contextualWhatsAppAction.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={contextualWhatsAppAction.label}
          class="flex-1 flex items-center justify-center gap-2 py-3 bg-[#1b8f53] text-white font-medium text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href="/contact"
          class="flex-1 flex items-center justify-center gap-2 py-3 bg-amber-500 text-white font-semibold text-sm"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          {mobileQuoteLabel}
        </a>
      </div>
    </div>
    <script is:inline>
      const ensureMainAnchor = () => {
        const main = document.querySelector('main');
        if (main && !main.id) {
          main.id = 'site-main';
        }
      };

      const initRevealObserver = () => {
        const revealEls = Array.from(document.querySelectorAll('.reveal'));
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (revealEls.length === 0) {
          return;
        }

        if (prefersReducedMotion || !('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('revealed'));
          return;
        }

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

        revealEls.forEach((el) => revealObserver.observe(el));
      };

      const scheduleRevealInit = () => {
        ensureMainAnchor();

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(initRevealObserver, { timeout: 1200 });
          return;
        }

        window.setTimeout(initRevealObserver, 120);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleRevealInit, { once: true });
      } else {
        scheduleRevealInit();
      }
    </script>
  </body>
</html>
