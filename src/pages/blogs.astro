---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { blogPosts } from '../data/blogs';
import { trendingBlogSlugs } from '../data/blogSeo';
import { getAuthorById } from '../data/authors';
import { truncateText } from '../utils/content';

const blogs = [...blogPosts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const latestPost = blogs[0];
const recentPosts = blogs.slice(1, 5);
const trendingPosts = trendingBlogSlugs
  .map((slug) => blogs.find((post) => post.slug === slug))
  .filter((post): post is (typeof blogPosts)[number] => Boolean(post))
  .slice(0, 4);
const technologyPosts = blogs.filter((post) => post.category === 'RFID TECHNOLOGY').slice(0, 6);
const applicationPosts = blogs.filter((post) => post.category === 'RFID APPLICATIONS').slice(0, 6);
const allPosts = blogs;

const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/blogs`;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'RFIDAK RFID Blog',
  description: 'RFID buying guides, NFC explainers, sourcing articles and application notes from RFIDAK.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: blogs.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/blogs/${post.slug}`,
      name: post.title,
    })),
  },
};

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${canonicalURL}#blog`,
  url: canonicalURL,
  name: 'RFIDAK RFID Blog',
  description: 'Practical RFID and NFC content for buyers, engineers and project teams.',
  publisher: { '@id': `${siteURL}/#organization` },
  blogPost: blogs.map((post) => {
    const author = getAuthorById(post.authorId || 'rfidak-rfid-editorial-team');
    return {
      '@type': 'BlogPosting',
      headline: post.title,
      url: `${siteURL}/blogs/${post.slug}`,
      datePublished: new Date(post.date).toISOString(),
      ...(post.updatedDate ? { dateModified: new Date(post.updatedDate).toISOString() } : {}),
      image: post.image.startsWith('http') ? post.image : `${siteURL}${post.image}`,
      ...(author
        ? {
            author: {
              '@type': 'Organization',
              '@id': `${siteURL}/authors/${author.slug}#author`,
              name: author.name,
              url: `${siteURL}/authors/${author.slug}`,
            },
          }
        : {}),
    };
  }),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Blog - Guides, NFC Articles and Buying Advice | RFIDAK"
  description="Explore practical RFID and NFC articles from RFIDAK, including frequency guides, application examples, sourcing tips and product selection advice."
  keywords="RFID blog, RFID guides, NFC articles, RFID sourcing guide, RFID applications, RFIDAK blog"
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, blogJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main class="overflow-x-hidden">

    <!-- Hero: Latest Post Feature -->
    <section class="bg-slate-50 border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-16">
        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-500 mb-8">
          <a href="/" class="hover:text-[#0d7377] transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-gray-800 font-medium">Blog</span>
        </nav>

        <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-8 lg:gap-12 items-start">
          <!-- Latest post image -->
          <a href={`/blogs/${latestPost.slug}`} class="block rounded-2xl overflow-hidden group">
            <div class="aspect-[16/10] overflow-hidden rounded-2xl">
              <img
                src={latestPost.image}
                alt={latestPost.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                decoding="async"
                width="720"
                height="450"
              />
            </div>
          </a>

          <!-- Latest post text -->
          <div class="flex flex-col justify-center">
            <span class="text-xs font-semibold uppercase tracking-[0.15em] text-[#0d7377]">Latest</span>
            <h1 class="mt-3 text-2xl md:text-3xl lg:text-[2rem] font-bold text-gray-900 leading-snug">
              <a href={`/blogs/${latestPost.slug}`} class="hover:text-[#0d7377] transition-colors">
                {latestPost.title}
              </a>
            </h1>
            <p class="mt-4 text-gray-600 leading-relaxed line-clamp-3">
              {truncateText(latestPost.excerpt, 200)}
            </p>
            <div class="mt-6 flex items-center gap-4 text-sm text-gray-500">
              <span>{latestPost.date}</span>
              <span class="w-1 h-1 rounded-full bg-gray-300"></span>
              <span class="text-xs uppercase tracking-wider font-medium text-gray-400">{latestPost.category}</span>
            </div>
            <a
              href={`/blogs/${latestPost.slug}`}
              class="mt-6 inline-flex items-center gap-2 text-[#0d7377] font-semibold text-sm hover:gap-3 transition-all"
            >
              Read article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Posts Grid -->
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-xl font-bold text-gray-900">Recent Articles</h2>
          <a href="#all" class="text-sm text-[#0d7377] font-medium hover:underline">View all &darr;</a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {recentPosts.map((post) => (
            <article class="group">
              <a href={`/blogs/${post.slug}`} class="block rounded-xl overflow-hidden mb-4">
                <div class="aspect-[4/3] overflow-hidden rounded-xl bg-gray-100">
                  <img
                    src={post.image}
                    alt={`${post.title} — RFIDAK RFID buyer guide and industry insight`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="300"
                  />
                </div>
              </a>
              <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-[#0d7377]">{post.category}</span>
              <h3 class="mt-1.5 text-[15px] font-semibold text-gray-900 leading-snug line-clamp-2 group-hover:text-[#0d7377] transition-colors">
                <a href={`/blogs/${post.slug}`}>{post.title}</a>
              </h3>
              <p class="mt-2 text-sm text-gray-500 leading-relaxed line-clamp-2">{truncateText(post.excerpt, 90)}</p>
              <span class="mt-2 block text-xs text-gray-400">{post.date}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-gray-100" /></div>

    <!-- Trending + Category Tabs -->
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="flex items-baseline justify-between mb-10">
          <div>
            <span class="text-xs font-semibold uppercase tracking-[0.15em] text-amber-600">Trending in 2026</span>
            <h2 class="mt-1 text-xl font-bold text-gray-900">Topics buyers are researching now</h2>
          </div>
        </div>

        {trendingPosts.length > 0 && (
          <div class="grid md:grid-cols-2 gap-5">
            {trendingPosts.map((post, i) => (
              <a href={`/blogs/${post.slug}`} class="group flex gap-5 p-4 rounded-xl hover:bg-slate-50 transition-colors">
                <div class="flex-shrink-0 w-28 h-28 md:w-32 md:h-32 rounded-lg overflow-hidden bg-gray-100">
                  <img
                    src={post.image}
                    alt={`${post.title} — RFIDAK RFID buyer guide and industry insight`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    width="256"
                    height="256"
                  />
                </div>
                <div class="flex flex-col justify-center min-w-0">
                  <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-[#0d7377]">{post.category}</span>
                  <h3 class="mt-1 text-base font-semibold text-gray-900 leading-snug line-clamp-2 group-hover:text-[#0d7377] transition-colors">
                    {post.title}
                  </h3>
                  <p class="mt-1.5 text-sm text-gray-500 line-clamp-2 hidden sm:block">{truncateText(post.excerpt, 100)}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Technology & Application Columns -->
    <section class="bg-slate-50 border-y border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

          <!-- Technology Column -->
          <div>
            <div class="flex items-baseline justify-between mb-6">
              <h2 class="text-lg font-bold text-gray-900">
                <span class="inline-block w-2 h-2 rounded-full bg-[#0d7377] mr-2 relative -top-[1px]"></span>
                Technology
              </h2>
              <span class="text-xs text-gray-400 uppercase tracking-wider">RFID / NFC / Chip</span>
            </div>
            <div class="space-y-0 divide-y divide-gray-200">
              {technologyPosts.map((post) => (
                <a href={`/blogs/${post.slug}`} class="group block py-4 first:pt-0 last:pb-0">
                  <h3 class="text-[15px] font-semibold text-gray-800 group-hover:text-[#0d7377] transition-colors leading-snug">
                    {post.title}
                  </h3>
                  <p class="mt-1 text-sm text-gray-500 line-clamp-1">{truncateText(post.excerpt, 100)}</p>
                </a>
              ))}
            </div>
            <a href="/rfid-technology" class="mt-5 inline-flex items-center gap-1 text-sm text-[#0d7377] font-medium hover:gap-2 transition-all">
              All technology guides
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Applications Column -->
          <div>
            <div class="flex items-baseline justify-between mb-6">
              <h2 class="text-lg font-bold text-gray-900">
                <span class="inline-block w-2 h-2 rounded-full bg-amber-500 mr-2 relative -top-[1px]"></span>
                Applications
              </h2>
              <span class="text-xs text-gray-400 uppercase tracking-wider">Real-world use</span>
            </div>
            <div class="space-y-0 divide-y divide-gray-200">
              {applicationPosts.map((post) => (
                <a href={`/blogs/${post.slug}`} class="group block py-4 first:pt-0 last:pb-0">
                  <h3 class="text-[15px] font-semibold text-gray-800 group-hover:text-[#0d7377] transition-colors leading-snug">
                    {post.title}
                  </h3>
                  <p class="mt-1 text-sm text-gray-500 line-clamp-1">{truncateText(post.excerpt, 100)}</p>
                </a>
              ))}
            </div>
            <a href="/rfid" class="mt-5 inline-flex items-center gap-1 text-sm text-[#0d7377] font-medium hover:gap-2 transition-all">
              Browse products
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="rounded-2xl bg-gradient-to-br from-[#0d7377] to-[#0a5c5f] p-8 md:p-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div class="max-w-lg">
            <h2 class="text-xl md:text-2xl font-bold text-white">Ready to move from research to sampling?</h2>
            <p class="mt-2 text-white/75 text-sm leading-relaxed">
              Share your chip requirement, quantity and application. We'll suggest matching products and prepare a sample plan.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="bg-white text-[#0d7377] px-6 py-2.5 rounded-lg font-semibold text-sm hover:bg-gray-50 transition-colors">
              Get a Quote
            </a>
            <a href="/rfid" class="border border-white/40 text-white px-6 py-2.5 rounded-lg font-semibold text-sm hover:bg-white/10 transition-colors">
              Browse Products
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- All Posts -->
    <section id="all" class="bg-slate-50 border-t border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="flex items-baseline justify-between mb-10">
          <h2 class="text-xl font-bold text-gray-900">All Articles ({allPosts.length})</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
          {allPosts.map((post) => (
            <article class="group">
              <a href={`/blogs/${post.slug}`} class="block mb-3">
                <div class="aspect-[16/10] overflow-hidden rounded-xl bg-gray-100">
                  <img
                    src={post.image}
                    alt={`${post.title} — RFIDAK RFID buyer guide and industry insight`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    width="480"
                    height="300"
                  />
                </div>
              </a>
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span class="font-semibold uppercase tracking-[0.12em] text-[#0d7377]">{post.category}</span>
                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                <span>{post.date}</span>
              </div>
              <h3 class="mt-2 text-base font-semibold text-gray-900 leading-snug line-clamp-2 group-hover:text-[#0d7377] transition-colors">
                <a href={`/blogs/${post.slug}`}>{post.title}</a>
              </h3>
              <p class="mt-1.5 text-sm text-gray-500 leading-relaxed line-clamp-2">{truncateText(post.excerpt, 110)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
