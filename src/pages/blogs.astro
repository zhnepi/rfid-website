---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { blogPosts } from '../data/blogs';
import { trendingBlogSlugs } from '../data/blogSeo';
import { comparisonPagesList } from '../data/comparisons';
import { getAuthorById } from '../data/authors';
import { truncateText } from '../utils/content';
import {
  getBlogContactHref,
  getBlogInquiryIntent,
  getComparisonContactHref,
  getContextualContactAction,
  getContextualInquiryLabel,
} from '../utils/contact';

const blogs = [...blogPosts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const decorateBlogPost = (post: (typeof blogPosts)[number]) => ({
  ...post,
  contactHref: getBlogContactHref(post),
  inquiryLabel: getContextualInquiryLabel(getBlogInquiryIntent(post), 'blog'),
});
const featuredPosts = blogs.slice(0, 3).map(decorateBlogPost);
const trendingPosts = trendingBlogSlugs
  .map((slug) => blogs.find((post) => post.slug === slug))
  .filter((post): post is (typeof blogPosts)[number] => Boolean(post))
  .map(decorateBlogPost);
const technologyPosts = blogs.filter((post) => post.category === 'RFID TECHNOLOGY').slice(0, 4).map(decorateBlogPost);
const applicationPosts = blogs.filter((post) => post.category === 'RFID APPLICATIONS').slice(0, 4).map(decorateBlogPost);
const sourcingPosts = blogs.filter((post) =>
  [
    'hotel-key-card-rfid-guide',
    'laundry-rfid-tags-buying-guide',
    'how-to-order-rfid-cards-from-china',
    'how-to-choose-rfid-readers-and-writers',
    'rfid-keyfob-buying-guide',
  ].includes(post.slug)
).map(decorateBlogPost);
const comparisonPages = [
  'hf-vs-uhf-rfid',
  'lf-vs-hf-rfid',
  'mifare-plus-vs-desfire',
  'rfid-labels-vs-hard-tags',
]
  .map((slug) => comparisonPagesList.find((page) => page.slug === slug))
  .filter((page): page is (typeof comparisonPagesList)[number] => Boolean(page))
  .map((page) => ({
    ...page,
    contactHref: getComparisonContactHref(page.slug),
  }));
const blogHubAction = getContextualContactAction('/blogs');
const featuredSourcingPost = sourcingPosts[0] || featuredPosts[0];

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/blogs`;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'ProudTek RFID Blog',
  description: 'RFID buying guides, NFC explainers, sourcing articles and application notes from ProudTek.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: blogs.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/blogs/${post.slug}`,
      name: post.title,
    })),
  },
};

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${canonicalURL}#blog`,
  url: canonicalURL,
  name: 'ProudTek RFID Blog',
  description: 'Practical RFID and NFC content for buyers, engineers and project teams.',
  publisher: { '@id': `${siteURL}/#organization` },
  blogPost: blogs.map((post) => {
    const author = getAuthorById(post.authorId || 'proudtek-rfid-editorial-team');

    return {
      '@type': 'BlogPosting',
      headline: post.title,
      url: `${siteURL}/blogs/${post.slug}`,
      datePublished: new Date(post.date).toISOString(),
      ...(post.updatedDate ? { dateModified: new Date(post.updatedDate).toISOString() } : {}),
      image: post.image.startsWith('http') ? post.image : `${siteURL}${post.image}`,
      ...(author
        ? {
            author: {
              '@type': 'Organization',
              '@id': `${siteURL}/authors/${author.slug}#author`,
              name: author.name,
              url: `${siteURL}/authors/${author.slug}`,
            },
          }
        : {}),
    };
  }),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Blog - Guides, NFC Articles and Buying Advice | ProudTek"
  description="Explore practical RFID and NFC articles from ProudTek, including frequency guides, application examples, sourcing tips and product selection advice."
  keywords="RFID blog, RFID guides, NFC articles, RFID sourcing guide, RFID applications, ProudTek blog"
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, blogJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#0e7490] via-[#155e75] to-[#008fa1] py-20 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <p class="eyebrow-label eyebrow-label-wide text-[#0e7490]/70 mb-4">Knowledge Hub</p>
          <h1 class="title-balance text-4xl md:text-6xl font-bold mb-6">RFID guides that help buyers, engineers and project teams move faster</h1>
          <p class="text-lg md:text-xl text-white/85 max-w-3xl">
            Explore RFID basics, NFC workflows, sourcing advice and category-specific buying content written to support product selection and project planning.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={blogHubAction.href} class="bg-white text-[#0e7490] px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
              Turn a guide into a sample plan
            </a>
            {featuredSourcingPost && (
              <a href={`/blogs/${featuredSourcingPost.slug}`} class="border border-white/70 px-6 py-3 rounded-lg font-semibold text-white hover:bg-white/10 transition-colors">
                Start with {featuredSourcingPost.title}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <a href="#featured" class="copy-safe rounded-2xl border border-gray-200 p-6 hover:border-[#0e7490] transition-colors">
            <span class="eyebrow-label text-[#0e7490]">Featured</span>
            <h2 class="title-balance text-xl font-semibold text-gray-800 mt-3">Latest and strongest evergreen guides</h2>
            <p class="card-copy text-sm text-gray-600 mt-2">Start with the most useful blog posts for general product evaluation.</p>
          </a>
          <a href="#technology" class="copy-safe rounded-2xl border border-gray-200 p-6 hover:border-[#0e7490] transition-colors">
            <span class="eyebrow-label text-[#0e7490]">Technology</span>
            <h2 class="title-balance text-xl font-semibold text-gray-800 mt-3">RFID, NFC and chip selection basics</h2>
            <p class="card-copy text-sm text-gray-600 mt-2">Useful for teams validating protocol, frequency and smartphone compatibility.</p>
          </a>
          <a href="#comparisons" class="copy-safe rounded-2xl border border-gray-200 p-6 hover:border-[#0e7490] transition-colors">
            <span class="eyebrow-label text-[#0e7490]">Comparisons</span>
            <h2 class="title-balance text-xl font-semibold text-gray-800 mt-3">Head-to-head buying decisions</h2>
            <p class="card-copy text-sm text-gray-600 mt-2">Useful when the team is choosing between two credible RFID directions.</p>
          </a>
          <a href="#sourcing" class="copy-safe rounded-2xl border border-gray-200 p-6 hover:border-[#0e7490] transition-colors">
            <span class="eyebrow-label text-[#0e7490]">Sourcing</span>
            <h2 class="title-balance text-xl font-semibold text-gray-800 mt-3">Buying and supplier selection content</h2>
            <p class="card-copy text-sm text-gray-600 mt-2">Helpful for import buyers comparing sample plans, MOQ and manufacturing support.</p>
          </a>
        </div>
      </div>
    </section>

    <section id="featured" class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Featured Articles</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800">Start with these high-value guides</h2>
          </div>
          <p class="card-copy text-gray-600 max-w-xl">Start here for the questions buyers and project teams usually need answered before choosing RFID products.</p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          {featuredPosts.map((post) => (
            <article class="copy-safe bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
              <a href={`/blogs/${post.slug}`} class="block">
                <div class="aspect-[16/10] overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    decoding="async"
                    width="640"
                    height="400"
                  />
                </div>
              </a>
              <div class="p-6">
                <span class="eyebrow-label text-[#0e7490]">{post.category}</span>
                <h3 class="title-balance text-2xl font-semibold text-gray-800 mt-3">
                  <a href={`/blogs/${post.slug}`} class="hover:text-[#0e7490] transition-colors">{post.title}</a>
                </h3>
                <p class="card-copy text-gray-600 mt-3">{truncateText(post.excerpt, 155)}</p>
                <a href={post.contactHref} class="mt-4 inline-flex text-sm font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                  {post.inquiryLabel}
                </a>
                <div class="mt-5 flex items-center justify-between text-sm text-gray-500">
                  <span>{post.date}</span>
                  <a href={`/blogs/${post.slug}`} class="text-[#0e7490] font-semibold hover:text-[#155e75] transition-colors">Read guide</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {trendingPosts.length > 0 && (
      <section class="py-16 bg-white border-y border-gray-100">
        <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
            <div>
              <p class="eyebrow-label text-[#0e7490] mb-2">Trending in 2026</p>
              <h2 class="title-balance text-3xl font-bold text-gray-800">High-intent topics buyers are actively researching now</h2>
            </div>
            <p class="card-copy text-gray-600 max-w-2xl">
              Use this cluster for current searches around DPP, traceability, compliance, retail operations and authentication. These are the topics most likely to turn into real sampling conversations.
            </p>
          </div>

          <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
            {trendingPosts.map((post) => (
              <article class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 overflow-hidden hover:border-[#0e7490] transition-colors">
                <a href={`/blogs/${post.slug}`} class="block aspect-[16/10] overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    width="560"
                    height="350"
                  />
                </a>
                <div class="p-5">
                  <span class="eyebrow-label text-[#0e7490]">{post.category}</span>
                  <h3 class="title-balance text-lg font-semibold text-gray-800 mt-3">
                    <a href={`/blogs/${post.slug}`} class="hover:text-[#0e7490] transition-colors">{post.title}</a>
                  </h3>
                  <p class="card-copy text-sm text-gray-600 mt-2">{truncateText(post.excerpt, 118)}</p>
                  <a href={post.contactHref} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                    {post.inquiryLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section id="technology" class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Technology Cluster</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800 mb-4">Understand the standards before you buy</h2>
            <p class="card-copy text-gray-600 mb-6">
              Use these posts when the team still needs to settle LF, HF/NFC or UHF behavior, chip family choice or real-world compatibility before sampling.
            </p>
            <div class="space-y-3">
              <a href="/category/rfid-cards" class="copy-safe block rounded-xl border border-gray-200 p-4 hover:border-[#0e7490] transition-colors">
                <span class="text-sm font-semibold text-gray-800">Explore RFID cards</span>
                <span class="block text-sm text-gray-500 mt-1">Compare card formats that pair with the chips discussed in these guides.</span>
              </a>
              <a href="/category/rfid-labels" class="copy-safe block rounded-xl border border-gray-200 p-4 hover:border-[#0e7490] transition-colors">
                <span class="text-sm font-semibold text-gray-800">Explore RFID labels</span>
                <span class="block text-sm text-gray-500 mt-1">Helpful if your project needs NFC stickers or UHF tracking labels.</span>
              </a>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-6">
            {technologyPosts.map((post) => (
              <article class="copy-safe rounded-2xl border border-gray-200 overflow-hidden bg-gray-50">
                <a href={`/blogs/${post.slug}`} class="block aspect-[16/10] overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    width="560"
                    height="350"
                  />
                </a>
                <div class="p-5">
                  <h3 class="title-balance text-lg font-semibold text-gray-800">
                    <a href={`/blogs/${post.slug}`} class="hover:text-[#0e7490] transition-colors">{post.title}</a>
                  </h3>
                  <p class="card-copy text-sm text-gray-600 mt-2">{truncateText(post.excerpt, 120)}</p>
                  <a href={post.contactHref} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                    {post.inquiryLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="comparisons" class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Comparison Cluster</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800 mb-4">Decision pages for teams narrowing two realistic options</h2>
            <p class="card-copy text-gray-600 mb-6">
              Use this cluster after basic research is done and the team is down to two realistic directions but still needs to choose the more practical one.
            </p>
            <div class="space-y-3">
              <a href="/compare" class="copy-safe block rounded-xl border border-gray-200 p-4 hover:border-[#0e7490] transition-colors">
                <span class="text-sm font-semibold text-gray-800">Open the comparison hub</span>
                <span class="block text-sm text-gray-500 mt-1">See chip, frequency, credential, material and laundry tag comparisons in one place.</span>
              </a>
              <a href="/rfid-technology" class="copy-safe block rounded-xl border border-gray-200 p-4 hover:border-[#0e7490] transition-colors">
                <span class="text-sm font-semibold text-gray-800">Return to the technology guide</span>
                <span class="block text-sm text-gray-500 mt-1">Useful when the team needs broader background before choosing one side of the comparison.</span>
              </a>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-6">
            {comparisonPages.map((page) => (
              <article class="copy-safe rounded-2xl border border-gray-200 overflow-hidden bg-white">
                <a href={`/compare/${page.slug}`} class="block p-5">
                  <span class="eyebrow-label text-[#0e7490]">{page.heroEyebrow}</span>
                  <h3 class="title-balance text-lg font-semibold text-gray-800 mt-3">{page.name}</h3>
                  <p class="card-copy text-sm text-gray-600 mt-2">{truncateText(page.description, 118)}</p>
                </a>
                <div class="px-5 pb-5">
                  <a href={page.contactHref} class="inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                    Discuss this comparison
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="applications" class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Applications</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800">See how RFID solves real operating problems</h2>
          </div>
          <p class="card-copy text-gray-600 max-w-xl">Use these guides when the workflow is clear and the next job is matching it to the right product format before sampling.</p>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
          {applicationPosts.map((post) => (
            <article class="copy-safe bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
              <a href={`/blogs/${post.slug}`} class="block aspect-[16/10] overflow-hidden">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  width="500"
                  height="315"
                />
              </a>
              <div class="p-5">
                <h3 class="title-balance text-lg font-semibold text-gray-800">
                  <a href={`/blogs/${post.slug}`} class="hover:text-[#0e7490] transition-colors">{post.title}</a>
                </h3>
                <p class="card-copy text-sm text-gray-600 mt-2">{truncateText(post.excerpt, 110)}</p>
                <a href={post.contactHref} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                  {post.inquiryLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="sourcing" class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-10 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Buyer Focus</p>
            <h2 class="title-balance text-3xl font-bold text-gray-800 mb-4">Content for international buyers and sourcing teams</h2>
            <p class="card-copy text-gray-600">
              Start here when the team is close to requesting samples, shortlisting suppliers or validating deployment details and needs sourcing advice rather than basic RFID theory.
            </p>
          </div>
          <div class="space-y-4">
            {sourcingPosts.map((post) => (
              <article class="copy-safe rounded-2xl border border-gray-200 p-5 hover:border-[#0e7490] transition-colors">
                <a href={`/blogs/${post.slug}`} class="block">
                  <span class="eyebrow-label text-[#0e7490]">{post.category}</span>
                  <h3 class="title-balance text-xl font-semibold text-gray-800 mt-2">{post.title}</h3>
                  <p class="card-copy text-sm text-gray-600 mt-2">{truncateText(post.excerpt, 140)}</p>
                </a>
                <a href={post.contactHref} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                  {post.inquiryLabel}
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="rounded-[2rem] bg-[#072a31] text-white p-8 md:p-12 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <div class="max-w-2xl">
            <p class="eyebrow-label text-[#0e7490] mb-2">Need direct help?</p>
            <h2 class="title-balance text-3xl font-bold mb-3">Turn blog research into a sample and sourcing plan</h2>
            <p class="text-white/75">
              If you already know the product type, send your chip requirement, quantity and application details. We can suggest matching products and sample options.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href={blogHubAction.href} class="bg-[#0e7490] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#155e75] transition-colors">
              Plan samples from these guides
            </a>
            <a href="/rfid" class="border border-white/30 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
              Browse products
            </a>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
