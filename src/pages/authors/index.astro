---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { authors } from '../../data/authors';

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/authors`;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'ProudTek Editorial Profiles',
  description: 'Editorial and author profiles for ProudTek RFID guides, product explainers and sourcing content.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: authors.map((author, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/authors/${author.slug}`,
      name: author.name,
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Authors', item: canonicalURL },
  ],
};
---

<Layout
  title="Editorial Profiles | ProudTek"
  description="Meet the editorial profiles behind ProudTek RFID guides, product explainers and sourcing content."
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>Authors</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label text-[#0d7377] mb-4">Editorial Profiles</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">Who publishes ProudTek’s RFID guides and product explainers</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">
            These profiles explain the editorial voice behind ProudTek’s buyer guides, technology articles and category content, so readers can understand the scope and focus of the guidance they are using.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-6 lg:grid-cols-2">
          {authors.map((author) => (
            <a href={`/authors/${author.slug}`} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-white p-8 shadow-sm hover:shadow-lg transition-shadow">
              <p class="eyebrow-label text-[#0d7377] mb-3">Editorial Team</p>
              <h2 class="title-balance text-2xl font-semibold text-gray-900">{author.name}</h2>
              <p class="mt-2 text-sm font-medium text-gray-500">{author.role}</p>
              <p class="mt-4 text-gray-600 leading-relaxed">{author.shortBio}</p>
              <div class="mt-6 flex flex-wrap gap-2">
                {author.expertise.slice(0, 4).map((item) => (
                  <span class="rounded-full bg-[#0d7377]/5 px-3 py-1 text-xs font-semibold text-[#0d7377]">{item}</span>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center text-sm font-semibold text-[#0d7377]">
                View profile
                <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
