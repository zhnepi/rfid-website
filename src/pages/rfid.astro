---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { products } from '../data/products';
import { getProductComparisonLinks } from '../utils/comparisons';
import { getProductBuyerQuestion, getProductBuyerSummary } from '../utils/productCopy';

const catalogProducts = products.map((product) => ({
  product,
  topComparison: getProductComparisonLinks(product, 1)[0],
  cardQuestion: getProductBuyerQuestion(product),
  cardSummary: getProductBuyerSummary(product, 92),
}));

const categoryLinks = [
  { name: 'RFID Cards', href: '/category/rfid-cards' },
  { name: 'RFID Tags', href: '/category/rfid-tags' },
  { name: 'RFID Labels', href: '/category/rfid-labels' },
  { name: 'RFID Wristbands', href: '/category/rfid-wristbands' },
  { name: 'RFID Keyfobs', href: '/category/rfid-keyfob' },
  { name: 'RFID Readers', href: '/category/rfid-readers' },
  { name: 'RFID Rings', href: '/category/rfid-rings' },
];

// 按产品分类分组，并计算每个分类的产品数量
const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

const groupedProducts = catalogProducts.reduce<Record<string, typeof catalogProducts>>((acc, item) => {
  const key = item.product.category || 'Other';
  if (!acc[key]) acc[key] = [];
  acc[key].push(item);
  return acc;
}, {});

// 按自定义顺序展示分类
const categoryOrder = ['RFID Cards', 'RFID Tags', 'RFID Labels', 'RFID Wristbands', 'RFID Keyfob', 'RFID Readers', 'RFID Rings'];
const sidebarSections = categoryOrder
  .filter((cat) => groupedProducts[cat] && groupedProducts[cat].length > 0)
  .map((cat) => ({
    name: cat,
    id: `cat-${slugify(cat)}`,
    count: groupedProducts[cat].length,
    items: groupedProducts[cat],
  }));

// 额外分类（兜底）
Object.keys(groupedProducts)
  .filter((cat) => !categoryOrder.includes(cat))
  .forEach((cat) => {
    sidebarSections.push({
      name: cat,
      id: `cat-${slugify(cat)}`,
      count: groupedProducts[cat].length,
      items: groupedProducts[cat],
    });
  });

const totalProductCount = catalogProducts.length;

const catalogJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "RFIDAK RFID Catalog",
  "url": "https://www.rfidak.com/rfid",
  "description": "Full RFID catalog from RFIDAK including cards, tags, labels, wristbands, keyfobs, and readers.",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": products.slice(0, 24).map((product, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": product.name,
      "url": `https://www.rfidak.com/product/${product.slug}`
    }))
  }
};

// BreadcrumbList JSON-LD added 2026-04-24 — was missing despite page being 2 levels deep.
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",          "item": "https://www.rfidak.com/" },
    { "@type": "ListItem", "position": 2, "name": "RFID Catalog",  "item": "https://www.rfidak.com/rfid" }
  ]
};
---

<Layout
  title="RFID Product Catalog - Cards, Tags, Labels, Wristbands & Readers | RFIDAK"
  description="Browse RFIDAK's complete RFID catalog with product images and application-focused descriptions: RFID cards, RFID tags, NFC stickers, laundry tags, wristbands, keyfobs, and readers."
  keywords="RFID catalog, RFID products, RFID cards, RFID tags, NFC stickers, laundry tags, RFID keyfobs, RFID readers, RFIDAK"
  jsonLd={[catalogJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-slate-950 via-slate-900 to-[#1e293b] py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl text-white">
          <Breadcrumb variant="dark" items={[
            { name: 'Home', href: '/' },
            { name: 'RFID Catalog' },
          ]} />
          <p class="eyebrow-label eyebrow-label-wide text-[#0d7377]/70 mb-3 mt-4">Complete RFID Catalog</p>
          <h1 class="title-balance text-4xl md:text-6xl font-semibold">Shortlist products by what you need to tag, carry, mount, or read</h1>
          <p class="card-copy text-white/75 text-lg mt-5 max-w-3xl">
            Use this image-first catalog when you are still comparing form factors and want to move from broad browsing into the right product, category, or inquiry path fast.
          </p>
        </div>
      </div>
    </section>

    <section class="py-10 bg-white border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap gap-3">
          {categoryLinks.map((link) => (
            <a href={link.href} class="rounded-full border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:border-[#0d7377] hover:text-[#0d7377] transition-colors">
              {link.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-6">
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-gray-50 p-6">
            <p class="eyebrow-label text-[#0d7377] mb-2">Start Here</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">Do you already know the product family?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              If yes, jump straight into the category shortcuts above. If not, use the product grid below to compare actual formats before you narrow the shortlist.
            </p>
          </div>
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-gray-50 p-6">
            <p class="eyebrow-label text-[#0d7377] mb-2">Key Filter</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">What must the product match or survive?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              Reader protocol, metal surfaces, wash cycles, printer setup, outdoor exposure, and visible branding usually narrow the right product much faster than catalog name alone.
            </p>
          </div>
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-[#0d7377]/5 p-6 border-[#0d7377]/15">
            <p class="eyebrow-label text-[#0d7377] mb-2">Fast Next Step</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">Need a shortlist before sending one inquiry?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              Save the product slugs that look closest, then open the matching category or contact path with the shortlist already in hand.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-8 bg-white relative">
      <!-- Floating Sticky Sidebar Nav — only appears while this section is in view -->
      <aside
        aria-label="Product categories"
        class="hidden min-[1600px]:block absolute top-0 bottom-0 w-48 pointer-events-none"
        style="left: max(1rem, calc((100vw - 1280px) / 2 - 12.5rem - 1rem));"
      >
        <div class="sticky top-24 pointer-events-auto">
          <nav class="rounded-[1.25rem] border border-gray-200 bg-white/95 backdrop-blur shadow-lg overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 bg-gradient-to-br from-[#0d7377] to-[#0a5c5f] text-white">
              <div>
                <p class="text-[0.65rem] uppercase tracking-[0.18em] text-white/70">Catalog</p>
                <p class="text-sm font-semibold mt-0.5">All Categories</p>
              </div>
              <span class="inline-flex items-center justify-center rounded-full bg-white/15 px-2.5 py-0.5 text-xs font-semibold text-white">{totalProductCount}</span>
            </div>
            <ul class="py-2" id="catalog-sidebar-list">
              {sidebarSections.map((section) => (
                <li>
                  <a
                    href={`#${section.id}`}
                    data-cat-link={section.id}
                    class="group flex items-center justify-between gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-[#0d7377]/5 hover:text-[#0d7377] border-l-2 border-transparent transition-colors"
                  >
                    <span class="truncate">{section.name}</span>
                    <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 group-hover:bg-[#0d7377]/10 group-hover:text-[#0d7377] px-2 py-0.5 text-xs font-semibold min-w-[2rem] transition-colors">
                      {section.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>

      <div class="container mx-auto px-4 max-w-screen-xl">
        {sidebarSections.map((section) => (
          <section id={section.id} class="scroll-mt-24 mb-12">
            <div class="flex items-baseline justify-between border-b border-gray-200 pb-3 mb-6">
              <h2 class="title-balance text-2xl font-semibold text-gray-900">
                {section.name}
                <span class="ml-2 text-sm font-medium text-gray-500">({section.count})</span>
              </h2>
              <a href={`/category/${slugify(section.name)}`} class="text-xs font-medium text-[#0d7377] hover:text-[#0a5c5f]">
                View category →
              </a>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
              {section.items.map(({ product, topComparison, cardQuestion, cardSummary }) => (
                <article class="copy-safe group overflow-hidden rounded-[1.25rem] border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                  <a href={`/product/${product.slug}`} class="block">
                    <div class="aspect-square overflow-hidden bg-gray-100">
                      <img
                        src={product.images[0]}
                        alt={`${product.name} — ${product.category} manufactured by RFIDAK`}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    </div>
                    <div class="p-4">
                      <p class="eyebrow-label text-[#0d7377] mb-2">{product.category}</p>
                      <h3 class="title-balance text-sm md:text-base font-semibold text-gray-900">{product.name}</h3>
                      <p class="mt-2 text-xs font-semibold leading-relaxed text-gray-800 line-clamp-2">{cardQuestion}</p>
                      <p class="card-copy mt-2 text-xs text-gray-500 line-clamp-3">{cardSummary}</p>
                    </div>
                  </a>
                  <div class="border-t border-gray-100 px-4 pb-4 pt-3">
                    {topComparison ? (
                      <a href={`/compare/${topComparison.slug}`} class="block text-xs font-medium text-[#0d7377] transition-colors hover:text-[#0a5c5f] line-clamp-2">
                        Compare: {topComparison.name}
                      </a>
                    ) : (
                      <span class="block text-xs text-gray-400">Open product details for full specs</span>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <script is:inline>
      // 滚动时高亮当前分类
      (function () {
        const links = document.querySelectorAll('[data-cat-link]');
        const sections = Array.from(links)
          .map((link) => document.getElementById(link.getAttribute('data-cat-link')))
          .filter(Boolean);
        if (!sections.length) return;

        const activeClasses = ['bg-[#0d7377]/10', 'text-[#0d7377]', 'border-[#0d7377]'];

        function setActive(id) {
          links.forEach((link) => {
            const target = link.getAttribute('data-cat-link');
            if (target === id) {
              link.classList.add(...activeClasses);
            } else {
              link.classList.remove(...activeClasses);
            }
          });
        }

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
            if (visible[0]) setActive(visible[0].target.id);
          },
          { rootMargin: '-96px 0px -55% 0px', threshold: [0, 0.25, 0.5, 1] }
        );
        sections.forEach((s) => observer.observe(s));
      })();
    </script>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-6">What to decide before you shortlist products</h2>
          <div class="grid md:grid-cols-2 gap-8 text-gray-600 leading-relaxed">
            <div>
              <p>
                Start from the real object and workflow. People-carry credentials, metal assets, linen, packaging, books, vehicles, and desktop enrollment each point to very different RFID formats.
              </p>
            </div>
            <div>
              <p>
                Then narrow by the constraint that matters most: reader compatibility, wash durability, anti-metal performance, printer handling, or installation method. That usually eliminates the wrong shortlist early.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
