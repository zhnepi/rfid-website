---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { products } from '../data/products';
import { getProductComparisonLinks } from '../utils/comparisons';
import { getProductBuyerQuestion, getProductBuyerSummary } from '../utils/productCopy';

const localImages: Record<string, string> = {
  'rfid-card-inlay': '/images/products/RFID-card-inaly-2x5-TK4100-500x500.webp',
  'mini-rfid-tag': '/images/products/plastic-rfid-tag-500x500.webp',
  'rfid-cable-tie-tag': '/images/products/rfid-cable-tie-1.webp',
  'rfid-waste-bin-tag': '/images/products/rfid-bin-tag-500x500.webp',
  'rfid-nail-tag': '/images/products/RFID-Nail-Tag-3608.webp',
  'pallet-rfid-tag': '/images/products/Pallet-RFID-tag.webp',
  'rfid-tyre-tag': '/images/products/rfid-tyre-tag02.webp',
  'spring-rfid-tire-tag': '/images/products/rfid-tire-tag-500x443.webp',
  'high-temperature-rfid-tag': '/images/products/high-temperature-rfid-tag-500x500.webp',
  'key-transponder': '/images/products/key-transponder.webp',
  'rfid-fpc-tag': '/images/products/13.56MHz-FPC-tag.webp',
  'rfid-ceramic-tag': '/images/products/UHF-Ceramic-Tag.webp',
  'rfid-pcb-tag': '/images/products/RFID-PCB-Tag-HF.webp',
  'rfid-pcb': '/images/products/PCB-RFID-Tag-1.webp',
  'silicone-laundry-tag': '/images/products/Silicone-laundry-tag.webp',
  'pps-laundry-tag-rfid-button': '/images/products/laundry-tag-rfid.webp',
  'rfid-windshield-tag': '/images/products/RFID-Windshield-Tag.webp',
  'tamper-proof-rfid-tag': '/images/products/tamper-proof-rfid-tag-500x500.webp',
  'library-rfid-tags': '/images/products/library-rfid-tags.webp',
  'uhf-library-label': '/images/products/uhf-library-500x500.webp',
  'rfid-jewellery-tags': '/images/products/rfid-jewellery-tags.webp',
  'uhf-sticker': '/images/products/UHF-sticker-500x500.webp',
  'nfc-sticker': '/images/products/nfc-sticker.webp',
  'nfc-epoxy-card': '/images/products/NFC-epoxy-card.webp',
  'nfc-coin': '/images/products/NFC-coin.webp',
  'rfid-clear-tag': '/images/products/RFID-Clear-tag.webp',
  'rfid-clamshell-card': '/images/products/clamshel-card-500x500.webp',
  'rfid-wood-card-2': '/images/products/RFID-wood-card.webp',
  'rfid-paper-card': '/images/products/RFID-Paper-Card-500x500.webp',
  'rfid-glass-tag': '/images/products/RFID-glass-tag-500x500.webp',
  'rfid-metal-tag': '/images/products/Printable-RFID-metal-tag.webp',
  'rfid-reader-writer': '/images/products/RFID_reader_writer.webp',
  'textile-rfid-laundry-tag': '/images/products/textile-RFID-laundry-tag-heat-seal.webp',
  'rfid-silicone-wristband': '/images/products/RFID-SIlicone-wristbands-006.webp',
  'rfid-cards': '/images/products/ticket-smart-card.webp',
  'rfid-keyfob': '/images/products/PROUDTEK-RFID-KEYFOB.webp',
};

function getProductImage(slug: string): string {
  return localImages[slug] || '/images/products/placeholder.webp';
}

const catalogProducts = products.map((product) => ({
  product,
  topComparison: getProductComparisonLinks(product, 1)[0],
  cardQuestion: getProductBuyerQuestion(product),
  cardSummary: getProductBuyerSummary(product, 92),
}));

const categoryLinks = [
  { name: 'RFID Cards', href: '/category/rfid-cards' },
  { name: 'RFID Tags', href: '/category/rfid-tags' },
  { name: 'RFID Labels', href: '/category/rfid-labels' },
  { name: 'RFID Wristbands', href: '/category/rfid-wristbands' },
  { name: 'RFID Keyfobs', href: '/category/rfid-keyfob' },
  { name: 'RFID Readers', href: '/category/rfid-readers' },
];

const catalogJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "ProudTek RFID Catalog",
  "url": "https://www.proudtek.com/rfid",
  "description": "Full RFID catalog from ProudTek including cards, tags, labels, wristbands, keyfobs, and readers.",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": products.slice(0, 24).map((product, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": product.name,
      "url": `https://www.proudtek.com/product/${product.slug}`
    }))
  }
};
---

<Layout
  title="RFID Product Catalog - Cards, Tags, Labels, Wristbands & Readers | ProudTek"
  description="Browse ProudTek's complete RFID catalog with product images and application-focused descriptions: RFID cards, RFID tags, NFC stickers, laundry tags, wristbands, keyfobs, and readers."
  keywords="RFID catalog, RFID products, RFID cards, RFID tags, NFC stickers, laundry tags, RFID keyfobs, RFID readers, ProudTek"
  jsonLd={catalogJsonLd}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-slate-950 via-slate-900 to-[#1a1a2e] py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl text-white">
          <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c]/70 mb-3">Complete RFID Catalog</p>
          <h1 class="title-balance text-4xl md:text-6xl font-semibold">Shortlist products by what you need to tag, carry, mount, or read</h1>
          <p class="card-copy text-white/75 text-lg mt-5 max-w-3xl">
            Use this image-first catalog when you are still comparing form factors and want to move from broad browsing into the right product, category, or inquiry path fast.
          </p>
        </div>
      </div>
    </section>

    <section class="py-10 bg-white border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap gap-3">
          {categoryLinks.map((link) => (
            <a href={link.href} class="rounded-full border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:border-[#c9a84c] hover:text-[#c9a84c] transition-colors">
              {link.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-6">
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-gray-50 p-6">
            <p class="eyebrow-label text-[#c9a84c] mb-2">Start Here</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">Do you already know the product family?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              If yes, jump straight into the category shortcuts above. If not, use the product grid below to compare actual formats before you narrow the shortlist.
            </p>
          </div>
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-gray-50 p-6">
            <p class="eyebrow-label text-[#c9a84c] mb-2">Key Filter</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">What must the product match or survive?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              Reader protocol, metal surfaces, wash cycles, printer setup, outdoor exposure, and visible branding usually narrow the right product much faster than catalog name alone.
            </p>
          </div>
          <div class="copy-safe rounded-[1.5rem] border border-gray-200 bg-[#c9a84c]/5 p-6 border-[#c9a84c]/15">
            <p class="eyebrow-label text-[#c9a84c] mb-2">Fast Next Step</p>
            <h2 class="title-balance text-xl font-semibold text-gray-900 mb-3">Need a shortlist before sending one inquiry?</h2>
            <p class="card-copy text-sm text-gray-600 leading-relaxed">
              Save the product slugs that look closest, then open the matching category or contact path with the shortlist already in hand.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-8 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          {catalogProducts.map(({ product, topComparison, cardQuestion, cardSummary }) => (
            <article class="copy-safe group overflow-hidden rounded-[1.25rem] border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
              <a href={`/product/${product.slug}`} class="block">
                <div class="aspect-square overflow-hidden bg-gray-100">
                  <img
                    src={getProductImage(product.slug)}
                    alt={product.name}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4">
                  <p class="eyebrow-label text-[#c9a84c] mb-2">{product.category}</p>
                  <h3 class="title-balance text-sm md:text-base font-semibold text-gray-900">{product.name}</h3>
                  <p class="mt-2 text-xs font-semibold leading-relaxed text-gray-800 line-clamp-2">{cardQuestion}</p>
                  <p class="card-copy mt-2 text-xs text-gray-500 line-clamp-3">{cardSummary}</p>
                </div>
              </a>
              <div class="border-t border-gray-100 px-4 pb-4 pt-3">
                {topComparison ? (
                  <a href={`/compare/${topComparison.slug}`} class="block text-xs font-medium text-[#c9a84c] transition-colors hover:text-[#b8943f] line-clamp-2">
                    Compare: {topComparison.name}
                  </a>
                ) : (
                  <span class="block text-xs text-gray-400">Open product details for full specs</span>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-6">What to decide before you shortlist products</h2>
          <div class="grid md:grid-cols-2 gap-8 text-gray-600 leading-relaxed">
            <div>
              <p>
                Start from the real object and workflow. People-carry credentials, metal assets, linen, packaging, books, vehicles, and desktop enrollment each point to very different RFID formats.
              </p>
            </div>
            <div>
              <p>
                Then narrow by the constraint that matters most: reader compatibility, wash durability, anti-metal performance, printer handling, or installation method. That usually eliminates the wrong shortlist early.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
