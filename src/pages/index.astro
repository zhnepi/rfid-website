---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlider from '../components/HeroSlider.astro';
import TrustBadges from '../components/TrustBadges.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import CommercialPathsSection from '../components/CommercialPathsSection.astro';
import FactoryProofSection from '../components/FactoryProofSection.astro';
import Newsletter from '../components/Newsletter.astro';

const homepageJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "ProudTek RFID Manufacturer",
  "url": "https://www.proudtek.com/",
  "description": "RFID cards, tags, labels, wristbands, keyfobs, and readers manufactured by ProudTek in Shenzhen, China.",
  "about": {
    "@type": "Thing",
    "name": "RFID manufacturing"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "url": "https://www.proudtek.com/category/rfid-cards", "name": "RFID Cards" },
      { "@type": "ListItem", "position": 2, "url": "https://www.proudtek.com/category/rfid-tags", "name": "RFID Tags" },
      { "@type": "ListItem", "position": 3, "url": "https://www.proudtek.com/category/rfid-labels", "name": "RFID Labels" },
      { "@type": "ListItem", "position": 4, "url": "https://www.proudtek.com/category/rfid-wristbands", "name": "RFID Wristbands" }
    ]
  }
};
---

<Layout
  title="ProudTek - RFID Card, Smart Card & RFID Tag Manufacturer | China Factory Since 2008"
  description="ProudTek is a leading RFID manufacturer in China since 2008. We provide RFID cards, smart cards, RFID tags, wristbands, keyfobs, and custom RFID solutions for access control, asset tracking, laundry management, and more."
  keywords="RFID manufacturer China, RFID cards, smart cards, RFID tags, NFC cards, RFID wristbands, RFID keyfob, RFID reader, access control cards, custom RFID solutions, Shenzhen RFID factory"
  jsonLd={homepageJsonLd}
>
  <Header />
  <main>
    <HeroSlider />
    <TrustBadges />
    <div class="defer-section"><FeaturedProducts /></div>
    <div class="defer-section"><FactoryProofSection /></div>
    <div class="defer-section"><CommercialPathsSection /></div>
    <div class="defer-section"><Newsletter /></div>
  </main>
  <Footer />
</Layout>
