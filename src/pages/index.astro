---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlider from '../components/HeroSlider.astro';
import TrustBadges from '../components/TrustBadges.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import ApplicationsSection from '../components/ApplicationsSection.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Layout
  title="RFIDAK | RFID Card, Tag & Wristband Manufacturer (Since 2008)"
  description="RFIDAK is a Shenzhen RFID factory since 2008. Custom RFID cards, tags, wristbands, keyfobs and readers for access control, asset tracking, hospitality and events."
  keywords="RFID manufacturer China, RFID cards, smart cards, RFID tags, NFC cards, RFID wristbands, RFID keyfob, RFID reader, access control cards, custom RFID solutions, Shenzhen RFID factory"
>
  <Header />
  <main>
    <h1 class="sr-only">RFIDAK — RFID Card, Tag, Wristband, Keyfob and Reader Manufacturer in Shenzhen, China</h1>
    <HeroSlider />
    <TrustBadges />
    <FeaturedProducts />
    <ApplicationsSection />
    <Testimonials />
    <FAQ />
    <Newsletter />
  </main>
  <Footer />
</Layout>
