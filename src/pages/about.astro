---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { getIntentContactHref } from '../utils/contact';

const valueProps = [
  {
    title: 'Manufacturing focus',
    description: 'RFID cards, tags, labels, wristbands, keyfobs and reader products supplied for OEM, sourcing and project-led deployments.',
  },
  {
    title: 'Customization support',
    description: 'Chip matching, print finishing, numbering, encoding, packaging and format selection for buyers who need more than a standard catalog item.',
  },
  {
    title: 'Sample-first workflow',
    description: 'Useful for import buyers and system integrators who want to verify compatibility before scaling into repeat production.',
  },
  {
    title: 'Practical communication',
    description: 'Built for teams that need clear answers around protocol, material, lead time and application fit before placing an order.',
  },
];

const processSteps = [
  {
    step: '1',
    title: 'Review the use case',
    description: 'We start with the reader type, chip requirement, target environment and final application so the product recommendation is grounded in real usage.',
  },
  {
    step: '2',
    title: 'Match the product format',
    description: 'Cards, labels, hard tags, wristbands or keyfobs are selected based on read distance, mounting surface, wear conditions and user flow.',
  },
  {
    step: '3',
    title: 'Confirm samples and customization',
    description: 'Before mass production, buyers can validate print, encoding, material and performance using samples or pilot quantities.',
  },
  {
    step: '4',
    title: 'Move into production',
    description: 'Once the sample path is approved, production planning, packaging and shipment can be aligned with the order schedule.',
  },
];

const buyerProfiles = [
  'Distributors building a stable RFID product line',
  'System integrators matching chips to installed readers',
  'Hotels, clubs and campuses needing contactless credentials',
  'Laundry and textile operators requiring washable tags',
  'Retail, logistics and industrial teams rolling out tracking labels or hard tags',
  'Buyers comparing factory support before long-term procurement',
];

const categoryLinks = [
  { href: '/category/rfid-cards', label: 'RFID cards', description: 'Smart cards, hotel key cards, clamshell cards and custom credential formats.' },
  { href: '/category/rfid-tags', label: 'RFID tags', description: 'Industrial, laundry, anti-metal, pallet and asset tracking tag options.' },
  { href: '/category/rfid-labels', label: 'RFID labels', description: 'Printable UHF labels, NFC stickers and tamper-evident solutions.' },
  { href: '/category/rfid-wristbands', label: 'RFID wristbands', description: 'Event, resort, healthcare and guest-experience wearable credentials.' },
];

const aboutFaqs = [
  {
    question: 'What does ProudTek mainly manufacture?',
    answer: 'ProudTek focuses on RFID cards, tags, labels, wristbands, keyfobs and related reader hardware for sourcing, OEM and project-based applications.',
  },
  {
    question: 'Can ProudTek support custom RFID projects, not only standard catalog items?',
    answer: 'Yes. Many projects require chip matching, print customization, numbering, encoding or special materials. ProudTek can help buyers move from requirements into sampling, compatibility checks and production planning.',
  },
  {
    question: 'Who is the About page most useful for?',
    answer: 'It is especially useful for buyers, distributors and integrators who want to understand manufacturing scope, customization support and how the team approaches RFID project communication.',
  },
  {
    question: 'Where should I go after reading the About page?',
    answer: 'Most buyers move next to the RFID technology guide, the category pages or the contact page, depending on whether they still need technical background, product shortlisting or a sample discussion.',
  },
];

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/about`;
const aboutContactHref = getIntentContactHref('samples');

const aboutPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${canonicalURL}#about-page`,
  url: canonicalURL,
  name: 'About ProudTek',
  description: 'Brand and manufacturing overview for ProudTek, an RFID supplier based in Shenzhen, China.',
  isPartOf: { '@id': `${siteURL}/#website` },
  about: { '@id': `${siteURL}/#organization` },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: canonicalURL },
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: aboutFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout
  title="About ProudTek - RFID Manufacturing Partner in Shenzhen, China"
  description="Learn about ProudTek, an RFID manufacturer in Shenzhen focused on cards, tags, labels, wristbands, keyfobs and project-based customization support."
  keywords="About ProudTek, RFID manufacturer Shenzhen, RFID factory China, custom RFID supplier, RFID OEM manufacturer"
  canonicalURL={canonicalURL}
  jsonLd={[aboutPageJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#0e7490] via-[#155e75] to-[#008fa1] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="text-sm text-white/80 mb-4" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>About</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label eyebrow-label-wide text-[#0e7490]/70 mb-4">About ProudTek</p>
          <h1 class="title-balance text-4xl md:text-6xl font-bold mb-6">An RFID supplier built around practical sourcing, customization and project support</h1>
          <p class="text-lg md:text-xl text-white/85 max-w-3xl">
            ProudTek works with buyers who need more than a simple catalog. Expect help matching chips, materials and product formats, then turning that choice into a workable sample and production plan.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Company Overview</p>
            <h2 class="title-balance text-3xl md:text-4xl font-semibold text-gray-900 mb-5">What buyers should understand about ProudTek first</h2>
            <div class="space-y-5 text-gray-600 leading-relaxed max-w-3xl">
              <p>
                ProudTek is an RFID manufacturing and sourcing partner based in Shenzhen, China. The company focuses on contactless product families such as RFID cards, industrial tags, labels, wristbands, keyfobs and readers, with support for standard products as well as project-based customization.
              </p>
              <p>
                For many buyers, the real challenge is not finding any RFID product. It is finding the correct chip, form factor, material and finishing for the actual environment in which the product will be used. That is why the buying path here keeps pulling attention back to compatibility, surface conditions, wear, encoding and sample approval.
              </p>
              <p>
                Whether the project involves hotel key cards, laundry tags, NFC labels, anti-metal tags or event wristbands, the focus stays the same: reduce mismatched samples, shorten the move from research into a shortlist and make repeat purchasing easier once the right format is approved.
              </p>
            </div>
          </div>

          <div class="rounded-[2rem] bg-slate-950 p-8 text-white shadow-[0_24px_80px_rgba(15,23,42,0.16)]">
            <p class="eyebrow-label text-[#0e7490] mb-2">Brand Snapshot</p>
            <h2 class="title-balance text-2xl font-semibold mb-6">What buyers usually want to confirm before they shortlist ProudTek</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {valueProps.map((item) => (
                <div class="copy-safe rounded-2xl border border-white/10 bg-white/5 p-5">
                  <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                  <p class="text-sm text-white/75 mt-2 leading-relaxed">{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface border-y border-gray-100">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow-label text-[#0e7490] mb-2">How We Work</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">A manufacturing workflow that starts with fit, not guesswork</h2>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
          {processSteps.map((item) => (
            <div class="copy-safe rounded-[1.75rem] border border-gray-200 bg-white p-7 shadow-sm">
              <div class="w-11 h-11 rounded-full bg-[#0e7490]/5 text-[#0e7490] font-bold flex items-center justify-center mb-5">
                {item.step}
              </div>
              <h3 class="text-xl font-semibold text-gray-800">{item.title}</h3>
              <p class="text-gray-600 leading-relaxed mt-3">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 items-start">
          <div>
            <p class="eyebrow-label text-[#0e7490] mb-2">Best Fit</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900 mb-5">Who usually gets the most value from working with ProudTek</h2>
            <p class="text-gray-600 leading-relaxed">
              ProudTek is especially useful for buyers who are evaluating suppliers, validating compatibility or preparing a sample request. It fits teams that want technical clarity and production support in the same conversation.
            </p>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {buyerProfiles.map((item) => (
              <div class="copy-safe rounded-2xl border border-warm/30 bg-surface-warm px-5 py-5 text-gray-700">
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow-label text-[#0e7490] mb-2">Explore Categories</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">Move from company overview into actual product families</h2>
          <p class="card-copy text-gray-600 mt-4">
            Start here if supplier scope looks right and the next question is which product family belongs on the shortlist first.
          </p>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
          {categoryLinks.map((item) => (
            <a href={item.href} class="copy-safe rounded-[1.75rem] bg-white border border-gray-200 p-6 hover:border-[#0e7490] hover:shadow-lg transition-all">
              <h3 class="text-xl font-semibold text-gray-800">{item.label}</h3>
              <p class="text-sm text-gray-600 leading-relaxed mt-3">{item.description}</p>
              <span class="mt-5 inline-flex items-center text-sm font-semibold text-[#0e7490]">
                View category
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <p class="eyebrow-label text-[#0e7490] mb-2">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Common questions about ProudTek</h2>
          </div>
          <div class="space-y-4">
            {aboutFaqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-surface-warm p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0e7490] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-gray-600 leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 bg-[#0e7490]">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Ready to turn product research into a sample plan?</h2>
        <p class="text-white/90 max-w-3xl mx-auto mb-7">
          Share your chip requirement, target application and quantity. We can guide you toward the right category, sample path and production discussion.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={aboutContactHref} class="bg-white text-[#0e7490] px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Contact ProudTek
          </a>
          <a href="/rfid-technology" class="border border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
            Read the technology guide
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
