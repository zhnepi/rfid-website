---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { comparisonPagesList } from '../../data/comparisons';
import { evidenceLinks, guideLinks } from '../../data/navigation';
import { getComparisonContactHref, getContextualContactAction } from '../../utils/contact';

const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/compare`;
const comparisonHubAction = getContextualContactAction('/compare');
const featuredComparison = comparisonPagesList.find((page) => page.slug === 'hf-vs-uhf-rfid') || comparisonPagesList[0];

function getSupportingActionLabel(href: string) {
  const normalizedHref = href.split(/[?#]/)[0] || '';

  if (normalizedHref.startsWith('/blogs')) return 'Read guide';
  if (normalizedHref.startsWith('/compare')) return 'Review comparison';
  if (normalizedHref.startsWith('/solutions')) return 'Review workflow';
  if (normalizedHref.startsWith('/markets')) return 'Review market path';
  if (normalizedHref.startsWith('/products') || normalizedHref.startsWith('/rfid') || normalizedHref.startsWith('/product') || normalizedHref.startsWith('/category')) {
    return 'Browse product path';
  }
  if (
    normalizedHref.startsWith('/certifications')
    || normalizedHref.startsWith('/quality-control')
    || normalizedHref.startsWith('/sample-policy')
    || normalizedHref.startsWith('/shipping-and-incoterms')
  ) {
    return 'Review proof page';
  }

  return 'Open resource';
}

const supportingCards = [...guideLinks, ...evidenceLinks].map((link) => ({
  ...link,
  contactAction: getContextualContactAction(link.href),
  openLabel: getSupportingActionLabel(link.href),
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'RFID Comparison Pages',
  description: 'Buyer-oriented RFID comparison pages covering chip families, LF/HF/UHF choices, product materials, credential formats and laundry-tag tradeoffs.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: comparisonPagesList.map((page, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/compare/${page.slug}`,
      name: page.name,
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Comparisons', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Comparison Pages - Chips, Frequencies and Product Formats | RFIDAK"
  description="Explore buyer-focused RFID comparison pages covering chip upgrades, LF/HF/UHF choices, cards vs keyfobs, PVC vs paper cards, labels vs hard tags and laundry tag tradeoffs."
  keywords="RFID comparison pages, Mifare Classic vs DESFire, Mifare Plus vs DESFire, LF vs HF RFID, HF vs UHF RFID, RFID cards vs keyfobs, RFID labels vs hard tags"
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>Comparisons</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label mb-4 text-[#0d7377]">Comparison Hub</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">RFID decision pages built for buyers choosing between two realistic paths</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">
            Use these decision pages when the shortlist is down to two realistic paths and the team needs a cleaner choice across chip, frequency, material, credential or laundry-tag tradeoffs.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={comparisonHubAction.href} class="rounded-lg bg-[#0d7377] px-6 py-3 font-semibold text-white hover:bg-[#0a5c5f] transition-colors">
              Talk through your shortlist
            </a>
            {featuredComparison && (
              <a href={`/compare/${featuredComparison.slug}`} class="rounded-lg border border-white/25 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                Start with {featuredComparison.name}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow-label mb-2 text-[#0d7377]">Current Comparison Pages</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">High-intent tradeoffs already covered</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {comparisonPagesList.map((page) => (
            <article class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0d7377] hover:bg-white">
              <a href={`/compare/${page.slug}`} class="block">
                <span class="eyebrow-label text-[#0d7377]">{page.heroEyebrow}</span>
                <h2 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{page.name}</h2>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">{page.description}</p>
              </a>
              <a href={getComparisonContactHref(page.slug)} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                Discuss this comparison
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">What To Confirm</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Use comparison pages to remove the biggest shortlist risk first</h2>
            <ul class="space-y-3 text-sm leading-relaxed text-gray-700">
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Start here when blog research is no longer enough and the last open question is which of two realistic routes belongs in the sample plan.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Use the linked products, workflow pages and guides to pressure-test the choice against the real application instead of treating it like a theory-only decision.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Move into inquiry once the comparison has narrowed the shortlist enough to talk about compatibility, samples or rollout details.</span>
              </li>
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0d7377]/15 bg-[#0d7377]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Supporting Pages</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Guides and proof pages buyers usually open before locking the choice</h2>
            <div class="space-y-3">
              {supportingCards.map((link) => (
                <article class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-white p-4 transition-colors hover:border-[#0d7377]">
                  <a href={link.href} class="block">
                    <span class="block text-sm font-semibold text-gray-800">{link.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{link.description}</span>
                  </a>
                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    <a href={link.href} class="inline-flex items-center text-sm font-semibold text-[#0d7377]">
                      {link.openLabel}
                      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                    <a href={link.contactAction.href} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                      {link.contactAction.label}
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
