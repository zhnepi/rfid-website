---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { products } from '../data/products';
import { blogPosts } from '../data/blogs';

const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/thank-you`;

// W10: serialize a compact dataset so client-side JS can render 3 products + 3 blogs
// matching the ?intent=, ?product=, ?category= params from the inquiry submission.
const recProducts = products.map((p) => ({
  slug: p.slug,
  name: p.name,
  category: p.category,
  image: p.images?.[0] || '/images/placeholder.webp',
}));
const recBlogs = blogPosts.map((b) => ({
  slug: b.slug,
  title: b.title,
  category: b.category,
  image: (b as any).image || (b as any).featuredImage || '/images/placeholder.webp',
  date: (b as any).date || '',
}));

const categoryBySlug: Record<string, string> = {
  'rfid-cards': 'RFID Cards',
  'rfid-tags': 'RFID Tags',
  'rfid-labels': 'RFID Labels',
  'rfid-wristbands': 'RFID Wristbands',
  'rfid-keyfob': 'RFID Keyfob',
  'rfid-readers': 'RFID Readers',
  'rfid-rings': 'RFID Rings',
};

const intentContent = {
  samples: {
    title: 'Your sample inquiry is in the queue',
    copy: 'The team now has the project details needed to narrow sample options, product fit, and the next approval step.',
  },
  oem: {
    title: 'Your customization inquiry has been received',
    copy: 'The team will review the product format, chip direction, artwork or encoding details, and the best next step for a custom quote.',
  },
  compatibility: {
    title: 'Your compatibility request is on its way to the team',
    copy: 'The next response should focus on reader, lock, chip, or credential matching so you can move faster into the right shortlist.',
  },
  'repeat-order': {
    title: 'Your repeat-order request has been recorded',
    copy: 'The team can now review the approved SKU, quantity target, and any changes needed before the next supply cycle.',
  },
  general: {
    title: 'Thanks, your inquiry has been received',
    copy: 'The team now has your project details and can continue the conversation through the contact method you selected.',
  },
} satisfies Record<string, { title: string; copy: string }>;
---

<Layout
  title="Thank You - RFIDAK Inquiry Received"
  description="Thanks for contacting RFIDAK. Your RFID inquiry has been received and the team will review the details you submitted."
  canonicalURL={canonicalURL}
  noindex={true}
>
  <Header />
  <main>
    <section class="brand-hero-band py-20 md:py-24">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl text-center">
          <p class="eyebrow-label mb-3 text-[#0d7377]">Inquiry Received</p>
          <h1 id="thankYouTitle" class="title-balance text-4xl font-bold text-white md:text-5xl lg:text-6xl">
            Thanks, your inquiry has been received
          </h1>
          <p id="thankYouCopy" class="card-copy mx-auto mt-5 max-w-2xl text-base text-white/74 md:text-lg">
            The team now has your message and can continue with the most relevant next step for your RFID project.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <span id="submissionReference" class="brand-chip-dark hidden"></span>
            <span class="brand-chip-dark">Typical reply target: 2 to 4 business hours</span>
            <span class="brand-chip-dark">Factory-direct support for samples and production</span>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="brand-panel p-7 md:p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">What Happens Next</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Your next reply should be more specific than a generic sales follow-up</h2>
            <div class="mt-6 space-y-4 text-sm leading-relaxed text-gray-600">
              <p>The team will review the product direction, quantity signal, and technical details you submitted before replying.</p>
              <p>If samples or compatibility checks are needed, the follow-up should move toward the most relevant shortlist instead of repeating basic questions.</p>
              <p>If the request is urgent, you can continue immediately on WhatsApp and reference the same project details.</p>
            </div>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/products" class="cta-primary">Browse Products</a>
              <a href="/compare" class="cta-secondary normal-case tracking-normal">Open Comparison Hub</a>
            </div>
          </div>

          <aside class="brand-panel-soft p-7 md:p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Useful While You Wait</p>
            <h2 class="title-balance text-2xl font-semibold text-gray-900">Keep the buying conversation moving</h2>
            <div class="mt-6 space-y-3">
              <a href="/sample-policy" class="brand-panel brand-panel-link block p-4">
                <span class="block text-sm font-semibold text-gray-900">Review sample policy</span>
                <span class="mt-1 block text-sm text-gray-500">Useful when the next step is sample matching or pilot approval.</span>
              </a>
              <a href="/quality-control" class="brand-panel brand-panel-link block p-4">
                <span class="block text-sm font-semibold text-gray-900">Review quality control</span>
                <span class="mt-1 block text-sm text-gray-500">Helpful if the project is already moving from sampling toward a production decision.</span>
              </a>
              <a href="https://wa.me/8618665820632" target="_blank" rel="noopener noreferrer" class="brand-panel brand-panel-link block p-4">
                <span class="block text-sm font-semibold text-gray-900">Continue on WhatsApp</span>
                <span class="mt-1 block text-sm text-gray-500">Best for urgent follow-up, quick clarifications, or sharing sample photos and system references.</span>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- W10: Dynamic recommendations based on inquiry intent / product / category -->
    <section id="thankYouRecs" class="bg-gray-50 border-t border-gray-100 py-14 md:py-16 hidden">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-5xl">
          <div class="mb-8">
            <p class="eyebrow-label text-[#0d7377] mb-1">Recommended for your project</p>
            <h2 class="title-balance text-2xl md:text-3xl font-semibold text-gray-900">Keep the momentum — 3 products + 3 guides that match your inquiry</h2>
          </div>

          <div id="thankYouProducts" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-10"></div>

          <div class="mb-3 flex items-end justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Related reading</h3>
          </div>
          <div id="thankYouBlogs" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script define:vars={{ recProducts, recBlogs, categoryBySlug }}>
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const intent = params.get('intent') || 'general';
    const productSlug = params.get('product') || '';
    const categorySlug = params.get('category') || '';
    const targetCategory = categorySlug ? categoryBySlug[categorySlug] : '';

    // Product selection: prefer same category as submitted product/category; exclude the exact product
    let productMatches = recProducts.filter((p) => p.slug !== productSlug);
    if (targetCategory) {
      productMatches = productMatches.filter((p) => p.category === targetCategory);
    } else if (productSlug) {
      const current = recProducts.find((p) => p.slug === productSlug);
      if (current) productMatches = productMatches.filter((p) => p.category === current.category);
    }
    if (productMatches.length < 3) {
      // fallback: top-of-list products
      const extras = recProducts.filter((p) => !productMatches.find((m) => m.slug === p.slug) && p.slug !== productSlug);
      productMatches = productMatches.concat(extras);
    }
    const finalProducts = productMatches.slice(0, 3);

    // Blog selection: intent to category mapping
    const intentToBlogCategory = {
      samples: 'RFID APPLICATIONS',
      oem: 'RFID APPLICATIONS',
      compatibility: 'RFID TECHNOLOGY',
      'repeat-order': 'RFID APPLICATIONS',
      general: '',
    };
    const preferredBlogCategory = intentToBlogCategory[intent] || '';
    let blogMatches = recBlogs.slice();
    if (preferredBlogCategory) {
      const filtered = blogMatches.filter((b) => (b.category || '').toUpperCase().includes(preferredBlogCategory));
      if (filtered.length >= 3) blogMatches = filtered;
    }
    const finalBlogs = blogMatches.slice(0, 3);

    if (!finalProducts.length && !finalBlogs.length) return;

    const section = document.getElementById('thankYouRecs');
    const productsContainer = document.getElementById('thankYouProducts');
    const blogsContainer = document.getElementById('thankYouBlogs');

    if (productsContainer) {
      productsContainer.innerHTML = finalProducts.map((p) => `
        <a href="/product/${p.slug}" data-analytics="thankyou_rec_product_${p.slug}" class="brand-panel brand-panel-link block overflow-hidden group">
          <div class="aspect-square bg-gray-100 overflow-hidden">
            <img src="${p.image}" alt="${p.name}" loading="lazy" class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="p-4">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-[#0d7377] mb-1">${p.category}</p>
            <h3 class="text-sm font-semibold text-gray-900 line-clamp-2">${p.name}</h3>
          </div>
        </a>
      `).join('');
    }

    if (blogsContainer) {
      blogsContainer.innerHTML = finalBlogs.map((b) => `
        <a href="/blogs/${b.slug}" data-analytics="thankyou_rec_blog_${b.slug}" class="brand-panel brand-panel-link block p-5">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-gray-500 mb-2">${b.category || 'GUIDE'}</p>
          <h3 class="text-sm font-semibold text-gray-900 leading-snug line-clamp-3">${b.title}</h3>
          <span class="mt-3 inline-flex items-center text-xs font-medium text-[#0d7377]">Read guide →</span>
        </a>
      `).join('');
    }

    section.classList.remove('hidden');
  });
</script>

<script define:vars={{ intentContent }}>
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const intent = params.get('intent') || 'general';
    const submission = params.get('submission') || '';
    const content = intentContent[intent] || intentContent.general;
    const titleEl = document.getElementById('thankYouTitle');
    const copyEl = document.getElementById('thankYouCopy');
    const referenceEl = document.getElementById('submissionReference');
    const analyticsWindow = window as Window & {
      rfidakTrack?: (name: string, properties?: Record<string, unknown>) => void;
      dataLayer?: Array<Record<string, unknown>>;
    };

    if (titleEl) {
      titleEl.textContent = content.title;
    }

    if (copyEl) {
      copyEl.textContent = content.copy;
    }

    if (referenceEl && submission) {
      referenceEl.textContent = `Reference: ${submission}`;
      referenceEl.classList.remove('hidden');
    }

    if (analyticsWindow.rfidakTrack) {
      analyticsWindow.rfidakTrack('inquiry_thank_you_view', {
        inquiry_intent: intent,
        submission_id: submission || 'unknown',
      });
      return;
    }

    analyticsWindow.dataLayer = analyticsWindow.dataLayer || [];
    analyticsWindow.dataLayer.push({
      event: 'inquiry_thank_you_view',
      inquiry_intent: intent,
      submission_id: submission || 'unknown',
      page_path: window.location.pathname,
      event_time: new Date().toISOString(),
    });
  });
</script>
