  {
    title: 'DPP triple-layer: UHF + NFC + QR',
    primary: 'UHF inside label for logistics; NTAG424 DNA for consumer tap; QR as universal fallback',
    why: 'One garment tag carries all three data paths. UHF scans at warehouse portal; NFC drives consumer auth; QR works on any phone without NFC or in low-light scenarios.',
    examples: 'Luxury apparel, premium FMCG brands preparing for EU DPP 2027',
  },
];

const alternatives = [
  { name: 'QR code', when: 'Need universal camera access, zero tag cost, no authentication requirement', limit: 'No anti-clone protection; line-of-sight only; no bulk read' },
  { name: 'WiFi RTT (802.11mc)', when: 'Indoor positioning where BLE beacons too costly; using existing WiFi access points', limit: 'AP must support RTT (many don\u2019t); accuracy 1-2 m' },
  { name: 'UWB (Ultra-Wideband)', when: 'Sub-meter location accuracy in industrial or healthcare', limit: 'Tag cost $30-150; specialized reader infrastructure' },
  { name: 'LoRaWAN', when: 'Asset tracking at campus or city scale with multi-km range', limit: 'Higher tag cost ($10-30); private or public LoRaWAN gateway required' },
  { name: 'Cellular (NB-IoT, LTE-M)', when: 'Cross-country asset tracking with no fixed infrastructure', limit: 'Carrier service fees; device cost $20-80; battery life 1-3 years' },
