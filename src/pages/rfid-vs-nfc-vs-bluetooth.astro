  { value: '\u2264 100 m', label: 'BLE 5.x long-range read (Bluetooth Core Spec)' },
];

const rfidOverview = [
  { axis: 'Power', value: 'Passive (no battery) or active' },
  { axis: 'Range', value: 'LF 10 cm \u00b7 HF 4 cm-1 m \u00b7 UHF 1-12 m' },
  { axis: 'Throughput', value: 'UHF 700+ tags/sec; HF one-at-a-time' },
  { axis: 'Unit cost', value: '$0.04-4.50 (format and security-tier dependent)' },
  { axis: 'Reader ecosystem', value: 'Specialized RFID readers required ($50-$15,000)' },
  { axis: 'Best for', value: 'Item-level inventory, supply chain, access control, credentials' },
];

const nfcOverview = [
  { axis: 'Power', value: 'Passive (tag); active (phone reader)' },
  { axis: 'Range', value: '4 cm operating, up to 10 cm practical' },
  { axis: 'Throughput', value: 'One tap at a time (intentional interaction)' },
  { axis: 'Unit cost', value: '$0.05-$1.10 (NTAG213 to NTAG424 DNA)' },
  { axis: 'Reader ecosystem', value: '2.4 B smartphones act as free readers' },
  { axis: 'Best for', value: 'Consumer interaction, payments, access, DPP, anti-counterfeit' },
];

const bleOverview = [
  { axis: 'Power', value: 'Active \u2014 battery on tag/beacon (3-5 year life)' },
  { axis: 'Range', value: '10-100 m (BLE 4.x vs 5.x / coded PHY)' },
  { axis: 'Throughput', value: 'Continuous broadcast; multi-device mesh' },
  { axis: 'Unit cost', value: '$3-$15 per beacon; $15-$100 per sensor-tag' },
  { axis: 'Reader ecosystem', value: 'Every smartphone, tablet, BLE gateway; no dedicated hardware needed' },
  { axis: 'Best for', value: 'Real-time location, asset tracking, sensor data, proximity notifications' },
];

const comparisonMatrix = [
  ['Dimension', 'RFID (passive UHF)', 'NFC (passive HF)', 'BLE (active)'],
  ['Battery required?', 'No', 'No', 'Yes (3-5 yr life)'],
  ['Typical read range', '1 \u2013 12 m', '\u2264 10 cm', '10 \u2013 100 m'],
  ['Typical tag cost', '$0.04 \u2013 0.10', '$0.05 \u2013 0.85', '$3 \u2013 15+'],
  ['Throughput', '700+ tags/sec', 'One tap at a time', 'Continuous broadcast'],
  ['Smartphone compatible', 'No (without reader)', 'Yes (all modern phones)', 'Yes (all modern phones + BLE stack)'],
  ['Sensor support', '(rare, BAP only)', 'No', 'Yes (temp, motion, humidity, etc.)'],
  ['Reader infrastructure cost', '$1,500 \u2013 15,000 per zone', 'Phone (free)', 'BLE gateway $100 \u2013 500 / zone'],
  ['Typical ISO / standard', 'ISO 18000-63 (Gen2v2)', 'ISO 14443, NFC Forum', 'Bluetooth Core 5.x'],
  ['Strongest use case', 'Item-level inventory, supply chain', 'Consumer tap, anti-counterfeit, DPP', 'Real-time location, asset tracking with sensors'],
  ['Weakest use case', 'Consumer mobile interaction', 'Bulk inventory', 'Low-cost high-volume item tagging'],
];

const decisionSteps = [
  { q: 'Do you need to read tags in bulk (more than 10 at a time, portal, conveyor)?', yes: 'UHF RFID', no: 'continue' },
  { q: 'Must the identifier be battery-free and cheaper than $1 per unit?', yes: 'RFID (LF / HF / UHF)', no: 'continue' },
  { q: 'Do end-users tap a smartphone to interact with the item?', yes: 'NFC', no: 'continue' },
  { q: 'Do you need real-time location (where is the asset right now?) at > 10 m range?', yes: 'BLE (or UWB for sub-meter)', no: 'continue' },
  { q: 'Do you need sensor data (temperature, motion, humidity)?', yes: 'BLE with sensor beacon', no: 'Re-evaluate \u2014 you may need a different technology entirely' },
];

const hybridScenarios = [
  {
    title: 'Retail item-level UHF + shopper BLE analytics',
    primary: 'UHF RFID on every item; BLE beacons in aisles',
    why: 'UHF gives 99% inventory accuracy at $0.06 / item. BLE beacons track customer dwell time per section without tagging each shopper.',
    examples: 'Apparel retail, supermarkets with loyalty-app users',
  },
  {
    title: 'Hospital asset BLE + access control HF',
    primary: 'BLE tags on portable medical equipment; HF DESFire on staff / patient wristbands',
    why: 'BLE covers the "where is the infusion pump?" use case; HF DESFire secures room / medication access.',
    examples: 'US hospital networks (5,000+ assets, 10,000+ staff)',
  },
  {
    title: 'Warehouse UHF portals + BLE yard tracking',
    primary: 'UHF at dock doors; BLE on trailers and yard trucks',
    why: 'UHF captures what moved through the door. BLE gives real-time position of trailers in the yard and loading dock queue.',
