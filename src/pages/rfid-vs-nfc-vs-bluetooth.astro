];

const directAnswer = "Use RFID (passive UHF or HF) for battery-free item identification, bulk read and sub-cent per-unit tag cost. Use NFC (HF subset) when smartphone tap and consumer interaction matter. Use Bluetooth Low Energy (BLE) for battery-powered asset tracking with 10-100 m range, real-time location and sensor data. The three are complementary, not substitutes \u2014 most mature deployments use two of them.";

const keyTakeaways = [
  '<strong>Technology family is a higher-level choice than frequency</strong> &mdash; decide RFID vs NFC vs BLE before asking LF / HF / UHF or chip family.',
  '<strong>RFID wins on unit cost</strong> &mdash; passive UHF tags at $0.04-0.08 / unit (IDTechEx, 2024); BLE beacons at $3-15 / unit including battery.',
  '<strong>NFC wins on consumer ubiquity</strong> &mdash; 2.4 B+ NFC-enabled smartphones (NFC Forum, 2025); zero app install for Background Tag Reading on iOS/Android.',
  '<strong>BLE wins on range plus active sensing</strong> &mdash; 10-100 m range, real-time location, temperature / humidity / motion sensor support built in.',
  '<strong>Hybrid is normal at scale</strong> &mdash; retail item-level RFID + BLE shopper analytics, or HF access + UHF inventory in the same facility.',
];

const industryStats = [
  { value: '42 B', label: 'UHF RFID tags shipped in 2024 (RAIN Alliance)' },
  { value: '2.4 B', label: 'NFC-enabled smartphones (NFC Forum, 2025)' },
  { value: '5 B', label: 'BLE-enabled devices shipped in 2024 (Bluetooth SIG)' },
