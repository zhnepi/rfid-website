function getGuideCardEyebrow(href: string) {
  if (href.startsWith('/compare/')) return 'Head-to-head';
  if (href.startsWith('/category/')) return 'Category path';
  if (href.startsWith('/rfid-technology')) return 'Tech basics';
  if (href.startsWith('/contact')) return 'Inquiry path';

  return 'Buyer guide';
}

function getGuideCardCta(href: string) {
  if (href.startsWith('/compare/')) return 'Open comparison';
  if (href.startsWith('/category/')) return 'Open category';
  if (href.startsWith('/contact')) return 'Start inquiry';

  return 'Open guide';
}

function getRelatedProductCardPrompt(relatedProduct: typeof product) {
  if (relatedProduct.category === 'RFID Cards') {
    return 'Compare this option if you may need a different card body, chip path, or print finish.';
  }

  if (relatedProduct.category === 'RFID Tags') {
    return 'Compare this option if enclosure, mounting, or environment fit may change the better tag choice.';
  }

  if (relatedProduct.category === 'RFID Labels') {
    return 'Compare this option if label stock, read mode, or application surface may change the shortlist.';
  }

  if (relatedProduct.category === 'RFID Readers') {
    return 'Compare this option if interface, deployment style, or encoding support may change the better hardware fit.';
  }

  if (relatedProduct.category === 'RFID Keyfob') {
    return 'Compare this option if shell style, durability, or system fit may point to a different credential.';
  }

  if (relatedProduct.category === 'RFID Wristbands') {
    return 'Compare this option if wear time, venue flow, or branding needs may favor another band format.';
  }

  return 'Compare this option if the current product is close but not quite the right format yet.';
}

function getProductGuideLinks() {
  const slug = product.slug.toLowerCase();

  if (product.category === 'RFID Cards') {
    return [
      { href: '/blogs/how-to-order-rfid-cards-from-china', label: 'How to order custom RFID cards', description: 'A sourcing guide covering samples, MOQ, QC and factory communication.' },
      { href: '/blogs/hotel-key-card-rfid-guide', label: 'Hotel RFID card guide', description: 'Useful when the project involves lock compatibility, chip choice and hospitality printing.' },
      { href: '/blogs/mifare-classic-vs-desfire', label: 'Mifare Classic vs DESFire', description: 'Compare chip security and fit before finalizing a card specification.' },
    ];
  }

  if (product.category === 'RFID Tags') {
    if (slug.includes('laundry')) {
      return [
        { href: '/blogs/laundry-rfid-tags-buying-guide', label: 'Laundry RFID tag guide', description: 'Compare washable tag constructions, attachment methods and sample checkpoints.' },
        { href: '/blogs/covid-rfid-laundry', label: 'RFID in the laundry industry', description: 'Background on how RFID supports textile visibility and process control.' },
        { href: '/category/rfid-tags', label: 'More RFID tag formats', description: 'Browse industrial, washable and rugged RFID tag options.' },
      ];
    }

    if (slug.includes('metal') || slug.includes('pcb') || slug.includes('ceramic')) {
      return [
        { href: '/blogs/anti-metal-rfid-tags-guide', label: 'Anti-metal RFID tag guide', description: 'Learn how to choose on-metal constructions for tools, IT assets and equipment.' },
        { href: '/blogs/rfid-labels-vs-hard-tags', label: 'Labels vs hard tags', description: 'Helpful when comparing printable on-metal labels with harder-wearing tag formats.' },
        { href: '/category/rfid-tags', label: 'Industrial RFID tags', description: 'Compare more rugged tags for harsh and reusable environments.' },
      ];
    }

    return [
      { href: '/blogs/rfid-types', label: 'RFID tag types guide', description: 'A high-level primer on common RFID tag categories and use cases.' },
      { href: '/blogs/rfid-supply-chain', label: 'RFID for supply chain', description: 'See how tags support logistics, warehouse and inventory visibility.' },
      { href: '/blogs/anti-metal-rfid-tags-guide', label: 'Anti-metal tag selection', description: 'Useful when the application involves metal assets or difficult mounting surfaces.' },
    ];
  }

  if (product.category === 'RFID Labels') {
    return [
      { href: '/blogs/rfid-labels-vs-hard-tags', label: 'RFID labels vs hard tags', description: 'Compare thin printable label formats with reusable tags before sampling.' },
      { href: '/blogs/nfc-technology', label: 'NFC technology guide', description: 'Helpful when labels need to be read by smartphones or support tap experiences.' },
      { href: '/blogs/rfid-vs-barcode', label: 'RFID vs barcode', description: 'Useful when planning a packaging or inventory upgrade.' },
    ];
  }

  if (product.category === 'RFID Readers') {
    return [
      { href: '/blogs/how-to-choose-rfid-readers-and-writers', label: 'Reader and writer guide', description: 'Compare desktop, USB, fixed and embedded hardware for real workflows.' },
      { href: '/blogs/rfid-frequency-guide', label: 'RFID frequency guide', description: 'Review LF, HF/NFC and UHF before selecting compatible reader hardware.' },
      { href: '/rfid-technology', label: 'RFID technology reference', description: 'Get a broader overview of standards, protocols and practical selection logic.' },
    ];
  }

  if (product.category === 'RFID Keyfob') {
    return [
      { href: '/blogs/rfid-keyfob-buying-guide', label: 'RFID keyfob buying guide', description: 'Match shell style and chip type to the installed reader before ordering.' },
      { href: '/blogs/rfid-frequency-guide', label: 'Frequency selection guide', description: 'Useful when confirming LF versus HF compatibility in access-control systems.' },
      { href: '/category/rfid-keyfob', label: 'RFID keyfob category page', description: 'Browse keyfob formats and buying guidance in one place.' },
    ];
  }

  if (product.category === 'RFID Wristbands') {
    return [
      { href: '/blogs/rfid-wristbands-for-events-and-hotels', label: 'RFID wristband guide', description: 'Compare silicone, fabric and disposable wristbands for guest-facing projects.' },
      { href: '/blogs/nfc-tags-business-use-cases', label: 'NFC business use cases', description: 'See how tap workflows support hospitality, events and branded experiences.' },
      { href: '/category/rfid-wristbands', label: 'RFID wristband category page', description: 'Explore more styles for resorts, clubs, festivals and water attractions.' },
    ];
  }

  return [
    { href: '/rfid-technology', label: 'RFID technology basics', description: 'Review standards, frequencies and product-selection fundamentals.' },
    { href: '/blogs', label: 'RFID buying guides', description: 'Browse broader sourcing, technology and application content.' },
    { href: getProductContactHref(product), label: 'Request project guidance', description: 'Send your application and we can help narrow the right sample plan.' },
  ];
}

const productGuideLinks = getProductGuideLinks();
const productComparisonLinks = getProductComparisonLinks(product, 3);
const productContactHref = getProductContactHref(product);
const productWhatsAppHref = getProductWhatsAppHref(product);
const productInquiryLabel = getContextualInquiryLabel(getProductInquiryIntent(product), 'product');
const productDecisionCards = getProductDecisionCards();
const specsSectionContent = getSpecsSectionContent();
const featuresSectionContent = getFeaturesSectionContent();
const applicationsSectionContent = getApplicationsSectionContent();
const proofSectionContent = getProofSectionContent();
const faqSectionContent = getFaqSectionContent();
const buyerGuidesSectionContent = getBuyerGuidesSectionContent();
const relatedProductsSectionContent = getRelatedProductsSectionContent();

// BreadcrumbList JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.proudtek.com/" },
    { "@type": "ListItem", "position": 2, "name": "RFID Products", "item": "https://www.proudtek.com/rfid" },
    { "@type": "ListItem", "position": 3, "name": product.category, "item": `https://www.proudtek.com${categoryHref}` },
    { "@type": "ListItem", "position": 4, "name": product.name, "item": `https://www.proudtek.com/product/${product.slug}` }
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": productFaqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const pageTitle = `${product.name} | ${product.category} - ProudTek RFID Manufacturer`;
const pageDescription = truncateText(
  `${product.name}. ${productBuyerSummary} Request samples, customization details and project guidance from ProudTek.`,
  160
);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={`${product.name}, ${product.category}, RFID manufacturer, custom RFID, ProudTek, China RFID factory`}
  ogImage={product.images[0] || '/images/hero/smart-card-banner.webp'}
  ogType="product"
  jsonLd={[productJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Header />
  <main>
    <!-- Breadcrumb -->
    <section class="bg-gray-100 py-4">
      <div class="container mx-auto px-4">
        <Breadcrumb items={[
          { name: 'Home', href: '/' },
          { name: 'RFID Products', href: '/rfid' },
          { name: product.category, href: categoryHref },
          { name: product.name },
        ]} />
      </div>
    </section>

    <!-- Product Detail -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Product Images -->
          <div class="space-y-4">
            <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden border border-gray-200">
              <img
                id="main-image"
                src={product.images[0] || '/images/placeholder.webp'}
                alt={`${product.name} - ${product.category} manufactured by ProudTek, ${specEntries.find(e => e.key === 'Frequency')?.value || 'multi-frequency'} RFID product from Shenzhen China`}
                class="w-full h-full object-contain"
                width="600"
                height="600"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            {product.images.length > 1 && (
              <div class="grid grid-cols-4 gap-2">
                {product.images.map((img: string, index: number) => (
                  <button
                    class="aspect-square bg-gray-100 rounded border border-gray-200 overflow-hidden hover:border-[#0d7377] transition-colors thumbnail-btn"
                    data-image={img}
                    aria-label={`View ${product.name} image ${index + 1}`}
                  >
                    <img src={img} alt={`${product.name} view ${index + 1}`} class="w-full h-full object-contain" loading="lazy" decoding="async" fetchpriority="low" width="150" height="150" />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Product Info -->
          <div class="space-y-6">
            <div>
              <span class="eyebrow-label text-[#0d7377]">{product.category}</span>
              <h1 class="title-balance text-3xl font-bold text-gray-800 mt-2">{product.name}</h1>
              <p class="mt-4 text-lg font-semibold leading-relaxed text-gray-900">{productBuyerQuestion}</p>
            </div>

            <div class="prose prose-gray max-w-none product-description" data-speakable>
              <p class="card-copy text-gray-600">{productBuyerIntro}</p>
            </div>

             <div class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-[#0d7377]/5 p-5">
              <p class="eyebrow-label text-[#0d7377] mb-2">What buyers usually confirm first</p>
              <div class="grid gap-4 sm:grid-cols-3">
                {productDecisionCards.map((card) => (
                  <div class="rounded-2xl border border-[#0d7377]/15 bg-white p-4">
                    <p class="eyebrow-label text-[#0d7377] mb-2">{card.label}</p>
                    <h2 class="title-balance text-base font-semibold text-gray-800">{card.title}</h2>
                    <p class="card-copy mt-2 text-sm text-gray-600">{card.description}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Contact Buttons -->
            <div class="pt-4 flex flex-wrap gap-4">
              <a
                href={productContactHref}
                class="inline-block bg-[#0d7377] text-white px-8 py-3 rounded-lg font-medium hover:bg-[#0a5c5f] transition-colors"
              >
                {productInquiryLabel}
              </a>
              <a
                href={productWhatsAppHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block border-2 border-[#25D366] text-[#25D366] px-8 py-3 rounded-lg font-medium hover:bg-[#25D366] hover:text-white transition-colors"
              >
                WhatsApp for a quick check
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Specifications -->
    {specEntries.length > 0 && (
      <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto" data-speakable="product-specifications">
            <div class="max-w-3xl mb-6">
              <p class="eyebrow-label text-[#0d7377] mb-2">{specsSectionContent.eyebrow}</p>
              <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{specsSectionContent.title}</h2>
              <p class="card-copy text-gray-600">{specsSectionContent.description}</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
              <table class="w-full text-sm">
                <tbody>
                  {specEntries.map(({ key, value }, index) => (
                    <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50/70'}>
                      <td class="px-6 py-3.5 font-medium text-gray-800 w-1/3 border-b border-gray-100">{key}</td>
                      <td class="px-6 py-3.5 text-gray-600 border-b border-gray-100">{value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Key Features -->
    {productFeatures.length > 0 && (
      <section class="py-12 bg-white">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="max-w-3xl mb-6">
              <p class="eyebrow-label text-[#0d7377] mb-2">{featuresSectionContent.eyebrow}</p>
              <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{featuresSectionContent.title}</h2>
              <p class="card-copy text-gray-600">{featuresSectionContent.description}</p>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              {productFeatures.map((feature: string) => (
                 <div class="copy-safe flex items-start gap-3 bg-gray-50 p-5 rounded-xl">
                  <svg class="w-5 h-5 text-[#0d7377] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-gray-700">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Applications -->
    {productApplications.length > 0 && (
      <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="max-w-3xl mb-6">
              <p class="eyebrow-label text-[#0d7377] mb-2">{applicationsSectionContent.eyebrow}</p>
              <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{applicationsSectionContent.title}</h2>
              <p class="card-copy text-gray-600">{applicationsSectionContent.description}</p>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {productApplications.map((app: string) => {
                const { title, description } = splitApplicationText(app);
                return (
                  <div class="flex items-start gap-4 bg-white p-5 rounded-xl shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 border border-gray-100">
                    <ApplicationIcon application={app} />
                    <div class="min-w-0">
                      <h3 class="copy-safe title-balance text-sm font-semibold text-gray-800">{title}</h3>
                      {description && (
                        <p class="copy-safe card-copy text-xs text-gray-500 mt-1">{description}</p>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Product Detail Sections (sub-types, variants, etc.) -->
    {productDetailSections.length > 0 && (
      <section class="py-12 bg-white">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <h2 class="text-2xl font-bold text-gray-800 mb-8">{product.name} Types</h2>
            <div class="space-y-8">
              {productDetailSections.map((section: any, index: number) => (
                <div class={`copy-safe flex flex-col md:flex-row gap-6 items-start ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
                  {section.image && (
                    <div class="w-full md:w-1/3 shrink-0">
                      <img src={section.image} alt={`${section.title} - ${product.name} detail`} class="w-full rounded-xl shadow-sm object-cover" loading="lazy" width="400" height="300" />
                    </div>
                  )}
                  <div class={section.image ? 'w-full md:w-2/3' : 'w-full'}>
                    <h3 class="title-balance text-xl font-semibold text-gray-800 mb-3 flex items-center gap-2">
                      <span class="w-8 h-8 bg-[#0d7377] text-white rounded-full flex items-center justify-center text-sm font-bold shrink-0">{index + 1}</span>
                      {section.title}
                    </h3>
                    <p class="card-copy text-gray-600">{section.content}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="py-12 bg-white border-t">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="max-w-3xl mb-6 text-center mx-auto">
            <p class="eyebrow-label text-[#0d7377] mb-2">{proofSectionContent.eyebrow}</p>
            <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{proofSectionContent.title}</h2>
            <p class="card-copy text-gray-600">{proofSectionContent.description}</p>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="copy-safe text-center p-4">
              <div class="text-3xl font-bold text-[#0d7377] mb-2">ISO 9001</div>
              <p class="text-sm text-gray-600">Quality-focused manufacturing and sample support for custom RFID projects.</p>
            </div>
            <div class="copy-safe text-center p-4">
              <div class="text-3xl font-bold text-[#0d7377] mb-2">15+ Years</div>
              <p class="text-sm text-gray-600">RFID manufacturing experience across cards, tags, labels, wristbands and readers.</p>
            </div>
            <div class="copy-safe text-center p-4">
              <div class="text-3xl font-bold text-[#0d7377] mb-2">Free Samples</div>
              <p class="text-sm text-gray-600">Test product compatibility before bulk purchasing and customization decisions.</p>
            </div>
          </div>
          <div class="mt-6 text-center">
            <p class="text-gray-600 text-sm">
              <a href="/rfid-technology" class="text-[#0d7377] hover:underline">Learn more about RFID technology</a> |
              <a href={categoryHref} class="text-[#0d7377] hover:underline">Browse all {product.category}</a> |
              <a href="/blogs" class="text-[#0d7377] hover:underline">Read our RFID blog</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="max-w-3xl mb-6">
            <p class="eyebrow-label text-[#0d7377] mb-2">{buyerGuidesSectionContent.eyebrow}</p>
            <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{buyerGuidesSectionContent.title}</h2>
            <p class="card-copy text-gray-600">{buyerGuidesSectionContent.description}</p>
          </div>
          <div class="grid md:grid-cols-3 gap-5">
            {productGuideLinks.map((guide) => (
              <a href={guide.href} class="copy-safe rounded-2xl border border-gray-200 bg-white p-6 hover:border-[#0d7377] hover:-translate-y-0.5 transition-all">
                <span class="eyebrow-label text-[#0d7377]">{getGuideCardEyebrow(guide.href)}</span>
                <span class="title-balance block text-base font-semibold text-gray-800">{guide.label}</span>
                <span class="card-copy block text-sm text-gray-500 mt-2">{guide.description}</span>
                <span class="mt-3 inline-flex items-center text-sm font-medium text-[#0d7377]">
                  {getGuideCardCta(guide.href)}
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    {productComparisonLinks.length > 0 && (
      <section class="py-12 bg-white border-t border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-6">
              <div>
                <p class="eyebrow-label text-[#0d7377] mb-2">Comparison Pages</p>
                <h2 class="title-balance text-2xl font-bold text-gray-800">Useful if you are still choosing between two directions</h2>
              </div>
              <p class="card-copy text-gray-600 max-w-xl">
                These head-to-head pages help buyers compare chip, frequency, material or format decisions before they lock a sample plan for this product.
              </p>
            </div>
            <div class="grid md:grid-cols-3 gap-5">
              {productComparisonLinks.map((page) => (
                <a href={`/compare/${page.slug}`} class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-6 hover:border-[#0d7377] hover:-translate-y-0.5 transition-all">
                  <span class="eyebrow-label text-[#0d7377]">{page.heroEyebrow}</span>
                  <span class="title-balance block text-base font-semibold text-gray-800 mt-3">{page.name}</span>
                  <span class="card-copy block text-sm text-gray-500 mt-2">{truncateText(page.description, 132)}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {categoryConfig && (
      <section class="py-12 bg-white border-t border-gray-100">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto grid lg:grid-cols-[1.02fr_0.98fr] gap-8 items-start">
            <div>
              <p class="eyebrow-label text-[#0d7377] mb-2">Commercial Fit</p>
              <h2 class="title-balance text-2xl font-bold text-gray-800 mb-4">How buyers usually move this product from shortlist to sample</h2>
              <p class="card-copy text-gray-600 mb-6">
                Most inquiry-ready visitors want to know whether this product matches their workflow, region and approval stage. These cues help them move faster without leaving the product page.
              </p>
              <div class="grid gap-4">
                {categoryConfig.buyerProfiles.map((profile) => (
                  <div class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-5">
                    <h3 class="title-balance text-lg font-semibold text-gray-800">{profile.title}</h3>
                    <p class="card-copy text-sm text-gray-600 mt-2">{profile.description}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="space-y-6">
              <div class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-[#0d7377]/5 p-6">
                <p class="eyebrow-label text-[#0d7377] mb-2">Quote Checklist</p>
                <h3 class="title-balance text-2xl font-semibold text-gray-800 mb-5">What to send us for a faster recommendation</h3>
                <ul class="space-y-3">
                  {categoryConfig.inquiryChecklist.map((item) => (
                    <li class="flex items-start gap-3 text-sm text-gray-600">
                      <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-6 flex flex-wrap gap-3">
                  <a href={productContactHref} class="rounded-lg bg-[#0d7377] px-5 py-3 text-sm font-semibold text-white hover:bg-[#0a5c5f] transition-colors">
                    Send project details
                  </a>
                  <a
                    href={productWhatsAppHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="rounded-lg border border-gray-200 px-5 py-3 text-sm font-semibold text-gray-700 hover:border-[#0d7377] hover:text-[#0d7377] transition-colors"
                  >
                    WhatsApp this product
                  </a>
                </div>
              </div>

              <div class="copy-safe rounded-2xl border border-gray-200 bg-white p-6">
                <p class="eyebrow-label text-[#0d7377] mb-2">Market Notes</p>
                <h3 class="title-balance text-xl font-semibold text-gray-800 mb-4">Regional conversations often tied to this category</h3>
                <div class="grid gap-3">
                  {categoryConfig.marketFocus.map((market) => (
                    <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
                      <h4 class="title-balance text-sm font-semibold text-gray-800">{market.title}</h4>
                      <p class="card-copy text-sm text-gray-600 mt-2">{market.description}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mb-8">
            <p class="eyebrow-label text-[#0d7377] mb-2">{relatedProductsSectionContent.eyebrow}</p>
            <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{relatedProductsSectionContent.title}</h2>
            <p class="card-copy text-gray-600">{relatedProductsSectionContent.description}</p>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {relatedProducts.map(related => (
              <a href={`/product/${related.slug}`} class="copy-safe group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow">
                <div class="aspect-square bg-gray-100 overflow-hidden">
                  <img
                    src={related.images[0] || '/images/placeholder.webp'}
                    alt={`${related.name} - ${related.category} by ProudTek RFID manufacturer`}
                    class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="300"
                    height="300"
                  />
                </div>
                <div class="p-4">
                  <p class="eyebrow-label text-[#0d7377] mb-2">{related.category}</p>
                  <h3 class="title-balance text-sm font-medium text-gray-800 group-hover:text-[#0d7377] transition-colors line-clamp-2">{related.name}</h3>
                  <p class="card-copy mt-2 text-xs text-gray-500">{getRelatedProductCardPrompt(related)}</p>
                  <span class="mt-3 inline-flex items-center text-sm font-medium text-[#0d7377]">
                    Compare this option
                    <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="max-w-3xl mb-6">
            <p class="eyebrow-label text-[#0d7377] mb-2">{faqSectionContent.eyebrow}</p>
            <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">{faqSectionContent.title}</h2>
            <p class="card-copy text-gray-600">{faqSectionContent.description}</p>
          </div>
          <div class="space-y-4">
            {productFaqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-gray-50 p-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0d7377] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-gray-600 leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>

<script>
  // Image gallery
  const mainImage = document.getElementById('main-image') as HTMLImageElement;
  const thumbnails = document.querySelectorAll('.thumbnail-btn');

  thumbnails.forEach(btn => {
    btn.addEventListener('click', () => {
      const newSrc = btn.getAttribute('data-image');
      if (newSrc && mainImage) {
        mainImage.src = newSrc;
      }
      thumbnails.forEach(t => t.classList.remove('border-[#0d7377]'));
      btn.classList.add('border-[#0d7377]');
    });
  });

