---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ApplicationIcon from '../../components/ApplicationIcon.astro';
import { products } from '../../data/products';
import { categoryPages } from '../../data/categoryPages';
import { splitApplicationText, truncateText } from '../../utils/content';
import { getProductComparisonLinks } from '../../utils/comparisons';
import { getContextualInquiryLabel, getProductContactHref, getProductInquiryIntent, getProductWhatsAppHref } from '../../utils/contact';
import { getProductBuyerIntro, getProductBuyerQuestion, getProductBuyerSummary } from '../../utils/productCopy';
import {
  getProductApplications,
  getProductDetailSections,
  getProductFeatureList,
  getProductSpecificationEntries,
} from '../../utils/productData';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const relatedProducts = products
  .filter(p => p.category === product.category && p.slug !== product.slug)
  .slice(0, 4);

const specEntries = getProductSpecificationEntries(product);
const productFeatures = getProductFeatureList(product);
const productApplications = getProductApplications(product);
const productDetailSections = getProductDetailSections(product);

const productFaqs = [
  {
    question: `Can ${product.name} be customized for my project?`,
    answer: `Yes. ProudTek can usually customize ${product.name} with suitable chip options, branding, numbering, encoding or packaging support depending on the exact product format and order plan.`,
  },
  {
    question: `How do I confirm compatibility before ordering ${product.name}?`,
    answer: `The safest approach is to test a sample with your real reader, surface material and workflow. Share your chip requirement or current system details and we can suggest a suitable sample plan.`,
  },
  {
    question: `Can ProudTek provide samples and production support for ${product.name}?`,
    answer: `Yes. We support sample requests, bulk production and export-oriented quoting for ${product.name}. Send your quantity, customization needs and target application to get a recommendation.`,
  },
];

const productBuyerQuestion = getProductBuyerQuestion(product);
const productBuyerIntro = getProductBuyerIntro(product);
const productBuyerSummary = getProductBuyerSummary(product, 112);

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": productBuyerIntro,
  "image": product.images.map((img: string) => img.startsWith('http') ? img : `https://www.proudtek.com${img}`),
  "brand": { "@type": "Brand", "name": "ProudTek" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Shenzhen Proud Tek Co., LTD",
    "url": "https://www.proudtek.com",
    "foundingDate": "2008"
  },
  "category": product.category,
  "url": `https://www.proudtek.com/product/${product.slug}`,
  "sku": product.slug,
  "mpn": product.slug,
  "offers": {
    "@type": "Offer",
    "url": `https://www.proudtek.com/product/${product.slug}`,
    "priceCurrency": "USD",
    "price": "0",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "price": "0",
      "description": "Contact ProudTek for project-based pricing. MOQ and unit cost depend on chip, customization, and order volume."
    },
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "ProudTek",
      "url": "https://www.proudtek.com"
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "001"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 15, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 10, "unitCode": "DAY" }
      }
    }
  },
  "additionalProperty": specEntries.slice(0, 10).map(({ key, value }) => ({
    "@type": "PropertyValue",
    "name": key,
    "value": value
  })),
  "subjectOf": {
    "@type": "WebPage",
    "url": `https://www.proudtek.com/product/${product.slug}`,
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [
        "[data-speakable]",
        "[data-speakable='product-specifications']"
      ]
    }
  }
};

// Category link for breadcrumb
const categorySlugMap: Record<string, string> = {
  'RFID Cards': '/category/rfid-cards',
  'RFID Tags': '/category/rfid-tags',
  'RFID Labels': '/category/rfid-labels',
  'RFID Wristbands': '/category/rfid-wristbands',
  'RFID Keyfob': '/category/rfid-keyfob',
  'RFID Readers': '/category/rfid-readers',
};
const categoryHref = categorySlugMap[product.category] || '/rfid';
const categoryConfigKeyMap: Record<string, string> = {
  'RFID Cards': 'rfid-cards',
  'RFID Tags': 'rfid-tags',
  'RFID Labels': 'rfid-labels',
  'RFID Wristbands': 'rfid-wristbands',
  'RFID Keyfob': 'rfid-keyfob',
  'RFID Readers': 'rfid-readers',
};
const categoryConfig = categoryPages[categoryConfigKeyMap[product.category]];

function getProductDecisionCards() {
  if (product.category === 'RFID Cards') {
    return [
      {
        label: 'System Match',
        title: 'Will it work with the installed reader or lock?',
        description: 'Start from protocol and chip family, then confirm whether you need blank, printed, or pre-encoded supply.',
      },
      {
        label: 'Card Build',
        title: 'PVC, paper, wood, clamshell, or inlay-only?',
        description: 'Choose the card body around durability, branding, and whether you are embedding the inlay into your own format.',
      },
      {
        label: 'Approval Step',
        title: 'Do you need sample matching before a bulk order?',
        description: 'Most buyers validate reader behavior, print finish, and numbering logic before they lock a production run.',
      },
    ];
  }

  if (product.category === 'RFID Tags') {
    return [
      {
        label: 'Surface Match',
        title: 'Will it sit on metal, textile, wood, plastic, or rubber?',
        description: 'The mounting surface usually decides tag construction faster than chip selection does.',
      },
      {
        label: 'Environment',
        title: 'Does it need to survive washing, heat, UV, or rough handling?',
        description: 'Laundry, anti-metal, tire, and rugged asset workflows all need different enclosures and materials.',
      },
      {
        label: 'Installation',
        title: 'Adhesive, screw, sew-on, nail-in, or loop install?',
        description: 'Attachment method changes both field speed and real-world read consistency, so it should be confirmed early.',
      },
    ];
  }

  if (product.category === 'RFID Labels') {
    return [
      {
        label: 'Read Mode',
        title: 'Is this for NFC phone tap or UHF inventory reading?',
        description: 'That one choice usually narrows frequency, inlay type, and read behavior right away.',
      },
      {
        label: 'Print Flow',
        title: 'Will the label run through your printer or packaging line?',
        description: 'Roll direction, label stock, adhesive, and visible print all matter when labels are applied at scale.',
      },
      {
        label: 'Packaging Risk',
        title: 'Do you need tamper evidence, thin stock, or metal-safe construction?',
        description: 'Authentication, retail, and smart packaging programs often need more than a basic sticker format.',
      },
    ];
  }

  if (product.category === 'RFID Readers') {
    return [
      {
        label: 'Protocol',
        title: 'Which chip, frequency, and standard must the reader support?',
        description: 'Compatibility with the credential comes first, especially for access, enrollment, and encoding workflows.',
      },
      {
        label: 'Form Factor',
        title: 'Desktop device, reader-writer, fixed reader, or OEM module?',
        description: 'Choose the hardware style around the operator workflow, not only the protocol.',
      },
      {
        label: 'Integration',
        title: 'What operating system, SDK, or interface does your team expect?',
        description: 'Reader projects move faster when interface expectations are confirmed before sampling.',
      },
    ];
  }

  if (product.category === 'RFID Keyfob') {
    return [
      {
        label: 'Reader Match',
        title: 'Will it match the access system already in the field?',
        description: 'Most keyfob projects start by checking reader frequency and installed credential compatibility.',
      },
      {
        label: 'Shell Choice',
        title: 'ABS, epoxy, or a more premium shell style?',
        description: 'Shell material affects durability, branding, and how the credential feels in everyday use.',
      },
      {
        label: 'Supply Plan',
        title: 'Need numbering, encoding, or dependable repeat-order supply?',
        description: 'Replacement and rollout programs often care as much about consistency as the first sample batch.',
      },
    ];
  }

  if (product.category === 'RFID Wristbands') {
    return [
      {
        label: 'Wear Model',
        title: 'Single event, resort reuse, or long daily wear?',
        description: 'Program length usually decides whether silicone, fabric, or disposable formats make more sense.',
      },
      {
        label: 'Workflow',
        title: 'Access only, locker control, guest ID, or payment too?',
        description: 'The more jobs the wristband handles, the more important chip selection and user comfort become.',
      },
      {
        label: 'Guest Experience',
        title: 'Does it need waterproof comfort and strong branding?',
        description: 'Venues often balance tap speed, wearability, and visible branding before they shortlist samples.',
      },
    ];
  }

  return [
    {
      label: 'Workflow Fit',
      title: 'What job does this product need to do first?',
      description: 'Use the real environment and operator workflow to decide whether this format belongs on the shortlist.',
    },
    {
      label: 'Compatibility',
      title: 'What must it match before you can approve samples?',
      description: 'Reader protocol, printer flow, installation method, or enclosure fit usually matter before bulk buying.',
    },
    {
      label: 'Rollout',
      title: 'Do you need pilot testing, OEM changes, or repeat supply?',
      description: 'Knowing the buying stage early helps narrow the right sample and production path.',
    },
  ];
}

function getSpecsSectionContent() {
  if (product.category === 'RFID Cards') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm in the card spec sheet',
      description: 'Protocol, chip family, card body, print finish, and encoding plan usually need to be locked before card samples are approved.',
    };
  }

  if (product.category === 'RFID Tags') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm before you sample this tag',
      description: 'Surface material, enclosure, attachment method, and environmental limits usually matter more than a broad tag name alone.',
    };
  }

  if (product.category === 'RFID Labels') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm before label rollout',
      description: 'Frequency, label stock, printer flow, adhesive, and visible print requirements should be aligned before you lock the inlay.',
    };
  }

  if (product.category === 'RFID Readers') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm before hardware testing',
      description: 'Chip protocol, operating system, interface, and SDK expectations should all be clear before a reader sample is approved.',
    };
  }

  if (product.category === 'RFID Keyfob') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm before keyfob sampling',
      description: 'Reader compatibility, shell style, numbering, and branding choices usually decide the right keyfob build.',
    };
  }

  if (product.category === 'RFID Wristbands') {
    return {
      eyebrow: 'Spec Check',
      title: 'What to confirm before wristband approval',
      description: 'Band material, wear duration, waterproofing, chip fit, and branding details normally drive the shortlist.',
    };
  }

  return {
    eyebrow: 'Spec Check',
    title: 'What to confirm in the spec sheet',
    description: 'These specifications help buyers decide whether the product belongs on the sample shortlist before they move into deeper review.',
  };
}

function getFeaturesSectionContent() {
  if (product.category === 'RFID Cards') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why buyers keep this card format on the shortlist',
      description: 'These points usually matter when a project is balancing reader compatibility, print quality, and repeat-order consistency.',
    };
  }

  if (product.category === 'RFID Tags') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why buyers shortlist this tag format',
      description: 'These features help teams decide whether the tag suits the environment, installation method, and read expectations of the real workflow.',
    };
  }

  if (product.category === 'RFID Labels') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why this label format stays in consideration',
      description: 'Buyers usually keep label options in play when they support the right reading mode, print flow, and packaging constraints.',
    };
  }

  if (product.category === 'RFID Readers') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why this reader setup makes the shortlist',
      description: 'Hardware usually stays in consideration when it reduces integration risk and supports the exact credential workflow being planned.',
    };
  }

  if (product.category === 'RFID Keyfob') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why buyers shortlist this keyfob style',
      description: 'These points usually matter when convenience, system match, and everyday durability all matter at once.',
    };
  }

  if (product.category === 'RFID Wristbands') {
    return {
      eyebrow: 'Shortlist Logic',
      title: 'Why this wristband format stays on the list',
      description: 'Wear comfort, guest throughput, and waterproof performance usually decide whether a wristband moves into sampling.',
    };
  }

  return {
    eyebrow: 'Shortlist Logic',
    title: 'Why buyers keep this option in play',
    description: 'These product traits often decide whether the format should move from browsing into a real sample plan.',
  };
}

function getApplicationsSectionContent() {
  if (product.category === 'RFID Cards') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where teams usually deploy this card format',
      description: 'These are the workflows where buyers most often compare this card against other credential options before they request samples.',
    };
  }

  if (product.category === 'RFID Tags') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where this tag format usually works best',
      description: 'Use cases matter because the right tag depends on surface, environment, attachment, and read distance in the field.',
    };
  }

  if (product.category === 'RFID Labels') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where buyers usually deploy this label format',
      description: 'These are the packaging, inventory, and item-level workflows where a thin RFID format typically makes the most sense.',
    };
  }

  if (product.category === 'RFID Readers') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where teams usually use this reader setup',
      description: 'Deployment context helps determine whether this hardware belongs at a desk, in a kiosk, in a gate, or inside a device.',
    };
  }

  if (product.category === 'RFID Keyfob') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where buyers usually deploy this keyfob',
      description: 'These are the access and membership workflows where a compact credential often beats a full-size card.',
    };
  }

  if (product.category === 'RFID Wristbands') {
    return {
      eyebrow: 'Use Cases',
      title: 'Where operators usually deploy this wristband',
      description: 'These use cases help buyers decide whether the band suits venue traffic, guest wear time, and tap behavior.',
    };
  }

  return {
    eyebrow: 'Use Cases',
    title: 'Where this product format usually fits',
    description: 'These common deployments help buyers judge whether the product belongs in the right sample batch.',
  };
}

function getProofSectionContent() {
  return {
    eyebrow: 'Supplier Fit',
    title: `Why buyers source ${product.name} from ProudTek`,
    description: 'Once the format is right, most teams still need confidence in manufacturing control, sample support, and repeat-order reliability.',
  };
}

function getFaqSectionContent() {
  return {
    eyebrow: 'Buyer Questions',
    title: 'Questions buyers usually ask before sample approval',
    description: 'These FAQs cover the points that usually come up between a first shortlist and a real sample or quote request.',
  };
}

function getBuyerGuidesSectionContent() {
  if (product.category === 'RFID Cards') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before you approve card samples',
      description: 'Use these guides when you still need to confirm chip path, lock or reader match, and sourcing details before the sample batch is locked.',
    };
  }

  if (product.category === 'RFID Tags') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before you lock the tag shortlist',
      description: 'These guides help buyers compare environments, tag formats, and mounting logic before they commit to the first sample plan.',
    };
  }

  if (product.category === 'RFID Labels') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before label rollout planning',
      description: 'These pages help narrow print flow, reading mode, and packaging-fit questions before label samples are approved.',
    };
  }

  if (product.category === 'RFID Readers') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before reader hardware testing',
      description: 'Use these references when protocol fit, interface choice, and reader workflow still need to be validated before sampling.',
    };
  }

  if (product.category === 'RFID Keyfob') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before matching access credentials',
      description: 'These guides help teams compare shell styles, chip fit, and installed reader compatibility before they request keyfob samples.',
    };
  }

  if (product.category === 'RFID Wristbands') {
    return {
      eyebrow: 'Next Reading',
      title: 'What to read before guest credential rollout',
      description: 'These guides help compare wearable formats, venue workflows, and branding needs before wristband samples move forward.',
    };
  }

  return {
    eyebrow: 'Next Reading',
    title: 'What to read before you lock the sample path',
    description: 'These references help buyers move from broad browsing into a tighter shortlist before they send project details.',
  };
}

function getRelatedProductsSectionContent() {
  if (product.category === 'RFID Cards') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby card formats before you drop them',
      description: 'Buyers often compare body style, chip path, and print approach across a few close card options before final sample approval.',
    };
  }

  if (product.category === 'RFID Tags') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby tag formats before you narrow the shortlist',
      description: 'A similar tag can behave very differently once surface, enclosure, and installation method change, so it helps to keep close options visible.',
    };
  }

  if (product.category === 'RFID Labels') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby label formats before rollout',
      description: 'Thin labels, stickers, and specialty label builds often look similar early, but they diverge quickly once print and read mode are considered.',
    };
  }

  if (product.category === 'RFID Readers') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby reader setups before testing starts',
      description: 'Teams often keep a few hardware paths open until interface, deployment style, and credential support are all clear.',
    };
  }

  if (product.category === 'RFID Keyfob') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby credential styles before keyfob approval',
      description: 'Small changes in shell style, material, and compatibility can change which credential works best in the field.',
    };
  }

  if (product.category === 'RFID Wristbands') {
    return {
      eyebrow: 'Nearby Options',
      title: 'Compare nearby wearable formats before sample sign-off',
      description: 'Wear duration, guest comfort, and venue workflow often make another wristband style worth comparing before rollout.',
