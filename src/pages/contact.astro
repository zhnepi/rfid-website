                {evidenceLinks.map((link) => (
                  <a href={link.href} class="brand-panel brand-panel-link copy-safe block p-4">
                    <span class="block text-sm font-semibold text-gray-800">{link.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{link.description}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script define:vars={{ comparisonNameMap, solutionNameMap, marketNameMap, productNameMap, categoryNameMap, blogNameMap, evidenceNameMap, contactThemes }}>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const companyInput = document.getElementById('company') as HTMLInputElement;
    const countryInput = document.getElementById('country') as HTMLInputElement;
    const inquiryType = document.getElementById('inquiryType') as HTMLSelectElement;
    const subjectInput = document.getElementById('subject') as HTMLInputElement;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement;
    const submitButton = document.getElementById('contactSubmitButton') as HTMLButtonElement;
    const contactStatus = document.getElementById('contactStatus');
    const draftPanel = document.getElementById('draftPanel');
    const draftEmailLink = document.getElementById('draftEmailLink') as HTMLAnchorElement;
    const draftWhatsAppLink = document.getElementById('draftWhatsAppLink') as HTMLAnchorElement;
    const draftPreview = document.getElementById('draftPreview') as HTMLTextAreaElement;
    const copyInquiryButton = document.getElementById('copyInquiryButton') as HTMLButtonElement;
    const inquiryContextBanner = document.getElementById('inquiryContextBanner');
    const inquiryContextEyebrow = document.getElementById('inquiryContextEyebrow');
    const inquiryContextTitle = document.getElementById('inquiryContextTitle');
    const inquiryContextCopy = document.getElementById('inquiryContextCopy');
    const quickEmailLink = document.getElementById('quickEmailLink') as HTMLAnchorElement;
    const quickEmailLabel = document.getElementById('quickEmailLabel');
    const quickWhatsAppLink = document.getElementById('quickWhatsAppLink') as HTMLAnchorElement;
    const quickWhatsAppLabel = document.getElementById('quickWhatsAppLabel');
    const contactHeroEyebrow = document.getElementById('contactHeroEyebrow');
    const contactHeroTitle = document.getElementById('contactHeroTitle');
    const contactHeroCopy = document.getElementById('contactHeroCopy');
    const contactInfoTitle = document.getElementById('contactInfoTitle');
    const contactInfoCopy = document.getElementById('contactInfoCopy');
    const contactFormTitle = document.getElementById('contactFormTitle');
    const contactFormCopy = document.getElementById('contactFormCopy');
    const contactFormHelp = document.getElementById('contactFormHelp');
    const contactPromptEyebrow = document.getElementById('contactPromptEyebrow');
    const contactPromptTitle = document.getElementById('contactPromptTitle');
    const contactPromptCopy = document.getElementById('contactPromptCopy');
    const contactPromptList = document.getElementById('contactPromptList');
    const contactSubmitLabel = document.getElementById('contactSubmitLabel');
    const messagePromptList = document.getElementById('messagePromptList');
    const productSelect = document.getElementById('product') as HTMLSelectElement;
    const contextTypeField = document.getElementById('contextTypeField') as HTMLInputElement;
    const contextSlugField = document.getElementById('contextSlugField') as HTMLInputElement;
    const contextNameField = document.getElementById('contextNameField') as HTMLInputElement;
    const contextPageField = document.getElementById('contextPageField') as HTMLInputElement;
    const sourcePathField = document.getElementById('sourcePathField') as HTMLInputElement;
    const sourcePageTitleField = document.getElementById('sourcePageTitleField') as HTMLInputElement;
    const landingPageField = document.getElementById('landingPageField') as HTMLInputElement;
    const referrerField = document.getElementById('referrerField') as HTMLInputElement;
    const referrerHostField = document.getElementById('referrerHostField') as HTMLInputElement;
    const utmSourceField = document.getElementById('utmSourceField') as HTMLInputElement;
    const utmMediumField = document.getElementById('utmMediumField') as HTMLInputElement;
    const utmCampaignField = document.getElementById('utmCampaignField') as HTMLInputElement;
    const utmTermField = document.getElementById('utmTermField') as HTMLInputElement;
    const utmContentField = document.getElementById('utmContentField') as HTMLInputElement;
    const gclidField = document.getElementById('gclidField') as HTMLInputElement;
    const msclkidField = document.getElementById('msclkidField') as HTMLInputElement;
    const fbclidField = document.getElementById('fbclidField') as HTMLInputElement;
    const timezoneField = document.getElementById('timezoneField') as HTMLInputElement;
    const browserLanguageField = document.getElementById('browserLanguageField') as HTMLInputElement;
    const whatsappBaseUrl = 'https://wa.me/8618665820632';
    const emailBase = 'mailto:info@proudtek.com';
    const attributionStorageKey = 'proudtek-inquiry-attribution';
    let formStartedTracked = false;

    const trackEvent = (eventName: string, detail: Record<string, unknown> = {}) => {
      const analyticsWindow = window as Window & {
        proudtekTrack?: (name: string, properties?: Record<string, unknown>) => void;
        dataLayer?: Array<Record<string, unknown>>;
      };

      if (analyticsWindow.proudtekTrack) {
        analyticsWindow.proudtekTrack(eventName, detail);
        return;
      }

      analyticsWindow.dataLayer = analyticsWindow.dataLayer || [];
      analyticsWindow.dataLayer.push({
        event: eventName,
        page_path: window.location.pathname,
        event_time: new Date().toISOString(),
        ...detail,
      });
    };

    const intentPrefills: Record<string, { subject: string; message: string }> = {
      samples: {
        subject: 'RFID sample request',
        message: `Hi ProudTek,

I would like to request RFID samples.

Product type:
Chip / protocol:
Application:
Quantity goal:
Target timeline:
`,
      },
      oem: {
        subject: 'RFID OEM / customization inquiry',
        message: `Hi ProudTek,

I need support with a custom RFID project.

Product type:
Chip / protocol:
Customization details:
Artwork / numbering / encoding:
Quantity goal:
`,
      },
      compatibility: {
        subject: 'RFID compatibility check',
        message: `Hi ProudTek,

I need help checking compatibility.

Current reader / lock / system:
Current credential or chip:
Target product type:
Application:
`,
      },
      'repeat-order': {
        subject: 'RFID repeat order inquiry',
        message: `Hi ProudTek,

I would like to discuss a repeat RFID order.

Previous product / SKU:
Quantity:
Any changes from last order:
Target delivery timing:
`,
      },
      'chip-comparison': {
        subject: 'RFID chip comparison inquiry',
        message: `Hi ProudTek,

I need help narrowing an RFID chip comparison before samples or quoting.

Current system / reader:
Target card or credential:
Application:
Quantity / timeline:
`,
      },
      'frequency-comparison': {
        subject: 'RFID frequency comparison inquiry',
        message: `Hi ProudTek,

I need help comparing RFID frequency options before moving into samples.

Current reader / device:
Target use case:
Preferred form factor:
Quantity / timeline:
`,
      },
      'product-format-comparison': {
        subject: 'RFID format comparison inquiry',
        message: `Hi ProudTek,

I need help comparing two RFID product formats before requesting samples or a quote.

Current shortlist:
Application:
Surface or operating environment:
Quantity / timeline:
`,
      },
      'laundry-tag-comparison': {
        subject: 'Laundry RFID tag comparison inquiry',
        message: `Hi ProudTek,

I need help comparing laundry RFID tag formats before pilot testing.

Textile or garment type:
Wash conditions:
Attachment preference:
Quantity / timeline:
`,
      },
    };

    const intentWhatsAppMessages: Record<string, string> = {
      samples: 'Hi ProudTek, I want help narrowing the right RFID samples and next steps for my project.',
      oem: 'Hi ProudTek, I need help with RFID customization, branding or OEM planning for my project.',
      compatibility: 'Hi ProudTek, I need help checking RFID compatibility and narrowing the right product path for my project.',
      'repeat-order': 'Hi ProudTek, I need help preparing an RFID repeat order and confirming the next supply step.',
      'chip-comparison': 'Hi ProudTek, I need help comparing RFID chip options before moving into samples or a quote.',
      'frequency-comparison': 'Hi ProudTek, I need help comparing RFID frequency options before I lock the shortlist.',
      'product-format-comparison': 'Hi ProudTek, I need help comparing RFID product formats before I request samples.',
      'laundry-tag-comparison': 'Hi ProudTek, I need help comparing laundry RFID tag formats before pilot testing.',
    };

    const comparisonIntents = new Set([
      'chip-comparison',
      'frequency-comparison',
      'product-format-comparison',
      'laundry-tag-comparison',
    ]);

    const getThemeKey = (contextType: string, contextSlug: string, intentValue: string | null) => {
      const searchText = `${contextType} ${contextSlug || ''}`.toLowerCase();

      if (
        searchText.includes('dpp')
        || searchText.includes('passport')
        || searchText.includes('sunrise-2027')
        || searchText.includes('anti-counterfeit')
      ) {
        return 'identity';
      }

      if (
        searchText.includes('food')
        || searchText.includes('fresh-food')
        || searchText.includes('fsma')
      ) {
        return 'food-traceability';
      }

      if (
        searchText.includes('dscsa')
        || searchText.includes('pharma')
        || searchText.includes('medical-device')
        || searchText.includes('udi')
      ) {
        return 'regulated';
      }

      if (
        searchText.includes('baggage')
        || searchText.includes('returns')
        || searchText.includes('retail')
      ) {
        return 'operations';
      }

      if (intentValue && comparisonIntents.has(intentValue)) {
        return 'comparison';
      }

      if (intentValue === 'oem') return 'oem';
      if (intentValue === 'compatibility') return 'compatibility';
      if (intentValue === 'repeat-order') return 'repeat-order';
      if (intentValue === 'samples') return 'samples';

      return 'default';
    };

    const applyTheme = (themeKey: string) => {
      const theme = contactThemes[themeKey] || contactThemes.default;

      if (contactHeroEyebrow) contactHeroEyebrow.textContent = theme.heroEyebrow;
      if (contactHeroTitle) contactHeroTitle.textContent = theme.heroTitle;
      if (contactHeroCopy) contactHeroCopy.textContent = theme.heroCopy;
      if (contactInfoTitle) contactInfoTitle.textContent = themeKey === 'default' ? 'Contact Information' : 'Project Contact Details';
      if (contactInfoCopy) {
        contactInfoCopy.textContent = themeKey === 'default'
          ? 'Reach out to us for product quotes, custom solutions, or free sample requests. Our team typically responds within 2-4 business hours.'
          : 'Use the channels below if you want to move this project forward quickly after reviewing the form prompts and prefilled details.';
      }
      if (contactFormTitle) contactFormTitle.textContent = theme.formTitle;
      if (contactFormCopy) contactFormCopy.textContent = theme.formCopy;
      if (contactFormHelp) contactFormHelp.textContent = theme.formHelp;
      if (subjectInput) subjectInput.placeholder = theme.subjectPlaceholder;
      if (messageInput) messageInput.placeholder = theme.messagePlaceholder;
      if (contactPromptEyebrow) contactPromptEyebrow.textContent = theme.promptEyebrow;
      if (contactPromptTitle) contactPromptTitle.textContent = theme.promptTitle;
      if (contactPromptCopy) contactPromptCopy.textContent = theme.promptCopy;
      if (contactPromptList) {
        contactPromptList.innerHTML = theme.promptBullets
          .map(
            (item: string) =>
              `<span class="brand-chip">${item}</span>`
          )
          .join('');
      }
      if (messagePromptList) {
        messagePromptList.innerHTML = theme.messageFields
          .map((item: string) => `<span class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs text-gray-600">${item}</span>`)
          .join('');
      }
      if (contactSubmitLabel) contactSubmitLabel.textContent = theme.submitLabel;
      if (submitButton) submitButton.dataset.readyLabel = theme.submitLabel;
      if (quickEmailLabel) quickEmailLabel.textContent = theme.quickEmailLabel;
      if (quickWhatsAppLabel) quickWhatsAppLabel.textContent = theme.quickWhatsAppLabel;
      if (productSelect && theme.productValue && !productSelect.value) productSelect.value = theme.productValue;

      return theme;
    };

    const buildThemePrefill = (theme: typeof contactThemes.default, contextName: string, contextPage: string) => {
      const subject = contextName ? `${theme.subjectDefault}: ${contextName}` : theme.subjectDefault;
      const intro = contextName
        ? `I need help with ${contextName}.`
        : theme.formCopy;
      const lines = theme.messageFields.map((field: string) => `${field}:`).join('\n');

      return {
        subject,
        message: `Hi ProudTek,

${intro}
${contextPage ? `Reference page: ${contextPage}\n` : ''}
Please help me confirm:
${lines}
`,
      };
    };

    const getSubmitReadyLabel = () =>
      submitButton?.dataset.readyLabel
      || contactSubmitLabel?.textContent?.trim()
      || 'Send inquiry';

    const setBusyState = (isBusy: boolean) => {
      if (submitButton) {
        submitButton.disabled = isBusy;
        submitButton.setAttribute('aria-busy', String(isBusy));
      }

      if (form) {
        form.setAttribute('aria-busy', String(isBusy));
      }

      if (contactSubmitLabel) {
        contactSubmitLabel.textContent = isBusy ? 'Sending inquiry...' : getSubmitReadyLabel();
      }
    };

    const showStatus = (message: string, announceAsAlert = false) => {
      if (!contactStatus) return;

      contactStatus.textContent = message;
      contactStatus.classList.remove('hidden');
      contactStatus.setAttribute('role', announceAsAlert ? 'alert' : 'status');
    };

    const clearStatus = () => {
      if (!contactStatus) return;

      contactStatus.classList.add('hidden');
      contactStatus.textContent = '';
      contactStatus.setAttribute('role', 'status');
    };

    const hideDraftPanel = () => {
      draftPanel?.classList.add('hidden');
    };

    const setHiddenField = (field: HTMLInputElement | null, value: string) => {
      if (field) {
        field.value = value;
      }
    };

    const validationFields = [nameInput, emailInput, inquiryType, subjectInput, messageInput]
      .filter((field): field is HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement => Boolean(field));

    const normalizeMultilineText = (value: string) => value.replace(/\r\n/g, '\n').trim();
    const trimSingleLineValue = (field: HTMLInputElement | null) => {
      if (!field) return '';

      const trimmed = field.value.trim();
      field.value = trimmed;
      return trimmed;
    };

    const trimTextAreaValue = (field: HTMLTextAreaElement | null) => {
      if (!field) return '';

      const trimmed = normalizeMultilineText(field.value);
      field.value = trimmed;
      return trimmed;
    };

    const serializeFormData = (formData: FormData) => {
      const payload: Record<string, string> = {};

      formData.forEach((value, key) => {
        if (typeof value !== 'string') return;

        payload[key] = key === 'message' ? normalizeMultilineText(value) : value.trim();
      });

      return payload;
    };

    const validateField = (field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null) => {
      if (!field) return true;

      field.setCustomValidity('');

      if (field instanceof HTMLInputElement) {
        trimSingleLineValue(field);

        if (field.required && !field.value) {
          field.setCustomValidity(`Please enter ${field.labels?.[0]?.textContent?.replace('*', '').trim().toLowerCase() || 'this field'}.`);
        } else if (field === subjectInput && field.value.length < 5) {
          field.setCustomValidity('Please add a subject with at least 5 characters.');
        }
      }

      if (field instanceof HTMLTextAreaElement) {
        trimTextAreaValue(field);

        if (field.required && !field.value) {
          field.setCustomValidity('Please enter a short description of your project.');
        } else if (field.value.length < 20) {
          field.setCustomValidity('Please add a bit more detail so the team can help quickly.');
        }
      }

      if (field instanceof HTMLSelectElement && field.required && !field.value) {
        field.setCustomValidity('Please choose an inquiry type.');
      }

      return field.checkValidity();
    };

    const validateForm = () => {
      const firstInvalidField = validationFields.find((field) => !validateField(field));

      if (firstInvalidField) {
        firstInvalidField.reportValidity();
        firstInvalidField.focus();
        return false;
      }

      return form ? form.reportValidity() : false;
    };

    const buildEmailBody = (values: {
      name: string;
      email: string;
      inquiryTypeValue: string;
      preferredContact: string;
      company: string;
      country: string;
      product: string;
      quantityRange: string;
      message: string;
    }) => {
      const lines = [
        `Name: ${values.name}`,
        `Email: ${values.email}`,
        values.inquiryTypeValue ? `Inquiry Type: ${values.inquiryTypeValue}` : '',
        values.preferredContact ? `Preferred Contact: ${values.preferredContact}` : '',
        values.company ? `Company: ${values.company}` : '',
        values.country ? `Country / Region: ${values.country}` : '',
        values.product ? `Product Interest: ${values.product}` : '',
        values.quantityRange ? `Estimated Quantity: ${values.quantityRange}` : '',
        '',
        'Message:',
        values.message,
        '',
        'Source Context:',
        contextNameField?.value ? `${contextTypeField?.value || 'context'}: ${contextNameField.value}` : '',
        contextPageField?.value ? `Reference Page: ${contextPageField.value}` : '',
        sourcePathField?.value ? `Source Path: ${sourcePathField.value}` : '',
        landingPageField?.value ? `First Landing Page: ${landingPageField.value}` : '',
        referrerField?.value ? `Referrer: ${referrerField.value}` : '',
        utmSourceField?.value ? `UTM Source: ${utmSourceField.value}` : '',
        utmMediumField?.value ? `UTM Medium: ${utmMediumField.value}` : '',
        utmCampaignField?.value ? `UTM Campaign: ${utmCampaignField.value}` : '',
      ];

      return lines.filter(Boolean).join('\n');
    };

    const buildWhatsAppFallbackMessage = (subject: string, body: string) => {
      const condensedBody = body.length > 1200 ? `${body.slice(0, 1200).trim()}...` : body;
      return `Hi ProudTek, I tried to send this inquiry by email and am continuing here.\n\nSubject: ${subject}\n\n${condensedBody}`;
    };

    const syncDraftTools = (subject: string, body: string, mailtoLink: string, reveal = true) => {
      if (draftEmailLink) {
        draftEmailLink.href = mailtoLink;
      }

      if (draftWhatsAppLink) {
        draftWhatsAppLink.href = `${whatsappBaseUrl}?text=${encodeURIComponent(buildWhatsAppFallbackMessage(subject, body))}`;
      }

      if (draftPreview) {
        draftPreview.value = `To: info@proudtek.com\nSubject: ${subject}\n\n${body}`;
      }

      if (reveal) {
        draftPanel?.classList.remove('hidden');
      }
    };

    const params = new URLSearchParams(window.location.search);
    const intent = params.get('intent');
    const comparisonSlug = params.get('comparison');
    const solutionSlug = params.get('solution');
    const marketSlug = params.get('market');
    const productSlug = params.get('product');
    const categoryKey = params.get('category');
    const blogSlug = params.get('blog');
    const evidenceSlug = params.get('evidence');
    const comparisonName = comparisonSlug ? comparisonNameMap[comparisonSlug] : '';
    const solutionName = solutionSlug ? solutionNameMap[solutionSlug] : '';
    const marketName = marketSlug ? marketNameMap[marketSlug] : '';
    const productName = productSlug ? productNameMap[productSlug] : '';
    const categoryName = categoryKey ? categoryNameMap[categoryKey] : '';
    const blogName = blogSlug ? blogNameMap[blogSlug] : '';
    const evidenceName = evidenceSlug ? evidenceNameMap[evidenceSlug] : '';
    const matchedPrefill = intent ? intentPrefills[intent] : null;
    const contextType = comparisonName
      ? 'comparison'
      : solutionName
        ? 'solution'
        : marketName
          ? 'market'
          : productName
            ? 'product'
            : categoryName
              ? 'category'
              : evidenceName
                ? 'evidence'
              : blogName
                ? 'blog'
                : '';
    const contextSlug = comparisonSlug || solutionSlug || marketSlug || productSlug || categoryKey || evidenceSlug || blogSlug || '';
    const contextName = comparisonName || solutionName || marketName || productName || categoryName || evidenceName || blogName || '';
    const contextLabel = contextType === 'comparison'
      ? 'Comparison topic'
      : contextType === 'solution'
        ? 'Solution path'
        : contextType === 'market'
          ? 'Market path'
        : contextType === 'product'
          ? 'Product page'
        : contextType === 'category'
          ? 'Category page'
          : contextType === 'evidence'
            ? 'Evidence page'
              : 'Guide page';
    const contextBasePath = contextType === 'comparison'
      ? 'compare'
      : contextType === 'solution'
        ? 'solutions'
        : contextType === 'market'
          ? 'markets'
          : contextType === 'product'
            ? 'product'
            : contextType === 'category'
              ? 'category'
              : contextType === 'evidence'
                ? ''
                : 'blogs';
    const contextPage = contextType
      ? `https://www.proudtek.com/${contextBasePath ? `${contextBasePath}/` : ''}${contextSlug}`
      : '';
    const themeKey = getThemeKey(contextType, contextSlug, intent);
    const activeTheme = applyTheme(themeKey);
    const themedPrefill = buildThemePrefill(activeTheme, contextName, contextPage);

    setHiddenField(contextTypeField, contextType);
    setHiddenField(contextSlugField, contextSlug);
    setHiddenField(contextNameField, contextName);
    setHiddenField(contextPageField, contextPage);

    const getReferrerHost = (value: string) => {
      try {
        return value ? new URL(value).hostname : '';
      } catch {
        return '';
      }
    };

    const syncAttributionFields = () => {
      const currentUrl = new URL(window.location.href);
      let storedAttribution: Record<string, string> = {};

      try {
        storedAttribution = JSON.parse(window.sessionStorage.getItem(attributionStorageKey) || '{}');
      } catch {
        storedAttribution = {};
      }

      const nextAttribution = {
        landingPage: storedAttribution.landingPage || currentUrl.toString(),
        referrer: storedAttribution.referrer || document.referrer || '',
        referrerHost: storedAttribution.referrerHost || getReferrerHost(storedAttribution.referrer || document.referrer || ''),
        utmSource: currentUrl.searchParams.get('utm_source') || storedAttribution.utmSource || '',
        utmMedium: currentUrl.searchParams.get('utm_medium') || storedAttribution.utmMedium || '',
        utmCampaign: currentUrl.searchParams.get('utm_campaign') || storedAttribution.utmCampaign || '',
        utmTerm: currentUrl.searchParams.get('utm_term') || storedAttribution.utmTerm || '',
        utmContent: currentUrl.searchParams.get('utm_content') || storedAttribution.utmContent || '',
        gclid: currentUrl.searchParams.get('gclid') || storedAttribution.gclid || '',
        msclkid: currentUrl.searchParams.get('msclkid') || storedAttribution.msclkid || '',
        fbclid: currentUrl.searchParams.get('fbclid') || storedAttribution.fbclid || '',
      };

      try {
        window.sessionStorage.setItem(attributionStorageKey, JSON.stringify(nextAttribution));
      } catch {
        // Ignore storage issues in private browsing / restricted environments.
      }

      setHiddenField(sourcePathField, `${window.location.pathname}${window.location.search}`);
      setHiddenField(sourcePageTitleField, document.title);
      setHiddenField(landingPageField, nextAttribution.landingPage);
      setHiddenField(referrerField, nextAttribution.referrer);
      setHiddenField(referrerHostField, nextAttribution.referrerHost);
      setHiddenField(utmSourceField, nextAttribution.utmSource);
      setHiddenField(utmMediumField, nextAttribution.utmMedium);
      setHiddenField(utmCampaignField, nextAttribution.utmCampaign);
      setHiddenField(utmTermField, nextAttribution.utmTerm);
      setHiddenField(utmContentField, nextAttribution.utmContent);
      setHiddenField(gclidField, nextAttribution.gclid);
      setHiddenField(msclkidField, nextAttribution.msclkid);
      setHiddenField(fbclidField, nextAttribution.fbclid);
      setHiddenField(timezoneField, Intl.DateTimeFormat().resolvedOptions().timeZone || '');
      setHiddenField(browserLanguageField, navigator.language || '');
    };

    syncAttributionFields();
    trackEvent('inquiry_form_view', {
      inquiry_intent: intent || 'default',
      context_type: contextType || 'none',
      context_slug: contextSlug || 'none',
    });

    const getContextualWhatsAppMessage = () => {
      if (contextName) {
        if (contextType === 'comparison') {
          return `Hi ProudTek, I'm comparing ${contextName} and need help turning this tradeoff into the right sample, compatibility or quote path.`;
        }

        if (contextType === 'solution') {
          return `Hi ProudTek, I'm reviewing your ${contextName} solution page and need help translating this workflow into the right RFID shortlist and next step.`;
        }

        if (contextType === 'market') {
          return `Hi ProudTek, I'm reviewing your ${contextName} market page and need help with the right sample or sourcing path for this region.`;
        }

        if (contextType === 'product') {
          return `Hi ProudTek, I'm reviewing your ${contextName} product page and need help choosing the right sample, compatibility or quote path for my project.`;
        }

        if (contextType === 'category') {
          return `Hi ProudTek, I'm reviewing your ${contextName} category page and need help narrowing the right options for my project.`;
        }

        if (contextType === 'evidence') {
          return `Hi ProudTek, I'm reviewing your ${contextName} page and want to confirm supplier proof and the right next buying step.`;
        }

        return `Hi ProudTek, I'm reading your ${contextName} guide and need help applying it to my RFID project.`;
      }

      return intentWhatsAppMessages[intent || 'samples'] || intentWhatsAppMessages.samples;
    };
    const contextualPrefill = contextName
      ? {
          subject: themedPrefill.subject,
          message: themedPrefill.message,
        }
      : matchedPrefill
        ? {
            subject: themedPrefill.subject,
            message: themedPrefill.message,
          }
        : themedPrefill;

    if (contextualPrefill) {
      if (intent && inquiryType) inquiryType.value = intent;
      if (subjectInput && !subjectInput.value) subjectInput.value = contextualPrefill.subject;
      if (messageInput && !messageInput.value) messageInput.value = contextualPrefill.message;
    }

    if (quickEmailLink) {
      const emailPrefill = contextualPrefill || {
        subject: 'RFID sample request',
        message: `Hi ProudTek,

I would like to request RFID samples.

Product type:
Chip / protocol:
Application:
Quantity goal:
Target timeline:
`,
      };
      quickEmailLink.href = `${emailBase}?subject=${encodeURIComponent(emailPrefill.subject)}&body=${encodeURIComponent(emailPrefill.message)}`;
      quickEmailLink.setAttribute('aria-label', contextName ? `Email about ${contextName}` : 'Email support');
    }

    if (quickEmailLabel && contextName) {
      quickEmailLabel.textContent = activeTheme.quickEmailLabel;
    }

    if (quickWhatsAppLink) {
      quickWhatsAppLink.href = `${whatsappBaseUrl}?text=${encodeURIComponent(getContextualWhatsAppMessage())}`;
        quickWhatsAppLink.setAttribute('aria-label', contextName ? `WhatsApp about ${contextName}` : 'WhatsApp for a quick check');
    }

    if (quickWhatsAppLabel && contextName) {
      quickWhatsAppLabel.textContent = activeTheme.quickWhatsAppLabel;
    }

    if (contextName && inquiryContextBanner && inquiryContextEyebrow && inquiryContextTitle && inquiryContextCopy) {
      inquiryContextEyebrow.textContent = activeTheme.contextEyebrow;
      inquiryContextTitle.textContent = contextName;
      inquiryContextCopy.textContent = `${activeTheme.contextCopy}${contextPage ? ` Reference page: ${contextPage}.` : ''}`;
      inquiryContextBanner.classList.remove('hidden');
    }

    quickEmailLink?.addEventListener('click', () => {
      trackEvent('inquiry_quick_email_click', {
        inquiry_intent: intent || 'default',
        context_type: contextType || 'none',
      });
    });

    quickWhatsAppLink?.addEventListener('click', () => {
      trackEvent('inquiry_quick_whatsapp_click', {
        inquiry_intent: intent || 'default',
        context_type: contextType || 'none',
      });
    });

    draftEmailLink?.addEventListener('click', () => {
      trackEvent('inquiry_email_backup_click', {
        inquiry_intent: inquiryType?.value || intent || 'default',
      });
    });

    draftWhatsAppLink?.addEventListener('click', () => {
      trackEvent('inquiry_whatsapp_backup_click', {
        inquiry_intent: inquiryType?.value || intent || 'default',
      });
    });

    validationFields.forEach((field) => {
      field.addEventListener('input', () => {
        field.setCustomValidity('');

        const fieldValue = field instanceof HTMLSelectElement ? field.value : field.value.trim();
        if (!formStartedTracked && fieldValue) {
          formStartedTracked = true;
          trackEvent('inquiry_form_started', {
            inquiry_intent: inquiryType?.value || intent || 'default',
            context_type: contextType || 'none',
          });
        }
      });

      field.addEventListener('change', () => {
        field.setCustomValidity('');
      });
    });

    copyInquiryButton?.addEventListener('click', async () => {
      const previewText = draftPreview?.value?.trim();

      if (!previewText) {
        showStatus('Build the email draft first, then copy it from here.', true);
        return;
      }

      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(previewText);
          showStatus('Inquiry copied. You can paste it into email or WhatsApp.');
          return;
        }

        draftPreview.focus();
        draftPreview.select();
        const copied = document.execCommand('copy');
        showStatus(
          copied
            ? 'Inquiry copied. You can paste it into email or WhatsApp.'
            : 'Select the draft preview and copy it manually.',
          !copied
        );
      } catch {
        showStatus('Copy did not complete automatically. Select the draft preview and copy it manually.', true);
      }
    });

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        syncAttributionFields();
        hideDraftPanel();
        clearStatus();

        if (!validateForm()) {
          trackEvent('inquiry_submit_invalid', {
            inquiry_intent: inquiryType?.value || intent || 'default',
            context_type: contextType || 'none',
          });
          showStatus('Please review the required fields and add enough detail for the team to respond accurately.', true);
          return;
        }

        const formData = new FormData(form);
        const name = trimSingleLineValue(nameInput);
        const email = trimSingleLineValue(emailInput);
        const inquiryTypeValue = (formData.get('inquiryType') as string || '').trim();
        const preferredContact = (formData.get('preferredContact') as string || '').trim();
        const company = trimSingleLineValue(companyInput);
        const country = trimSingleLineValue(countryInput);
        const product = (formData.get('product') as string || '').trim();
        const quantityRange = (formData.get('quantityRange') as string || '').trim();
        const subject = trimSingleLineValue(subjectInput);
        const message = trimTextAreaValue(messageInput);
        const body = buildEmailBody({
          name,
          email,
          inquiryTypeValue,
          preferredContact,
          company,
          country,
          product,
          quantityRange,
          message,
        });
        const mailtoLink = `mailto:info@proudtek.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        const payload = serializeFormData(formData);

        payload.name = name;
        payload.email = email;
        payload.inquiryType = inquiryTypeValue;
        payload.preferredContact = preferredContact;
        payload.company = company;
        payload.country = country;
        payload.product = product;
        payload.quantityRange = quantityRange;
        payload.subject = subject;
        payload.message = message;

        syncDraftTools(subject, body, mailtoLink, false);
        setBusyState(true);

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
            },
            body: JSON.stringify(payload),
          });
          const result = await response.json().catch(() => null) as
            | { ok?: boolean; redirectTo?: string; deliveryMode?: string; errors?: string[]; error?: string }
            | null;

          if (!response.ok || !result?.ok) {
            const errorMessage = result?.errors?.[0] || result?.error || 'We could not submit your inquiry right now.';
            syncDraftTools(subject, body, mailtoLink);
            trackEvent('inquiry_submit_failed', {
              inquiry_intent: inquiryTypeValue || 'general',
              context_type: contextType || 'none',
              response_status: response.status,
            });
            showStatus(`${errorMessage} Use the backup draft below if you need to send this immediately.`, true);
            return;
          }

          trackEvent('inquiry_submit_success', {
            inquiry_intent: inquiryTypeValue || 'general',
            context_type: contextType || 'none',
            delivery_mode: result.deliveryMode || 'unknown',
          });

          window.location.assign(result.redirectTo || `/thank-you?intent=${encodeURIComponent(inquiryTypeValue || 'general')}`);
        } catch {
          syncDraftTools(subject, body, mailtoLink);
          trackEvent('inquiry_submit_failed', {
            inquiry_intent: inquiryTypeValue || 'general',
            context_type: contextType || 'none',
            response_status: 'network-error',
          });
          showStatus('The live submission did not complete. Use the backup draft below, or try again in a moment.', true);
        } finally {
          setBusyState(false);
        }
      });
    }
  });
</script>
