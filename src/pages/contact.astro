              <div id="contactStatus" class="brand-panel-soft hidden mt-4 px-4 py-4 text-sm text-gray-700" role="status" aria-live="polite"></div>

              <div id="draftPanel" class="brand-panel-soft hidden mt-6 p-6">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="max-w-2xl">
                    <p class="eyebrow-label text-[#0e7490] mb-2">Draft Support</p>
                    <h3 class="title-balance text-xl font-semibold text-gray-900">Use this backup if the live submission is temporarily unavailable</h3>
                    <p class="mt-2 text-sm text-gray-600">Your inquiry details stay here as a fallback draft. You can reopen it in email, copy it, or continue on WhatsApp with the same information.</p>
                  </div>
                  <a
                    id="draftEmailLink"
                    href="mailto:info@proudtek.com"
                    class="cta-secondary normal-case tracking-normal"
                  >
                    Open email backup
                  </a>
                </div>

                <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                  <a
                    id="draftWhatsAppLink"
                    href={defaultWhatsAppHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="cta-whatsapp normal-case tracking-normal"
                  >
                    Continue on WhatsApp
                  </a>
                  <button
                    id="copyInquiryButton"
                    type="button"
                    class="cta-secondary normal-case tracking-normal"
                  >
                    Copy inquiry
                  </button>
                </div>

                <div class="mt-5">
                  <label for="draftPreview" class="block text-sm font-medium text-gray-700 mb-1.5">Inquiry preview</label>
                  <textarea
                    id="draftPreview"
                    rows="10"
