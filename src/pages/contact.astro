---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { blogPosts } from '../data/blogs';
import { categoryPages } from '../data/categoryPages';
import { comparisonPages } from '../data/comparisons';
import { contactThemes } from '../data/contactThemes';
import { marketPages } from '../data/markets';
import { evidenceLinks } from '../data/navigation';
import { products } from '../data/products';
import { solutionPages } from '../data/solutions';
import { comparisonInquiryPaths, getIntentEmailHref, getIntentWhatsAppHref } from '../utils/contact';

const contactInfo = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>`,
    title: 'Address',
    content: 'A2109, Zhantao Science & Tech Park, Minzhi Ave, Longhua District, Shenzhen, 518131, China',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
    </svg>`,
    title: 'Phone',
    content: '0086-755-2376 5843',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
    </svg>`,
    title: 'Email',
    content: 'info@proudtek.com',
  },
  {
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>`,
    title: 'WhatsApp',
    content: '0086-18665820632',
  },
];

const contactHeroPoints = [
  'Reply target: within 2 to 4 business hours',
  'Support for samples, OEM, and compatibility checks',
  'Factory-direct supply for repeat orders and export projects',
];

const inquiryPaths = [
  {
    intent: 'samples',
    title: 'Sample planning',
    description: 'Best for buyers comparing stock samples, custom samples or a pilot run before bulk production.',
    cta: 'Plan sample request',
  },
  {
    intent: 'oem',
    title: 'OEM or customization',
    description: 'Use this path when chip matching, print, numbering, encoding or special materials are part of the project.',
    cta: 'Discuss customization',
  },
  {
    intent: 'compatibility',
    title: 'Compatibility check',
    description: 'Useful when you have a reader, lock, installed system or current credential and need the closest match.',
    cta: 'Check compatibility',
  },
  {
    intent: 'repeat-order',
    title: 'Repeat procurement',
    description: 'Designed for buyers who already know the SKU or approved sample and want to move faster into a repeat order discussion.',
    cta: 'Prepare repeat order',
  },
];

const comparisonPagesList = Object.values(comparisonPages);
const comparisonPageMap = new Map(comparisonPagesList.map((page) => [page.slug, page]));
const comparisonNameMap = Object.fromEntries(comparisonPagesList.map((page) => [page.slug, page.name]));
const solutionNameMap = Object.fromEntries(Object.values(solutionPages).map((page) => [page.slug, page.name]));
const marketNameMap = Object.fromEntries(Object.values(marketPages).map((page) => [page.slug, `${page.regionName} - ${page.productFocus}`]));
const productNameMap = Object.fromEntries(products.map((product) => [product.slug, product.name]));
const categoryNameMap = Object.fromEntries(Object.values(categoryPages).map((page) => [page.key, page.categoryName]));
const blogNameMap = Object.fromEntries(blogPosts.map((post) => [post.slug, post.title]));
const evidenceNameMap = Object.fromEntries(evidenceLinks.map((link) => [link.href.replace(/^\/+/, ''), link.name]));
const defaultEmailHref = getIntentEmailHref('samples');
const defaultWhatsAppHref = getIntentWhatsAppHref('samples');
const defaultContactTheme = contactThemes.default;

const comparisonInquiryCards = comparisonInquiryPaths.map((item) => ({
  ...item,
  examples: item.comparisonSlugs
    .map((slug) => comparisonPageMap.get(slug))
    .filter(Boolean),
}));

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/contact`;

const contactPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${canonicalURL}#contact-page`,
  url: canonicalURL,
  name: 'Contact ProudTek',
  description: 'Contact ProudTek for RFID quotes, compatibility checks, sample support and comparison-led inquiries across chips, frequencies and product formats.',
  isPartOf: { '@id': `${siteURL}/#website` },
  about: { '@id': `${siteURL}/#organization` },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: canonicalURL },
  ],
};

---

<Layout
  title="Contact ProudTek - Get RFID Product Quotes & Custom Solutions | Free Samples"
  description="Contact ProudTek for RFID quotes, sample support, compatibility checks and comparison-led inquiries covering chips, frequencies, tags and credential formats."
  keywords="contact RFID manufacturer, RFID quote, RFID comparison inquiry, custom RFID order, ProudTek contact, RFID sample request"
  canonicalURL={canonicalURL}
  jsonLd={[contactPageJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="brand-hero-band py-16 md:py-20">
      <div class="absolute inset-0 opacity-60">
        <div class="absolute top-10 left-10 w-32 h-32 rounded-full border border-[#0e7490]/18"></div>
        <div class="absolute bottom-10 right-10 w-48 h-48 rounded-full border border-white/10"></div>
        <div class="absolute top-1/2 left-1/3 w-20 h-20 rounded-full border border-[#0891b2]/20"></div>
      </div>
      <div class="container mx-auto px-4 relative z-10">
        <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
          <div class="copy-safe">
            <p id="contactHeroEyebrow" class="eyebrow-label mb-3 text-[#0891b2]">{defaultContactTheme.heroEyebrow}</p>
            <h1 id="contactHeroTitle" class="title-balance text-4xl font-bold text-white md:text-5xl lg:text-6xl">{defaultContactTheme.heroTitle}</h1>
            <p id="contactHeroCopy" class="card-copy mt-4 max-w-2xl text-base text-white/72 md:text-lg">{defaultContactTheme.heroCopy}</p>

            <div class="mt-6 flex flex-wrap gap-2">
              {contactHeroPoints.map((item) => (
                <span class="brand-chip-dark">{item}</span>
              ))}
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              <a
                id="quickWhatsAppLink"
                href={defaultWhatsAppHref}
                target="_blank"
                rel="noopener noreferrer"
                class="cta-whatsapp normal-case tracking-normal text-sm"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span id="quickWhatsAppLabel">WhatsApp a quick question</span>
              </a>
              <a
                id="quickEmailLink"
                href={defaultEmailHref}
                class="cta-secondary-dark normal-case tracking-normal text-sm"
              >
                <svg class="w-5 h-5 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <span id="quickEmailLabel">Email your inquiry</span>
              </a>
            </div>

            <p class="mt-4 text-sm text-white/58">
              Best for accurate pricing: use the form below when you already know the product type, chip, application, or quantity target.
            </p>
          </div>

          <div class="brand-panel-dark copy-safe p-6 md:p-7">
            <p class="eyebrow-label text-[#0e7490]">Best Results</p>
            <h2 class="title-balance mt-3 text-2xl font-semibold text-white">One useful inquiry beats three back-and-forth emails</h2>
            <p class="card-copy mt-3 text-sm text-white/72">
              The fastest path is to send the product family, reader or chip requirement, quantity range, and any print or encoding needs in one message.
            </p>
            <div class="mt-6 space-y-3 border-t border-white/10 pt-5 text-sm text-white/72">
              <p><span class="font-semibold text-white">Start with:</span> cards, tags, labels, wristbands, keyfobs, or readers.</p>
              <p><span class="font-semibold text-white">Add fit details:</span> chip family, protocol, reader model, or working sample.</p>
              <p><span class="font-semibold text-white">Finish with:</span> quantity target, timeline, and any OEM customization requirements.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="defer-section border-b border-gray-100 bg-white">
      <div class="container mx-auto px-4 py-12 md:py-16">
        <div class="grid gap-8 xl:grid-cols-[1.16fr_0.84fr]">
          <div>
            <div class="max-w-2xl">
              <p class="eyebrow-label text-[#0e7490] mb-2">Inquiry Paths</p>
              <h2 class="title-balance text-3xl font-bold text-gray-900">Choose the path that matches what still needs to be confirmed</h2>
              <p class="card-copy mt-4 text-gray-600">
                Most buyers only need one route: samples, OEM customization, compatibility, or repeat procurement.
              </p>
            </div>
            <div class="mt-8 grid gap-5 md:grid-cols-2">
              {inquiryPaths.map((item) => (
                <a href={`/contact?intent=${item.intent}#contactForm`} class="brand-panel brand-panel-link copy-safe p-6">
                  <h3 class="title-balance text-xl font-semibold text-gray-900">{item.title}</h3>
                  <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.description}</p>
                  <span class="accent-link mt-5 inline-flex items-center text-sm">
                    {item.cta}
                    <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>

          <aside class="brand-panel-dark copy-safe p-6 md:p-7">
            <p class="eyebrow-label text-[#0e7490]">Still Comparing?</p>
            <h2 class="title-balance mt-3 text-2xl font-semibold text-white">Use one comparison route when two close options are still on the table</h2>
            <p class="card-copy mt-3 text-sm text-white/72">
              This is the better path when you are not ready to choose one format, chip, or frequency direction yet.
            </p>
            <div class="mt-6 space-y-3">
              {comparisonInquiryCards.map((item) => (
                <a href={`/contact?intent=${item.intent}#contactForm`} class="block rounded-2xl border border-white/10 bg-white/5 px-4 py-4 transition-colors hover:bg-white/8">
                  <span class="block text-sm font-semibold text-white">{item.title}</span>
                  <span class="mt-1 block text-sm text-white/68">{item.description}</span>
                  <span class="mt-3 flex flex-wrap gap-2">
                    {item.examples.slice(0, 2).map((example) => (
                      <span class="brand-chip-dark">{example!.name}</span>
                    ))}
                  </span>
                </a>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Contact Form -->
          <div class="order-1 lg:order-2 lg:col-span-3">
            <div class="brand-panel p-6 md:p-8">
              <h2 id="contactFormTitle" class="text-2xl font-bold text-gray-900 mb-1">{defaultContactTheme.formTitle}</h2>
              <p id="contactFormCopy" class="text-gray-500 text-sm mb-2">{defaultContactTheme.formCopy}</p>
              <p id="contactFormHelp" class="text-xs text-gray-500 mb-6">The more specific the inquiry, the faster we can match the right product path.</p>

              <div id="inquiryContextBanner" class="brand-panel-soft hidden mb-6 p-5">
                <p id="inquiryContextEyebrow" class="eyebrow-label text-[#0e7490] mb-2">Inquiry Context Loaded</p>
                <h3 id="inquiryContextTitle" class="title-balance text-xl font-semibold text-gray-900">Inquiry context ready</h3>
                <p id="inquiryContextCopy" class="card-copy mt-2 text-sm text-gray-600"></p>
              </div>

              <div id="contactPromptCard" class="brand-panel-soft mb-6 p-5">
                <p id="contactPromptEyebrow" class="eyebrow-label text-[#0e7490] mb-2">{defaultContactTheme.promptEyebrow}</p>
                <h3 id="contactPromptTitle" class="title-balance text-xl font-semibold text-gray-900">{defaultContactTheme.promptTitle}</h3>
                <p id="contactPromptCopy" class="card-copy mt-2 text-sm text-gray-600">{defaultContactTheme.promptCopy}</p>
                <div id="contactPromptList" class="mt-4 flex flex-wrap gap-2">
                  {defaultContactTheme.promptBullets.map((item) => (
                    <span class="brand-chip">{item}</span>
                  ))}
                </div>
              </div>

              <form id="contactForm" class="space-y-5" action="/api/inquiry" method="post">
                <input type="hidden" id="contextTypeField" name="contextType" value="" />
                <input type="hidden" id="contextSlugField" name="contextSlug" value="" />
                <input type="hidden" id="contextNameField" name="contextName" value="" />
                <input type="hidden" id="contextPageField" name="contextPage" value="" />
                <input type="hidden" id="sourcePathField" name="sourcePath" value="" />
                <input type="hidden" id="sourcePageTitleField" name="sourcePageTitle" value="" />
                <input type="hidden" id="landingPageField" name="landingPage" value="" />
                <input type="hidden" id="referrerField" name="referrer" value="" />
                <input type="hidden" id="referrerHostField" name="referrerHost" value="" />
                <input type="hidden" id="utmSourceField" name="utmSource" value="" />
                <input type="hidden" id="utmMediumField" name="utmMedium" value="" />
                <input type="hidden" id="utmCampaignField" name="utmCampaign" value="" />
                <input type="hidden" id="utmTermField" name="utmTerm" value="" />
                <input type="hidden" id="utmContentField" name="utmContent" value="" />
                <input type="hidden" id="gclidField" name="gclid" value="" />
                <input type="hidden" id="msclkidField" name="msclkid" value="" />
                <input type="hidden" id="fbclidField" name="fbclid" value="" />
                <input type="hidden" id="timezoneField" name="timezone" value="" />
                <input type="hidden" id="browserLanguageField" name="browserLanguage" value="" />
                <div class="absolute -left-[100vw] top-auto h-px w-px overflow-hidden opacity-0 pointer-events-none" aria-hidden="true">
                  <label for="website">Website</label>
                  <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
                </div>
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Your Name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      autocomplete="name"
                      maxlength="80"
                      placeholder="John Smith"
                      class="field-control"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      autocomplete="email"
                      inputmode="email"
                      spellcheck="false"
                      placeholder="john@company.com"
                      class="field-control"
                    />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="inquiryType" class="block text-sm font-medium text-gray-700 mb-1.5">Inquiry Type <span class="text-red-500">*</span></label>
                    <select
                      id="inquiryType"
                      name="inquiryType"
                      required
                      class="field-control"
                    >
                      <option value="">Select an inquiry type</option>
                      <option value="samples">Sample Planning</option>
                      <option value="oem">OEM / Customization</option>
                      <option value="compatibility">Compatibility Check</option>
                      <option value="repeat-order">Repeat Order</option>
                      <option value="chip-comparison">Chip Comparison</option>
                      <option value="frequency-comparison">Frequency Comparison</option>
                      <option value="product-format-comparison">Tag / Credential Format Comparison</option>
                      <option value="laundry-tag-comparison">Laundry Tag Comparison</option>
                      <option value="general">General Product Inquiry</option>
                    </select>
                  </div>
                  <div>
                    <label for="preferredContact" class="block text-sm font-medium text-gray-700 mb-1.5">Preferred Contact Method</label>
                    <select
                      id="preferredContact"
                      name="preferredContact"
                      class="field-control"
                    >
                      <option value="">Choose preferred method</option>
                      <option value="email">Email</option>
                      <option value="whatsapp">WhatsApp</option>
                      <option value="either">Either is fine</option>
                    </select>
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">Company Name</label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      autocomplete="organization"
                      maxlength="120"
                      placeholder="Your Company"
                      class="field-control"
                    />
                  </div>
                  <div>
                    <label for="country" class="block text-sm font-medium text-gray-700 mb-1.5">Country / Region</label>
                    <input
                      type="text"
                      id="country"
                      name="country"
                      autocomplete="country-name"
                      maxlength="80"
                      placeholder="e.g., United States"
                      class="field-control"
                    />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="product" class="block text-sm font-medium text-gray-700 mb-1.5">Product Interest</label>
                    <select
                      id="product"
                      name="product"
                      class="field-control"
                    >
                      <option value="">Select a product category</option>
                      <option value="RFID Cards">RFID Cards</option>
                      <option value="RFID Tags">RFID Tags (Industrial)</option>
                      <option value="RFID Labels">RFID Labels & Stickers</option>
                      <option value="RFID Wristbands">RFID Wristbands</option>
                      <option value="RFID Key Fobs">RFID Key Fobs</option>
                      <option value="RFID Readers">RFID Readers</option>
                      <option value="Custom Solution">Custom RFID Solution</option>
                    </select>
                  </div>
                  <div>
                    <label for="quantityRange" class="block text-sm font-medium text-gray-700 mb-1.5">Estimated Quantity</label>
                    <select
                      id="quantityRange"
                      name="quantityRange"
                      class="field-control"
                    >
                      <option value="">Select quantity range</option>
                      <option value="sample-only">Sample only</option>
                      <option value="under-1000">Under 1,000 pcs</option>
                      <option value="1000-10000">1,000 - 10,000 pcs</option>
                      <option value="10000-50000">10,000 - 50,000 pcs</option>
                      <option value="over-50000">Over 50,000 pcs</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label for="subject" class="block text-sm font-medium text-gray-700 mb-1.5">Subject <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    minlength="5"
                    maxlength="140"
                    dir="auto"
                    placeholder={defaultContactTheme.subjectPlaceholder}
                    class="field-control"
                  />
                </div>

                <div>
