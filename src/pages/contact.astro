                    class="field-control text-sm text-gray-700"
                  ></textarea>
                </div>
              </div>

              <noscript>
                <div class="brand-panel-soft mt-6 p-5 text-sm text-gray-700">
                  JavaScript is turned off. This form can still be submitted normally. If you prefer, email <a class="font-semibold text-gray-900 underline decoration-[#0e7490]/40 underline-offset-4" href="mailto:info@proudtek.com">info@proudtek.com</a> or continue on <a class="font-semibold text-gray-900 underline decoration-[#0e7490]/40 underline-offset-4" href={defaultWhatsAppHref}>WhatsApp</a>.
                </div>
              </noscript>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="order-2 lg:order-1 lg:col-span-2">
            <h2 id="contactInfoTitle" class="text-2xl font-bold text-gray-900 mb-2">Contact Information</h2>
            <p id="contactInfoCopy" class="text-gray-600 mb-8">
              Use these channels when you need a fast human follow-up on pricing, samples, compatibility, or repeat supply.
            </p>

            <div class="space-y-5">
              {contactInfo.map((info) => (
                <div class="copy-safe flex items-start gap-4 p-3 rounded-lg hover:bg-gray-50 transition-colors">
                  <div class="text-[#0e7490] flex-shrink-0 mt-0.5 bg-[#0e7490]/5 p-2 rounded-lg" set:html={info.icon}></div>
