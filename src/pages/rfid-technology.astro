const commonMistakes = [
  { title: 'Choosing UHF for a sub-1 m access flow', fix: 'Use HF/NFC \u2014 13.56 MHz proximity reads are faster and more secure than de-tuning a UHF reader.' },
  { title: 'Skipping regional sub-band specification', fix: 'Specify the target market UHF sub-band (US 902-928, EU 865-868, Japan 916-921) before tag tooling.' },
  { title: 'Mounting passive UHF directly on metal', fix: 'Use an on-metal tag with a tuned spacer or PCB ground plane \u2014 standard inlays detune to near-zero range on bare metal.' },
  { title: 'Ignoring chip authenticity', fix: 'Confirm genuine NXP, Impinj or NXP UCODE chips; gray-market clones often fail FCC, CE and ISO certification.' },
  { title: 'Mixing HF and UHF readers without a multi-band reader', fix: 'Plan a single-band fleet per workflow, or buy a multi-band reader from the start.' },
  { title: 'Encoding without a backup identifier', fix: 'Specify both human-readable EPC and TID (factory unique chip ID) for traceability.' },
  { title: 'Buying tags before sample testing', fix: 'Run a 50-100 unit pilot in the real environment with the intended reader before committing to bulk MOQ.' },
];

const clusterArticles = [
