---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { getIntentContactHref } from '../utils/contact';

const tocItems = [
  { href: '#what-is-rfid', label: '1. What RFID means and how systems are built' },
  { href: '#frequency-bands', label: '2. LF, HF/NFC and UHF compared' },
  { href: '#chip-families', label: '3. Common chip families and when to use them' },
  { href: '#form-factors', label: '4. Choosing between cards, tags, labels and wristbands' },
  { href: '#environment', label: '5. Environment and installation considerations' },
  { href: '#selection-process', label: '6. How to choose the right RFID product' },
  { href: '#related-guides', label: '7. Related guides, comparisons and category pages' },
];

const frequencyRows = [
  ['LF', '125 to 134 kHz', 'Access control, animal ID, legacy credentials', 'Short read range with stable performance near water and in simple access systems'],
  ['HF / NFC', '13.56 MHz', 'Smart cards, NFC interaction, libraries, ticketing', 'A strong fit when phone compatibility or secure card workflows matter'],
  ['UHF', '860 to 960 MHz', 'Inventory, logistics, industrial tracking', 'Longer read range and faster bulk reading, especially for operational visibility'],
];

const chipFamilies = [
  {
    title: 'LF chips',
    examples: 'EM4100, T5577 and similar low-frequency credentials',
    use: 'Often used for simple access control or legacy systems where short-range identification is enough.',
  },
  {
    title: 'HF and NFC chips',
    examples: 'Mifare Classic, Mifare DESFire, NTAG, ICODE',
    use: 'Useful for smart cards, mobile tap experiences, library systems, hospitality and higher-security projects.',
  },
  {
    title: 'UHF chips',
    examples: 'Impinj Monza, NXP UCODE and related EPC Gen2 families',
    use: 'A common choice for warehouse, retail and asset-tracking programs that need speed and read distance.',
  },
];

const frequencyCompareLinks = [
  {
    href: '/compare/lf-vs-hf-rfid',
    label: 'LF vs HF RFID',
    description: 'Useful when a project is choosing between legacy low-frequency credentials and 13.56 MHz smart-card workflows.',
  },
  {
    href: '/compare/hf-vs-uhf-rfid',
    label: 'HF vs UHF RFID',
    description: 'Helpful when the core question is close-range intentional interaction versus longer-range operational reading.',
  },
];

const chipCompareLinks = [
  {
    href: '/compare/mifare-classic-vs-desfire',
    label: 'Mifare Classic vs DESFire',
    description: 'A strong path when the project is weighing legacy continuity against a more secure card platform.',
  },
  {
    href: '/compare/mifare-plus-vs-desfire',
    label: 'Mifare Plus vs DESFire',
    description: 'Useful for upgrade conversations where the team is balancing migration ease against long-term security.',
  },
];

const formFactors = [
  {
    title: 'Cards',
    description: 'Best for access control, hotel key cards, memberships and smart credential programs where printing and portability matter.',
    href: '/category/rfid-cards',
  },
  {
    title: 'Industrial tags',
    description: 'Used for pallets, tools, equipment, laundry and anti-metal installations where ruggedness matters more than appearance.',
    href: '/category/rfid-tags',
  },
  {
    title: 'Labels and stickers',
    description: 'Useful for packaging, books, retail inventory, NFC tap points and applications that need a printable adhesive format.',
    href: '/category/rfid-labels',
  },
  {
    title: 'Wristbands and keyfobs',
    description: 'Chosen when the credential needs to be wearable or attached to a keychain for event, hospitality or access workflows.',
    href: '/category/rfid-wristbands',
  },
];

const environmentChecks = [
  'Surface material: metal, plastic, paper, glass, textile or packaging all influence the best RFID format.',
  'Read distance and speed: a tap-based access flow needs a different solution from a warehouse portal.',
  'Water, liquid and detergent exposure: especially important for laundry, healthcare and hospitality.',
  'Heat, pressure and wear: industrial tags and special materials matter when standard labels will fail.',
  'Reader compatibility: chip family and standard must match the reader already in use or planned for deployment.',
];

const selectionSteps = [
  'Define the application first: access control, asset tracking, product authentication, events, logistics or something else.',
  'Confirm your reader or chip requirement so protocol compatibility is solved before design and printing decisions.',
  'Choose the product format that fits the user flow and operating environment, not just the lowest-cost option.',
  'Test samples in the real environment whenever metal, liquid, custom encoding or special read positions are involved.',
  'Only then lock in artwork, numbering, packaging and production quantities.',
];

const relatedGuides = [
  { href: '/blogs/rfid-frequency-guide', label: 'RFID frequency guide', description: 'A focused article for teams comparing LF, HF and UHF before requesting samples.' },
  { href: '/blogs/nfc-technology', label: 'NFC technology guide', description: 'Useful when smartphone tap, marketing or mobile-friendly workflows are part of the project.' },
  { href: '/blogs/rfid-vs-barcode', label: 'RFID vs barcode', description: 'Helpful when an operations team is planning an upgrade from manual scanning.' },
  { href: '/blogs/how-to-order-rfid-cards-from-china', label: 'How to order RFID cards from China', description: 'A practical sourcing guide for buyers evaluating suppliers and sampling process.' },
  { href: '/compare/rfid-cards-vs-keyfobs', label: 'RFID cards vs keyfobs', description: 'Useful when the access project is choosing a credential format after compatibility is already understood.' },
  { href: '/compare/pvc-rfid-cards-vs-paper-cards', label: 'PVC cards vs paper cards', description: 'Helpful when the decision is between durable reusable credentials and short-life ticket formats.' },
  { href: '/compare/rfid-labels-vs-hard-tags', label: 'RFID labels vs hard tags', description: 'A good next step when the project is balancing printability, reuse and ruggedness.' },
  { href: '/compare/textile-vs-silicone-laundry-tags', label: 'Textile vs silicone laundry tags', description: 'Useful for linen and garment teams comparing low-profile fabric tags with sealed silicone formats.' },
];

const technologyFaqs = [
  {
    question: 'How do I know whether I need LF, HF/NFC or UHF RFID?',
    answer: 'Start with the read distance, reader type and application. LF is common for simple short-range credentials, HF/NFC is strong for smart cards and phone tap scenarios, and UHF is usually chosen for longer-range operational tracking.',
  },
  {
    question: 'Is NFC the same thing as RFID?',
    answer: 'NFC is part of the broader RFID family. It operates at 13.56 MHz and is especially useful when smartphones or two-way tap experiences are involved.',
  },
  {
    question: 'What is the most common mistake when choosing RFID products?',
    answer: 'Many teams choose by chip name or unit price before checking reader compatibility, environment and installation surface. In practice, those factors usually decide whether the project performs well.',
  },
  {
    question: 'Should I test samples before placing a bulk RFID order?',
    answer: 'Yes. Sample testing is one of the safest ways to confirm compatibility, especially for anti-metal tags, laundry tags, encoded credentials and operational deployments with fixed readers.',
  },
];

const technologyContactHref = getIntentContactHref('compatibility');

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/rfid-technology`;

const techArticleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${canonicalURL}#article`,
  headline: 'RFID Technology Guide',
  description: 'An overview of RFID basics, frequencies, chip families, form factors and product selection process.',
  url: canonicalURL,
  author: { '@id': `${siteURL}/#organization` },
  publisher: { '@id': `${siteURL}/#organization` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  about: [
    { '@type': 'Thing', name: 'RFID' },
    { '@type': 'Thing', name: 'NFC' },
    { '@type': 'Thing', name: 'RFID product selection' },
  ],
};

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to choose the right RFID product',
  description: 'A practical selection process for matching RFID frequency, chip family and product format to a real-world application.',
  step: selectionSteps.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    text: step,
  })),
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: technologyFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'RFID Technology Guide', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Technology Guide - Frequencies, Chips, Form Factors and Selection"
  description="Learn how RFID works, compare LF, HF/NFC and UHF, understand common chip families and choose the right RFID product for your use case."
  keywords="RFID technology guide, LF vs HF vs UHF, RFID chip selection, NFC vs RFID, RFID product selection"
  canonicalURL={canonicalURL}
  jsonLd={[techArticleJsonLd, howToJsonLd, faqJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-r from-[#0e7490] to-[#0097a7] py-16 text-white">
      <div class="container mx-auto px-4">
        <nav class="text-sm mb-4 text-white/80" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>RFID Technology Guide</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label eyebrow-label-wide text-[#0e7490]/70 mb-4">Pillar Guide</p>
          <h1 class="title-balance text-4xl md:text-5xl font-bold mb-5">RFID technology guide for buyers, engineers and sourcing teams</h1>
          <p class="text-lg md:text-xl text-white/90 max-w-3xl">
            Use this page to understand how RFID systems work, how frequency bands differ and how to match chips and product formats to a real application before requesting samples.
          </p>
        </div>
      </div>
    </section>

    <section class="py-8 bg-gray-50 border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto grid lg:grid-cols-[0.85fr_1.15fr] gap-8 items-start">
          <div>
            <h2 class="text-lg font-semibold text-gray-800 mb-3">On this page</h2>
            <nav class="space-y-2">
              {tocItems.map((item) => (
                <a href={item.href} class="block text-sm text-[#0e7490] hover:underline">{item.label}</a>
              ))}
            </nav>
          </div>
          <div class="rounded-3xl border border-[#0e7490]/15 bg-[#0e7490]/5 p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-2">Why this guide matters</h2>
            <p class="text-gray-600 leading-relaxed">
              Many RFID projects stall because teams compare products before clarifying reader compatibility, environment or use case. Use this guide to settle those basics before you compare specific products or request samples.
            </p>
          </div>
        </div>
      </div>
    </section>

    <article class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto space-y-14">
          <section id="what-is-rfid">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">1. What RFID means and how systems are built</h2>
            <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-8 items-start">
              <div class="space-y-4 text-gray-600 leading-relaxed">
                <p>
                  RFID stands for Radio Frequency Identification. In practical terms, it means a reader communicates with a tag, card or label using radio waves so an object, person or asset can be identified without manual contact or line-of-sight scanning.
                </p>
                <p>
                  A typical RFID system includes three parts: the credential itself, the reader hardware and the software or operational process that decides what happens after the read event. When one of those pieces is mismatched, the project becomes harder to deploy even if the tag itself is technically correct.
                </p>
                <p>
                  That is why product selection should be based on the full workflow rather than only the chip name or the visible product shape.
                </p>
              </div>
              <div class="rounded-3xl border border-gray-200 bg-gray-50 p-6">
                <h3 class="text-xl font-semibold text-gray-800 mb-4">Core system elements</h3>
                <ul class="space-y-3 text-sm text-gray-600">
                  <li><strong class="text-gray-800">Credential:</strong> card, tag, label, wristband or keyfob carrying the chip and antenna.</li>
                  <li><strong class="text-gray-800">Reader:</strong> desktop, fixed, gate, OEM module or handheld device that communicates with the credential.</li>
                  <li><strong class="text-gray-800">Application:</strong> access control, attendance, inventory, logistics, laundry, NFC content delivery and more.</li>
                </ul>
              </div>
            </div>
          </section>

          <section id="frequency-bands">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">2. LF, HF/NFC and UHF compared</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              RFID products are usually grouped by frequency band. The right band depends on how far the reader must work, what is being tagged and whether smartphones or installed readers are part of the workflow.
            </p>
            <div class="overflow-x-auto rounded-3xl border border-gray-200">
              <table class="w-full text-sm bg-white">
                <thead class="bg-gray-100 text-gray-700">
                  <tr>
                    <th class="px-5 py-4 text-left font-semibold border-b border-gray-200">Band</th>
                    <th class="px-5 py-4 text-left font-semibold border-b border-gray-200">Typical frequency</th>
                    <th class="px-5 py-4 text-left font-semibold border-b border-gray-200">Common uses</th>
                    <th class="px-5 py-4 text-left font-semibold border-b border-gray-200">Why teams choose it</th>
                  </tr>
                </thead>
                <tbody>
                  {frequencyRows.map((row, index) => (
                    <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                      {row.map((cell) => (
                        <td class="px-5 py-4 border-b border-gray-100 text-gray-600 align-top">{cell}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="mt-6 grid md:grid-cols-2 gap-4">
              {frequencyCompareLinks.map((item) => (
                <a href={item.href} class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-5 hover:border-[#0e7490] transition-colors">
                  <h3 class="text-lg font-semibold text-gray-800">{item.label}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.description}</p>
                </a>
              ))}
            </div>
          </section>

          <section id="chip-families">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">3. Common chip families and when to use them</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {chipFamilies.map((item) => (
                <div class="rounded-[1.75rem] border border-gray-200 bg-gray-50 p-7">
                  <h3 class="text-xl font-semibold text-gray-800">{item.title}</h3>
                  <p class="text-sm text-[#0e7490] font-medium mt-3">{item.examples}</p>
                  <p class="text-gray-600 leading-relaxed mt-3">{item.use}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 grid md:grid-cols-2 gap-4">
              {chipCompareLinks.map((item) => (
                <a href={item.href} class="copy-safe rounded-2xl border border-gray-200 bg-white p-5 hover:border-[#0e7490] hover:shadow-lg transition-all">
                  <h3 class="text-lg font-semibold text-gray-800">{item.label}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.description}</p>
                </a>
              ))}
            </div>
          </section>

          <section id="form-factors">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">4. Choosing between cards, tags, labels and wristbands</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              The best RFID product format depends on how the user or object interacts with the system. The same HF chip could work inside a card, a wristband or a sticker, but each one serves a different operational experience.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              {formFactors.map((item) => (
                <a href={item.href} class="rounded-[1.75rem] border border-gray-200 bg-white p-7 hover:border-[#0e7490] hover:shadow-lg transition-all">
                  <h3 class="text-xl font-semibold text-gray-800">{item.title}</h3>
                  <p class="text-gray-600 leading-relaxed mt-3">{item.description}</p>
                  <span class="mt-5 inline-flex items-center text-sm font-semibold text-[#0e7490]">
                    View related category
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </section>

          <section id="environment">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">5. Environment and installation considerations</h2>
            <div class="grid lg:grid-cols-[0.95fr_1.05fr] gap-8 items-start">
              <div class="rounded-3xl bg-slate-950 text-white p-7">
                <h3 class="text-2xl font-semibold mb-4">Why environment often decides the winning product</h3>
                <p class="text-white/75 leading-relaxed">
                  Teams often focus on chip family first, but in the field the mounting surface, temperature, moisture and reader placement can be just as important. A great chip inside the wrong enclosure still creates a poor deployment.
                </p>
              </div>
              <ul class="space-y-4">
                {environmentChecks.map((item) => (
                  <li class="flex items-start gap-3 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-4 text-gray-700">
                    <svg class="w-5 h-5 text-[#0e7490] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <section id="selection-process">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">6. How to choose the right RFID product</h2>
            <div class="space-y-4">
              {selectionSteps.map((item, index) => (
                <div class="copy-safe flex gap-4 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-5">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#0e7490] text-white font-semibold">{index + 1}</span>
                  <p class="text-gray-600 leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </section>

          <section id="related-guides">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">7. Related guides, comparisons and category pages</h2>
            <div class="grid md:grid-cols-2 gap-5">
              {relatedGuides.map((item) => (
                <a href={item.href} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-white p-6 hover:border-[#0e7490] hover:shadow-lg transition-all">
                  <h3 class="text-xl font-semibold text-gray-800">{item.label}</h3>
                  <p class="text-gray-600 leading-relaxed mt-3">{item.description}</p>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>
    </article>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <p class="eyebrow-label text-[#0e7490] mb-2">FAQ</p>
            <h2 class="title-balance text-3xl font-semibold text-gray-900">Questions buyers often ask first</h2>
          </div>
          <div class="space-y-4">
            {technologyFaqs.map((faq) => (
              <details class="copy-safe group rounded-2xl border border-gray-200 bg-white p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-gray-800">
                  {faq.question}
                  <span class="text-[#0e7490] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-gray-600 leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 bg-[#0e7490]">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Need help matching technology choices to real products?</h2>
        <p class="text-white/90 max-w-3xl mx-auto mb-7">
          Share your reader type, environment and target application. We can suggest which category pages or sample options make the most sense to test next.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={technologyContactHref} class="bg-white text-[#0e7490] px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Contact our team
          </a>
          <a href="/rfid" class="border border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
            Browse products
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
