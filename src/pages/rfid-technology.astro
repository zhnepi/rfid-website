  { href: '#common-mistakes', label: '10. 7 common procurement mistakes (and fixes)' },
  { href: '#cluster-articles', label: '11. Continue your research — 8 deep-dive articles' },
  { href: '#download', label: '12. Download the RFID Buyer\u2019s Guide (PDF)' },
  { href: '#related-guides', label: '13. Related comparisons and category pages' },
];

const directAnswer = "RFID identifies, counts and tracks objects with radio waves. Pick LF (125-134 kHz) for animal ID and short-range access, HF/NFC (13.56 MHz) for smart cards and smartphone-tap workflows, or UHF (860-960 MHz) for retail and supply-chain visibility. Reader compatibility, environment and ISO standard usually decide the right product before chip name or unit price.";

const keyTakeaways = [
  '<strong>3 frequency bands carry &gt; 95% of B2B volume</strong> &mdash; LF, HF/NFC and UHF. Microwave 2.45 GHz is rare outside tolling.',
  '<strong>UHF Gen2v2 is the workhorse</strong> &mdash; RAIN Alliance reported 42 billion passive UHF tags shipped in 2024.',
  '<strong>Reader-side compatibility is the #1 hidden risk</strong> &mdash; ISO 14443A, 15693 and 18000-63 readers cannot be swapped without re-tooling.',
  '<strong>Environment beats chip choice</strong> &mdash; metal, liquid, temperature and reader placement decide deployment success more than the brand on the chip.',
  '<strong>Sample testing is non-negotiable</strong> &mdash; for any anti-metal, laundry, encoded or fixed-reader project, run a 50-100 unit pilot before bulk MOQ.',
];

const industryStats = [
  { value: '$22.4 B', label: 'Global RFID market 2026 (IDTechEx, 2024)' },
  { value: '42 B', label: 'RAIN UHF tags shipped in 2024 (RAIN Alliance)' },
  { value: '2.4 B', label: 'NFC-enabled smartphones (NFC Forum, 2025)' },
  { value: '98%', label: 'Decathlon inventory accuracy after UHF rollout (GS1, 2023)' },
  { value: '$0.04-0.08', label: 'Passive UHF inlay unit cost at MOQ 100K (IDTechEx, 2024)' },
];

const standardsReference = [
  { standard: 'ISO 11784 / 11785', scope: 'LF animal ID', notes: 'Universal for livestock ear tags at 134.2 kHz' },
