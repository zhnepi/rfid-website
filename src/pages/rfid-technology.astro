  { standard: 'EPC Tag Data Standard 1.13', scope: 'GS1 EPC encoding', notes: 'Walmart and major retailer mandate baseline' },
  { standard: 'GS1 Digital Link 1.4', scope: 'Web-resolvable URI', notes: 'Foundation for EU Digital Product Passport (ESPR 2024/1781)' },
];

const regionalCompliance = [
  ['United States', '902 \u2013 928 MHz', '4 W EIRP', 'FCC Part 15.247'],
  ['European Union', '865.6 \u2013 867.6 MHz', '2 W ERP', 'ETSI EN 302 208'],
  ['Japan', '916.7 \u2013 920.9 MHz', '1 W ERP', 'ARIB STD-T107'],
  ['China', '920.5 \u2013 924.5 MHz', '2 W ERP', 'GB/T 29768'],
  ['Brazil', '902 \u2013 907.5 / 915 \u2013 928 MHz', '4 W EIRP', 'ANATEL 506'],
  ['India', '865 \u2013 867 MHz', '4 W EIRP', 'WPC Notification 2008-S.O.1763(E)'],
];

const costBenchmarks = [
  ['Format', 'LF', 'HF / NFC', 'UHF'],
  ['Sticker / wet inlay', '$0.18 \u2013 0.30', '$0.05 \u2013 0.15', '$0.04 \u2013 0.08'],
  ['PVC card', '$0.45 \u2013 0.80', '$0.15 \u2013 0.40', '$0.20 \u2013 0.55'],
  ['Silicone wristband', '$0.65 \u2013 1.20', '$0.45 \u2013 0.95', '$0.55 \u2013 1.10'],
  ['Textile laundry tag', 'n/a', '$0.65 \u2013 1.30', '$0.55 \u2013 1.10'],
