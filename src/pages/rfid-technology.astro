];

const chipCompareLinks = [
  {
    href: '/compare/mifare-classic-vs-desfire',
    label: 'Mifare Classic vs DESFire',
    description: 'A strong path when the project is weighing legacy continuity against a more secure card platform.',
  },
  {
    href: '/compare/mifare-plus-vs-desfire',
    label: 'Mifare Plus vs DESFire',
    description: 'Useful for upgrade conversations where the team is balancing migration ease against long-term security.',
  },
];

const formFactors = [
  {
    title: 'Cards',
    description: 'Best for access control, hotel key cards, memberships and smart credential programs where printing and portability matter.',
    href: '/category/rfid-cards',
  },
  {
    title: 'Industrial tags',
    description: 'Used for pallets, tools, equipment, laundry and anti-metal installations where ruggedness matters more than appearance.',
    href: '/category/rfid-tags',
  },
