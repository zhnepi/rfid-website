---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { guideLinks, evidenceLinks } from '../../data/navigation';
import { marketPagesList } from '../../data/markets';
import { getContextualContactAction, getContextualInquiryLabel, getMarketContactHref, getMarketInquiryIntent } from '../../utils/contact';

const siteURL = 'https://www.rfidak.com';
const canonicalURL = `${siteURL}/markets`;
const marketCards = marketPagesList.map((page) => {
  const intent = getMarketInquiryIntent(page.slug);

  return {
    ...page,
    contactHref: getMarketContactHref(page.slug),
    contactLabel: getContextualInquiryLabel(intent, 'market'),
  };
});
const marketHubAction = getContextualContactAction('/markets');
const featuredMarket = marketCards[0];

function getSupportingActionLabel(href: string) {
  const normalizedHref = href.split(/[?#]/)[0] || '';

  if (normalizedHref.startsWith('/blogs')) return 'Read guide';
  if (normalizedHref.startsWith('/compare')) return 'Review comparison';
  if (normalizedHref.startsWith('/solutions')) return 'Review workflow';
  if (normalizedHref.startsWith('/markets')) return 'Review market path';
  if (normalizedHref.startsWith('/products') || normalizedHref.startsWith('/rfid') || normalizedHref.startsWith('/product') || normalizedHref.startsWith('/category')) {
    return 'Browse product path';
  }
  if (
    normalizedHref.startsWith('/certifications')
    || normalizedHref.startsWith('/quality-control')
    || normalizedHref.startsWith('/sample-policy')
    || normalizedHref.startsWith('/shipping-and-incoterms')
  ) {
    return 'Review proof page';
  }

  return 'Open resource';
}

const supportingCards = [...guideLinks, ...evidenceLinks].map((link) => ({
  ...link,
  contactAction: getContextualContactAction(link.href),
  openLabel: getSupportingActionLabel(link.href),
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'RFID Markets And Regions',
  description: 'Regional buyer hubs for RFID cards, laundry tags and anti-metal tags.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: marketPagesList.map((page, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/markets/${page.slug}`,
      name: `${page.regionName} - ${page.productFocus}`,
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Markets', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Markets And Regions - Buyer Hubs for North America, Europe and the Middle East | RFIDAK"
  description="Explore RFIDAK market pages built for North American RFID cards, European laundry RFID tags and Middle East anti-metal RFID tag sourcing conversations."
  keywords="RFID markets, RFID buyer hubs, North America RFID cards, Europe laundry RFID tags, Middle East anti-metal RFID tags"
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>Markets</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label mb-4 text-[#0d7377]">Markets And Regions</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">Regional RFID buying paths for markets with different approval and sourcing habits</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">
            Start here when region-specific approval pace, packaging expectations or first-sample priorities shape the buying decision as much as the product family itself.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={marketHubAction.href} class="rounded-lg bg-[#0d7377] px-6 py-3 font-semibold text-white hover:bg-[#0a5c5f] transition-colors">
              Request region-fit samples
            </a>
            {featuredMarket && (
              <a href={`/markets/${featuredMarket.slug}`} class="rounded-lg border border-white/25 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                Start with {featuredMarket.regionName}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow-label mb-2 text-[#0d7377]">Active Market Pages</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">Current regional landing pages</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {marketCards.map((page) => (
            <article class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0d7377] hover:bg-white">
              <a href={`/markets/${page.slug}`} class="block">
                <span class="eyebrow-label text-[#0d7377]">{page.regionName}</span>
                <h2 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{page.productFocus}</h2>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">{page.description}</p>
              </a>
              <div class="mt-5 flex flex-wrap items-center gap-4">
                <a href={`/markets/${page.slug}`} class="inline-flex items-center text-sm font-semibold text-[#0d7377]">
                  Review market path
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
                <a href={page.contactHref} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                  {page.contactLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">What Buyers Confirm By Region</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Use a regional path when geography changes what the first inquiry should cover</h2>
            <ul class="space-y-3 text-sm leading-relaxed text-gray-700">
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Start with the region page when geography is already fixed but product family, approval sequence or sample priorities are still open.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Use it to confirm what that market usually buys, which products deserve the first shortlist and what details should go into the first RFQ.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0d7377]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Open the linked guides and proof pages if the team still needs QC, shipping, certification or sourcing answers before sending a regional inquiry.</span>
              </li>
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0d7377]/15 bg-[#0d7377]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0d7377]">Supporting Hubs</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Pages buyers usually open before they send the first regional RFQ</h2>
            <div class="space-y-3">
              {supportingCards.map((link) => (
                <article class="copy-safe rounded-2xl border border-[#0d7377]/15 bg-white p-4 transition-colors hover:border-[#0d7377]">
                  <a href={link.href} class="block">
                    <span class="block text-sm font-semibold text-gray-800">{link.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{link.description}</span>
                  </a>
                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    <a href={link.href} class="inline-flex items-center text-sm font-semibold text-[#0d7377]">
                      {link.openLabel}
                      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                    <a href={link.contactAction.href} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0d7377]">
                      {link.contactAction.label}
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
