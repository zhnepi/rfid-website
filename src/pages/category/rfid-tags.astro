---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryStickyNav from '../../components/CategoryStickyNav.astro';
import CategoryDecisionCards from '../../components/CategoryDecisionCards.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollCTA from '../../components/cta/ScrollCTA.astro';
import ExitIntent from '../../components/cta/ExitIntent.astro';
import { products } from '../../data/products';
import { buildCategoryJsonLd } from '../../utils/categoryJsonLd';
import { getContextualContactAction, getContextualWhatsAppAction } from '../../utils/contact';

const categoryName = 'RFID Tags';
const categoryProducts = products.filter(p => p.category === categoryName);
const description = "Industrial RFID tags from RFIDAK: laundry, library, nail, ceramic, PCB, tire and asset tracking tags — high temperature resistant, IP68 waterproof, custom built.";
const categoryJsonLd = buildCategoryJsonLd({ categoryName, categorySlug: 'rfid-tags', categoryProducts, description });
const categoryContact = getContextualContactAction(Astro.url.pathname);
const categoryWhatsApp = getContextualWhatsAppAction(Astro.url.pathname);
---

<Layout
  title="RFID Tags | Laundry, Ceramic & Industrial Tags — RFIDAK"
  description={description}
  keywords="RFID tags, industrial RFID tag, laundry RFID tag, library RFID tag, ceramic RFID tag, PCB tag, asset tracking tag, RFID tag manufacturer"
  jsonLd={categoryJsonLd}
>
  <Header />
  <CategoryStickyNav activeCategory={categoryName} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-[#0d7377] to-[#0a5c5f] text-white py-16">
    <div class="container mx-auto px-4">
      <div class="mb-4">
        <Breadcrumb variant="dark" items={[
          { name: 'Home', href: '/' },
          { name: 'RFID Products', href: '/rfid' },
          { name: categoryName },
        ]} />
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{categoryName}</h1>
      <p class="text-xl opacity-90 max-w-3xl">
        Industrial-grade RFID tags for asset tracking, inventory management, laundry management, 
        and specialized applications. Available in various form factors and materials.
      </p>
    </div>
  </section>

  <CategoryDecisionCards categorySlug="rfid-tags" />

  <!-- Products Grid -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <p class="text-gray-600">{categoryProducts.length} products found</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {categoryProducts.map((product) => (
          <a 
            href={`/product/${product.slug}`}
            class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group"
          >
            <div class="aspect-square overflow-hidden bg-gray-100">
              <img 
                src={product.images[0]} 
                alt={`${product.name} — ${categoryName} manufactured by RFIDAK in Shenzhen, China`}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-gray-800 group-hover:text-[#0d7377] transition-colors line-clamp-2">
                {product.name}
              </h3>
              <p class="text-sm text-gray-500 mt-2 line-clamp-2">
                {product.description.substring(0, 100)}...
              </p>
              <div class="mt-4 flex items-center text-[#0d7377] text-sm font-medium">
                View Details
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Category Description - GEO: Comprehensive, authoritative content -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-800 mb-6">RFID Tag Buying Guide</h2>
        <div class="prose prose-lg text-gray-600">
          <p>
            RFID tags are electronic devices containing a microchip and antenna enclosed in a durable housing, designed for automatic identification and tracking in industrial environments. The global RFID tag market is valued at over $12 billion and growing at 11.2% CAGR. RFIDAK manufactures 20+ types of industrial RFID tags, with ruggedized designs that withstand temperatures from -40°C to +250°C, chemical exposure, and IP68 waterproofing.
          </p>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">RFID Tag Types Comparison</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse border border-gray-200 my-4">
              <thead>
                <tr class="bg-gray-100">
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Tag Type</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Material</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Temperature Range</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Best Application</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="border border-gray-200 px-4 py-2">Laundry Tag</td><td class="border border-gray-200 px-4 py-2">Silicone / PPS</td><td class="border border-gray-200 px-4 py-2">-25°C to +200°C</td><td class="border border-gray-200 px-4 py-2">Textile tracking, industrial washing</td></tr>
                <tr class="bg-gray-50"><td class="border border-gray-200 px-4 py-2">Ceramic Tag</td><td class="border border-gray-200 px-4 py-2">Ceramic</td><td class="border border-gray-200 px-4 py-2">-40°C to +250°C</td><td class="border border-gray-200 px-4 py-2">Metal surface mounting</td></tr>
                <tr><td class="border border-gray-200 px-4 py-2">Nail Tag</td><td class="border border-gray-200 px-4 py-2">ABS / Nylon</td><td class="border border-gray-200 px-4 py-2">-20°C to +85°C</td><td class="border border-gray-200 px-4 py-2">Wood, pallets, tree tracking</td></tr>
                <tr class="bg-gray-50"><td class="border border-gray-200 px-4 py-2">Tire Tag</td><td class="border border-gray-200 px-4 py-2">Rubber / Silicone</td><td class="border border-gray-200 px-4 py-2">-40°C to +120°C</td><td class="border border-gray-200 px-4 py-2">Vehicle and tire lifecycle tracking</td></tr>
                <tr><td class="border border-gray-200 px-4 py-2">PCB Tag</td><td class="border border-gray-200 px-4 py-2">FR4 PCB</td><td class="border border-gray-200 px-4 py-2">-20°C to +85°C</td><td class="border border-gray-200 px-4 py-2">Electronics, small asset tracking</td></tr>
                <tr class="bg-gray-50"><td class="border border-gray-200 px-4 py-2">Cable Tie Tag</td><td class="border border-gray-200 px-4 py-2">Nylon</td><td class="border border-gray-200 px-4 py-2">-20°C to +85°C</td><td class="border border-gray-200 px-4 py-2">Cables, pipes, outdoor assets</td></tr>
                <tr><td class="border border-gray-200 px-4 py-2">Metal Tag</td><td class="border border-gray-200 px-4 py-2">ABS + Metal</td><td class="border border-gray-200 px-4 py-2">-25°C to +85°C</td><td class="border border-gray-200 px-4 py-2">IT assets, equipment, tools</td></tr>
              </tbody>
            </table>
          </div>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">How to Choose the Right RFID Tag</h3>
          <p>Selecting the optimal RFID tag depends on your specific application requirements:</p>
          <ol class="list-decimal list-inside space-y-2 mt-3">
            <li><strong>Environment:</strong> Consider temperature extremes, chemical exposure, moisture (IP rating), and UV resistance. Ceramic and silicone tags offer the highest environmental resistance.</li>
            <li><strong>Mounting surface:</strong> Tags for metal surfaces require special anti-metal designs (ceramic, PCB, or foam-spacer tags). Standard tags lose performance on metal.</li>
            <li><strong>Read range:</strong> UHF tags (860-960MHz) provide 1-12m read range for logistics; HF tags (13.56MHz) offer 1-10cm for item-level tracking; LF tags (125KHz) work in 1-5cm range for animal or access applications.</li>
            <li><strong>Size constraints:</strong> Mini tags (as small as 5mm diameter) for electronics; standard tags (30-60mm) for general assets; large tags for pallets and containers.</li>
            <li><strong>Durability:</strong> Laundry tags survive 200+ industrial wash cycles. High-temperature tags withstand autoclave sterilization. Outdoor tags resist UV degradation for 10+ years.</li>
          </ol>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">Industry Applications</h3>
          <p>
            RFIDAK RFID tags serve diverse industries: healthcare (surgical instrument tracking, patient wristbands), automotive (tire lifecycle management across 500,000+ vehicles), manufacturing (WIP tracking on production lines), logistics (pallet and container tracking across global supply chains), hospitality (uniform and linen management for hotels processing 10,000+ items daily), and forestry (tree tagging for lumber traceability).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 bg-[#0d7377]">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Need Custom RFID Tags?</h2>
      <p class="text-white/90 mb-6 max-w-2xl mx-auto">Get free samples and a quote within 24 hours. RFIDAK offers 20+ tag types with full customization for your specific application.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={categoryContact.href} data-analytics="quote_click_category_cta_rfid-tags" class="bg-white text-[#0d7377] px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors">Request a Quote</a>
        <a href={categoryWhatsApp.href} target="_blank" rel="noopener noreferrer" data-analytics="whatsapp_click_category_cta_rfid-tags" class="border-2 border-white text-white px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <ScrollCTA contactHref={categoryContact.href} contactLabel="Get Quote" whatsappHref={categoryWhatsApp.href} source="category" />
  <ExitIntent sampleHref="/contact?intent=samples&category=rfid-tags&express=1&source=exit-intent#contactForm" whatsappHref={categoryWhatsApp.href} contextName="RFID Tags" />

  <Footer />
</Layout>
