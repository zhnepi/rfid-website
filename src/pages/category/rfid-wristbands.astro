---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryStickyNav from '../../components/CategoryStickyNav.astro';
import CategoryDecisionCards from '../../components/CategoryDecisionCards.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollCTA from '../../components/cta/ScrollCTA.astro';
import ExitIntent from '../../components/cta/ExitIntent.astro';
import { products } from '../../data/products';
import { buildCategoryJsonLd } from '../../utils/categoryJsonLd';
import { getContextualContactAction, getContextualWhatsAppAction } from '../../utils/contact';

const categoryName = 'RFID Wristbands';
const categoryProducts = products.filter(p => p.category === categoryName);
const description = "RFID wristbands from RFIDAK: silicone, fabric woven, paper, PVC, Tyvek and elastic wristbands for events, festivals, water parks and access control.";
const categoryJsonLd = buildCategoryJsonLd({ categoryName, categorySlug: 'rfid-wristbands', categoryProducts, description });
const categoryContact = getContextualContactAction(Astro.url.pathname);
const categoryWhatsApp = getContextualWhatsAppAction(Astro.url.pathname);
---

<Layout
  title="RFID Wristbands | Silicone, Fabric & Disposable Bands — RFIDAK"
  description={description}
  keywords="RFID wristband, silicone RFID wristband, RFID bracelet, NFC wristband, event wristband, waterproof RFID wristband, RFID wristband manufacturer"
  jsonLd={categoryJsonLd}
>
  <Header />
  <CategoryStickyNav activeCategory={categoryName} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-[#0d7377] to-[#0a5c5f] text-white py-16">
    <div class="container mx-auto px-4">
      <div class="mb-4">
        <Breadcrumb variant="dark" items={[
          { name: 'Home', href: '/' },
          { name: 'RFID Products', href: '/rfid' },
          { name: categoryName },
        ]} />
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{categoryName}</h1>
      <p class="text-xl opacity-90 max-w-3xl">
        Comfortable and durable RFID wristbands for events, hotels, waterparks, fitness clubs, 
        and access control applications. Waterproof and customizable.
      </p>
    </div>
  </section>

  <CategoryDecisionCards categorySlug="rfid-wristbands" />

  <!-- Products Grid -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <p class="text-gray-600">{categoryProducts.length} products found</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {categoryProducts.map((product) => (
          <a 
            href={`/product/${product.slug}`}
            class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group"
          >
            <div class="aspect-square overflow-hidden bg-gray-100">
              <img 
                src={product.images[0]} 
                alt={`${product.name} — ${categoryName} manufactured by RFIDAK in Shenzhen, China`}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-gray-800 group-hover:text-[#0d7377] transition-colors line-clamp-2">
                {product.name}
              </h3>
              <p class="text-sm text-gray-500 mt-2 line-clamp-2">
                {product.description.substring(0, 100)}...
              </p>
              <div class="mt-4 flex items-center text-[#0d7377] text-sm font-medium">
                View Details
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Downloads -->
  <section id="downloads" class="py-12 bg-white border-t border-gray-100">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="max-w-3xl mb-6">
          <p class="eyebrow-label text-[#0d7377] mb-2">Catalog Download</p>
          <h2 class="title-balance text-2xl font-bold text-gray-800 mb-3">RFID Wristband product list</h2>
          <p class="card-copy text-gray-600">Download the full RFIDAK wristband mold catalog covering 44 silicone, PVC, Tyvek, woven and elastic models with WB mold codes, dimensions, and product photos.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <a
            href="/downloads/rfidak-rfid-wristband-list-2026.pdf"
            target="_blank"
            rel="noopener noreferrer"
            download
            class="copy-safe group flex items-start gap-4 rounded-2xl border border-gray-200 bg-gray-50 p-5 hover:border-[#0d7377] hover:bg-white hover:-translate-y-0.5 transition-all"
          >
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center" aria-hidden="true">
              <svg class="h-12 w-12" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 4h22l8 8v28a4 4 0 01-4 4H10a4 4 0 01-4-4V8a4 4 0 014-4z" fill="#dc2626"/>
                <path d="M32 4v8h8L32 4z" fill="#fca5a5"/>
                <text x="24" y="33" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="10" font-weight="700">PDF</text>
              </svg>
            </span>
            <div class="min-w-0 flex-1">
              <h3 class="title-balance text-base font-semibold text-gray-800 group-hover:text-[#0d7377] transition-colors">RFIDAK RFID Wristband List 2026</h3>
              <p class="card-copy mt-1 text-sm text-gray-600">Full mold catalog: 44 wristband models across silicone, PVC, Tyvek, woven and elastic. WB mold codes, dimensions, and product photos. 13 pages.</p>
              <p class="mt-2 inline-flex items-center text-sm font-medium text-[#0d7377]">
                Download
                <span class="ml-2 text-xs text-gray-500">(794 KB)</span>
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"></path>
                </svg>
              </p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Description - GEO: Comprehensive, authoritative content -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-800 mb-6">RFID Wristband Buying Guide</h2>
        <div class="prose prose-lg text-gray-600">
          <p>
            RFID wristbands are wearable identification devices that combine an RFID chip and antenna inside a comfortable band material. The global RFID wristband market is growing at 14.8% CAGR, driven by demand from events, hospitality, and healthcare sectors. RFIDAK manufactures RFID wristbands in silicone, fabric, Tyvek, and PVC materials, all meeting international safety standards (RoHS, REACH, FDA-grade silicone).
          </p>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">RFID Wristband Types Comparison</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse border border-gray-200 my-4">
              <thead>
                <tr class="bg-gray-100">
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Material</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Durability</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Waterproof</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Best For</th>
                  <th class="border border-gray-200 px-4 py-3 text-left font-semibold text-gray-700">Reusable</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="border border-gray-200 px-4 py-2">Silicone</td><td class="border border-gray-200 px-4 py-2">Very High</td><td class="border border-gray-200 px-4 py-2">IP68</td><td class="border border-gray-200 px-4 py-2">Water parks, pools, gym memberships</td><td class="border border-gray-200 px-4 py-2">Yes (5+ years)</td></tr>
                <tr class="bg-gray-50"><td class="border border-gray-200 px-4 py-2">Fabric / Woven</td><td class="border border-gray-200 px-4 py-2">High</td><td class="border border-gray-200 px-4 py-2">Splash-proof</td><td class="border border-gray-200 px-4 py-2">Music festivals, multi-day events</td><td class="border border-gray-200 px-4 py-2">Limited</td></tr>
                <tr><td class="border border-gray-200 px-4 py-2">Tyvek (Paper)</td><td class="border border-gray-200 px-4 py-2">Low</td><td class="border border-gray-200 px-4 py-2">Water-resistant</td><td class="border border-gray-200 px-4 py-2">Single-day events, hospitals</td><td class="border border-gray-200 px-4 py-2">No (disposable)</td></tr>
                <tr class="bg-gray-50"><td class="border border-gray-200 px-4 py-2">PVC / Vinyl</td><td class="border border-gray-200 px-4 py-2">Moderate</td><td class="border border-gray-200 px-4 py-2">Waterproof</td><td class="border border-gray-200 px-4 py-2">Amusement parks, short-term access</td><td class="border border-gray-200 px-4 py-2">No</td></tr>
                <tr><td class="border border-gray-200 px-4 py-2">Nylon</td><td class="border border-gray-200 px-4 py-2">High</td><td class="border border-gray-200 px-4 py-2">Water-resistant</td><td class="border border-gray-200 px-4 py-2">VIP access, employee ID</td><td class="border border-gray-200 px-4 py-2">Yes</td></tr>
              </tbody>
            </table>
          </div>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">How to Choose the Right RFID Wristband</h3>
          <ol class="list-decimal list-inside space-y-2 mt-3">
            <li><strong>Usage duration:</strong> Disposable Tyvek bands for single-day events (lowest cost at $0.15-$0.30/pc); silicone bands for long-term membership programs (reusable for 5+ years).</li>
            <li><strong>Water exposure:</strong> IP68-rated silicone wristbands for water parks, pools, and marine environments. Fabric bands suit dry outdoor events.</li>
            <li><strong>Chip selection:</strong> NTAG213/215 for NFC tap-and-go payments; Mifare Classic 1K for access control; UHF chips for long-range crowd management.</li>
            <li><strong>Comfort and safety:</strong> All RFIDAK silicone wristbands use FDA-compliant, hypoallergenic material. Available in adult (210mm) and child (165mm) sizes with adjustable closures.</li>
            <li><strong>Branding:</strong> Full-color silkscreen printing, debossed/embossed logos, custom Pantone color matching, and individual UID laser engraving are all available.</li>
          </ol>

          <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-4">Industry Applications</h3>
          <p>
            RFID wristbands transform guest experiences across sectors: hospitality (hotel room access and resort charging for 500+ properties worldwide), events (cashless payment and crowd flow management at festivals with 50,000+ attendees), healthcare (patient identification reducing medical errors by up to 70%), fitness (gym membership and locker access), and amusement parks (ride access, fast-pass systems, and in-park spending).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 bg-[#0d7377]">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Need Custom RFID Wristbands?</h2>
      <p class="text-white/90 mb-6 max-w-2xl mx-auto">Get free samples with your logo. RFIDAK offers 10+ wristband styles with full custom branding and fast 7-day production.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={categoryContact.href} data-analytics="quote_click_category_cta_rfid-wristbands" class="bg-white text-[#0d7377] px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors">Request a Quote</a>
        <a href={categoryWhatsApp.href} target="_blank" rel="noopener noreferrer" data-analytics="whatsapp_click_category_cta_rfid-wristbands" class="border-2 border-white text-white px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <ScrollCTA contactHref={categoryContact.href} contactLabel="Get Quote" whatsappHref={categoryWhatsApp.href} source="category" />
  <ExitIntent sampleHref="/contact?intent=samples&category=rfid-wristbands&express=1&source=exit-intent#contactForm" whatsappHref={categoryWhatsApp.href} contextName="RFID Wristbands" />

  <Footer />
</Layout>
