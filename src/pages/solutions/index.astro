---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { guideLinks, evidenceLinks } from '../../data/navigation';
import { solutionPagesList } from '../../data/solutions';
import { getContextualContactAction, getContextualInquiryLabel, getSolutionContactHref, getSolutionInquiryIntent } from '../../utils/contact';

const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/solutions`;
const solutionCards = solutionPagesList.map((page) => {
  const intent = getSolutionInquiryIntent(page.slug);

  return {
    ...page,
    contactHref: getSolutionContactHref(page.slug),
    contactLabel: getContextualInquiryLabel(intent, 'solution'),
  };
});
const solutionHubAction = getContextualContactAction('/solutions');
const featuredSolution = solutionCards[0];

function getSupportingActionLabel(href: string) {
  const normalizedHref = href.split(/[?#]/)[0] || '';

  if (normalizedHref.startsWith('/blogs')) return 'Read guide';
  if (normalizedHref.startsWith('/compare')) return 'Review comparison';
  if (normalizedHref.startsWith('/solutions')) return 'Review workflow';
  if (normalizedHref.startsWith('/markets')) return 'Review market path';
  if (normalizedHref.startsWith('/products') || normalizedHref.startsWith('/rfid') || normalizedHref.startsWith('/product') || normalizedHref.startsWith('/category')) {
    return 'Browse product path';
  }
  if (
    normalizedHref.startsWith('/certifications')
    || normalizedHref.startsWith('/quality-control')
    || normalizedHref.startsWith('/sample-policy')
    || normalizedHref.startsWith('/shipping-and-incoterms')
  ) {
    return 'Review proof page';
  }

  return 'Open resource';
}

const supportingCards = [...guideLinks, ...evidenceLinks].map((link) => ({
  ...link,
  contactAction: getContextualContactAction(link.href),
  openLabel: getSupportingActionLabel(link.href),
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalURL}#collection`,
  url: canonicalURL,
  name: 'RFID Solutions And Use Cases',
  description: 'Use-case hubs for access control, hotel access, laundry tracking, asset tracking, library workflows and NFC engagement.',
  isPartOf: { '@id': `${siteURL}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: solutionPagesList.map((page, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteURL}/solutions/${page.slug}`,
      name: page.name,
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: canonicalURL },
  ],
};
---

<Layout
  title="RFID Solutions And Use Cases - Access, Hotels, Laundry, Asset Tracking and NFC | ProudTek"
  description="Explore ProudTek RFID solution hubs built around access control, hotel access, laundry and linen tracking, industrial asset tracking, library workflows and event or NFC engagement."
  keywords="RFID solutions, access control RFID, hotel RFID, laundry RFID, industrial asset tracking RFID, library RFID, NFC solutions"
  canonicalURL={canonicalURL}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-[#072a31] via-slate-900 to-[#0c4a56] py-20 text-white">
      <div class="container mx-auto px-4">
        <nav class="mb-4 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:underline">Home</a>
          <span class="mx-2">/</span>
          <span>Solutions</span>
        </nav>
        <div class="max-w-4xl">
          <p class="eyebrow-label mb-4 text-[#0e7490]">Solutions And Use Cases</p>
          <h1 class="title-balance text-4xl font-bold md:text-6xl">RFID landing pages built around the operational problem, not just the product family</h1>
          <p class="mt-6 max-w-3xl text-lg text-white/82">
            Start here when the workflow is clear but the right card, tag, label or reader path is still open. Each solution page keeps the shortlist tied to the operating problem instead of the catalog alone.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={solutionHubAction.href} class="rounded-lg bg-[#0e7490] px-6 py-3 font-semibold text-white hover:bg-[#155e75] transition-colors">
              Plan solution samples
            </a>
            {featuredSolution && (
              <a href={`/solutions/${featuredSolution.slug}`} class="rounded-lg border border-white/25 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                Start with {featuredSolution.name}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow-label mb-2 text-[#0e7490]">Current Solution Hubs</p>
          <h2 class="title-balance text-3xl font-semibold text-gray-900">High-intent RFID use cases now covered</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {solutionCards.map((page) => (
            <article class="copy-safe rounded-[1.75rem] border border-gray-200 bg-gray-50 p-6 transition-all hover:border-[#0e7490] hover:bg-white">
              <a href={`/solutions/${page.slug}`} class="block">
                <span class="eyebrow-label text-[#0e7490]">{page.heroEyebrow}</span>
                <h2 class="title-balance mt-3 text-2xl font-semibold text-gray-900">{page.name}</h2>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">{page.description}</p>
              </a>
              <div class="mt-5 flex flex-wrap items-center gap-4">
                <a href={`/solutions/${page.slug}`} class="inline-flex items-center text-sm font-semibold text-[#0e7490]">
                  Review workflow
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
                <a href={page.contactHref} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                  {page.contactLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
          <div class="copy-safe rounded-[2rem] border border-gray-200 bg-white p-8">
            <p class="eyebrow-label mb-2 text-[#0e7490]">What Buyers Confirm Here</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Use a workflow page to settle fit before you compare too many products</h2>
            <ul class="space-y-3 text-sm leading-relaxed text-gray-700">
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Start with the workflow when the operational problem is clear but the exact RFID product name still is not.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Use the linked products, proof pages and buyer guides to see which formats deserve samples first and which can be ruled out early.</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0e7490]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Move into inquiry once the workflow page has narrowed the product family enough to talk about compatibility, sample planning or rollout timing.</span>
              </li>
            </ul>
          </div>

          <div class="copy-safe rounded-[2rem] border border-[#0e7490]/15 bg-[#0e7490]/5 p-8">
            <p class="eyebrow-label mb-2 text-[#0e7490]">Supporting Pages</p>
            <h2 class="title-balance mb-4 text-3xl font-semibold text-gray-900">Guides and proof pages buyers usually check before they approve the path</h2>
            <div class="space-y-3">
              {supportingCards.map((link) => (
                <article class="copy-safe rounded-2xl border border-[#0e7490]/15 bg-white p-4 transition-colors hover:border-[#0e7490]">
                  <a href={link.href} class="block">
                    <span class="block text-sm font-semibold text-gray-800">{link.name}</span>
                    <span class="mt-1 block text-sm text-gray-500">{link.description}</span>
                  </a>
                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    <a href={link.href} class="inline-flex items-center text-sm font-semibold text-[#0e7490]">
                      {link.openLabel}
                      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                    <a href={link.contactAction.href} class="text-sm font-medium text-gray-500 transition-colors hover:text-[#0e7490]">
                      {link.contactAction.label}
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
