---
import SolutionLandingPage from '../../components/SolutionLandingPage.astro';
import { solutionPagesList } from '../../data/solutions';

export function getStaticPaths() {
  return solutionPagesList.map((page) => ({
    params: { slug: page.slug },
    props: { solutionKey: page.key },
  }));
}

const { solutionKey } = Astro.props;
---

<SolutionLandingPage solutionKey={solutionKey} />
