                    <span class="text-[#0d7377] transition-transform group-open:rotate-45">+</span>
                  </summary>
                  <p class="mt-4 text-gray-600 leading-relaxed">{faq.answer}</p>
                </details>
              ))}
            </div>
          </section>

          <section id="related-guides">
            <h2 class="text-3xl font-semibold text-gray-900 mb-5">Related pillar guides and category pages</h2>
            <div class="grid md:grid-cols-2 gap-5">
              {relatedGuides.map((item) => (
                <a href={item.href} class="copy-safe rounded-[1.75rem] border border-gray-200 bg-white p-6 hover:border-[#0d7377] hover:shadow-lg transition-all">
                  <h3 class="text-xl font-semibold text-gray-800">{item.label}</h3>
                  <p class="text-gray-600 leading-relaxed mt-3">{item.description}</p>
                </a>
              ))}
            </div>
          </section>

          <aside class="rounded-2xl border border-gray-200 bg-gray-50 p-6 md:p-7 text-sm text-gray-600">
            <div class="flex flex-wrap items-center gap-3">
              <svg class="w-5 h-5 text-[#0d7377] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <p>
                <strong class="text-gray-800">Last reviewed:</strong> {lastReviewed.date} by {lastReviewed.reviewer}.
                Sources cited inline: NXP Investor Relations 2024 (market share); IDTechEx 2024 RAIN RFID Forecasts (UHF volumes and pricing); RAIN Alliance 2024 annual report; OECD 2023 counterfeit market estimate; Garcia et al. &quot;Dismantling MIFARE Classic&quot; USENIX Security 2008; NIST CMVP #3659 FIPS 140-2 validation; NXP MIFARE / NTAG / UCODE public datasheets 2024; Impinj Monza R6 / M730 / M750 / M770 / M780 / M800 datasheets 2024. Numbers confirmed against RFIDAK 2026 production records.
              </p>
            </div>
          </aside>
        </div>
      </div>
    </article>

    <section class="py-14 bg-[#0d7377]">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Need help locking in the right chip?</h2>
        <p class="text-white/90 max-w-3xl mx-auto mb-7">
          Share your application, reader fleet, environment and target volume. We&rsquo;ll return a chip shortlist + sample request within one business day.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={chipContactHref} class="bg-white text-[#0d7377] px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Contact our engineering team
          </a>
          <a href="/rfid" class="border border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
            Browse products
          </a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
