# Website inquiry delivery
# Option A: Send website inquiries to email through Resend
# Use a verified sender domain on Resend before going live.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL="ProudTek Website <onboarding@resend.dev>"
INQUIRY_TO_EMAIL=info@proudtek.com

# Option B: Forward inquiries to a webhook / CRM automation
INQUIRY_WEBHOOK_URL=
INQUIRY_WEBHOOK_SECRET=
