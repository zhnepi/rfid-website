---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { blogPosts } from '../../data/blogs';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const relatedPosts = blogPosts
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

// Article JSON-LD
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt,
  "image": post.image,
  "datePublished": new Date(post.date).toISOString(),
  "author": {
    "@type": "Organization",
    "name": "ProudTek",
    "url": "https://www.proudtek.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ProudTek",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.proudtek.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.proudtek.com/blogs/${post.slug}`
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.proudtek.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.proudtek.com/blogs" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://www.proudtek.com/blogs/${post.slug}` }
  ]
};
---

<Layout
  title={`${post.title} | RFID Technology Blog - ProudTek`}
  description={post.metaDescription}
  keywords={post.keywords}
  ogImage={post.image}
  ogType="article"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <!-- Breadcrumb -->
    <section class="bg-gray-100 py-4">
      <div class="container mx-auto px-4">
        <nav class="text-sm text-gray-600" aria-label="Breadcrumb">
          <ol class="flex items-center flex-wrap">
            <li><a href="/" class="hover:text-[#00bcd4]">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/blogs" class="hover:text-[#00bcd4]">Blog</a></li>
            <li><span class="mx-2">/</span></li>
            <li><span class="text-gray-800 line-clamp-1">{post.title}</span></li>
          </ol>
        </nav>
      </div>
    </section>

    <!-- Article -->
    <article class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Header -->
          <header class="mb-8">
            <span class="text-[#00bcd4] text-xs uppercase tracking-wider font-medium">{post.category}</span>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mt-2 mb-4">{post.title}</h1>
            <div class="flex items-center gap-4 text-sm text-gray-500">
              <time datetime={new Date(post.date).toISOString()}>{post.date}</time>
              <span>By ProudTek</span>
            </div>
          </header>

          <!-- Featured Image -->
          <div class="aspect-[16/9] rounded-lg overflow-hidden mb-8">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover"
              width="800"
              height="450"
            />
          </div>

          <!-- Content -->
          <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed
            prose-headings:text-gray-800 prose-headings:font-semibold
            prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4
            prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
            prose-p:mb-4
            prose-ul:my-4 prose-ul:list-disc prose-ul:pl-6
            prose-li:mb-2
            prose-strong:text-gray-700"
            set:html={post.content}
          />

          <!-- CTA -->
          <div class="mt-12 p-8 bg-gray-50 rounded-lg text-center">
            <h3 class="text-xl font-semibold text-gray-800 mb-3">Need RFID Products for Your Project?</h3>
            <p class="text-gray-600 mb-6">ProudTek offers custom RFID solutions with free samples. Contact us today for expert recommendations.</p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/contact" class="bg-[#00bcd4] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#00acc1] transition-colors">
                Request a Quote
              </a>
              <a href="/rfid" class="border-2 border-[#00bcd4] text-[#00bcd4] px-6 py-3 rounded-lg font-medium hover:bg-[#00bcd4] hover:text-white transition-colors">
                Browse Products
              </a>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Posts -->
    <section class="py-12 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-800 mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map(related => (
            <a href={`/blogs/${related.slug}`} class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow group">
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={related.image}
                  alt={related.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  width="400"
                  height="250"
                />
              </div>
              <div class="p-6">
                <span class="text-[#00bcd4] text-xs uppercase tracking-wider font-medium">{related.category}</span>
                <h3 class="text-lg font-semibold text-gray-800 mt-2 group-hover:text-[#00bcd4] transition-colors line-clamp-2">{related.title}</h3>
                <span class="text-gray-400 text-sm mt-2 block">{related.date}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
