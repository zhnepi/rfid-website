---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';

const productCategories = [
  {
    id: 'card',
    name: 'RFID Cards',
    description: 'High-quality RFID cards for access control, public transportation, cashless payment, and more.',
    products: [
      { name: 'Mifare Classic 1K Card', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&q=80' },
      { name: 'Mifare DESFire EV2 Card', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&q=80' },
      { name: 'NTAG213 NFC Card', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&q=80' },
      { name: 'Dual Frequency Card', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&q=80' },
    ],
  },
  {
    id: 'keyfob',
    name: 'RFID Keyfobs',
    description: 'Durable and compact RFID keyfobs for convenient access control solutions.',
    products: [
      { name: 'ABS Keyfob', image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80' },
      { name: 'Leather Keyfob', image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80' },
      { name: 'Epoxy Keyfob', image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80' },
      { name: 'Metal Keyfob', image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80' },
    ],
  },
  {
    id: 'wristband',
    name: 'RFID Wristbands',
    description: 'Comfortable and waterproof RFID wristbands for events, hotels, and fitness clubs.',
    products: [
      { name: 'Silicone Wristband', image: 'https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=400&q=80' },
      { name: 'Fabric Wristband', image: 'https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=400&q=80' },
      { name: 'Disposable Wristband', image: 'https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=400&q=80' },
      { name: 'PVC Wristband', image: 'https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=400&q=80' },
    ],
  },
  {
    id: 'laundry-tag',
    name: 'RFID Laundry Tags',
    description: 'Heat-resistant and durable RFID tags for laundry management and tracking.',
    products: [
      { name: 'Textile Laundry Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'Silicone Laundry Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'PPS Laundry Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'Flexible Laundry Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
    ],
  },
  {
    id: 'reader-writer',
    name: 'RFID Readers & Writers',
    description: 'Professional RFID reader/writer devices for various applications.',
    products: [
      { name: 'Desktop Reader', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80' },
      { name: 'USB Reader', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80' },
      { name: 'Long Range Reader', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80' },
      { name: 'Handheld Reader', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80' },
    ],
  },
  {
    id: 'metal-tag',
    name: 'RFID Metal Tags',
    description: 'Anti-metal RFID tags designed for tracking metal assets and equipment.',
    products: [
      { name: 'PCB Anti-metal Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'Ceramic Anti-metal Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'ABS Anti-metal Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
      { name: 'Flexible Anti-metal Tag', image: 'https://images.unsplash.com/photo-1558171813-4c088753af8f?w=400&q=80' },
    ],
  },
];
---

<Layout title="RFID Products - ProudTek">
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="bg-[#00bcd4] py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-script text-white">RFID Products</h1>
        <p class="text-white/80 mt-4 max-w-2xl mx-auto">
          Explore our comprehensive range of RFID products designed for various applications
        </p>
      </div>
    </section>
    
    <!-- Products Section -->
    {productCategories.map((category) => (
      <section id={category.id} class="py-16 odd:bg-white even:bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-semibold text-gray-800 mb-4">{category.name}</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">{category.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {category.products.map((product) => (
              <div class="product-card bg-white rounded-lg overflow-hidden shadow-lg">
                <div class="aspect-square overflow-hidden">
                  <img 
                    src={product.image} 
                    alt={product.name}
                    class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
                  />
                </div>
                <div class="p-4">
                  <h3 class="text-lg font-medium text-gray-800 text-center">{product.name}</h3>
                </div>
              </div>
            ))}
          </div>
          
          <div class="text-center mt-8">
            <a 
              href="/contact" 
              class="inline-block bg-[#00bcd4] text-white px-8 py-3 rounded hover:bg-[#00acc1] transition-colors font-medium"
            >
              Request Quote
            </a>
          </div>
        </div>
      </section>
    ))}
    
    <Newsletter />
  </main>
  <Footer />
</Layout>
