---
const testimonials = [
  {
    quote: "We would hate to go to another supplier, as we prefer doing business with Proud Tek! We are very satisfied with your company! It is always a pleasure to do business with you.",
    name: "Sladjan M.",
    title: "CEO",
    company: "Security Solutions",
    country: "Serbia",
    rating: 5,
  },
  {
    quote: "Your cards and keyfobs are selling very well here in Brazil. After this order is ready, I will probably place another order of 50k or 100k for each card type and keyfobs.",
    name: "Claudio R.",
    title: "Director",
    company: "RFID Distributor",
    country: "Brazil",
    rating: 5,
  },
  {
    quote: "I am very excited to say the cards worked perfectly with our system. The readers entered the required information into our software program and enrolment of users is very easy and quick. Thanks so much for all your help!",
    name: "James W.",
    title: "Project Engineer",
    company: "Access Systems Ltd",
    country: "Australia",
    rating: 5,
  },
  {
    quote: "ProudTek delivered 200,000 RFID laundry tags on time with zero defects. Their quality control is exceptional and pricing is very competitive. We have been working together for 5 years now.",
    name: "Ahmed K.",
    title: "Procurement Manager",
    company: "Industrial Laundry Group",
    country: "UAE",
    rating: 5,
  },
  {
    quote: "The NFC wristbands worked flawlessly at our music festival with 30,000 attendees. Custom printing quality was excellent. ProudTek is now our go-to supplier for all event RFID products.",
    name: "Maria L.",
    title: "Operations Director",
    company: "Event Tech Solutions",
    country: "Mexico",
    rating: 5,
  },
];
---

<section class="py-16 bg-gray-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-semibold text-gray-800">What Our Clients Say</h2>
    </div>

    <div class="relative max-w-4xl mx-auto" role="region" aria-roledescription="carousel" aria-label="Client testimonials">
      <!-- Testimonial Slider -->
      <div id="testimonial-slider" class="overflow-hidden">
        <div id="testimonial-track" class="flex transition-transform duration-500" aria-live="off">
          {testimonials.map((testimonial) => (
            <div class="testimonial-slide w-full flex-shrink-0 px-4" role="group" aria-roledescription="slide" aria-label={`Testimonial from ${testimonial.name}, ${testimonial.company}`}>
              <div class="bg-white rounded-lg p-8 shadow-lg">
                <!-- Stars -->
                <div class="flex gap-1 mb-4" role="img" aria-label={`Rating: ${testimonial.rating} out of 5 stars`}>
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                    </svg>
                  ))}
                </div>
                <div class="border-l-4 border-primary pl-6">
                  <p class="text-gray-700 text-lg italic leading-relaxed mb-6">
                    "{testimonial.quote}"
                  </p>
                </div>
                <div class="mt-6 flex items-center gap-4">
                  <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white font-bold text-lg">
                    {testimonial.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-gray-800">{testimonial.name}</p>
                    <p class="text-sm text-gray-500">{testimonial.title}, {testimonial.company}</p>
                    <p class="text-xs text-gray-400">{testimonial.country}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Buttons -->
      <button
        id="testimonial-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-white shadow-lg p-3 rounded-full hover:bg-gray-50 transition-colors z-10"
        aria-label="Previous testimonial"
      >
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        id="testimonial-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-white shadow-lg p-3 rounded-full hover:bg-gray-50 transition-colors z-10"
        aria-label="Next testimonial"
      >
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('testimonial-track');
  const slider = document.getElementById('testimonial-slider');
  const slides = document.querySelectorAll('.testimonial-slide');
  const prevBtn = document.getElementById('testimonial-prev');
  const nextBtn = document.getElementById('testimonial-next');
  let currentIndex = 0;
  let autoPlayInterval: ReturnType<typeof setInterval>;

  function updateSlider() {
    if (track) {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
    }
  }

  function startAutoPlay() {
    autoPlayInterval = setInterval(() => {
      currentIndex = (currentIndex + 1) % slides.length;
      updateSlider();
    }, 6000);
  }

  function stopAutoPlay() {
    clearInterval(autoPlayInterval);
  }

  prevBtn?.addEventListener('click', () => {
    stopAutoPlay();
    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
    updateSlider();
    startAutoPlay();
  });

  nextBtn?.addEventListener('click', () => {
    stopAutoPlay();
    currentIndex = (currentIndex + 1) % slides.length;
    updateSlider();
    startAutoPlay();
  });

  // Pause on hover for accessibility (WCAG 2.2.2)
  slider?.addEventListener('mouseenter', stopAutoPlay);
  slider?.addEventListener('mouseleave', startAutoPlay);
  slider?.addEventListener('focusin', stopAutoPlay);
  slider?.addEventListener('focusout', startAutoPlay);

  startAutoPlay();
</script>
