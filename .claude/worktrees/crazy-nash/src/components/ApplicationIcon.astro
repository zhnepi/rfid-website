---
/**
 * ApplicationIcon - Maps application text to a relevant SVG icon
 * Uses keyword matching to find the best icon for each application
 */
interface Props {
  application: string;
  size?: number;
}

const { application, size = 48 } = Astro.props;

const text = application.toLowerCase();

// Determine icon category based on keywords
function getIconCategory(t: string): string {
  if (t.includes('access control') || t.includes('door') || t.includes('building access') || t.includes('residential access') || t.includes('gated community') || t.includes('office building') || t.includes('security')) return 'access';
  if (t.includes('hospital') || t.includes('healthcare') || t.includes('medical') || t.includes('patient') || t.includes('surgical') || t.includes('sterilization')) return 'healthcare';
  if (t.includes('warehouse') || t.includes('logistics') || t.includes('supply chain') || t.includes('shipping') || t.includes('distribution') || t.includes('cross-docking') || t.includes('cold chain')) return 'logistics';
  if (t.includes('retail') || t.includes('store') || t.includes('shopping') || t.includes('inventory') || t.includes('stock') || t.includes('shelf')) return 'retail';
  if (t.includes('manufacturing') || t.includes('production') || t.includes('factory') || t.includes('industrial') || t.includes('work-in-progress') || t.includes('injection mold')) return 'manufacturing';
  if (t.includes('automotive') || t.includes('vehicle') || t.includes('car') || t.includes('fleet') || t.includes('tire') || t.includes('tyre') || t.includes('parking') || t.includes('highway') || t.includes('toll')) return 'automotive';
  if (t.includes('hotel') || t.includes('resort') || t.includes('hospitality') || t.includes('spa') || t.includes('guest')) return 'hotel';
  if (t.includes('library') || t.includes('book') || t.includes('archive') || t.includes('document') || t.includes('file') || t.includes('museum')) return 'library';
  if (t.includes('laundry') || t.includes('linen') || t.includes('textile') || t.includes('garment') || t.includes('uniform') || t.includes('wash') || t.includes('cleanroom')) return 'laundry';
  if (t.includes('pet') || t.includes('animal') || t.includes('livestock') || t.includes('wildlife') || t.includes('fish') || t.includes('aquaculture') || t.includes('veterinary')) return 'animal';
  if (t.includes('payment') || t.includes('cashless') || t.includes('e-wallet') || t.includes('transit') || t.includes('contactless') || t.includes('pay-as-you')) return 'payment';
  if (t.includes('event') || t.includes('festival') || t.includes('concert') || t.includes('theme park') || t.includes('attraction') || t.includes('ticket') || t.includes('badge')) return 'event';
  if (t.includes('school') || t.includes('campus') || t.includes('university') || t.includes('student') || t.includes('education')) return 'education';
  if (t.includes('jewelry') || t.includes('jewellery') || t.includes('luxury') || t.includes('watch') || t.includes('fashion') || t.includes('clothing') || t.includes('apparel')) return 'jewelry';
  if (t.includes('nfc') || t.includes('smart') || t.includes('phone') || t.includes('tap')) return 'nfc';
  if (t.includes('tool') || t.includes('equipment') || t.includes('machinery') || t.includes('instrument') || t.includes('it asset') || t.includes('server')) return 'tool';
  if (t.includes('food') || t.includes('restaurant') || t.includes('dining') || t.includes('chef') || t.includes('kitchen')) return 'food';
  if (t.includes('waste') || t.includes('recycling') || t.includes('bin') || t.includes('trash') || t.includes('garbage')) return 'waste';
  if (t.includes('tree') || t.includes('forest') || t.includes('wood') || t.includes('lumber') || t.includes('concrete') || t.includes('construction') || t.includes('railway') || t.includes('pole')) return 'construction';
  if (t.includes('water park') || t.includes('swimming') || t.includes('pool') || t.includes('waterproof')) return 'water';
  if (t.includes('gym') || t.includes('fitness') || t.includes('wearable')) return 'fitness';
  if (t.includes('authentication') || t.includes('anti-counterfeiting') || t.includes('tamper') || t.includes('counterfeit') || t.includes('seal')) return 'auth';
  if (t.includes('gas cylinder') || t.includes('utility') || t.includes('fire extinguisher') || t.includes('meter')) return 'utility';
  if (t.includes('gaming') || t.includes('casino') || t.includes('gambling') || t.includes('chip') || t.includes('toy')) return 'gaming';
  if (t.includes('military') || t.includes('government') || t.includes('defense') || t.includes('correctional') || t.includes('prison')) return 'government';
  if (t.includes('airline') || t.includes('cruise') || t.includes('travel') || t.includes('ski')) return 'travel';
  if (t.includes('keyfob') || t.includes('key fob') || t.includes('keychain') || t.includes('key') || t.includes('ignition') || t.includes('immobilizer')) return 'key';
  if (t.includes('card') || t.includes('pvc') || t.includes('pet card') || t.includes('combi') || t.includes('membership') || t.includes('loyalty')) return 'card';
  if (t.includes('wristband') || t.includes('silicone') || t.includes('bracelet')) return 'wristband';
  if (t.includes('pcb') || t.includes('circuit') || t.includes('solder') || t.includes('oem') || t.includes('integration') || t.includes('embed')) return 'electronic';
  if (t.includes('pharmaceutical') || t.includes('medicine') || t.includes('drug')) return 'pharma';
  if (t.includes('wine') || t.includes('bottle') || t.includes('beverage')) return 'bottle';
  if (t.includes('packaging') || t.includes('label') || t.includes('sticker')) return 'package';
  if (t.includes('reader') || t.includes('kiosk') || t.includes('terminal') || t.includes('self-service')) return 'reader';
  if (t.includes('pallet') || t.includes('crate') || t.includes('container') || t.includes('drum')) return 'pallet';
  if (t.includes('lab') || t.includes('sample') || t.includes('test tube') || t.includes('research')) return 'lab';
  if (t.includes('furniture') || t.includes('chair') || t.includes('table') || t.includes('desk') || t.includes('cabinet')) return 'furniture';
  if (t.includes('mining') || t.includes('steel') || t.includes('foundry') || t.includes('aerospace')) return 'heavy_industry';
  if (t.includes('marketing') || t.includes('promotion') || t.includes('advertising') || t.includes('poster') || t.includes('brand')) return 'marketing';
  if (t.includes('gift') || t.includes('voucher') || t.includes('corporate')) return 'gift';
  if (t.includes('vending') || t.includes('machine')) return 'vending';
  if (t.includes('insurance') || t.includes('bank') || t.includes('finance') || t.includes('claim') || t.includes('loan')) return 'finance';
  if (t.includes('safe') || t.includes('lock')) return 'lock';
  if (t.includes('home') || t.includes('automation')) return 'home';
  if (t.includes('art') || t.includes('collectible') || t.includes('display')) return 'art';
  return 'default';
}

const category = getIconCategory(text);
