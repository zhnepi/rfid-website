---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - ProudTek RFID" noindex={true}>
  <Header />
  <main class="flex-1 flex items-center justify-center py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-8xl font-bold text-primary mb-4">404</h1>
      <h2 class="text-3xl font-semibold text-gray-800 mb-4">Page Not Found</h2>
      <p class="text-gray-600 mb-8 max-w-lg mx-auto">
        Sorry, the page you are looking for doesn't exist or has been moved.
        Please check the URL or navigate to our popular pages below.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors">
          Go to Homepage
        </a>
        <a href="/rfid" class="border-2 border-primary text-primary px-6 py-3 rounded-lg font-medium hover:bg-primary hover:text-white transition-colors">
          Browse Products
        </a>
        <a href="/contact" class="border-2 border-gray-300 text-gray-600 px-6 py-3 rounded-lg font-medium hover:border-gray-400 hover:text-gray-800 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
