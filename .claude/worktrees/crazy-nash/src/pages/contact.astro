---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactInfo = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>`,
    title: 'Address',
    content: 'A2109, Zhantao Science & Tech Park, Minzhi Ave, Longhua District, Shenzhen, 518131, China',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
    </svg>`,
    title: 'Phone',
    content: '0086-755-2376 5843',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
    </svg>`,
    title: 'E-Mail',
    content: 'info@proudtek.com',
  },
  {
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>`,
    title: 'WhatsApp',
    content: '0086-18665820632',
  },
  {
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
    </svg>`,
    title: 'Skype',
    content: 'Luckycathy2',
  },
];
---

<Layout
  title="Contact ProudTek - Get RFID Product Quotes & Custom Solutions | Free Samples"
  description="Contact ProudTek for RFID cards, tags, wristbands quotes and custom RFID solutions. Located in Shenzhen, China. Email: info@proudtek.com, WhatsApp: +86-18665820632. Free samples available."
  keywords="contact RFID manufacturer, RFID quote, custom RFID order, ProudTek contact, RFID sample request"
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="bg-primary py-16">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-3">Get in Touch</h1>
        <p class="text-white/80 text-lg max-w-xl mx-auto">Request a quote, free samples, or discuss your custom RFID project.</p>
      </div>
    </section>

    <!-- Quick Action Buttons -->
    <section class="bg-gray-50 border-b border-gray-100">
      <div class="container mx-auto px-4">
        <div class="flex flex-col sm:flex-row gap-4 py-6 justify-center max-w-2xl mx-auto">
          <a
            href="https://wa.me/8618665820632?text=Hi%20ProudTek%2C%20I%27m%20interested%20in%20your%20RFID%20products.%20Can%20you%20help%20me%3F"
            target="_blank"
            class="flex items-center justify-center gap-3 bg-whatsapp text-white px-6 py-3.5 rounded-lg font-semibold hover:bg-whatsapp-dark transition-all shadow-md hover:shadow-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Us Now
          </a>
          <a
            href="mailto:info@proudtek.com?subject=RFID%20Product%20Inquiry"
            class="flex items-center justify-center gap-3 bg-white text-gray-700 px-6 py-3.5 rounded-lg font-semibold hover:bg-gray-100 transition-all shadow-md hover:shadow-lg border border-gray-200"
          >
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Email Us
          </a>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Contact Info -->
          <div class="lg:col-span-2">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Contact Information</h2>
            <p class="text-gray-600 mb-8">
              Reach out to us for product quotes, custom solutions, or free sample requests. Our team typically responds within 2-4 business hours.
            </p>

            <div class="space-y-5">
              {contactInfo.map((info) => (
                <div class="flex items-start gap-4 p-3 rounded-lg hover:bg-gray-50 transition-colors">
                  <div class="text-primary flex-shrink-0 mt-0.5 bg-cyan-50 p-2 rounded-lg" set:html={info.icon}></div>
                  <div>
                    <h3 class="font-semibold text-gray-800 text-sm uppercase tracking-wide">{info.title}</h3>
                    <p class="text-gray-600 mt-0.5">{info.content}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- Business Hours -->
            <div class="mt-8 p-5 bg-cyan-50 rounded-xl border border-cyan-100">
              <h3 class="font-semibold text-gray-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Business Hours (China Standard Time)
              </h3>
              <div class="space-y-1.5 text-sm text-gray-600">
                <p class="flex justify-between"><span>Monday - Friday:</span> <span class="font-medium text-gray-800">9:00 AM - 6:00 PM</span></p>
                <p class="flex justify-between"><span>Saturday:</span> <span class="font-medium text-gray-800">9:00 AM - 12:00 PM</span></p>
                <p class="flex justify-between"><span>Sunday:</span> <span class="text-gray-400">Closed</span></p>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <div class="bg-gray-50 rounded-2xl p-6 md:p-8 shadow-sm border border-gray-100">
              <h2 class="text-2xl font-bold text-gray-900 mb-1">Send Us a Message</h2>
              <p class="text-gray-500 text-sm mb-6">Fill out the form below and we'll get back to you shortly.</p>

              <form id="contactForm" class="space-y-5" aria-label="Contact inquiry form">
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Your Name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder="John Smith"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      placeholder="john@company.com"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white"
                    />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">Company Name</label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      placeholder="Your Company"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white"
                    />
                  </div>
                  <div>
                    <label for="product" class="block text-sm font-medium text-gray-700 mb-1.5">Product Interest</label>
                    <select
                      id="product"
                      name="product"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white text-gray-700"
                    >
                      <option value="">Select a product category</option>
                      <option value="RFID Cards">RFID Cards</option>
                      <option value="RFID Tags">RFID Tags (Industrial)</option>
                      <option value="RFID Labels">RFID Labels & Stickers</option>
                      <option value="RFID Wristbands">RFID Wristbands</option>
                      <option value="RFID Key Fobs">RFID Key Fobs</option>
                      <option value="RFID Readers">RFID Readers</option>
                      <option value="Custom Solution">Custom RFID Solution</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label for="subject" class="block text-sm font-medium text-gray-700 mb-1.5">Subject <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    placeholder="e.g., Request quote for 10,000 RFID cards"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white"
                  />
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-red-500">*</span></label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                    placeholder="Tell us about your project requirements, quantities needed, customization details..."
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors resize-none bg-white"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full bg-primary text-white py-3.5 rounded-lg font-semibold hover:bg-primary-dark transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                  </svg>
                  Send Inquiry
                </button>
              </form>

              <!-- Success Message -->
              <div id="successMessage" class="hidden mt-6 p-6 bg-green-50 border border-green-200 rounded-xl text-center" role="alert" aria-live="assertive">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-green-800 mb-2">Message Sent Successfully!</h3>
                <p class="text-green-600 text-sm">Thank you for your inquiry. Our team will respond within 2-4 business hours. For urgent requests, please contact us via WhatsApp.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const successMessage = document.getElementById('successMessage');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const name = formData.get('name') as string;
        const email = formData.get('email') as string;
        const company = formData.get('company') as string;
        const product = formData.get('product') as string;
        const subject = formData.get('subject') as string;
        const message = formData.get('message') as string;

        // Build email body
        let body = `Name: ${name}\n`;
        body += `Email: ${email}\n`;
        if (company) body += `Company: ${company}\n`;
        if (product) body += `Product Interest: ${product}\n`;
        body += `\nMessage:\n${message}`;

        // Open mailto
        const mailtoLink = `mailto:info@proudtek.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.location.href = mailtoLink;

        // Show success message
        if (successMessage) {
          form.style.display = 'none';
          successMessage.classList.remove('hidden');
        }
      });
    }
  });
</script>
