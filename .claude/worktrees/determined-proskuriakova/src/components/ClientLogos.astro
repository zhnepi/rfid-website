---
const stats = [
  { number: '108+', label: 'Global Clients' },
  { number: '50+', label: 'Countries Served' },
  { number: '15+', label: 'Years Experience' },
  { number: '46+', label: 'Product Models' },
];

const industries = [
  'Public Transit', 'Hotels & Resorts', 'Hospitals', 'Libraries',
  'Retail Chains', 'Industrial Laundry', 'Events & Festivals', 'Smart Buildings',
  'Logistics', 'Automotive', 'Education', 'Government',
];
---

<section class="py-12 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-8">
      <p class="text-[#00bcd4] text-sm uppercase tracking-widest mb-2">Trusted Worldwide</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-800">Serving Clients in 50+ Countries</h2>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-10 max-w-4xl mx-auto">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-[#00bcd4]">{stat.number}</p>
          <p class="text-sm text-gray-500 mt-1">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Industries Served -->
    <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
      {industries.map((industry) => (
        <span class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm text-gray-600 font-medium">
          {industry}
        </span>
      ))}
    </div>
  </div>
</section>
