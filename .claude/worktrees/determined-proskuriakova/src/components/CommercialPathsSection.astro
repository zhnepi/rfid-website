---
import { getIntentContactHref } from '../utils/contact';

const buyingPaths = [
  {
    eyebrow: 'Compatibility First',
    title: 'Replacing an existing RFID card, tag or label',
    description: 'Best for buyers who already have a working credential and need a compatible manufacturer for sampling, repeat supply or cost optimization.',
    bullets: [
      'Share your current reader model or a photo of the working credential.',
      'We help narrow the closest chip, material and form-factor match.',
      'Sample approval comes before print, encoding or bulk planning.',
    ],
    href: getIntentContactHref('compatibility'),
    cta: 'Ask for a matching sample',
  },
  {
    eyebrow: 'OEM Project',
    title: 'Launching a custom RFID product or branded program',
    description: 'Useful for teams that need custom print, UID numbering, encoding, packaging or special materials for a new rollout.',
    bullets: [
      'Start with the application, quantity and target delivery window.',
      'Add artwork, numbering logic and any encoding requirement.',
      'Move from proofing into samples and then repeatable mass production.',
    ],
    href: '/products',
    cta: 'Explore product families',
  },
  {
    eyebrow: 'Sampling Plan',
    title: 'Shortlisting 2 to 3 options before committing',
    description: 'A practical route for importers, distributors and integrators who want to compare a few close variants in the real workflow.',
    bullets: [
      'Compare nearby materials, chip families or installation methods.',
      'Validate in the real reader, surface and operating environment.',
      'Use the test result to remove risk before bulk purchasing.',
    ],
    href: '/blogs',
    cta: 'Read buyer guides',
  },
  {
    eyebrow: 'Repeat Supply',
    title: 'Moving a proven SKU into stable recurring procurement',
    description: 'Designed for teams that already know what works and now care most about quality consistency, lead time and clean reorder communication.',
    bullets: [
      'Lock the approved sample and production notes first.',
      'Keep numbering, packaging and shipment expectations consistent.',
      'Use fast quote paths for repeatable SKUs and scheduled replenishment.',
    ],
    href: getIntentContactHref('repeat-order'),
    cta: 'Plan a repeat order',
  },
];

const marketSignals = [
  {
    title: 'North America',
    description: 'Buyers here often focus on access-control replacement cards, durable asset tags and clear sample validation before wider rollout.',
  },
  {
    title: 'Europe',
    description: 'Common conversations include NFC-ready labels, premium hotel cards, eco-look materials and repeat OEM packaging standards.',
  },
  {
    title: 'Middle East and Africa',
    description: 'Projects often center on hospitality, residential access, event credentials and rugged products that handle demanding daily use.',
  },
  {
    title: 'Southeast Asia and Oceania',
    description: 'Typical requests include resorts, events, logistics visibility, campus programs and scalable custom production for growing deployments.',
  },
];
---

<section class="py-20 bg-gray-50 border-y border-gray-100">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mb-10">
      <p class="eyebrow-label eyebrow-label-wide text-[#c9a84c] mb-2">Commercial Paths</p>
      <h2 class="title-balance text-3xl md:text-4xl font-semibold text-gray-900">Choose the fastest route to samples, pricing, or repeat supply</h2>
      <p class="card-copy text-gray-600 mt-4 max-w-3xl">
        Start with the path that matches what still needs confirming first: compatibility, customization, sample planning, or repeat procurement. Each route is designed to help buyers send a more useful inquiry faster.
      </p>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
      {buyingPaths.map((path) => (
        <a
          href={path.href}
          class="brand-panel brand-panel-link copy-safe group p-7"
        >
          <p class="eyebrow-label text-[#c9a84c]">{path.eyebrow}</p>
          <h3 class="title-balance text-2xl font-semibold text-gray-900 mt-4">{path.title}</h3>
          <p class="card-copy text-gray-600 mt-3">{path.description}</p>
          <ul class="mt-5 space-y-2">
            {path.bullets.map((bullet) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <svg class="w-4 h-4 text-[#c9a84c] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <span class="accent-link mt-6 inline-flex items-center text-sm">
            {path.cta}
            <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="brand-panel-dark mt-12 px-7 py-8 text-white">
      <div class="grid lg:grid-cols-[0.82fr_1.18fr] gap-8 items-start">
        <div>
          <p class="eyebrow-label text-[#c9a84c] mb-2">Market Signals</p>
          <h3 class="title-balance text-2xl font-semibold">Regional buying signals that often shape the first inquiry</h3>
          <p class="card-copy text-white/75 mt-3">
            Use these signals when approval style, packaging expectations, or pilot requirements matter as much as the product family.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {marketSignals.map((market) => (
            <div class="copy-safe rounded-2xl border border-white/10 bg-white/5 p-5">
              <h4 class="title-balance text-lg font-semibold text-white">{market.title}</h4>
              <p class="card-copy text-sm text-white/75 mt-2">{market.description}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="mt-7 flex flex-wrap gap-4">
        <a href={getIntentContactHref('samples')} class="cta-primary">
          Send a sample or quote inquiry
        </a>
        <a href="/blogs/how-to-order-rfid-cards-from-china" class="cta-secondary-dark">
          Read the sourcing guide
        </a>
      </div>
    </div>
  </div>
</section>
