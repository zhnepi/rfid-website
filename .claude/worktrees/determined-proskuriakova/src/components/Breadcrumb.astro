---
export interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  variant?: 'light' | 'dark';
}

const { items, variant = 'light' } = Astro.props;
const linkClass = variant === 'dark' ? 'hover:underline' : 'hover:text-[#c9a84c]';
const textClass = variant === 'dark' ? 'text-white/70' : 'text-gray-600';
const activeClass = variant === 'dark' ? 'text-white' : 'text-gray-800';
const separatorClass = variant === 'dark' ? 'text-white/40' : 'text-gray-400';
---

<nav class={`text-sm ${textClass}`} aria-label="Breadcrumb">
  <ol class="flex items-center flex-wrap" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, index) => (
      <li
        class="flex items-center"
        itemprop="itemListElement"
        itemscope
        itemtype="https://schema.org/ListItem"
      >
        {index > 0 && <span class={`mx-2 ${separatorClass}`}>/</span>}
        {item.href ? (
          <a href={item.href} class={linkClass} itemprop="item">
            <span itemprop="name">{item.name}</span>
          </a>
        ) : (
          <span class={`${activeClass} copy-safe line-clamp-1`} itemprop="name">{item.name}</span>
        )}
        <meta itemprop="position" content={String(index + 1)} />
      </li>
    ))}
  </ol>
</nav>
