---
import ComparisonLandingPage from '../../components/ComparisonLandingPage.astro';
import { comparisonPagesList } from '../../data/comparisons';

export function getStaticPaths() {
  return comparisonPagesList.map((page) => ({
    params: { slug: page.slug },
    props: { comparisonKey: page.key },
  }));
}

const { comparisonKey } = Astro.props;
---

<ComparisonLandingPage comparisonKey={comparisonKey} />
