---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { blogPosts } from '../../data/blogs';
import { blogFaqs, getClusterRelatedSlugs } from '../../data/blogSeo';
import { getAuthorById } from '../../data/authors';
import { addHeadingAnchors, estimateReadingTime, truncateText } from '../../utils/content';
import { getBlogComparisonLinks } from '../../utils/comparisons';
import {
  getBlogContactHref,
  getBlogInquiryIntent,
  getComparisonContactHref,
  getContextualInquiryLabel,
} from '../../utils/contact';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { content, headings } = addHeadingAnchors(post.content);
const { wordCount, readingTime } = estimateReadingTime(post.content);
const publishedIso = new Date(post.date).toISOString();
const modifiedIso = post.updatedDate ? new Date(post.updatedDate).toISOString() : undefined;
const siteURL = 'https://www.proudtek.com';
const canonicalURL = `${siteURL}/blogs/${post.slug}`;
const author = getAuthorById(post.authorId || 'proudtek-rfid-editorial-team');
const comparisonLinks = getBlogComparisonLinks(post.slug, post.category, 3);
const blogContactHref = getBlogContactHref(post);
const blogInquiryLabel = getContextualInquiryLabel(getBlogInquiryIntent(post), 'blog');
const faqItems = blogFaqs[post.slug] || [];
const clusterRelatedSlugs = [...new Set(getClusterRelatedSlugs(post.slug))];
const clusterPriority = new Map(clusterRelatedSlugs.map((slug, index) => [slug, index]));
const clusterPosts = clusterRelatedSlugs
  .map((slug) => blogPosts.find((item) => item.slug === slug))
  .filter((item): item is (typeof blogPosts)[number] => Boolean(item))
  .slice(0, 4);

const relatedPosts = [...blogPosts]
  .filter((item) => item.slug !== post.slug)
  .sort((a, b) => {
    const inClusterDiff = Number(clusterPriority.has(b.slug)) - Number(clusterPriority.has(a.slug));

    if (inClusterDiff !== 0) {
      return inClusterDiff;
    }

    const clusterOrderDiff = (clusterPriority.get(a.slug) ?? 999) - (clusterPriority.get(b.slug) ?? 999);

    if (clusterOrderDiff !== 0) {
      return clusterOrderDiff;
    }

    const sameCategoryScore = Number(b.category === post.category) - Number(a.category === post.category);

    if (sameCategoryScore !== 0) {
      return sameCategoryScore;
    }

    return new Date(b.date).getTime() - new Date(a.date).getTime();
  })
  .slice(0, 3);

function getBlogCtaContent(slug: string) {
  if (slug.includes('dpp') || slug.includes('passport') || slug.includes('sunrise-2027') || slug.includes('anti-counterfeit')) {
    return {
      title: 'Turn this identity strategy into a tag shortlist',
      description:
        'Best for teams deciding between QR, NFC and RFID and now needing help with tag placement, material fit, sample options or pilot scope.',
      primaryLabel: 'Plan DPP and NFC samples',
      secondaryHref: '/category/rfid-labels',
      secondaryLabel: 'Browse RFID and NFC labels',
    };
  }

  if (slug.includes('food') || slug.includes('fresh-food')) {
    return {
      title: 'Build a practical food-traceability pilot',
      description:
        'Send your packaging material, cold-chain conditions and read points and we can narrow the right label path for a first pilot.',
      primaryLabel: 'Request traceability samples',
      secondaryHref: '/product/uhf-sticker',
      secondaryLabel: 'View UHF label options',
    };
  }

  if (slug.includes('pharma') || slug.includes('dscsa') || slug.includes('medical-device') || slug.includes('udi')) {
    return {
      title: 'Discuss a regulated RFID workflow before you sample',
      description:
        'Use this next step when the project touches UDI, DSCSA or other controlled environments and the team needs a safer pilot path.',
      primaryLabel: 'Discuss a regulated pilot',
      secondaryHref: '/category/rfid-readers',
      secondaryLabel: 'Review readers and labels',
    };
  }

  if (slug.includes('baggage') || slug.includes('returns') || slug.includes('retail')) {
    return {
      title: 'Map the right operational tracking setup',
      description:
        'Best for airports, retailers and operations teams that already understand the use case and now need the right labels, readers and checkpoint flow.',
      primaryLabel: 'Plan an operations pilot',
      secondaryHref: '/category/rfid-labels',
      secondaryLabel: 'Browse tracking labels',
    };
  }

  return {
    title: 'Need help turning this guidance into a product shortlist?',
    description:
      'Use this next step when the article has narrowed the direction and you now need help choosing chips, formats, samples or the closest product family.',
    primaryLabel: blogInquiryLabel,
    secondaryHref: '/rfid',
    secondaryLabel: 'Browse products',
  };
}

function getResourceLinks(slug: string, category: string) {
  if (slug.includes('dpp') || slug.includes('passport') || slug.includes('sunrise-2027')) {
    return [
      { href: '/category/rfid-labels', label: 'RFID labels for DPP and retail', description: 'Compare UHF and NFC-ready label paths for product passport and retail identity programs.' },
      { href: '/product/nfc-sticker', label: 'NFC sticker product', description: 'See a smartphone-readable tag option for DPP, authentication and service journeys.' },
      { href: blogContactHref, label: 'Ask about DPP sampling', description: 'Share your carrier choice, placement and use case to narrow the right sample set.' },
    ];
  }

  if (slug.includes('food') || slug.includes('fresh-food')) {
    return [
      { href: '/category/rfid-labels', label: 'Moisture-ready RFID labels', description: 'Browse label formats suited to grocery, carton and cold-chain workflows.' },
      { href: '/product/uhf-sticker', label: 'UHF sticker product', description: 'Review a label-style product option for faster pilots and packaging tests.' },
      { href: blogContactHref, label: 'Request food-traceability samples', description: 'Send your packaging material, temperature and read points for a shortlist.' },
    ];
  }

  if (slug.includes('pharma') || slug.includes('dscsa') || slug.includes('medical-device') || slug.includes('udi')) {
    return [
      { href: '/category/rfid-labels', label: 'RFID labels for regulated workflows', description: 'Compare label paths for packaging, kits and controlled operational pilots.' },
      { href: '/category/rfid-readers', label: 'Reader hardware options', description: 'Useful when the pilot also needs encoding, desktop read or workflow validation.' },
      { href: blogContactHref, label: 'Discuss a regulated pilot', description: 'Share your device, packaging or warehouse workflow to narrow the next sample step.' },
    ];
  }

  if (slug.includes('baggage') || slug.includes('returns') || slug.includes('retail')) {
    return [
      { href: '/category/rfid-labels', label: 'RFID labels for operational tracking', description: 'Compare labels used in item-level inventory, baggage and post-sale workflows.' },
      { href: '/category/rfid-readers', label: 'Readers for checkpoint and workflow testing', description: 'Review reader hardware for operational pilots and validation.' },
      { href: blogContactHref, label: 'Request an operations sample plan', description: 'Tell us your environment, read distance and workflow to narrow the right setup.' },
    ];
  }

  if (slug.includes('hotel-key-card')) {
    return [
      { href: '/category/rfid-cards', label: 'RFID hotel cards', description: 'Move from buying research to card formats, materials and product pages.' },
      { href: '/blogs/how-to-order-rfid-cards-from-china', label: 'Card sourcing guide', description: 'Compare samples, MOQ, QC and factory communication before ordering.' },
      { href: blogContactHref, label: 'Ask about hotel card matching', description: 'Send your lock brand or current card sample for a recommendation.' },
    ];
  }

  if (slug.includes('laundry')) {
    return [
      { href: '/category/rfid-tags', label: 'Laundry and industrial RFID tags', description: 'Browse tag formats for textile, garment and linen tracking programs.' },
      { href: '/product/textile-rfid-laundry-tag', label: 'Textile laundry tag product', description: 'See a sample product page for heat-seal or sewn textile laundry tags.' },
      { href: blogContactHref, label: 'Request laundry tag samples', description: 'Share wash temperature, attachment method and read point for a shortlist.' },
    ];
  }

  if (slug.includes('anti-metal')) {
    return [
      { href: '/category/rfid-tags', label: 'Industrial RFID tags', description: 'Compare anti-metal, hard-tag and high-temperature formats.' },
      { href: '/product/rfid-metal-tag', label: 'Printable RFID metal tag', description: 'Review an on-metal product option for asset and equipment tracking.' },
      { href: blogContactHref, label: 'Ask about on-metal samples', description: 'Send your asset material, size and target read distance for guidance.' },
    ];
  }

  if (slug.includes('labels-vs-hard-tags')) {
    return [
      { href: '/category/rfid-labels', label: 'RFID labels and stickers', description: 'Explore printable NFC and UHF label options for packaging and inventory.' },
      { href: '/category/rfid-tags', label: 'Reusable RFID tags', description: 'Review harder-wearing formats for reusable and industrial assets.' },
      { href: blogContactHref, label: 'Compare sample sets', description: 'Tell us your surface and environment so we can suggest label and hard-tag samples.' },
    ];
  }

  if (slug.includes('reader')) {
    return [
      { href: '/category/rfid-readers', label: 'RFID readers and writers', description: 'Browse reader hardware for desktop, encoding and deployment workflows.' },
      { href: '/rfid-technology', label: 'RFID technology reference', description: 'Review standards and frequencies before choosing reader hardware.' },
      { href: blogContactHref, label: 'Ask about compatibility', description: 'Send your chip, OS and integration goal to narrow the right reader.' },
    ];
  }

  if (slug.includes('keyfob')) {
    return [
      { href: '/category/rfid-keyfob', label: 'RFID keyfobs', description: 'Compare ABS, epoxy and other keyfob styles for access control.' },
      { href: '/blogs/rfid-frequency-guide', label: 'RFID frequency guide', description: 'Useful when matching LF and HF credentials to existing readers.' },
      { href: blogContactHref, label: 'Request keyfob samples', description: 'Send your current credential or reader details for matching help.' },
    ];
  }

  if (slug.includes('wristband')) {
    return [
      { href: '/category/rfid-wristbands', label: 'RFID wristbands', description: 'Browse venue-ready wristband formats for access, cashless and guest ID.' },
      { href: '/blogs/nfc-tags-business-use-cases', label: 'NFC and guest-experience ideas', description: 'See related tap-to-engage and hospitality use cases.' },
      { href: blogContactHref, label: 'Request wristband samples', description: 'Share your venue type and wear-time requirement for a recommendation.' },
    ];
  }

  if (slug.includes('nfc') || slug.includes('mifare')) {
    return [
      { href: '/category/rfid-cards', label: 'RFID and NFC cards', description: 'Compare card products that match common HF and NFC chip families.' },
      { href: '/category/rfid-labels', label: 'NFC labels and stickers', description: 'Useful if your project needs smartphone-readable labels.' },
      { href: blogContactHref, label: 'Ask about chip matching', description: 'Send your reader or chip requirement for a quick recommendation.' },
    ];
  }

  if (slug.includes('supply') || slug.includes('barcode') || slug.includes('frequency')) {
    return [
      { href: '/category/rfid-tags', label: 'Industrial RFID tags', description: 'Explore rugged tags for logistics and asset tracking programs.' },
      { href: '/category/rfid-labels', label: 'RFID labels', description: 'Review label options for carton, retail and warehouse workflows.' },
      { href: '/rfid-technology', label: 'RFID technology reference', description: 'Get a high-level frequency and protocol overview.' },
    ];
  }

  if (slug.includes('order-rfid-cards')) {
    return [
      { href: '/category/rfid-cards', label: 'Custom RFID cards', description: 'Move from sourcing research to actual product selection.' },
      { href: blogContactHref, label: 'Request quote and samples', description: 'Send quantity, artwork and chip details to start a sample plan.' },
      { href: '/rfid', label: 'Browse all products', description: 'Compare additional formats if your project needs more than cards.' },
    ];
  }

  if (category === 'RFID APPLICATIONS') {
    return [
      { href: '/category/rfid-tags', label: 'RFID tags by application', description: 'Find tags for laundry, assets, pallets and operational use cases.' },
      { href: '/category/rfid-wristbands', label: 'RFID wristbands', description: 'Useful for event, hospitality and guest-experience projects.' },
      { href: blogContactHref, label: 'Talk through your use case', description: 'Share your environment and we can recommend matching products.' },
    ];
  }

  return [
    { href: '/rfid-technology', label: 'RFID technology basics', description: 'Review standards, frequencies and practical RFID fundamentals.' },
    { href: '/rfid', label: 'Browse product categories', description: 'Move from research content to product pages and buying guides.' },
    { href: blogContactHref, label: 'Request samples', description: 'Start a sample plan once you know the product direction.' },
  ];
}

const resourceLinks = getResourceLinks(post.slug, post.category);
const blogCta = getBlogCtaContent(post.slug);

// Build mentions from keywords — link to relevant product/concept entities for GEO
const mentionKeywordMap: Record<string, { name: string; url: string; sameAs?: string }> = {
  'rfid cards': { name: 'RFID Cards', url: `${siteURL}/category/rfid-cards` },
  'rfid tags': { name: 'RFID Tags', url: `${siteURL}/category/rfid-tags` },
  'rfid labels': { name: 'RFID Labels', url: `${siteURL}/category/rfid-labels` },
  'rfid wristbands': { name: 'RFID Wristbands', url: `${siteURL}/category/rfid-wristbands` },
  'rfid keyfob': { name: 'RFID Keyfobs', url: `${siteURL}/category/rfid-keyfob` },
  'rfid reader': { name: 'RFID Readers', url: `${siteURL}/category/rfid-readers` },
  'mifare': { name: 'MIFARE', url: `${siteURL}/rfid-glossary`, sameAs: 'https://en.wikipedia.org/wiki/MIFARE' },
  'desfire': { name: 'MIFARE DESFire', url: `${siteURL}/rfid-glossary`, sameAs: 'https://en.wikipedia.org/wiki/MIFARE' },
  'nfc': { name: 'NFC (Near Field Communication)', url: `${siteURL}/rfid-glossary`, sameAs: 'https://en.wikipedia.org/wiki/Near-field_communication' },
  'uhf': { name: 'UHF RFID', url: `${siteURL}/rfid-glossary`, sameAs: 'https://en.wikipedia.org/wiki/Radio-frequency_identification' },
  'laundry': { name: 'RFID Laundry Management', url: `${siteURL}/solutions/laundry-linen-rfid` },
  'hotel': { name: 'Hotel RFID Access Control', url: `${siteURL}/solutions/hotel-access-rfid` },
  'access control': { name: 'RFID Access Control', url: `${siteURL}/solutions/access-control-rfid` },
  'event': { name: 'Event NFC RFID', url: `${siteURL}/solutions/event-nfc-rfid` },
  'supply chain': { name: 'RFID Supply Chain Tracking', url: `${siteURL}/rfid-technology` },
  'anti-metal': { name: 'Anti-Metal RFID Tags', url: `${siteURL}/product/rfid-metal-tag` },
};
const combinedSearchText = `${post.keywords.toLowerCase()} ${post.title.toLowerCase()}`;
const mentionEntities = Object.entries(mentionKeywordMap)
  .filter(([keyword]) => combinedSearchText.includes(keyword))
  .map(([_, entity]) => ({
    '@type': 'Thing' as const,
    name: entity.name,
    url: entity.url,
    ...(entity.sameAs ? { sameAs: entity.sameAs } : {}),
  }));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${canonicalURL}#article`,
  headline: post.title,
  description: post.metaDescription || truncateText(post.excerpt, 160),
  image: post.image.startsWith('http') ? post.image : `${siteURL}${post.image}`,
  datePublished: publishedIso,
  ...(modifiedIso ? { dateModified: modifiedIso } : {}),
  wordCount,
  articleSection: post.category,
  keywords: post.keywords.split(',').map((keyword: string) => keyword.trim()),
  ...(mentionEntities.length > 0 ? { mentions: mentionEntities } : {}),
  ...(author
    ? {
        author: {
          '@type': 'Organization',
          '@id': `${siteURL}/authors/${author.slug}#author`,
          name: author.name,
          url: `${siteURL}/authors/${author.slug}`,
        },
      }
    : {
        author: {
          '@type': 'Organization',
          '@id': `${siteURL}/#organization`,
          name: 'ProudTek',
          url: siteURL,
        },
      }),
  publisher: {
    '@type': 'Organization',
    '@id': `${siteURL}/#organization`,
    name: 'ProudTek',
    logo: {
      '@type': 'ImageObject',
      url: `${siteURL}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
  isPartOf: {
    '@type': 'Blog',
    '@id': `${siteURL}/blogs#blog`,
    name: 'ProudTek RFID Blog',
  },
  about: {
    '@type': 'Thing',
    name: post.category,
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['article header h1', '.blog-excerpt', 'article .prose h2', 'article .prose p:first-of-type'],
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteURL}/blogs` },
    { '@type': 'ListItem', position: 3, name: post.title, item: canonicalURL },
  ],
};
const faqJsonLd = faqItems.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;
---

<Layout
  title={post.seoTitle || `${post.title} | ProudTek RFID Blog`}
  description={post.metaDescription}
  keywords={post.keywords}
  canonicalURL={canonicalURL}
  ogImage={post.image}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={modifiedIso}
  articleAuthor={author?.name || 'ProudTek'}
  jsonLd={faqJsonLd ? [articleJsonLd, breadcrumbJsonLd, faqJsonLd] : [articleJsonLd, breadcrumbJsonLd]}
>
  <Header />
  <main>
    <section class="bg-gray-100 py-4">
      <div class="container mx-auto px-4">
        <nav class="text-sm text-gray-600" aria-label="Breadcrumb">
          <ol class="flex items-center flex-wrap">
            <li><a href="/" class="hover:text-[#c9a84c]">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/blogs" class="hover:text-[#c9a84c]">Blog</a></li>
            <li><span class="mx-2">/</span></li>
            <li><span class="copy-safe text-gray-800 line-clamp-1">{post.title}</span></li>
          </ol>
        </nav>
      </div>
    </section>

    <article class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <header class="mb-10">
            <span class="text-[#c9a84c] text-xs uppercase tracking-[0.2em] font-medium">{post.category}</span>
            <h1 class="text-3xl md:text-5xl font-bold text-gray-800 mt-3">{post.title}</h1>
            <p class="text-lg text-gray-600 mt-4 max-w-3xl blog-excerpt" data-speakable>{post.excerpt}</p>
            <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mt-5">
              <time datetime={publishedIso}>{post.date}</time>
              {modifiedIso && <span>Updated {post.updatedDate}</span>}
              <span>{readingTime} min read</span>
              <span>{wordCount} words</span>
              <a href={author ? `/authors/${author.slug}` : '/about'} class="font-medium text-gray-600 hover:text-[#c9a84c] transition-colors">
                By {author?.name || 'ProudTek'}
              </a>
            </div>
          </header>

          <div class="aspect-[16/9] rounded-3xl overflow-hidden mb-10 bg-gray-100">
            <img
              src={post.image}
              alt={`${post.title} - ProudTek RFID buyer guide covering ${post.category.toLowerCase()}`}
              class="w-full h-full object-cover"
              width="1200"
              height="675"
              decoding="async"
              fetchpriority="high"
            />
          </div>

          {clusterPosts.length > 0 && (
            <div class="mb-10 rounded-3xl border border-gray-200 bg-gray-50 p-8">
              <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="eyebrow-label mb-2 text-[#c9a84c]">Topic Cluster</p>
                  <h2 class="title-balance text-2xl font-bold text-gray-800">Continue this topic with the next closest guides</h2>
                </div>
                <p class="card-copy max-w-2xl text-gray-600">
                  These are the articles buyers usually need next when they are moving from basic research into a real shortlist, pilot or compliance discussion.
                </p>
              </div>
              <div class={`grid gap-4 ${clusterPosts.length > 2 ? 'lg:grid-cols-2' : 'md:grid-cols-2'}`}>
                {clusterPosts.map((clusterPost) => (
                  <a href={`/blogs/${clusterPost.slug}`} class="copy-safe rounded-2xl border border-gray-200 bg-white p-5 transition-all hover:-translate-y-0.5 hover:border-[#c9a84c]">
                    <span class="eyebrow-label text-[#c9a84c]">{clusterPost.category}</span>
                    <h3 class="title-balance mt-3 text-lg font-semibold text-gray-800">{clusterPost.title}</h3>
                    <p class="card-copy mt-2 text-sm text-gray-600">{truncateText(clusterPost.excerpt, 118)}</p>
                    <span class="mt-4 inline-flex text-sm font-semibold text-[#c9a84c]">Read this next</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="grid lg:grid-cols-[minmax(0,1fr)_280px] gap-10 items-start">
            <div>
              <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed prose-headings:text-gray-800 prose-headings:font-semibold prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-xl prose-h3:mt-7 prose-h3:mb-3 prose-a:text-[#c9a84c] prose-strong:text-gray-700 prose-li:mb-2" set:html={content} />

              <div class="mt-10 rounded-3xl border border-gray-200 bg-gray-50 p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-3">{blogCta.title}</h2>
                <p class="text-gray-600 leading-relaxed mb-6">{blogCta.description}</p>
                <div class="flex flex-wrap gap-4">
                  <a href={blogContactHref} class="bg-[#c9a84c] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#b8943f] transition-colors">
                    {blogCta.primaryLabel}
                  </a>
                  <a href={blogCta.secondaryHref} class="border border-[#c9a84c] text-[#c9a84c] px-6 py-3 rounded-lg font-semibold hover:bg-[#c9a84c] hover:text-white transition-colors">
                    {blogCta.secondaryLabel}
                  </a>
                </div>
              </div>

              {comparisonLinks.length > 0 && (
                <div class="mt-8 rounded-3xl border border-gray-200 bg-white p-8">
                <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                  <div>
                    <p class="eyebrow-label mb-2 text-[#c9a84c]">Comparison Pages</p>
                    <h2 class="title-balance text-2xl font-bold text-gray-800">Compare the closest alternatives before you request samples</h2>
                  </div>
                  <p class="card-copy max-w-xl text-gray-600">
                    Open one of these if the article clarified the topic but the team still needs a cleaner format, chip or frequency decision.
                  </p>
                </div>
                  <div class="grid gap-4 md:grid-cols-3">
                    {comparisonLinks.map((page) => (
                      <article class="copy-safe rounded-2xl border border-gray-200 bg-gray-50 p-5 transition-all hover:-translate-y-0.5 hover:border-[#c9a84c]">
                        <a href={`/compare/${page.slug}`} class="block">
                          <span class="eyebrow-label text-[#c9a84c]">{page.heroEyebrow}</span>
                          <span class="title-balance mt-3 block text-base font-semibold text-gray-800">{page.name}</span>
                          <span class="card-copy mt-2 block text-sm text-gray-500">{truncateText(page.description, 108)}</span>
                        </a>
                        <a href={getComparisonContactHref(page.slug)} class="mt-4 inline-flex text-xs font-medium text-gray-500 transition-colors hover:text-[#c9a84c]">
                          Discuss this comparison
                        </a>
                      </article>
                    ))}
                  </div>
                </div>
              )}

              {faqItems.length > 0 && (
                <div class="mt-8 rounded-3xl border border-gray-200 bg-white p-8">
                  <p class="eyebrow-label mb-2 text-[#c9a84c]">Quick FAQ</p>
                  <h2 class="title-balance text-2xl font-bold text-gray-800">Questions buyers often ask after reading this guide</h2>
                  <div class="mt-6 space-y-5">
                    {faqItems.map((item) => (
                      <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
                        <h3 class="text-lg font-semibold text-gray-800">{item.question}</h3>
                        <p class="mt-2 text-gray-600 leading-relaxed">{item.answer}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div class="mt-8 rounded-3xl bg-[#072a31] text-white p-8">
                <p class="text-[#c9a84c] text-sm uppercase tracking-[0.2em] mb-2">Author</p>
                <h2 class="text-2xl font-bold mb-2">{author?.name || 'ProudTek RFID Team'}</h2>
                <p class="text-[#c9a84c]/70 text-sm font-medium mb-3">{author?.role || 'RFID manufacturer editorial team'}</p>
                <p class="text-white/75 leading-relaxed">
                  {author?.shortBio || 'We publish practical RFID content to help buyers and project teams compare card, tag, label, wristband and reader options before sampling or production.'}
                </p>
                <div class="mt-5 flex flex-wrap gap-3">
                  <a href={author ? `/authors/${author.slug}` : '/about'} class="rounded-full border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:bg-white/10 transition-colors">
                    View editorial profile
                  </a>
                  <a href={blogContactHref} class="rounded-full border border-cyan-300/30 px-4 py-2 text-sm font-semibold text-[#c9a84c]/70 hover:bg-white/10 transition-colors">
                    {blogCta.primaryLabel}
                  </a>
                </div>
              </div>
            </div>

            <aside class="space-y-6 lg:sticky lg:top-24">
              {headings.length > 0 && (
                <div class="copy-safe rounded-3xl border border-gray-200 bg-white p-6">
                  <h2 class="text-lg font-semibold text-gray-800 mb-4">On this page</h2>
                  <nav class="space-y-3">
                    {headings.map((heading) => (
                      <a
                        href={`#${heading.id}`}
                        class={`block text-sm leading-relaxed hover:text-[#c9a84c] transition-colors ${heading.level === 3 ? 'pl-4 text-gray-500' : 'text-gray-700 font-medium'}`}
                      >
                        {heading.text}
                      </a>
                    ))}
                  </nav>
                </div>
              )}

              <div class="copy-safe rounded-3xl border border-[#c9a84c]/15 bg-[#c9a84c]/5 p-6">
                <h2 class="text-lg font-semibold text-gray-800 mb-4">What buyers usually open next</h2>
                <div class="space-y-3">
                  {resourceLinks.map((resource) => (
                    <a href={resource.href} class="copy-safe block rounded-2xl bg-white p-4 border border-[#c9a84c]/15 hover:border-[#c9a84c] transition-colors">
                      <span class="block text-sm font-semibold text-gray-800">{resource.label}</span>
                      <span class="block text-sm text-gray-500 mt-1">{resource.description}</span>
                    </a>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </article>

    <section class="py-12 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-[#c9a84c] mb-2">Related Reading</p>
            <h2 class="text-2xl font-bold text-gray-800">Read the next closest guide before you lock the shortlist</h2>
          </div>
          <a href="/blogs" class="text-[#c9a84c] font-semibold hover:text-[#b8943f] transition-colors">Back to all articles</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((related) => (
            <a href={`/blogs/${related.slug}`} class="copy-safe bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={related.image}
                  alt={related.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  width="560"
                  height="350"
                />
              </div>
              <div class="p-6">
                <span class="text-[#c9a84c] text-xs uppercase tracking-[0.2em] font-medium">{related.category}</span>
                <h3 class="text-lg font-semibold text-gray-800 mt-3 group-hover:text-[#c9a84c] transition-colors line-clamp-2">{related.title}</h3>
                <p class="text-sm text-gray-600 mt-2 line-clamp-3">{truncateText(related.excerpt, 120)}</p>
                <span class="text-gray-400 text-sm mt-3 block">{related.date}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
