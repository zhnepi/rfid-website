---
const highlights = [
  { number: '17+', label: 'Years in RFID' },
  { number: '5M', label: 'Cards / Month' },
  { number: '99%', label: 'On-time Delivery' },
  { number: '108+', label: 'Global Clients' },
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: Text content -->
      <div>
        <p class="section-subtitle mb-2">Since 2008</p>
        <h2 class="section-title mb-6">Smart Card Manufacturer</h2>

        <p class="text-gray-600 leading-relaxed mb-5">
          ProudTek manufactures RFID cards, tags, wristbands, keyfobs, and readers across 46+ product models. We serve transit authorities, hotel chains, hospitals, and industrial laundries in over 50 countries.
        </p>

        <p class="text-gray-600 leading-relaxed mb-8">
          Every order includes free samples, full customization (chip, material, printing, encoding), and a 99% on-time delivery guarantee. Our factory produces 5 million cards per month with 100% chip verification on every unit.
        </p>

        <a
          href="/about"
          class="inline-block bg-cta text-white px-8 py-3 rounded hover:bg-cta-dark transition-colors font-medium"
        >
          About ProudTek
        </a>
      </div>

      <!-- Right: Key stats grid -->
      <div class="grid grid-cols-2 gap-6">
        {highlights.map((item) => (
          <div class="bg-gray-light rounded-lg p-6 text-center">
            <p class="text-3xl font-bold text-primary mb-1" style="font-variant-numeric: tabular-nums;">{item.number}</p>
            <p class="text-sm text-gray-500 font-medium">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
