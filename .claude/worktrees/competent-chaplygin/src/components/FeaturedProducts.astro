---
const products = [
  {
    name: 'RFID Keyfob',
    image: '/images/products/PROUDTEK-RFID-KEYFOB.webp',
    href: '/product/rfid-keyfob',
  },
  {
    name: 'RFID Card',
    image: '/images/products/ticket-smart-card.webp',
    href: '/product/rfid-cards',
  },
  {
    name: 'Skin friendly RFID Silicone Wristband',
    image: '/images/products/RFID-SIlicone-wristbands-006.webp',
    href: '/product/rfid-silicone-wristband',
  },
  {
    name: 'Most Reliable Textile RFID Laundry Tag',
    image: '/images/products/textile-RFID-laundry-tag-heat-seal.webp',
    href: '/product/textile-rfid-laundry-tag',
  },
  {
    name: 'High quality RFID Reader Writer',
    image: '/images/products/RFID_reader_writer.webp',
    href: '/product/rfid-reader-writer',
  },
  {
    name: 'Printable RFID Metal Tag',
    image: '/images/products/Printable-RFID-metal-tag.webp',
    href: '/product/rfid-metal-tag',
  },
];
---

<section class="py-24 bg-gray-light">
  <div class="container mx-auto px-4">
    <div class="text-center md:text-left mb-12">
      <p class="section-subtitle mb-2">46+ Product Models</p>
      <h2 class="section-title">Featured Products</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a 
          href={product.href}
          class="product-card group relative overflow-hidden rounded-lg shadow-lg aspect-[4/3]"
        >
          <img
            src={product.image}
            alt={product.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-white text-xl font-medium line-clamp-2">{product.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
